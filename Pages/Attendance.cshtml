@page
@{
    ViewData["Title"] = "Điểm danh";
    Layout = "_TeacherLayout";
    ViewData["ActivePage"] = "Attendance";

    var mockAttendance = new[] {
        new { Id = 1, Name = "Nguyễn Văn Minh", Status = "present", Notes = "Có mặt", Present = true, Absent = false, Late = false },
        new { Id = 2, Name = "Trần Thị Lan", Status = "present", Notes = "Có mặt", Present = true, Absent = false, Late = false },
        new { Id = 3, Name = "Lê Hoàng Nam", Status = "late", Notes = "Đến muộn 10 phút", Present = false, Absent = false, Late = true },
        new { Id = 4, Name = "Phạm Thu Hương", Status = "absent", Notes = "Vắng", Present = false, Absent = true, Late = false },
        new { Id = 5, Name = "Đỗ Minh Tú", Status = "present", Notes = "Có mặt", Present = true, Absent = false, Late = false }
    };

    int presentCount = mockAttendance.Count(x => x.Present);
    int absentCount = mockAttendance.Count(x => x.Absent);
    int lateCount = mockAttendance.Count(x => x.Late);
    double attendanceRate = (double)presentCount / mockAttendance.Length * 100;
}

<!-- Header -->
<div class="attendance-header-section">
    <div>
        <h1 class="attendance-main-title">Điểm danh</h1>
        <p class="attendance-subtitle">Ghi nhận tình trạng chuyên cần</p>
    </div>
    <button class="btn-export">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
        Xuất báo cáo
    </button>
</div>

<!-- Stats Cards -->
<div class="attendance-stats-grid">
    <div class="stat-card">
        <div class="stat-value">@presentCount</div>
        <div class="stat-label">Có mặt</div>
        <svg class="stat-icon stat-icon-present" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
    </div>
    <div class="stat-card">
        <div class="stat-value">@absentCount</div>
        <div class="stat-label">Vắng mặt</div>
        <svg class="stat-icon stat-icon-absent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>
    </div>
    <div class="stat-card">
        <div class="stat-value">@lateCount</div>
        <div class="stat-label">Đi muộn</div>
        <svg class="stat-icon stat-icon-late" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
    </div>
    <div class="stat-card">
        <div class="stat-value">@attendanceRate.ToString("F0")%</div>
        <div class="stat-label">Tỷ lệ</div>
        <svg class="stat-icon stat-icon-rate" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
    </div>
</div>

<!-- Main Card -->
<div class="attendance-card">
    <!-- Card Header -->
    <div class="attendance-card-header">
        <h3 class="attendance-card-title">Điểm danh hôm nay</h3>
        <div class="attendance-filters">
            <select class="attendance-select">
                <option>Toán 10A</option>
                <option>Toán 10B</option>
            </select>
            <input type="date" class="attendance-date" value="2026-03-26" />
            <div class="search-wrapper">
                <svg class="search-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
                <input type="text" placeholder="Tìm học sinh..." class="search-input-field" />
            </div>
        </div>
    </div>

    <!-- Table -->
    <div class="attendance-table-wrapper">
        <table class="attendance-table">
            <thead>
                <tr>
                    <th>Học sinh</th>
                    <th>Trạng thái</th>
                    <th>Ghi chú</th>
                    <th>Cập nhật</th>
                </tr>
            </thead>
            <tbody>
                @foreach(var att in mockAttendance)
                {
                    <tr>
                        <td class="student-name">@att.Name</td>
                        <td class="status-cell">
                            @if(att.Present)
                            {
                                <span class="status-badge status-present">✓ Có mặt</span>
                            }
                            else if(att.Late)
                            {
                                <span class="status-badge status-late">⏱ Muộn</span>
                            }
                            else
                            {
                                <span class="status-badge status-absent">✕ Vắng</span>
                            }
                        </td>
                        <td>
                            <div class="notes-cell">@att.Notes</div>
                        </td>
                        <td class="action-buttons">
                            <button class="btn-status @(att.Present ? "btn-status-active" : "")">Có mặt</button>
                            <button class="btn-status @(att.Late ? "btn-status-active" : "")">Muộn</button>
                            <button class="btn-status @(att.Absent ? "btn-status-active" : "")">Vắng</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <!-- Save Button -->
    <div class="attendance-footer">
        <button class="btn-save">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg>
            Lưu điểm danh
        </button>
    </div>
</div>