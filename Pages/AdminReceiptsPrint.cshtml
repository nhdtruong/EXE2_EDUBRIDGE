@page "{id:int}"
@model EduBridge.Pages.AdminReceiptsPrintModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>In Phiếu Thu - @Model.ReceiptData.ReceiptNumber</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body {
            font-family: 'Inter', sans-serif;
            background-color: #f3f4f6; /* gray-100 */
        }
        
        .receipt-container {
            width: 210mm;
            min-height: 297mm;
            padding: 20mm;
            margin: 10mm auto;
            border-radius: 5px;
            background: white;
            box-shadow: 0 0 5px rgba(0, 0, 0, 0.1);
        }

        @@media print {
            body {
                background-color: white;
            }
            .receipt-container {
                width: 100%;
                margin: 0;
                border-radius: 0;
                box-shadow: none;
                padding: 10mm;
            }
            .no-print {
                display: none !important;
            }
        }
    </style>
</head>
<body class="text-gray-800">

    <div class="fixed top-4 right-4 no-print flex gap-2">
        <button onclick="window.print()" class="bg-blue-600 hover:bg-blue-700 text-white font-semibold py-2 px-4 rounded shadow">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 inline-block mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 17h2a2 2 0 002-2v-4a2 2 0 00-2-2H5a2 2 0 00-2 2v4a2 2 0 002 2h2m2 4h6a2 2 0 002-2v-4a2 2 0 00-2-2H9a2 2 0 00-2 2v4a2 2 0 002 2zm8-12V5a2 2 0 00-2-2H9a2 2 0 00-2 2v4h10z" />
            </svg>
            In Biên Lai / Xuất PDF
        </button>
        <button onclick="window.close()" class="bg-gray-500 hover:bg-gray-600 text-white font-semibold py-2 px-4 rounded shadow">
            Đóng
        </button>
    </div>

    <div class="receipt-container relative">
        <!-- Header -->
        <div class="flex justify-between items-start border-b-2 border-gray-800 pb-4 mb-6">
            <div class="w-2/3">
                <h1 class="text-2xl font-bold uppercase text-gray-900 tracking-wider">@Model.ReceiptData.CenterName</h1>
                <p class="text-sm mt-1 text-gray-700"><strong>Địa chỉ:</strong> @Model.ReceiptData.CenterAddress</p>
                @if (!string.IsNullOrEmpty(Model.ReceiptData.CenterPhoneNumber))
                {
                    <p class="text-sm text-gray-700"><strong>Điện thoại:</strong> @Model.ReceiptData.CenterPhoneNumber</p>
                }
                @if (!string.IsNullOrEmpty(Model.ReceiptData.CenterEmail))
                {
                    <p class="text-sm text-gray-700"><strong>Email:</strong> @Model.ReceiptData.CenterEmail</p>
                }
            </div>
            <div class="w-1/3 text-right">
                <p class="text-sm">Mẫu số: <strong>01-TT</strong></p>
                <p class="text-sm text-gray-500">(Ban hành theo thông tư hệ thống)</p>
            </div>
        </div>

        <!-- Title -->
        <div class="text-center mb-8">
            <h2 class="text-3xl font-bold uppercase tracking-widest text-gray-900">Phiếu Thu Tiền</h2>
            <p class="italic text-gray-600 mt-1">
                Ngày @Model.ReceiptData.IssuedAt.Day tháng @Model.ReceiptData.IssuedAt.Month năm @Model.ReceiptData.IssuedAt.Year
            </p>
        </div>

        <!-- Metadata Info -->
        <div class="absolute top-[35mm] right-[20mm] text-right text-sm">
            <p><strong>Số Phiếu:</strong> @Model.ReceiptData.ReceiptNumber</p>
            <p><strong>Mã HĐ:</strong> @Model.ReceiptData.InvoiceCode</p>
            @* <p><strong>Trạng thái:</strong> <span class="font-semibold @(Model.ReceiptData.Status == "Active" ? "text-green-600" : "text-red-600")">@(Model.ReceiptData.Status == "Active" ? "Đã xác nhận" : "Đã hủy")</span></p> *@
        </div>

        <!-- Customer Details -->
        <div class="mb-6 space-y-2 text-base">
            <div class="flex">
                <span class="w-48 font-semibold">Họ tên người nộp:</span>
                <span class="flex-1 border-b border-dotted border-gray-400">
                    @(string.IsNullOrEmpty(Model.ReceiptData.ParentName) ? Model.ReceiptData.StudentName : Model.ReceiptData.ParentName)
                </span>
            </div>
            
            @if (!string.IsNullOrEmpty(Model.ReceiptData.ParentPhoneNumber))
            {
                <div class="flex">
                    <span class="w-48 font-semibold">Số điện thoại liên hệ:</span>
                    <span class="flex-1 border-b border-dotted border-gray-400">@Model.ReceiptData.ParentPhoneNumber</span>
                </div>
            }

            <div class="flex">
                <span class="w-48 font-semibold">Học sinh:</span>
                <span class="flex-1 border-b border-dotted border-gray-400">
                    @Model.ReceiptData.StudentName (Mã: @Model.ReceiptData.StudentCode)
                </span>
            </div>
            <div class="flex">
                <span class="w-48 font-semibold">Khóa học / Lớp học:</span>
                <span class="flex-1 border-b border-dotted border-gray-400">
                    @Model.ReceiptData.CourseName / @Model.ReceiptData.ClassName
                </span>
            </div>
            <div class="flex">
                <span class="w-48 font-semibold">Hình thức thanh toán:</span>
                <span class="flex-1 border-b border-dotted border-gray-400">
                    @(Model.ReceiptData.PaymentMethod == "TRANSFER" ? "Chuyển khoản" : (Model.ReceiptData.PaymentMethod == "CASH" ? "Tiền mặt" : Model.ReceiptData.PaymentMethod))
                </span>
            </div>
            @if (!string.IsNullOrEmpty(Model.ReceiptData.TransactionReference))
            {
                <div class="flex">
                    <span class="w-48 font-semibold">Mã giao dịch (Bank):</span>
                    <span class="flex-1 border-b border-dotted border-gray-400">
                        @Model.ReceiptData.TransactionReference
                    </span>
                </div>
            }
        </div>

        <!-- Payment Details Table -->
        <div class="mt-8 mb-6">
            <table class="w-full border-collapse border border-gray-800 text-sm">
                <thead>
                    <tr class="bg-gray-100">
                        <th class="border border-gray-800 px-4 py-2 text-left w-12 text-center">STT</th>
                        <th class="border border-gray-800 px-4 py-2 text-left">Nội dung thu</th>
                        <th class="border border-gray-800 px-4 py-2 text-right w-40">Số tiền (VNĐ)</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td class="border border-gray-800 px-4 py-3 text-center">1</td>
                        <td class="border border-gray-800 px-4 py-3">@Model.ReceiptData.Description</td>
                        <td class="border border-gray-800 px-4 py-3 text-right">@Model.ReceiptData.AmountPaid.ToString("N0")</td>
                    </tr>
                </tbody>
            </table>
        </div>

        <!-- Financial Summary -->
        <div class="flex justify-end mb-6 text-sm">
            <div class="w-1/2">
                <div class="flex justify-between py-1 border-b border-dashed border-gray-300">
                    <span>Tổng học phí gốc:</span>
                    <span class="font-semibold">@Model.ReceiptData.InvoiceAmount.ToString("N0") VNĐ</span>
                </div>
                @if (Model.ReceiptData.DiscountAmount > 0)
                {
                    <div class="flex justify-between py-1 border-b border-dashed border-gray-300">
                        <span>Giảm giá:</span>
                        <span class="font-semibold text-red-600">-@Model.ReceiptData.DiscountAmount.ToString("N0") VNĐ</span>
                    </div>
                }
                
                <div class="flex justify-between py-1 border-b border-dashed border-gray-300 text-base">
                    <span class="font-bold">Tổng thanh toán lần này:</span>
                    <span class="font-bold text-lg">@Model.ReceiptData.AmountPaid.ToString("N0") VNĐ</span>
                </div>
                
                @{
                    var remaining = Model.ReceiptData.FinalInvoiceAmount - Model.ReceiptData.TotalPaidBeforeThis - Model.ReceiptData.AmountPaid;
                }
                
                @if (remaining > 0)
                {
                    <div class="flex justify-between py-1 text-red-600 italic mt-2">
                        <span>Số tiền còn nợ:</span>
                        <span class="font-semibold">@remaining.ToString("N0") VNĐ</span>
                    </div>
                }
                else
                {
                    <div class="flex justify-between py-1 text-green-600 italic mt-2">
                        <span>Đã thanh toán đủ toàn bộ khóa học</span>
                        <span></span>
                    </div>
                }
            </div>
        </div>

        <div class="flex mb-12">
            <span class="font-semibold mr-2 text-base">Số tiền bằng chữ:</span>
            <span class="flex-1 italic border-b border-dotted border-gray-400 text-base">
                @Model.ReceiptData.AmountInWords
            </span>
        </div>

        <!-- Signatures -->
        <div class="flex justify-between mt-12 text-center">
            <div class="w-1/3">
                <p class="font-bold uppercase">Người nộp tiền</p>
                <p class="text-sm italic mt-1">(Ký, ghi rõ họ tên)</p>
                <div class="mt-24 font-semibold">
                    @(string.IsNullOrEmpty(Model.ReceiptData.ParentName) ? Model.ReceiptData.StudentName : Model.ReceiptData.ParentName)
                </div>
            </div>
            
            <div class="w-1/3">
                <p class="font-bold uppercase">Người lập phiếu</p>
                <p class="text-sm italic mt-1">(Ký, ghi rõ họ tên)</p>
                <div class="mt-24 font-semibold">
                    @Model.ReceiptData.IssuedByUserName
                </div>
            </div>
        </div>
        
    </div>

</body>
</html>
