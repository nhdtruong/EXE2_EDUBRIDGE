@page
@model EduBridge.Pages.GradesModel
@{
    ViewData["Title"] = "Sổ điểm";
    Layout = "_TeacherLayout";
    ViewData["ActivePage"] = "Grades";
}

<div class="mb-6 rounded-2xl bg-gradient-to-br from-white to-blue-50 p-6 shadow-[0_4px_6px_-1px_rgba(0,0,0,0.02)] border border-slate-200/80">
    <h1 class="text-3xl font-extrabold bg-gradient-to-r from-blue-500 to-blue-700 bg-clip-text text-transparent">Sổ điểm & Đánh giá</h1>
    <p class="mt-2 text-base text-gray-500">Quản lý điểm số và nhận xét học sinh</p>
    <div class="mt-4 flex gap-3">
        <button id="btnEnterGrades" class="inline-flex items-center justify-center rounded-xl bg-blue-600 px-4 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-blue-500 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-blue-600 transition-all">
            <svg class="mr-2 h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 5v14"/><path d="M5 12h14"/></svg>
            Nhập điểm
        </button>
    </div>
</div>

<div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
    <div class="px-6 py-5 border-b border-gray-200 bg-gray-50 flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4">
        <h2 class="text-lg font-bold text-gray-900">Bảng điểm</h2>
        <div class="flex items-center gap-3 w-full sm:w-auto">
            <select id="classSelect" class="block w-full sm:w-48 rounded-lg border-gray-300 py-2 pl-3 pr-10 text-sm focus:border-blue-500 focus:outline-none focus:ring-1 focus:ring-blue-500">
                @foreach(var c in Model.TeacherClasses)
                {
                    <!option value="@c.ClassId" @(c.ClassId == Model.SelectedClassId ? "selected" : "")>@c.ClassName</!option>
                }
            </select>
            <div class="relative w-full sm:w-64">
                <div class="pointer-events-none absolute inset-y-0 left-0 flex items-center pl-3">
                    <svg class="h-5 w-5 text-gray-400" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                        <path fill-rule="evenodd" d="M9 3.5a5.5 5.5 0 100 11 5.5 5.5 0 000-11zM2 9a7 7 0 1112.452 4.391l3.328 3.329a.75.75 0 11-1.06 1.06l-3.329-3.328A7 7 0 012 9z" clip-rule="evenodd"></path>
                    </svg>
                </div>
                <input type="text" id="studentSearchInput" class="block w-full rounded-lg border-0 py-2 pl-10 text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 placeholder:text-gray-400 focus:ring-2 focus:ring-inset focus:ring-blue-600 sm:text-sm sm:leading-6" placeholder="Tìm học sinh...">
            </div>
        </div>
    </div>
    
    <div class="overflow-x-auto">
        <table class="w-full text-left border-collapse">
            <thead>
                <tr class="whitespace-nowrap bg-slate-100 border-b border-slate-200 text-sm font-bold text-slate-800">
                    <th class="py-4 px-4 text-center font-bold border-r border-slate-200 w-16">STT</th>
                    <th class="py-4 px-6 text-left font-bold border-r border-slate-200">Học sinh</th>
                    <th class="py-4 px-6 text-center font-bold border-r border-slate-200 w-24">KT 1</th>
                    <th class="py-4 px-6 text-center font-bold border-r border-slate-200 w-24">KT 2</th>
                    <th class="py-4 px-6 text-center font-bold border-r border-slate-200 w-28">Giữa kỳ</th>
                    <th class="py-4 px-6 text-center font-bold border-r border-slate-200 w-28">Cuối kỳ</th>
                    <th class="py-4 px-6 text-center font-bold border-r border-slate-200 w-24">TB</th>
                    <th class="py-4 px-6 text-center font-bold w-24">Thao tác</th>
                </tr>
            </thead>
            <tbody id="gradesTableBody" class="text-sm divide-y divide-gray-100">
            </tbody>
        </table>
        <div id="gradesPagination"></div>
    </div>
</div>

<!-- Modal -->
<div id="editGradeModal" class="fixed inset-0 z-[60] hidden items-center justify-center bg-gray-900/60 backdrop-blur-sm p-4 transition-all duration-300">
    <div class="bg-white rounded-2xl shadow-2xl w-full max-w-2xl overflow-hidden flex flex-col max-h-[90vh]">
        <div class="flex items-center justify-between border-b border-gray-200 px-6 py-4 bg-gray-50">
            <h3 class="text-lg font-bold text-gray-900" id="editGradeModalLabel">Nhập & Chỉnh sửa điểm số</h3>
            <button type="button" class="text-gray-400 hover:text-gray-600 focus:outline-none transition-colors" onclick="toggleModal('editGradeModal', false)">
                <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
            </button>
        </div>
        <form id="editGradeForm" class="flex flex-col overflow-hidden">
            <div class="px-6 py-4 overflow-y-auto">
                <div class="mb-4">
                    <label class="block text-sm font-semibold text-gray-700 mb-1">Chọn học sinh:</label>
                    <select id="modalStudentSelect" class="block w-full rounded-xl border-gray-300 py-2.5 px-3 text-gray-900 shadow-sm focus:border-blue-500 focus:ring-blue-500 sm:text-sm font-medium">
                    </select>
                </div>

                <div class="border-t border-dashed border-gray-300 my-4"></div>

                <div class="grid grid-cols-12 gap-4 mb-4 items-start">
                    <div class="col-span-4">
                        <label class="block text-sm font-semibold text-gray-700 mb-1">Kiểm tra 1</label>
                        <input type="number" id="scoreKT1" min="0" max="10" step="0.1" class="block w-full rounded-xl border-0 py-2 text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 placeholder:text-gray-400 focus:ring-2 focus:ring-inset focus:ring-blue-600 sm:text-sm" placeholder="-" />
                    </div>
                    <div class="col-span-8">
                        <label class="block text-sm font-medium text-gray-500 mb-1">Nhận xét KT 1</label>
                        <input type="text" id="commentKT1" class="block w-full rounded-xl border-0 py-2 text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 placeholder:text-gray-400 focus:ring-2 focus:ring-inset focus:ring-blue-600 sm:text-sm" placeholder="Nhận xét bài làm..." />
                    </div>
                </div>

                <div class="grid grid-cols-12 gap-4 mb-4 items-start">
                    <div class="col-span-4">
                        <label class="block text-sm font-semibold text-gray-700 mb-1">Kiểm tra 2</label>
                        <input type="number" id="scoreKT2" min="0" max="10" step="0.1" class="block w-full rounded-xl border-0 py-2 text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 placeholder:text-gray-400 focus:ring-2 focus:ring-inset focus:ring-blue-600 sm:text-sm" placeholder="-" />
                    </div>
                    <div class="col-span-8">
                        <label class="block text-sm font-medium text-gray-500 mb-1">Nhận xét KT 2</label>
                        <input type="text" id="commentKT2" class="block w-full rounded-xl border-0 py-2 text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 placeholder:text-gray-400 focus:ring-2 focus:ring-inset focus:ring-blue-600 sm:text-sm" placeholder="Nhận xét bài làm..." />
                    </div>
                </div>

                <div class="grid grid-cols-12 gap-4 mb-4 items-start">
                    <div class="col-span-4">
                        <label class="block text-sm font-semibold text-gray-700 mb-1">Giữa kỳ</label>
                        <input type="number" id="scoreMidterm" min="0" max="10" step="0.1" class="block w-full rounded-xl border-0 py-2 text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 placeholder:text-gray-400 focus:ring-2 focus:ring-inset focus:ring-blue-600 sm:text-sm" placeholder="-" />
                    </div>
                    <div class="col-span-8">
                        <label class="block text-sm font-medium text-gray-500 mb-1">Nhận xét Giữa kỳ</label>
                        <input type="text" id="commentMidterm" class="block w-full rounded-xl border-0 py-2 text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 placeholder:text-gray-400 focus:ring-2 focus:ring-inset focus:ring-blue-600 sm:text-sm" placeholder="Nhận xét bài làm..." />
                    </div>
                </div>

                <div class="grid grid-cols-12 gap-4 mb-4 items-start">
                    <div class="col-span-4">
                        <label class="block text-sm font-semibold text-gray-700 mb-1">Cuối kỳ</label>
                        <input type="number" id="scoreFinal" min="0" max="10" step="0.1" class="block w-full rounded-xl border-0 py-2 text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 placeholder:text-gray-400 focus:ring-2 focus:ring-inset focus:ring-blue-600 sm:text-sm" placeholder="-" />
                    </div>
                    <div class="col-span-8">
                        <label class="block text-sm font-medium text-gray-500 mb-1">Nhận xét Cuối kỳ</label>
                        <input type="text" id="commentFinal" class="block w-full rounded-xl border-0 py-2 text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 placeholder:text-gray-400 focus:ring-2 focus:ring-inset focus:ring-blue-600 sm:text-sm" placeholder="Nhận xét bài làm..." />
                    </div>
                </div>
            </div>
            <div class="border-t border-gray-200 px-6 py-4 flex justify-end gap-3 bg-gray-50">
                <button type="button" class="rounded-xl bg-white px-4 py-2.5 text-sm font-semibold text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 hover:bg-gray-50 transition-colors" onclick="toggleModal('editGradeModal', false)">Hủy</button>
                <button type="submit" class="rounded-xl bg-blue-600 px-4 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-blue-500 transition-colors">Lưu điểm</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        function toggleModal(modalId, show) {
            const modal = document.getElementById(modalId);
            if (!modal) return;
            if (show) {
                modal.classList.remove('hidden');
                modal.classList.add('flex');
            } else {
                modal.classList.add('hidden');
                modal.classList.remove('flex');
            }
        }

        let rawGradesData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.StudentsGrades));
        let studentGradesData = (rawGradesData || []).map(std => ({
            StudentId: std.StudentId !== undefined ? std.StudentId : std.studentId,
            StudentName: std.StudentName !== undefined ? std.StudentName : std.studentName,
            StudentCode: std.StudentCode !== undefined ? std.StudentCode : std.studentCode,
            ScoreKT1: std.ScoreKT1 !== undefined ? std.ScoreKT1 : std.scoreKT1,
            CommentKT1: std.CommentKT1 !== undefined ? std.CommentKT1 : std.commentKT1,
            ScoreKT2: std.ScoreKT2 !== undefined ? std.ScoreKT2 : std.scoreKT2,
            CommentKT2: std.CommentKT2 !== undefined ? std.CommentKT2 : std.commentKT2,
            ScoreMidterm: std.ScoreMidterm !== undefined ? std.ScoreMidterm : std.scoreMidterm,
            CommentMidterm: std.CommentMidterm !== undefined ? std.CommentMidterm : std.commentMidterm,
            ScoreFinal: std.ScoreFinal !== undefined ? std.ScoreFinal : std.scoreFinal,
            CommentFinal: std.CommentFinal !== undefined ? std.CommentFinal : std.commentFinal,
            AverageScore: std.AverageScore !== undefined ? std.AverageScore : std.averageScore
        }));
        let gradesCurrentPage = 1;
        let gradesPageSize = 10;
        let filteredGrades = [...studentGradesData];

        document.addEventListener("DOMContentLoaded", function () {
            renderGradesTable();

            document.getElementById("classSelect").addEventListener("change", function () {
                loadGradesForClass(this.value);
            });

            document.getElementById("studentSearchInput").addEventListener("input", function () {
                const query = this.value.trim().toLowerCase();
                filteredGrades = studentGradesData.filter(std => 
                    std.StudentName.toLowerCase().includes(query) || 
                    (std.StudentCode && std.StudentCode.toLowerCase().includes(query))
                );
                gradesCurrentPage = 1;
                renderGradesTable();
            });

            document.getElementById("btnEnterGrades").addEventListener("click", function () {
                if (studentGradesData && studentGradesData.length > 0) {
                    openEditModal(studentGradesData[0].StudentId);
                } else {
                    showToast("Lớp học hiện tại chưa có học sinh để nhập điểm.", false);
                }
            });

            document.getElementById("editGradeForm").addEventListener("submit", function (e) {
                e.preventDefault();
                saveGrades();
            });

            document.getElementById("modalStudentSelect").addEventListener("change", function () {
                fillGradesToInputs(parseInt(this.value));
            });
        });

        function loadGradesForClass(classId) {
            fetch(`/api/v1/teacher/grades?classId=${classId}`)
                .then(res => res.json())
                .then(res => {
                    if (res.success) {
                        studentGradesData = res.data.map(std => ({
                            StudentId: std.studentId,
                            StudentName: std.studentName,
                            StudentCode: std.studentCode,
                            ScoreKT1: std.scoreKT1,
                            CommentKT1: std.commentKT1,
                            ScoreKT2: std.scoreKT2,
                            CommentKT2: std.commentKT2,
                            ScoreMidterm: std.scoreMidterm,
                            CommentMidterm: std.commentMidterm,
                            ScoreFinal: std.scoreFinal,
                            CommentFinal: std.commentFinal,
                            AverageScore: std.averageScore
                        }));
                        filteredGrades = [...studentGradesData];
                        gradesCurrentPage = 1;
                        renderGradesTable();
                        document.getElementById("studentSearchInput").value = "";
                    } else {
                        showToast(res.message, false);
                    }
                })
                .catch(err => {
                    console.error(err);
                    showToast("Đã xảy ra lỗi khi tải danh sách điểm số.", false);
                });
        }

        function renderGradesTable() {
            const tbody = document.getElementById("gradesTableBody");
            const paginationEl = document.getElementById("gradesPagination");
            if (!tbody) return;
            tbody.innerHTML = "";
            
            const totalItems = filteredGrades.length;
            const totalPages = Math.ceil(totalItems / gradesPageSize) || 1;

            if (gradesCurrentPage > totalPages) gradesCurrentPage = totalPages;
            if (gradesCurrentPage < 1) gradesCurrentPage = 1;

            const start = (gradesCurrentPage - 1) * gradesPageSize;
            const end = Math.min(start + gradesPageSize, totalItems);
            const pageItems = filteredGrades.slice(start, end);

            if (pageItems.length === 0) {
                tbody.innerHTML = `<tr><td colspan="8" class="text-center text-gray-500 py-8">Không tìm thấy học sinh nào.</td></tr>`;
                if (paginationEl) paginationEl.innerHTML = "";
                return;
            }

            pageItems.forEach((std, index) => {
                const indexGlobal = start + index + 1;
                const stdName = std.StudentName || "";
                const avatarText = stdName.substring(0, Math.min(2, stdName.length)).toUpperCase() || "??";

                const tr = document.createElement("tr");
                tr.className = "group hover:bg-slate-100 transition-colors";
                tr.innerHTML = `
                    <td class="py-5 px-4 text-center font-medium text-gray-700 border-r border-gray-200">${indexGlobal}</td>
                    <td class="py-5 px-6 border-r border-gray-200">
                        <div class="flex items-center">
                            <div class="h-10 w-10 flex-shrink-0 rounded-full bg-gradient-to-r from-blue-500 to-blue-600 flex items-center justify-center text-white font-bold text-sm">
                                ${avatarText}
                            </div>
                            <div class="ml-4">
                                <div class="text-sm font-semibold text-gray-900">${stdName}</div>
                                <div class="text-sm text-gray-500">Mã: ${std.StudentCode || ""}</div>
                            </div>
                        </div>
                    </td>
                    <td class="py-5 px-6 text-center border-r border-gray-200"><span class="inline-flex items-center rounded-md px-2.5 py-1 text-xs font-semibold ${getScoreColor(std.ScoreKT1)}">${formatScore(std.ScoreKT1)}</span></td>
                    <td class="py-5 px-6 text-center border-r border-gray-200"><span class="inline-flex items-center rounded-md px-2.5 py-1 text-xs font-semibold ${getScoreColor(std.ScoreKT2)}">${formatScore(std.ScoreKT2)}</span></td>
                    <td class="py-5 px-6 text-center border-r border-gray-200"><span class="inline-flex items-center rounded-md px-2.5 py-1 text-xs font-semibold ${getScoreColor(std.ScoreMidterm)}">${formatScore(std.ScoreMidterm)}</span></td>
                    <td class="py-5 px-6 text-center border-r border-gray-200"><span class="inline-flex items-center rounded-md px-2.5 py-1 text-xs font-semibold ${getScoreColor(std.ScoreFinal)}">${formatScore(std.ScoreFinal)}</span></td>
                    <td class="py-5 px-6 text-center border-r border-gray-200"><span class="inline-flex items-center rounded-md px-2.5 py-1 text-xs font-bold ${getScoreColor(std.AverageScore)}">${formatScore(std.AverageScore)}</span></td>
                    <td class="py-5 px-6 text-center text-sm font-medium">
                        <button type="button" class="edit-grade-btn inline-flex h-10 w-10 items-center justify-center rounded-full border border-blue-500 bg-blue-50 text-blue-600 transition-colors hover:bg-blue-100" data-id="${std.StudentId}" title="Xem/Sửa điểm">
                            <svg class="h-5 w-5 pointer-events-none" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.25 12s3.75-6.75 9.75-6.75S21.75 12 21.75 12 18 18.75 12 18.75 2.25 12 2.25 12z"></path>
                                <circle cx="12" cy="12" r="3" stroke-width="2"></circle>
                            </svg>
                        </button>
                    </td>
                `;
                tbody.appendChild(tr);
            });

            document.querySelectorAll(".edit-grade-btn").forEach(btn => {
                btn.addEventListener("click", function () {
                    openEditModal(parseInt(this.getAttribute("data-id")));
                });
            });

            renderGradesPagination(totalPages, totalItems);
        }

        function renderGradesPagination(totalPages, totalItems) {
            const container = document.getElementById("gradesPagination");
            if (!container) return;

            let html = `<div class="flex flex-wrap items-center justify-center gap-6 rounded-b-2xl border-t border-gray-200 bg-white px-6 py-4 text-sm text-gray-600">`;
            
            html += `<div class="flex items-center gap-1">`;
            
            html += `<button class="ds-page-link inline-flex h-9 w-9 items-center justify-center rounded text-gray-400 transition-colors ${gradesCurrentPage === 1 ? 'opacity-50 cursor-not-allowed' : 'hover:bg-blue-50 hover:text-blue-600'}" data-page="1" ${gradesCurrentPage === 1 ? 'disabled' : ''}>«</button>`;
            html += `<button class="ds-page-link inline-flex h-9 w-9 items-center justify-center rounded text-gray-400 transition-colors ${gradesCurrentPage === 1 ? 'opacity-50 cursor-not-allowed' : 'hover:bg-blue-50 hover:text-blue-600'}" data-page="${gradesCurrentPage - 1}" ${gradesCurrentPage === 1 ? 'disabled' : ''}>‹</button>`;

            let startPage = Math.max(1, gradesCurrentPage - 2);
            let endPage = Math.min(totalPages, startPage + 4);
            if (endPage - startPage < 4) {
                startPage = Math.max(1, endPage - 4);
            }

            for (let i = startPage; i <= endPage; i++) {
                if (i === gradesCurrentPage) {
                    html += `<button class="ds-page-link inline-flex h-9 w-9 items-center justify-center rounded bg-blue-100 text-blue-700 font-semibold" data-page="${i}">${i}</button>`;
                } else {
                    html += `<button class="ds-page-link inline-flex h-9 w-9 items-center justify-center rounded text-gray-600 hover:bg-blue-50 hover:text-blue-600 transition-colors" data-page="${i}">${i}</button>`;
                }
            }

            html += `<button class="ds-page-link inline-flex h-9 w-9 items-center justify-center rounded text-gray-400 transition-colors ${gradesCurrentPage === totalPages || totalPages === 0 ? 'opacity-50 cursor-not-allowed' : 'hover:bg-blue-50 hover:text-blue-600'}" data-page="${gradesCurrentPage + 1}" ${gradesCurrentPage === totalPages || totalPages === 0 ? 'disabled' : ''}>›</button>`;
            html += `<button class="ds-page-link inline-flex h-9 w-9 items-center justify-center rounded text-gray-400 transition-colors ${gradesCurrentPage === totalPages || totalPages === 0 ? 'opacity-50 cursor-not-allowed' : 'hover:bg-blue-50 hover:text-blue-600'}" data-page="${totalPages}" ${gradesCurrentPage === totalPages || totalPages === 0 ? 'disabled' : ''}>»</button>`;
            
            html += `</div>`;

            html += `<div class="font-medium text-gray-600">Tổng số: ${totalItems} bản ghi</div>`;
            
            html += `<div class="flex items-center">
                        <select class="ds-page-size h-10 rounded border border-blue-300 bg-white px-3 text-sm text-gray-700 focus:border-blue-500 focus:outline-none focus:ring-1 focus:ring-blue-500">
                            <option value="10" ${gradesPageSize === 10 ? 'selected' : ''}>10</option>
                            <option value="20" ${gradesPageSize === 20 ? 'selected' : ''}>20</option>
                            <option value="50" ${gradesPageSize === 50 ? 'selected' : ''}>50</option>
                            <option value="100" ${gradesPageSize === 100 ? 'selected' : ''}>100</option>
                            <option value="200" ${gradesPageSize === 200 ? 'selected' : ''}>200</option>
                            <option value="500" ${gradesPageSize === 500 ? 'selected' : ''}>500</option>
                        </select>
                     </div>`;
                     
            html += `</div>`;

            container.innerHTML = html;

            container.querySelectorAll(".ds-page-link").forEach(link => {
                if(!link.hasAttribute('disabled')){
                    link.addEventListener("click", function(e) {
                        e.preventDefault();
                        gradesCurrentPage = parseInt(this.getAttribute("data-page"));
                        renderGradesTable();
                    });
                }
            });

            container.querySelector(".ds-page-size").addEventListener("change", function() {
                gradesPageSize = parseInt(this.value);
                gradesCurrentPage = 1;
                renderGradesTable();
            });
        }

        function openEditModal(studentId) {
            if (!studentGradesData || studentGradesData.length === 0) return;
            const select = document.getElementById("modalStudentSelect");
            select.innerHTML = "";
            studentGradesData.forEach(std => {
                const opt = document.createElement("option");
                opt.value = std.StudentId;
                opt.textContent = `${std.StudentName} (${std.StudentCode || ""})`;
                select.appendChild(opt);
            });
            select.value = studentId;
            fillGradesToInputs(studentId);
            toggleModal('editGradeModal', true);
        }

        function fillGradesToInputs(studentId) {
            const std = studentGradesData.find(s => s.StudentId === studentId);
            if (!std) return;
            document.getElementById("scoreKT1").value = std.ScoreKT1 !== null ? std.ScoreKT1 : "";
            document.getElementById("commentKT1").value = std.CommentKT1 || "";
            document.getElementById("scoreKT2").value = std.ScoreKT2 !== null ? std.ScoreKT2 : "";
            document.getElementById("commentKT2").value = std.CommentKT2 || "";
            document.getElementById("scoreMidterm").value = std.ScoreMidterm !== null ? std.ScoreMidterm : "";
            document.getElementById("commentMidterm").value = std.CommentMidterm || "";
            document.getElementById("scoreFinal").value = std.ScoreFinal !== null ? std.ScoreFinal : "";
            document.getElementById("commentFinal").value = std.CommentFinal || "";
        }

        function saveGrades() {
            const classId = parseInt(document.getElementById("classSelect").value);
            const studentId = parseInt(document.getElementById("modalStudentSelect").value);

            const scoreKT1 = document.getElementById("scoreKT1").value;
            const scoreKT2 = document.getElementById("scoreKT2").value;
            const scoreMidterm = document.getElementById("scoreMidterm").value;
            const scoreFinal = document.getElementById("scoreFinal").value;

            const scores = [scoreKT1, scoreKT2, scoreMidterm, scoreFinal];
            for (let s of scores) {
                if (s !== "" && (parseFloat(s) < 0 || parseFloat(s) > 10)) {
                    showToast("Điểm số phải nằm trong khoảng từ 0 đến 10.", false);
                    return;
                }
            }

            const requestData = {
                ClassId: classId,
                StudentId: studentId,
                ScoreKT1: scoreKT1 !== "" ? parseFloat(scoreKT1) : null,
                CommentKT1: document.getElementById("commentKT1").value,
                ScoreKT2: scoreKT2 !== "" ? parseFloat(scoreKT2) : null,
                CommentKT2: document.getElementById("commentKT2").value,
                ScoreMidterm: scoreMidterm !== "" ? parseFloat(scoreMidterm) : null,
                CommentMidterm: document.getElementById("commentMidterm").value,
                ScoreFinal: scoreFinal !== "" ? parseFloat(scoreFinal) : null,
                CommentFinal: document.getElementById("commentFinal").value
            };

            fetch('/api/v1/teacher/grades/save', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(requestData)
            })
            .then(res => res.json())
            .then(res => {
                if (res.success) {
                    showToast("Cập nhật điểm số thành công!");
                    toggleModal('editGradeModal', false);
                    loadGradesForClass(classId);
                } else {
                    showToast(res.message, false);
                }
            })
            .catch(err => {
                console.error(err);
                showToast("Không thể kết nối đến server để lưu điểm.", false);
            });
        }

        function getScoreColor(score) {
            if (score === null || score === undefined) return "bg-gray-100 text-gray-800";
            const val = parseFloat(score);
            if (val >= 9) return "bg-green-100 text-green-800";
            if (val >= 7) return "bg-blue-100 text-blue-800";
            if (val >= 5) return "bg-orange-100 text-orange-800";
            return "bg-red-100 text-red-800";
        }

        function formatScore(score) {
            return (score === null || score === undefined) ? "-" : parseFloat(score).toFixed(1);
        }
    </script>
}