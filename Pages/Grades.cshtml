@page
@model EduBridge.Pages.GradesModel
@{
    ViewData["Title"] = "Sổ điểm";
    Layout = "_TeacherLayout";
    ViewData["ActivePage"] = "Grades";

    string GetScoreColor(decimal? score) {
        if (!score.HasValue) return "score-empty";
        if (score >= 9.0m) return "score-green";
        if (score >= 7.0m) return "score-blue";
        if (score >= 5.0m) return "score-orange";
        return "score-red";
    }
}

<!-- Header -->
<div class="grades-header-section">
    <div>
        <h1 class="grades-main-title">Sổ điểm & Đánh giá</h1>
        <p class="grades-subtitle">Quản lý điểm số và nhận xét học sinh</p>
    </div>
    <div class="grades-buttons">
        <button class="btn-primary" id="btnEnterGrades">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 5v14"/><path d="M5 12h14"/></svg>
            Nhập điểm
        </button>
    </div>
</div>

<!-- Main Card -->
<div class="grades-card">
    <!-- Card Header with Filter -->
    <div class="grades-card-header">
        <h3 class="grades-card-title">Bảng điểm</h3>
        <div class="grades-filters">
            <select class="grades-select" id="classSelect">
                @foreach(var c in Model.TeacherClasses)
                {
                    <!option value="@c.ClassId" @(c.ClassId == Model.SelectedClassId ? "selected" : "")>@c.ClassName</!option>
                }
            </select>
            <div class="search-wrapper">
                <svg class="search-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
                <input type="text" id="studentSearchInput" placeholder="Tìm học sinh..." class="search-input-field" />
            </div>
        </div>
    </div>

    <!-- Table -->
    <div class="grades-table-wrapper">
        <table class="grades-table">
            <thead>
                <tr>
                    <th>Học sinh</th>
                    <th>KT 1</th>
                    <th>KT 2</th>
                    <th>Giữa kỳ</th>
                    <th>Cuối kỳ</th>
                    <th>TB</th>
                    <th>Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.StudentsGrades.Any())
                {
                    @foreach(var std in Model.StudentsGrades)
                    {
                        <tr data-student-id="@std.StudentId">
                            <td class="student-name">
                                @std.StudentName
                                <div class="student-code text-muted small">@std.StudentCode</div>
                            </td>
                            <td class="score-cell"><span class="score-badge @GetScoreColor(std.ScoreKT1)">@(std.ScoreKT1?.ToString("F1") ?? "-")</span></td>
                            <td class="score-cell"><span class="score-badge @GetScoreColor(std.ScoreKT2)">@(std.ScoreKT2?.ToString("F1") ?? "-")</span></td>
                            <td class="score-cell"><span class="score-badge @GetScoreColor(std.ScoreMidterm)">@(std.ScoreMidterm?.ToString("F1") ?? "-")</span></td>
                            <td class="score-cell"><span class="score-badge @GetScoreColor(std.ScoreFinal)">@(std.ScoreFinal?.ToString("F1") ?? "-")</span></td>
                            <td class="score-cell"><span class="score-badge @GetScoreColor(std.AverageScore)">@(std.AverageScore?.ToString("F1") ?? "-")</span></td>
                            <td class="action-cell">
                                <button class="btn-action edit-grade-btn" data-id="@std.StudentId">Chỉnh sửa</button>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="7" class="text-center text-muted py-4">Không có học sinh nào trong lớp.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<!-- Modal Chỉnh sửa điểm -->
<div class="modal fade" id="editGradeModal" tabindex="-1" aria-labelledby="editGradeModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" style="border-radius: 20px; border: none; box-shadow: 0 25px 50px -12px rgba(0,0,0,0.25);">
            <div class="modal-header" style="border-bottom: 1px solid rgba(226,232,240,0.8); padding: 1.5rem;">
                <h5 class="modal-title fw-bold" id="editGradeModalLabel" style="color: #1e293b;">Nhập & Chỉnh sửa điểm số</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form id="editGradeForm">
                <div class="modal-body" style="padding: 1.5rem;">
                    
                    <div class="mb-3">
                        <label class="form-label text-secondary small font-weight-bold" style="font-weight: 600; color: #475569;">Chọn học sinh:</label>
                        <select class="form-select" id="modalStudentSelect" style="border-radius: 12px; padding: 0.75rem 1rem; border-color: #cbd5e1; font-weight: 600; color: #334155;">
                            <!-- Sẽ được nạp động bằng JavaScript -->
                        </select>
                    </div>

                    <hr class="my-3" style="border-top: 1px dashed #cbd5e1;" />

                    <!-- Điểm KT 1 -->
                    <div class="row mb-3 align-items-center">
                        <div class="col-4">
                            <label class="form-label mb-1" style="font-weight: 600; color: #475569;">Kiểm tra 1</label>
                            <input type="number" class="form-control score-input" id="scoreKT1" min="0" max="10" step="0.1" placeholder="-" style="border-radius: 12px; padding: 0.6rem 1rem; border-color: #cbd5e1;" />
                        </div>
                        <div class="col-8">
                            <label class="form-label text-secondary small mb-1">Nhận xét KT 1</label>
                            <input type="text" class="form-control" id="commentKT1" placeholder="Nhận xét bài làm..." style="border-radius: 12px; padding: 0.6rem 1rem; border-color: #cbd5e1;" />
                        </div>
                    </div>

                    <!-- Điểm KT 2 -->
                    <div class="row mb-3 align-items-center">
                        <div class="col-4">
                            <label class="form-label mb-1" style="font-weight: 600; color: #475569;">Kiểm tra 2</label>
                            <input type="number" class="form-control score-input" id="scoreKT2" min="0" max="10" step="0.1" placeholder="-" style="border-radius: 12px; padding: 0.6rem 1rem; border-color: #cbd5e1;" />
                        </div>
                        <div class="col-8">
                            <label class="form-label text-secondary small mb-1">Nhận xét KT 2</label>
                            <input type="text" class="form-control" id="commentKT2" placeholder="Nhận xét bài làm..." style="border-radius: 12px; padding: 0.6rem 1rem; border-color: #cbd5e1;" />
                        </div>
                    </div>

                    <!-- Điểm Giữa kỳ -->
                    <div class="row mb-3 align-items-center">
                        <div class="col-4">
                            <label class="form-label mb-1" style="font-weight: 600; color: #475569;">Giữa kỳ</label>
                            <input type="number" class="form-control score-input" id="scoreMidterm" min="0" max="10" step="0.1" placeholder="-" style="border-radius: 12px; padding: 0.6rem 1rem; border-color: #cbd5e1;" />
                        </div>
                        <div class="col-8">
                            <label class="form-label text-secondary small mb-1">Nhận xét Giữa kỳ</label>
                            <input type="text" class="form-control" id="commentMidterm" placeholder="Nhận xét bài làm..." style="border-radius: 12px; padding: 0.6rem 1rem; border-color: #cbd5e1;" />
                        </div>
                    </div>

                    <!-- Điểm Cuối kỳ -->
                    <div class="row mb-3 align-items-center">
                        <div class="col-4">
                            <label class="form-label mb-1" style="font-weight: 600; color: #475569;">Cuối kỳ</label>
                            <input type="number" class="form-control score-input" id="scoreFinal" min="0" max="10" step="0.1" placeholder="-" style="border-radius: 12px; padding: 0.6rem 1rem; border-color: #cbd5e1;" />
                        </div>
                        <div class="col-8">
                            <label class="form-label text-secondary small mb-1">Nhận xét Cuối kỳ</label>
                            <input type="text" class="form-control" id="commentFinal" placeholder="Nhận xét bài làm..." style="border-radius: 12px; padding: 0.6rem 1rem; border-color: #cbd5e1;" />
                        </div>
                    </div>
                </div>
                <div class="modal-footer" style="border-top: 1px solid rgba(226,232,240,0.8); padding: 1.5rem;">
                    <button type="button" class="btn btn-outline" data-bs-dismiss="modal" style="border-radius: 12px; font-weight: 600;">Hủy</button>
                    <button type="submit" class="btn-primary-green" style="border-radius: 12px; padding: 0.5rem 1.5rem; border: none; font-weight: 600; color: #ffffff;">Lưu điểm</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Lưu trữ danh sách học sinh và điểm số của lớp học hiện tại
        let studentGradesData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.StudentsGrades));

        document.addEventListener("DOMContentLoaded", function () {
            // Sự kiện thay đổi Lớp học
            document.getElementById("classSelect").addEventListener("change", function () {
                const classId = this.value;
                loadGradesForClass(classId);
            });

            // Tìm kiếm học sinh trực tiếp bằng Javascript
            document.getElementById("studentSearchInput").addEventListener("input", function () {
                const query = this.value.trim().toLowerCase();
                const filtered = studentGradesData.filter(std => 
                    std.StudentName.toLowerCase().includes(query) || 
                    std.StudentCode.toLowerCase().includes(query)
                );
                renderGradesTable(filtered);
            });

            // Sự kiện click nút Chỉnh sửa của dòng học sinh ban đầu
            registerEditButtons();

            // Nút Nhập điểm nhanh (mở của học sinh đầu tiên trong bảng)
            document.getElementById("btnEnterGrades").addEventListener("click", function () {
                if (studentGradesData && studentGradesData.length > 0) {
                    openEditModal(studentGradesData[0].StudentId);
                } else {
                    showToast("Lớp học hiện tại chưa có học sinh để nhập điểm.", false);
                }
            });

            // Submit form chỉnh sửa điểm số
            document.getElementById("editGradeForm").addEventListener("submit", function (e) {
                e.preventDefault();
                saveGrades();
            });

            // Sự kiện thay đổi học sinh trong dropdown của modal
            document.getElementById("modalStudentSelect").addEventListener("change", function () {
                const studentId = parseInt(this.value);
                fillGradesToInputs(studentId);
            });
        });

        // Hàm lấy danh sách điểm lớp học qua API
        function loadGradesForClass(classId) {
            fetch(`/api/v1/teacher/grades?classId=${classId}`)
                .then(res => res.json())
                .then(res => {
                    if (res.success) {
                        // API DTO trả về snakeCase/camelCase, ta cần chuẩn hóa khớp PascalCase
                        studentGradesData = res.data.map(std => ({
                            StudentId: std.studentId,
                            StudentName: std.studentName,
                            StudentCode: std.studentCode,
                            ScoreKT1: std.scoreKT1,
                            CommentKT1: std.commentKT1,
                            ScoreKT2: std.scoreKT2,
                            CommentKT2: std.commentKT2,
                            ScoreMidterm: std.scoreMidterm,
                            CommentMidterm: std.commentMidterm,
                            ScoreFinal: std.scoreFinal,
                            CommentFinal: std.commentFinal,
                            AverageScore: std.averageScore
                        }));
                        renderGradesTable(studentGradesData);
                        // Reset input tìm kiếm
                        document.getElementById("studentSearchInput").value = "";
                    } else {
                        showToast(res.message, false);
                    }
                })
                .catch(err => {
                    console.error(err);
                    showToast("Đã xảy ra lỗi khi tải danh sách điểm số.", false);
                });
        }

        // Render bảng điểm bằng JS
        function renderGradesTable(studentsList) {
            const tbody = document.querySelector(".grades-table tbody");
            tbody.innerHTML = "";
            
            if (studentsList.length === 0) {
                tbody.innerHTML = `<tr><td colspan="7" class="text-center text-muted py-4">Không tìm thấy học sinh nào.</td></tr>`;
                return;
            }

            studentsList.forEach(std => {
                const tr = document.createElement("tr");
                tr.setAttribute("data-student-id", std.StudentId);
                tr.innerHTML = `
                    <td class="student-name">
                        ${std.StudentName}
                        <div class="student-code text-muted small">${std.StudentCode}</div>
                    </td>
                    <td class="score-cell"><span class="score-badge ${getScoreColor(std.ScoreKT1)}">${formatScore(std.ScoreKT1)}</span></td>
                    <td class="score-cell"><span class="score-badge ${getScoreColor(std.ScoreKT2)}">${formatScore(std.ScoreKT2)}</span></td>
                    <td class="score-cell"><span class="score-badge ${getScoreColor(std.ScoreMidterm)}">${formatScore(std.ScoreMidterm)}</span></td>
                    <td class="score-cell"><span class="score-badge ${getScoreColor(std.ScoreFinal)}">${formatScore(std.ScoreFinal)}</span></td>
                    <td class="score-cell"><span class="score-badge ${getScoreColor(std.AverageScore)}">${formatScore(std.AverageScore)}</span></td>
                    <td class="action-cell">
                        <button class="btn-action edit-grade-btn" data-id="${std.StudentId}">Chỉnh sửa</button>
                    </td>
                `;
                tbody.appendChild(tr);
            });

            registerEditButtons();
        }

        // Đăng ký sự kiện click cho các nút sửa
        function registerEditButtons() {
            document.querySelectorAll(".edit-grade-btn").forEach(btn => {
                btn.addEventListener("click", function () {
                    const studentId = parseInt(this.getAttribute("data-id"));
                    openEditModal(studentId);
                });
            });
        }

        // Mở modal nhập điểm
        function openEditModal(studentId) {
            if (!studentGradesData || studentGradesData.length === 0) return;

            // Đổ danh sách học sinh vào dropdown select của modal
            const select = document.getElementById("modalStudentSelect");
            select.innerHTML = "";
            studentGradesData.forEach(std => {
                const opt = document.createElement("option");
                opt.value = std.StudentId;
                opt.textContent = `${std.StudentName} (${std.StudentCode})`;
                select.appendChild(opt);
            });

            // Chọn học sinh hiện tại trong dropdown
            select.value = studentId;

            // Điền điểm số tương ứng
            fillGradesToInputs(studentId);

            const modal = new bootstrap.Modal(document.getElementById("editGradeModal"));
            modal.show();
        }

        // Điền điểm số của học sinh được chọn lên các input
        function fillGradesToInputs(studentId) {
            const std = studentGradesData.find(s => s.StudentId === studentId);
            if (!std) return;

            document.getElementById("scoreKT1").value = std.ScoreKT1 !== null ? std.ScoreKT1 : "";
            document.getElementById("commentKT1").value = std.CommentKT1 || "";

            document.getElementById("scoreKT2").value = std.ScoreKT2 !== null ? std.ScoreKT2 : "";
            document.getElementById("commentKT2").value = std.CommentKT2 || "";

            document.getElementById("scoreMidterm").value = std.ScoreMidterm !== null ? std.ScoreMidterm : "";
            document.getElementById("commentMidterm").value = std.CommentMidterm || "";

            document.getElementById("scoreFinal").value = std.ScoreFinal !== null ? std.ScoreFinal : "";
            document.getElementById("commentFinal").value = std.CommentFinal || "";
        }

        // Gọi API lưu điểm
        function saveGrades() {
            const classId = parseInt(document.getElementById("classSelect").value);
            const studentId = parseInt(document.getElementById("modalStudentSelect").value);

            const scoreKT1 = document.getElementById("scoreKT1").value;
            const scoreKT2 = document.getElementById("scoreKT2").value;
            const scoreMidterm = document.getElementById("scoreMidterm").value;
            const scoreFinal = document.getElementById("scoreFinal").value;

            // Validate client side
            const scores = [scoreKT1, scoreKT2, scoreMidterm, scoreFinal];
            for (let s of scores) {
                if (s !== "" && (parseFloat(s) < 0 || parseFloat(s) > 10)) {
                    showToast("Điểm số phải nằm trong khoảng từ 0 đến 10.", false);
                    return;
                }
            }

            const requestData = {
                ClassId: classId,
                StudentId: studentId,
                ScoreKT1: scoreKT1 !== "" ? parseFloat(scoreKT1) : null,
                CommentKT1: document.getElementById("commentKT1").value,
                ScoreKT2: scoreKT2 !== "" ? parseFloat(scoreKT2) : null,
                CommentKT2: document.getElementById("commentKT2").value,
                ScoreMidterm: scoreMidterm !== "" ? parseFloat(scoreMidterm) : null,
                CommentMidterm: document.getElementById("commentMidterm").value,
                ScoreFinal: scoreFinal !== "" ? parseFloat(scoreFinal) : null,
                CommentFinal: document.getElementById("commentFinal").value
            };

            fetch('/api/v1/teacher/grades/save', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify(requestData)
            })
            .then(res => res.json())
            .then(res => {
                if (res.success) {
                    showToast("Cập nhật điểm số thành công!");
                    // Đóng modal
                    const modalElement = document.getElementById("editGradeModal");
                    const modalInstance = bootstrap.Modal.getInstance(modalElement);
                    if (modalInstance) {
                        modalInstance.hide();
                    }
                    // Tải lại bảng điểm lớp học
                    loadGradesForClass(classId);
                } else {
                    showToast(res.message, false);
                }
            })
            .catch(err => {
                console.error(err);
                showToast("Không thể kết nối đến server để lưu điểm.", false);
            });
        }

        // Định dạng màu badge điểm số
        function getScoreColor(score) {
            if (score === null || score === undefined) return "score-empty";
            const val = parseFloat(score);
            if (val >= 9) return "score-green";
            if (val >= 7) return "score-blue";
            if (val >= 5) return "score-orange";
            return "score-red";
        }

        // Định dạng số hiển thị
        function formatScore(score) {
            return (score === null || score === undefined) ? "-" : parseFloat(score).toFixed(1);
        }
    </script>
}