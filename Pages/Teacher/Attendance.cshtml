@page
@model EduBridge.Pages.Teacher.AttendanceModel
@{
    Layout = "_TeacherLayout";
    ViewData["Title"] = "Điểm danh";
    ViewData["ActivePage"] = "Attendance";

    string GetBadgeClass(string? status) {
        return status switch {
            "Present" => "status-present",
            "Late" => "status-late",
            "Absent" => "status-absent",
            _ => "status-empty"
        };
    }

    var currentLesson = Model.ClassLessons.FirstOrDefault(l => l.LessonId == Model.SelectedLessonId);
    var initialCanEdit = currentLesson?.CanEdit ?? true;
}

<div class="mb-6 rounded-2xl bg-gradient-to-br from-white to-blue-50 p-6 shadow-[0_4px_6px_-1px_rgba(0,0,0,0.02)] border border-slate-200/80 flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4">
    <div>
        <h1 class="text-3xl font-extrabold bg-gradient-to-r from-blue-500 to-blue-700 bg-clip-text text-transparent">Điểm danh</h1>
        <p class="mt-2 text-base text-gray-500">Ghi nhận tình trạng chuyên cần</p>
    </div>
    <button class="inline-flex items-center justify-center rounded-lg border border-gray-300 bg-white px-4 py-2 text-sm font-medium text-gray-700 shadow-sm hover:bg-gray-50 transition-colors focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2" id="btnExportReport">
        <svg class="mr-2" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="7 10 12 15 17 10"></polyline><line x1="12" y1="15" x2="12" y2="3"></line></svg>
        Xuất báo cáo
    </button>
</div>

<!-- 4 Thẻ Thống kê -->
<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-6">
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-5 flex justify-between items-center">
        <div>
            <div class="text-sm font-medium text-gray-500 mb-2">Có mặt</div>
            <div class="text-3xl font-bold text-green-600" id="statPresent">0</div>
        </div>
        <div class="text-green-600 bg-green-100 p-3 rounded-xl">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
        </div>
    </div>
    
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-5 flex justify-between items-center">
        <div>
            <div class="text-sm font-medium text-gray-500 mb-2">Vắng mặt</div>
            <div class="text-3xl font-bold text-red-600" id="statAbsent">0</div>
        </div>
        <div class="text-red-600 bg-red-100 p-3 rounded-xl">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"></circle><line x1="15" y1="9" x2="9" y2="15"></line><line x1="9" y1="9" x2="15" y2="15"></line></svg>
        </div>
    </div>
    
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-5 flex justify-between items-center">
        <div>
            <div class="text-sm font-medium text-gray-500 mb-2">Đi muộn</div>
            <div class="text-3xl font-bold text-orange-600" id="statLate">0</div>
        </div>
        <div class="text-orange-600 bg-orange-100 p-3 rounded-xl">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
        </div>
    </div>
    
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-5 flex justify-between items-center">
        <div>
            <div class="text-sm font-medium text-gray-500 mb-2">Tỷ lệ chuyên cần</div>
            <div class="text-3xl font-bold text-blue-600" id="statRate">0%</div>
        </div>
        <div class="text-blue-600 bg-blue-100 p-3 rounded-xl">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg>
        </div>
    </div>
</div>

<div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden mb-6">
    <div class="px-6 py-5 border-b border-gray-200 bg-gray-50 flex flex-col xl:flex-row justify-between items-start xl:items-center gap-4">
        <h3 class="text-lg font-bold text-gray-900 m-0">Bảng điểm danh</h3>
        <div class="flex flex-col sm:flex-row items-center gap-3 w-full xl:w-auto">
            <!-- Select Lớp học -->
            <select class="block w-full sm:w-48 pl-3 pr-8 py-2 text-base border-gray-300 focus:outline-none focus:ring-blue-500 focus:border-blue-500 sm:text-sm rounded-lg border border-solid" id="classSelect">
                @foreach(var c in Model.TeacherClasses)
                {
                    <!option value="@c.ClassId" @(c.ClassId == Model.SelectedClassId ? "selected" : "")>@c.ClassName</!option>
                }
            </select>
            
            <!-- Select Buổi học -->
            <select class="block w-full sm:w-56 pl-3 pr-8 py-2 text-base border-gray-300 focus:outline-none focus:ring-blue-500 focus:border-blue-500 sm:text-sm rounded-lg border border-solid" id="lessonSelect">
                @foreach(var l in Model.ClassLessons)
                {
                    <!option value="@l.LessonId" data-can-edit="@l.CanEdit.ToString().ToLower()" @(l.LessonId == Model.SelectedLessonId ? "selected" : "")>@l.LessonTitle (@l.DateString)</!option>
                }
            </select>

            <div class="relative w-full sm:w-56">
                <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                    <svg class="h-5 w-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
                </div>
                <input type="text" id="studentSearchInput" class="block w-full pl-10 pr-3 py-2 border border-gray-300 rounded-lg leading-5 bg-white placeholder-gray-500 focus:outline-none focus:ring-1 focus:ring-blue-500 focus:border-blue-500 sm:text-sm" placeholder="Tìm học sinh...">
            </div>
        </div>
    </div>
    
    <div class="px-6 py-4">
        <div id="attendanceAlert" class="rounded-lg bg-yellow-50 p-4 mb-2 @(initialCanEdit ? "hidden" : "flex")">
            <div class="flex">
                <div class="flex-shrink-0">
                    <svg class="h-5 w-5 text-yellow-400" viewBox="0 0 20 20" fill="currentColor">
                        <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd" />
                    </svg>
                </div>
                <div class="ml-3">
                    <h3 class="text-sm font-medium text-yellow-800">Cảnh báo</h3>
                    <div class="mt-2 text-sm text-yellow-700">
                        <p>Buổi học đã kết thúc quá 48h. Không thể chỉnh sửa thông tin điểm danh.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-gray-200">
            <thead class="bg-gray-50">
                <tr>
                    <th scope="col" class="px-6 py-3 text-center text-xs font-semibold text-gray-500 uppercase tracking-wider w-16">STT</th>
                    <th scope="col" class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Học sinh</th>
                    <th scope="col" class="px-6 py-3 text-center text-xs font-semibold text-gray-500 uppercase tracking-wider w-40">Trạng thái</th>
                    <th scope="col" class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Ghi chú</th>
                    <th scope="col" class="px-6 py-3 text-center text-xs font-semibold text-gray-500 uppercase tracking-wider w-64">Cập nhật</th>
                </tr>
            </thead>
            <tbody id="attendanceTableBody" class="bg-white divide-y divide-gray-200">
                @if (Model.StudentAttendances.Any())
                {
                    int idx = 1;
                    @foreach(var std in Model.StudentAttendances)
                    {
                        <tr data-student-id="@std.StudentId">
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500 text-center">@(idx++)</td>
                            <td class="px-6 py-4 whitespace-nowrap">
                                <div class="flex items-center">
                                    <div class="flex-shrink-0 h-10 w-10 rounded-full bg-blue-100 flex items-center justify-center text-blue-600 font-bold">
                                        @std.StudentName.Substring(0, Math.Min(2, std.StudentName.Length)).ToUpper()
                                    </div>
                                    <div class="ml-4">
                                        <div class="text-sm font-bold text-gray-900">@std.StudentName</div>
                                        <div class="text-sm text-gray-500">Mã: @std.StudentCode</div>
                                    </div>
                                </div>
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap text-center">
                                <span class="status-badge @GetBadgeClass(std.Status)" id="badge-@std.StudentId">
                                    @if (std.Status == "Present")
                                    {
                                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin-right: 4px;"><polyline points="20 6 9 17 4 12"></polyline></svg>@:Có mặt
                                    }
                                    else if (std.Status == "Late")
                                    {
                                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin-right: 4px;"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>@:Muộn
                                    }
                                    else if (std.Status == "Absent")
                                    {
                                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin-right: 4px;"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>@:Vắng
                                    }
                                    else
                                    {
                                        @:Chưa điểm danh
                                    }
                                </span>
                            </td>
                            <td class="px-6 py-4"><input type="text" class="notes-input" id="note-@std.StudentId" value="@std.Note" placeholder="Nhập ghi chú..." @(initialCanEdit ? "" : "disabled") /></td>
                            <td class="px-6 py-4 whitespace-nowrap text-center">
                                <div class="inline-flex rounded-md shadow-sm" role="group">
                                    <button class="px-3 py-1 text-sm font-medium border border-gray-200 rounded-l-lg hover:bg-gray-100 hover:text-blue-700 focus:z-10 focus:ring-2 focus:ring-blue-700 btn-status btn-present-select @(std.Status == "Present" ? "btn-status-active text-blue-700 bg-gray-100 ring-2 ring-blue-700" : "text-gray-900 bg-white")" @(initialCanEdit ? "" : "disabled") data-id="@std.StudentId">Có mặt</button>
                                    <button class="px-3 py-1 text-sm font-medium border-t border-b border-gray-200 hover:bg-gray-100 hover:text-blue-700 focus:z-10 focus:ring-2 focus:ring-blue-700 btn-status btn-late-select @(std.Status == "Late" ? "btn-status-active text-blue-700 bg-gray-100 ring-2 ring-blue-700" : "text-gray-900 bg-white")" @(initialCanEdit ? "" : "disabled") data-id="@std.StudentId">Muộn</button>
                                    <button class="px-3 py-1 text-sm font-medium border border-gray-200 rounded-r-lg hover:bg-gray-100 hover:text-blue-700 focus:z-10 focus:ring-2 focus:ring-blue-700 btn-status btn-absent-select @(std.Status == "Absent" ? "btn-status-active text-blue-700 bg-gray-100 ring-2 ring-blue-700" : "text-gray-900 bg-white")" @(initialCanEdit ? "" : "disabled") data-id="@std.StudentId">Vắng</button>
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="5" class="px-6 py-10 text-center text-gray-500">
                            Không có học sinh hoặc buổi học nào được chọn.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    
    <div class="px-6 py-4 border-t border-gray-200 bg-gray-50 flex justify-end">
        <button class="inline-flex justify-center py-2 px-4 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500" id="btnSaveAttendance" style="@(initialCanEdit ? "" : "display: none;")">Lưu điểm danh</button>
    </div>
</div>

<div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
    <div class="px-6 py-5 border-b border-gray-200 bg-gray-50">
        <h3 class="text-lg font-bold text-gray-900 m-0">Lịch sử điểm danh</h3>
    </div>
    
    <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-gray-200">
            <thead class="bg-gray-50">
                <tr>
                    <th scope="col" class="px-6 py-3 text-center text-xs font-semibold text-gray-500 uppercase tracking-wider w-16">STT</th>
                    <th scope="col" class="px-6 py-3 text-center text-xs font-semibold text-gray-500 uppercase tracking-wider w-32">Ngày</th>
                    <th scope="col" class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Lớp</th>
                    <th scope="col" class="px-6 py-3 text-center text-xs font-semibold text-gray-500 uppercase tracking-wider w-24">Có mặt</th>
                    <th scope="col" class="px-6 py-3 text-center text-xs font-semibold text-gray-500 uppercase tracking-wider w-24">Vắng</th>
                    <th scope="col" class="px-6 py-3 text-center text-xs font-semibold text-gray-500 uppercase tracking-wider w-24">Muộn</th>
                    <th scope="col" class="px-6 py-3 text-center text-xs font-semibold text-gray-500 uppercase tracking-wider w-24">Tỷ lệ</th>
                    <th scope="col" class="px-6 py-3 text-center text-xs font-semibold text-gray-500 uppercase tracking-wider w-24">Thao tác</th>
                </tr>
            </thead>
            <tbody id="attendanceHistoryTableBody" class="text-sm divide-y divide-gray-100 bg-white">
                <!-- Nạp động bằng JavaScript -->
            </tbody>
        </table>
        <div id="attendanceHistoryPagination"></div>
    </div>
</div>

@section Scripts {
    <style>
        .notes-input {
            width: 100%;
            padding: 0.5rem 1rem;
            border: 1px solid #cbd5e1;
            background-color: #f8fafc;
            border-radius: 8px;
            font-size: 0.9rem;
            color: #334155;
            outline: none;
            transition: all 0.2s;
        }
        .notes-input:focus {
            background-color: #ffffff;
            border-color: #94a3b8;
        }
        .stat-circle-green {
            background-color: #dcfce7;
            color: #166534;
            padding: 2px 10px;
            border-radius: 12px;
            font-weight: 600;
            font-size: 0.85rem;
            display: inline-block;
            min-width: 32px;
            text-align: center;
        }
        .stat-circle-red {
            background-color: #fee2e2;
            color: #991b1b;
            padding: 2px 10px;
            border-radius: 12px;
            font-weight: 600;
            font-size: 0.85rem;
            display: inline-block;
            min-width: 32px;
            text-align: center;
        }
        .stat-circle-orange {
            background-color: #ffedd5;
            color: #9a3412;
            padding: 2px 10px;
            border-radius: 12px;
            font-weight: 600;
            font-size: 0.85rem;
            display: inline-block;
            min-width: 32px;
            text-align: center;
        }
        .status-badge {
            display: inline-flex;
            align-items: center;
            padding: 0.25rem 0.75rem;
            border-radius: 8px;
            font-weight: 600;
            font-size: 0.85rem;
        }
        .status-present {
            background-color: #dcfce7;
            color: #166534;
        }
        .status-late {
            background-color: #ffedd5;
            color: #b45309;
        }
        .status-absent {
            background-color: #fee2e2;
            color: #b91c1c;
        }
        .status-empty {
            background-color: #f1f5f9;
            color: #64748b;
        }
    </style>

    <script>
        // Dữ liệu học sinh điểm danh cục bộ
        let rawAttendancesData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.StudentAttendances));
        let studentAttendancesData = (rawAttendancesData || []).map(std => ({
            StudentId: std.StudentId !== undefined ? std.StudentId : std.studentId,
            StudentName: std.StudentName !== undefined ? std.StudentName : std.studentName,
            StudentCode: std.StudentCode !== undefined ? std.StudentCode : std.studentCode,
            Status: std.Status !== undefined ? std.Status : std.status,
            Note: std.Note !== undefined ? std.Note : std.note
        }));
        let rawHistoryData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.AttendanceHistory));
        let attendanceHistoryData = (rawHistoryData || []).map(h => ({
            LessonId: h.LessonId !== undefined ? h.LessonId : h.lessonId,
            DateString: h.DateString !== undefined ? h.DateString : h.dateString,
            ClassName: h.ClassName !== undefined ? h.ClassName : h.className,
            PresentCount: h.PresentCount !== undefined ? h.PresentCount : h.presentCount,
            AbsentCount: h.AbsentCount !== undefined ? h.AbsentCount : h.absentCount,
            LateCount: h.LateCount !== undefined ? h.LateCount : h.lateCount,
            AttendanceRate: h.AttendanceRate !== undefined ? h.AttendanceRate : h.attendanceRate
        }));
        let historyCurrentPage = 1;
        let historyPageSize = 10;

        document.addEventListener("DOMContentLoaded", function () {
            // Thống kê lúc load trang ban đầu
            updateStatistics();
            renderAttendanceHistoryTable();

            // Lắng nghe đổi Lớp học
            document.getElementById("classSelect").addEventListener("change", function () {
                const classId = this.value;
                loadLessonsForClass(classId);
            });

            // Lắng nghe đổi Buổi học
            document.getElementById("lessonSelect").addEventListener("change", function () {
                const lessonId = this.value;
                loadAttendanceForLesson(lessonId);
            });

            // Tìm kiếm học sinh trực tiếp
            document.getElementById("studentSearchInput").addEventListener("input", function () {
                const query = this.value.trim().toLowerCase();
                const filtered = studentAttendancesData.filter(std => 
                    std.StudentName.toLowerCase().includes(query) || 
                    std.StudentCode.toLowerCase().includes(query)
                );
                const lessonSelect = document.getElementById("lessonSelect");
                const selectedOption = lessonSelect.options[lessonSelect.selectedIndex];
                const canEdit = selectedOption ? (selectedOption.getAttribute("data-can-edit") === "true") : true;
                renderAttendanceTable(filtered, canEdit);
            });

            // Gán sự kiện click nút bấm đổi trạng thái & ghi chú ban đầu
            registerAttendanceActions();

            // Sự kiện Click xem chi tiết ở bảng lịch sử điểm danh
            registerHistoryDetails();

            // Sự kiện lưu điểm danh
            document.getElementById("btnSaveAttendance").addEventListener("click", function () {
                saveAttendance();
            });

            // Xuất báo cáo chuyên cần
            document.getElementById("btnExportReport").addEventListener("click", function () {
                exportAttendanceToCSV();
            });
        });

        // Xuất báo cáo chuyên cần ra file CSV chuẩn UTF-8 có BOM
        function exportAttendanceToCSV() {
            if (!studentAttendancesData || studentAttendancesData.length === 0) {
                showToast("Không có dữ liệu để xuất báo cáo.", false);
                return;
            }

            const classSelect = document.getElementById("classSelect");
            const className = classSelect.options[classSelect.selectedIndex].text;
            const lessonSelect = document.getElementById("lessonSelect");
            if (!lessonSelect || !lessonSelect.value) {
                showToast("Vui lòng chọn một buổi học để xuất báo cáo.", false);
                return;
            }
            const lessonTitle = lessonSelect.options[lessonSelect.selectedIndex].text;

            let csvContent = "\uFEFF"; // BOM để Excel nhận dạng UTF-8 tiếng Việt
            csvContent += `BÁO CÁO ĐIỂM DANH - LỚP: ${className}\r\n`;
            csvContent += `Buổi học: ${lessonTitle}\r\n\r\n`;
            csvContent += "Mã học sinh,Học sinh,Trạng thái,Ghi chú\r\n";

            studentAttendancesData.forEach(std => {
                const statusText = std.Status === "Present" ? "Có mặt" :
                                   std.Status === "Late" ? "Muộn" :
                                   std.Status === "Absent" ? "Vắng" : "Chưa điểm danh";
                const noteText = std.Note ? std.Note.replace(/"/g, '""').replace(/,/g, ";") : "";
                csvContent += `"${std.StudentCode}","${std.StudentName}","${statusText}","${noteText}"\r\n`;
            });

            const blob = new Blob([csvContent], { type: "text/csv;charset=utf-8;" });
            const link = document.createElement("a");
            const url = URL.createObjectURL(blob);
            link.setAttribute("href", url);
            
            const fileName = `diem_danh_${className.replace(/\s+/g, "_")}_lesson_${lessonSelect.value}.csv`;
            link.setAttribute("download", fileName);
            link.style.visibility = 'hidden';
            document.body.appendChild(link);
            link.click();
            document.body.removeChild(link);
            
            showToast("Xuất báo cáo chuyên cần thành công!");
        }

        // Tải danh sách buổi học & lịch sử khi đổi lớp
        function loadLessonsForClass(classId) {
            fetch(`/api/v1/teacher/attendance/lessons?classId=${classId}`)
                .then(res => res.json())
                .then(res => {
                    const lessonSelect = document.getElementById("lessonSelect");
                    lessonSelect.innerHTML = "";
                    
                    if (res.success && res.data.length > 0) {
                        res.data.forEach(l => {
                            const opt = document.createElement("option");
                            opt.value = l.lessonId;
                            opt.textContent = `${l.lessonTitle} (${l.dateString})`;
                            opt.setAttribute("data-can-edit", l.canEdit);
                            lessonSelect.appendChild(opt);
                        });
                        
                        // Tải bảng điểm danh buổi học đầu tiên
                        loadAttendanceForLesson(res.data[0].lessonId);
                    } else {
                        lessonSelect.innerHTML = `<option value="">-- Không có buổi học --</option>`;
                        studentAttendancesData = [];
                        renderAttendanceTable([]);
                        updateStatistics();
                    }
                })
                .catch(err => {
                    console.error(err);
                    showToast("Đã xảy ra lỗi khi tải danh sách buổi học.", false);
                });

            // Tải lịch sử điểm danh của lớp
            loadHistoryForClass(classId);
        }

        // Tải lịch sử điểm danh qua API
        function loadHistoryForClass(classId) {
            fetch(`/api/v1/teacher/attendance/history?classId=${classId}`)
                .then(res => res.json())
                .then(res => {
                    if (res.success) {
                        attendanceHistoryData = res.data;
                        historyCurrentPage = 1;
                        renderAttendanceHistoryTable();
                    } else {
                        attendanceHistoryData = [];
                        renderAttendanceHistoryTable();
                    }
                })
                .catch(err => {
                    console.error(err);
                    attendanceHistoryData = [];
                    renderAttendanceHistoryTable();
                });
        }

        // Tải bảng điểm danh của một buổi học
        function loadAttendanceForLesson(lessonId) {
            if (!lessonId) return;
            fetch(`/api/v1/teacher/attendance?lessonId=${lessonId}`)
                .then(res => res.json())
                .then(res => {
                    if (res.success) {
                        studentAttendancesData = res.data.map(std => ({
                            StudentId: std.studentId,
                            StudentName: std.studentName,
                            StudentCode: std.studentCode,
                            Status: std.status,
                            Note: std.note
                        }));

                        // Đọc canEdit từ option được chọn
                        const lessonSelect = document.getElementById("lessonSelect");
                        const selectedOption = lessonSelect.options[lessonSelect.selectedIndex];
                        const canEdit = selectedOption ? (selectedOption.getAttribute("data-can-edit") === "true") : true;

                        // Ẩn/Hiện alert
                        const alertEl = document.getElementById("attendanceAlert");
                        if (alertEl) {
                            if (canEdit) {
                                alertEl.classList.add("d-none");
                            } else {
                                alertEl.classList.remove("d-none");
                            }
                        }

                        // Ẩn/Hiện nút Save
                        const saveBtn = document.getElementById("btnSaveAttendance");
                        if (saveBtn) {
                            saveBtn.style.display = canEdit ? "" : "none";
                        }

                        renderAttendanceTable(studentAttendancesData, canEdit);
                        updateStatistics();
                        // Reset tìm kiếm
                        document.getElementById("studentSearchInput").value = "";
                    } else {
                        showToast(res.message, false);
                    }
                })
                .catch(err => {
                    console.error(err);
                    showToast("Đã xảy ra lỗi khi tải danh sách điểm danh.", false);
                });
        }

        // Render bảng Lịch sử điểm danh kèm phân trang
        function renderAttendanceHistoryTable() {
            const tbody = document.getElementById("attendanceHistoryTableBody");
            const paginationEl = document.getElementById("attendanceHistoryPagination");
            if (!tbody) return;

            tbody.innerHTML = "";

            const totalItems = attendanceHistoryData.length;
            const totalPages = Math.ceil(totalItems / historyPageSize) || 1;

            if (historyCurrentPage > totalPages) historyCurrentPage = totalPages;
            if (historyCurrentPage < 1) historyCurrentPage = 1;

            const start = (historyCurrentPage - 1) * historyPageSize;
            const end = Math.min(start + historyPageSize, totalItems);
            const pageItems = attendanceHistoryData.slice(start, end);

            if (pageItems.length === 0) {
                tbody.innerHTML = `<tr><td colspan="8" class="px-6 py-10 text-center text-gray-500">Chưa có lịch sử điểm danh nào.</td></tr>`;
                if (paginationEl) paginationEl.innerHTML = "";
                return;
            }

            pageItems.forEach((h, index) => {
                const indexGlobal = start + index + 1;
                const tr = document.createElement("tr");
                tr.innerHTML = `
                    <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500 text-center">${indexGlobal}</td>
                    <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500 text-center">${h.dateString || h.DateString}</td>
                    <td class="px-6 py-4 whitespace-nowrap text-sm"><span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-800">${h.className || h.ClassName}</span></td>
                    <td class="px-6 py-4 whitespace-nowrap text-center"><span class="inline-flex items-center justify-center h-8 w-8 rounded-full bg-green-100 text-green-800 font-bold text-sm">${h.presentCount ?? h.PresentCount}</span></td>
                    <td class="px-6 py-4 whitespace-nowrap text-center"><span class="inline-flex items-center justify-center h-8 w-8 rounded-full bg-red-100 text-red-800 font-bold text-sm">${h.absentCount ?? h.AbsentCount}</span></td>
                    <td class="px-6 py-4 whitespace-nowrap text-center"><span class="inline-flex items-center justify-center h-8 w-8 rounded-full bg-orange-100 text-orange-800 font-bold text-sm">${h.lateCount ?? h.LateCount}</span></td>
                    <td class="px-6 py-4 whitespace-nowrap text-sm font-bold text-gray-900 text-center">${h.attendanceRate || h.AttendanceRate}</td>
                    <td class="px-6 py-4 whitespace-nowrap text-center text-sm font-medium">
                        <button class="text-blue-600 hover:text-blue-900 bg-blue-50 hover:bg-blue-100 p-2 rounded-lg transition-colors view-history-detail" data-lesson-id="${h.lessonId || h.LessonId}" title="Xem chi tiết">
                            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.25 12s3.75-6.75 9.75-6.75S21.75 12 21.75 12 18 18.75 12 18.75 2.25 12 2.25 12z"></path>
                                <circle cx="12" cy="12" r="3" stroke-width="2"></circle>
                            </svg>
                        </button>
                    </td>
                `;
                tbody.appendChild(tr);
            });

            registerHistoryDetails();
            renderHistoryPagination(totalPages, totalItems);
        }

        function renderHistoryPagination(totalPages, totalItems) {
            const container = document.getElementById("attendanceHistoryPagination");
            if (!container) return;

            let html = `<div class="flex flex-wrap items-center justify-center gap-6 rounded-b-2xl border-t border-gray-200 bg-white px-6 py-4 text-sm text-gray-600">`;
            
            html += `<div class="flex items-center gap-1">`;
            
            // Trang đầu
            html += `<button class="inline-flex h-9 w-9 items-center justify-center rounded text-gray-400 hover:bg-blue-50 hover:text-blue-600 page-link-btn" data-page="1" ${historyCurrentPage === 1 ? 'disabled' : ''}>«</button>`;
            
            // Trang trước
            html += `<button class="inline-flex h-9 w-9 items-center justify-center rounded text-gray-400 hover:bg-blue-50 hover:text-blue-600 page-link-btn" data-page="${Math.max(1, historyCurrentPage - 1)}" ${historyCurrentPage === 1 ? 'disabled' : ''}>‹</button>`;

            let startPage = Math.max(1, historyCurrentPage - 2);
            let endPage = Math.min(totalPages, startPage + 4);
            if (endPage - startPage < 4) {
                startPage = Math.max(1, endPage - 4);
            }

            for (let i = startPage; i <= endPage; i++) {
                if (i === historyCurrentPage) {
                    html += `<button class="page-link-btn inline-flex h-9 w-9 items-center justify-center rounded bg-blue-100 text-blue-700 font-semibold" data-page="${i}">${i}</button>`;
                } else {
                    html += `<button class="page-link-btn inline-flex h-9 w-9 items-center justify-center rounded text-gray-600 hover:bg-blue-50 hover:text-blue-600 transition-colors" data-page="${i}">${i}</button>`;
                }
            }

            // Trang tiếp
            html += `<button class="inline-flex h-9 w-9 items-center justify-center rounded text-gray-500 hover:bg-blue-50 hover:text-blue-600 page-link-btn" data-page="${Math.min(totalPages, historyCurrentPage + 1)}" ${historyCurrentPage === totalPages ? 'disabled' : ''}>›</button>`;
            
            // Trang cuối
            html += `<button class="inline-flex h-9 w-9 items-center justify-center rounded text-gray-500 hover:bg-blue-50 hover:text-blue-600 page-link-btn" data-page="${totalPages}" ${historyCurrentPage === totalPages ? 'disabled' : ''}>»</button>`;
            html += `</div>`;

            // Tổng số bản ghi
            html += `<div class="font-medium text-gray-600">Tổng số: ${totalItems} bản ghi</div>`;

            // Chọn số lượng hiển thị
            html += `<div class="flex items-center">
                        <select class="page-size-select h-10 rounded border border-blue-300 bg-white px-3 text-sm text-gray-700 focus:border-blue-500 focus:outline-none focus:ring-1 focus:ring-blue-500">
                            <option value="10" ${historyPageSize === 10 ? 'selected' : ''}>10</option>
                            <option value="20" ${historyPageSize === 20 ? 'selected' : ''}>20</option>
                            <option value="50" ${historyPageSize === 50 ? 'selected' : ''}>50</option>
                            <option value="100" ${historyPageSize === 100 ? 'selected' : ''}>100</option>
                            <option value="200" ${historyPageSize === 200 ? 'selected' : ''}>200</option>
                            <option value="500" ${historyPageSize === 500 ? 'selected' : ''}>500</option>
                        </select>
                     </div>`;
            html += `</div>`;

            container.innerHTML = html;

            container.querySelectorAll(".page-link-btn").forEach(link => {
                if(!link.hasAttribute('disabled')){
                    link.addEventListener("click", function(e) {
                        e.preventDefault();
                        historyCurrentPage = parseInt(this.getAttribute("data-page"));
                        renderAttendanceHistoryTable();
                    });
                }
            });

            container.querySelector(".page-size-select").addEventListener("change", function() {
                historyPageSize = parseInt(this.value);
                historyCurrentPage = 1;
                renderAttendanceHistoryTable();
            });
        }

        // Render bảng điểm danh học sinh
        function renderAttendanceTable(studentsList, canEdit = true) {
            const tbody = document.getElementById("attendanceTableBody");
            if (!tbody) return;
            tbody.innerHTML = "";

            if (studentsList.length === 0) {
                tbody.innerHTML = `<tr><td colspan="5" class="px-6 py-10 text-center text-gray-500">Không tìm thấy học sinh nào.</td></tr>`;
                return;
            }

            const disabledAttr = canEdit ? "" : "disabled";

            studentsList.forEach((std, index) => {
                const tr = document.createElement("tr");
                tr.setAttribute("data-student-id", std.StudentId);
                const stdName = std.StudentName || "";
                const avatarText = stdName.substring(0, Math.min(2, stdName.length)).toUpperCase() || "??";
                tr.innerHTML = `
                    <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500 text-center">${index + 1}</td>
                    <td class="px-6 py-4 whitespace-nowrap">
                        <div class="flex items-center">
                            <div class="flex-shrink-0 h-10 w-10 rounded-full bg-blue-100 flex items-center justify-center text-blue-600 font-bold">${avatarText}</div>
                            <div class="ml-4">
                                <div class="text-sm font-bold text-gray-900">${stdName}</div>
                                <div class="text-sm text-gray-500">Mã: ${std.StudentCode || ""}</div>
                            </div>
                        </div>
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap text-center">
                        <span class="status-badge ${getBadgeClass(std.Status)}" id="badge-${std.StudentId}">
                            ${getBadgeText(std.Status)}
                        </span>
                    </td>
                    <td class="px-6 py-4"><input type="text" class="notes-input border-gray-300 rounded-md w-full focus:ring-blue-500 focus:border-blue-500 sm:text-sm px-3 py-2 border" id="note-${std.StudentId}" value="${std.Note || ''}" placeholder="Nhập ghi chú..." ${disabledAttr} /></td>
                    <td class="px-6 py-4 whitespace-nowrap text-center">
                        <div class="inline-flex rounded-md shadow-sm" role="group">
                            <button class="px-3 py-1 text-sm font-medium border border-gray-200 rounded-l-lg hover:bg-gray-100 hover:text-blue-700 focus:z-10 focus:ring-2 focus:ring-blue-700 btn-status btn-present-select ${std.Status === 'Present' ? 'btn-status-active text-blue-700 bg-gray-100 ring-2 ring-blue-700' : 'text-gray-900 bg-white'}" ${disabledAttr} data-id="${std.StudentId}">Có mặt</button>
                            <button class="px-3 py-1 text-sm font-medium border-t border-b border-gray-200 hover:bg-gray-100 hover:text-blue-700 focus:z-10 focus:ring-2 focus:ring-blue-700 btn-status btn-late-select ${std.Status === 'Late' ? 'btn-status-active text-blue-700 bg-gray-100 ring-2 ring-blue-700' : 'text-gray-900 bg-white'}" ${disabledAttr} data-id="${std.StudentId}">Muộn</button>
                            <button class="px-3 py-1 text-sm font-medium border border-gray-200 rounded-r-lg hover:bg-gray-100 hover:text-blue-700 focus:z-10 focus:ring-2 focus:ring-blue-700 btn-status btn-absent-select ${std.Status === 'Absent' ? 'btn-status-active text-blue-700 bg-gray-100 ring-2 ring-blue-700' : 'text-gray-900 bg-white'}" ${disabledAttr} data-id="${std.StudentId}">Vắng</button>
                        </div>
                    </td>
                `;
                tbody.appendChild(tr);
            });

            registerAttendanceActions();
        }

        // Gán sự kiện click nút bấm đổi trạng thái & ghi chú
        function registerAttendanceActions() {
            // Có mặt
            document.querySelectorAll(".btn-present-select").forEach(btn => {
                btn.addEventListener("click", function () {
                    const studentId = parseInt(this.getAttribute("data-id"));
                    changeStudentStatus(studentId, "Present", this);
                });
            });

            // Muộn
            document.querySelectorAll(".btn-late-select").forEach(btn => {
                btn.addEventListener("click", function () {
                    const studentId = parseInt(this.getAttribute("data-id"));
                    changeStudentStatus(studentId, "Late", this);
                });
            });

            // Vắng
            document.querySelectorAll(".btn-absent-select").forEach(btn => {
                btn.addEventListener("click", function () {
                    const studentId = parseInt(this.getAttribute("data-id"));
                    changeStudentStatus(studentId, "Absent", this);
                });
            });

            // Lắng nghe ghi chú thay đổi để cập nhật dữ liệu cục bộ
            document.querySelectorAll(".notes-input").forEach(input => {
                input.addEventListener("change", function () {
                    const tr = this.closest("tr");
                    if (tr) {
                        const studentId = parseInt(tr.getAttribute("data-student-id"));
                        const std = studentAttendancesData.find(s => s.StudentId === studentId);
                        if (std) {
                            std.Note = this.value;
                        }
                    }
                });
            });
        }

        // Đổi trạng thái học sinh cục bộ
        function changeStudentStatus(studentId, status, clickedBtn) {
            const std = studentAttendancesData.find(s => s.StudentId === studentId);
            if (!std) return;

            std.Status = status;

            // Cập nhật giao diện nút bấm trong dòng tương ứng
            const row = clickedBtn.closest("tr");
            row.querySelectorAll(".btn-status").forEach(btn => {
                btn.classList.remove("btn-status-active", "text-blue-700", "bg-gray-100", "ring-2", "ring-blue-700");
                btn.classList.add("text-gray-900", "bg-white");
            });
            clickedBtn.classList.add("btn-status-active", "text-blue-700", "bg-gray-100", "ring-2", "ring-blue-700");
            clickedBtn.classList.remove("text-gray-900", "bg-white");

            // Cập nhật badge
            const badge = document.getElementById(`badge-${studentId}`);
            badge.className = `status-badge ${getBadgeClass(status)}`;
            badge.innerHTML = getBadgeText(status);

            // Cập nhật lại số liệu thống kê
            updateStatistics();
        }

        // Đăng ký sự kiện nút Xem chi tiết ở bảng Lịch sử
        function registerHistoryDetails() {
            document.querySelectorAll(".view-history-detail").forEach(btn => {
                btn.addEventListener("click", function () {
                    const lessonId = parseInt(this.getAttribute("data-lesson-id"));
                    const lessonSelect = document.getElementById("lessonSelect");
                    
                    lessonSelect.value = lessonId;
                    loadAttendanceForLesson(lessonId);
                    
                    // Cuộn trang lên trên để xem bảng
                    window.scrollTo({
                        top: 0,
                        behavior: 'smooth'
                    });
                });
            });
        }

        // Lưu thông tin điểm danh lên Server
        function saveAttendance() {
            const lessonSelect = document.getElementById("lessonSelect");
            if (!lessonSelect || !lessonSelect.value) {
                showToast("Vui lòng chọn một buổi học hợp lệ trước khi lưu.", false);
                return;
            }

            const lessonId = parseInt(lessonSelect.value);

            // Gom dữ liệu nộp theo định dạng camelCase
            const attendances = studentAttendancesData.map(std => {
                const noteInput = document.getElementById(`note-${std.StudentId}`);
                return {
                    studentId: std.StudentId,
                    status: std.Status || "Present", // Mặc định là Có mặt nếu giáo viên chưa chọn
                    note: noteInput ? noteInput.value : (std.Note || "")
                };
            });

            const requestData = {
                lessonId: lessonId,
                attendances: attendances
            };

            fetch('/api/v1/teacher/attendance/save', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify(requestData)
            })
            .then(async res => {
                const isJson = res.headers.get('content-type')?.includes('application/json');
                const data = isJson ? await res.json() : null;
                
                if (res.ok) {
                    return data;
                } else {
                    const errorMsg = data?.message || `Lỗi máy chủ (${res.status})`;
                    throw new Error(errorMsg);
                }
            })
            .then(res => {
                if (res && res.success) {
                    showToast("Lưu thông tin điểm danh thành công!");
                    // Tải lại lịch sử điểm danh của lớp
                    const classId = parseInt(document.getElementById("classSelect").value);
                    loadHistoryForClass(classId);
                } else {
                    showToast(res ? res.message : "Đã có lỗi xảy ra", false);
                }
            })
            .catch(err => {
                console.error(err);
                showToast("Lỗi lưu điểm danh: " + err.message, false);
            });
        }

        // Tính toán lại số liệu thống kê ở 4 thẻ trên
        function updateStatistics() {
            if (!studentAttendancesData || studentAttendancesData.length === 0) {
                document.getElementById("statPresent").textContent = "0";
                document.getElementById("statAbsent").textContent = "0";
                document.getElementById("statLate").textContent = "0";
                document.getElementById("statRate").textContent = "0%";
                return;
            }

            let present = 0;
            let absent = 0;
            let late = 0;
            let total = studentAttendancesData.length;

            studentAttendancesData.forEach(std => {
                if (std.Status === "Present") present++;
                else if (std.Status === "Absent") absent++;
                else if (std.Status === "Late") late++;
                // Nếu chưa điểm danh, ta có thể mặc định là Có mặt trong thống kê hoặc bỏ qua
                else total--; // Không tính vào tổng nếu chưa điểm danh
            });

            document.getElementById("statPresent").textContent = present;
            document.getElementById("statAbsent").textContent = absent;
            document.getElementById("statLate").textContent = late;

            let rate = "0%";
            if (total > 0) {
                const percent = Math.round((present + late) / total * 100);
                rate = `${percent}%`;
            }
            document.getElementById("statRate").textContent = rate;
        }

        // Hàm helper lấy class của Badge
        function getBadgeClass(status) {
            return status === "Present" ? "status-present" :
                   status === "Late" ? "status-late" :
                   status === "Absent" ? "status-absent" : "status-empty";
        }

        // Hàm helper lấy text kèm icon của Badge
        function getBadgeText(status) {
            if (status === "Present") {
                return `<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin-right: 4px;"><polyline points="20 6 9 17 4 12"></polyline></svg>Có mặt`;
            } else if (status === "Late") {
                return `<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin-right: 4px;"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>Muộn`;
            } else if (status === "Absent") {
                return `<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin-right: 4px;"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>Vắng`;
            }
            return "Chưa điểm danh";
        }
    </script>
}
