@page
@model EduBridge.Pages.Teacher.AttendanceModel
@{
    Layout = "_TeacherLayout";
    ViewData["Title"] = "Điểm danh";
    ViewData["ActivePage"] = "Attendance";

    string GetBadgeClass(string? status) {
        return status switch {
            "Present" => "status-present",
            "Late" => "status-late",
            "Absent" => "status-absent",
            _ => "status-empty"
        };
    }

    var currentLesson = Model.ClassLessons.FirstOrDefault(l => l.LessonId == Model.SelectedLessonId);
    var initialCanEdit = currentLesson?.CanEdit ?? true;
}

<div class="attendance-header-section">
    <div>
        <h1 class="attendance-main-title">Điểm danh</h1>
        <p class="attendance-subtitle">Ghi nhận tình trạng chuyên cần</p>
    </div>
    <button class="btn-export" id="btnExportReport">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="7 10 12 15 17 10"></polyline><line x1="12" y1="15" x2="12" y2="3"></line></svg>
        Xuất báo cáo
    </button>
</div>

<!-- 4 Thẻ Thống kê -->
<div class="attendance-stats-grid">
    <div class="attendance-card" style="padding: 1.5rem; display: flex; justify-content: space-between; align-items: center;">
        <div>
            <div style="font-size: 0.9rem; color: #6b7280; margin-bottom: 0.5rem;">Có mặt</div>
            <div style="font-size: 1.75rem; font-weight: 700; color: #16a34a;" id="statPresent">0</div>
        </div>
        <div style="color: #16a34a;">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
        </div>
    </div>
    
    <div class="attendance-card" style="padding: 1.5rem; display: flex; justify-content: space-between; align-items: center;">
        <div>
            <div style="font-size: 0.9rem; color: #6b7280; margin-bottom: 0.5rem;">Vắng mặt</div>
            <div style="font-size: 1.75rem; font-weight: 700; color: #dc2626;" id="statAbsent">0</div>
        </div>
        <div style="color: #dc2626;">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"></circle><line x1="15" y1="9" x2="9" y2="15"></line><line x1="9" y1="9" x2="15" y2="15"></line></svg>
        </div>
    </div>
    
    <div class="attendance-card" style="padding: 1.5rem; display: flex; justify-content: space-between; align-items: center;">
        <div>
            <div style="font-size: 0.9rem; color: #6b7280; margin-bottom: 0.5rem;">Đi muộn</div>
            <div style="font-size: 1.75rem; font-weight: 700; color: #ea580c;" id="statLate">0</div>
        </div>
        <div style="color: #ea580c;">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
        </div>
    </div>
    
    <div class="attendance-card" style="padding: 1.5rem; display: flex; justify-content: space-between; align-items: center;">
        <div>
            <div style="font-size: 0.9rem; color: #6b7280; margin-bottom: 0.5rem;">Tỷ lệ chuyên cần</div>
            <div style="font-size: 1.75rem; font-weight: 700; color: #2563eb;" id="statRate">0%</div>
        </div>
        <div style="color: #2563eb;">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg>
        </div>
    </div>
</div>

<div class="attendance-card">
    <div class="attendance-card-header d-flex justify-content-between align-items-center">
        <h3 class="attendance-card-title m-0">Bảng điểm danh</h3>
        <div class="attendance-filters">
            <!-- Select Lớp học -->
            <select class="attendance-select" id="classSelect">
                @foreach(var c in Model.TeacherClasses)
                {
                    <!option value="@c.ClassId" @(c.ClassId == Model.SelectedClassId ? "selected" : "")>@c.ClassName</!option>
                }
            </select>
            
            <!-- Select Buổi học (Thay thế cho ô nhập ngày tĩnh) -->
            <select class="attendance-select" id="lessonSelect" style="width: 200px;">
                @foreach(var l in Model.ClassLessons)
                {
                    <!option value="@l.LessonId" data-can-edit="@l.CanEdit.ToString().ToLower()" @(l.LessonId == Model.SelectedLessonId ? "selected" : "")>@l.LessonTitle (@l.DateString)</!option>
                }
            </select>

            <div class="search-wrapper" style="width: 200px;">
                <svg class="search-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
                <input type="text" id="studentSearchInput" class="search-input-field" placeholder="Tìm học sinh...">
            </div>
        </div>
    </div>
    
    <div class="px-4 pt-3">
        <div id="attendanceAlert" class="alert alert-warning mb-0 @(initialCanEdit ? "d-none" : "")" style="border-radius: 12px; font-size: 0.9rem;">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin-right: 8px; vertical-align: text-bottom;"><path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"></path><line x1="12" y1="9" x2="12" y2="13"></line><line x1="12" y1="17" x2="12.01" y2="17"></line></svg>
            Buổi học đã kết thúc quá 48h. Không thể chỉnh sửa thông tin điểm danh.
        </div>
    </div>

    <div class="ds-table-wrap">
        <table class="ds-table">
            <thead>
                <tr>
                    <th class="ds-table-center" style="width: 80px;">STT</th>
                    <th>Học sinh</th>
                    <th class="ds-table-center" style="width: 180px;">Trạng thái</th>
                    <th>Ghi chú</th>
                    <th class="ds-table-center" style="width: 250px;">Cập nhật</th>
                </tr>
            </thead>
            <tbody id="attendanceTableBody">
                @if (Model.StudentAttendances.Any())
                {
                    int idx = 1;
                    @foreach(var std in Model.StudentAttendances)
                    {
                        <tr data-student-id="@std.StudentId">
                            <td class="ds-table-center">@(idx++)</td>
                            <td>
                                <div class="ds-entity">
                                    <div class="ds-avatar">@std.StudentName.Substring(0, Math.Min(2, std.StudentName.Length)).ToUpper()</div>
                                    <div>
                                        <div class="ds-entity-title">@std.StudentName</div>
                                        <div class="ds-entity-subtitle">Mã: @std.StudentCode</div>
                                    </div>
                                </div>
                            </td>
                            <td class="ds-table-center">
                                <span class="ds-badge @GetBadgeClass(std.Status)" id="badge-@std.StudentId">
                                    @if (std.Status == "Present")
                                    {
                                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin-right: 4px;"><polyline points="20 6 9 17 4 12"></polyline></svg>@:Có mặt
                                    }
                                    else if (std.Status == "Late")
                                    {
                                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin-right: 4px;"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>@:Muộn
                                    }
                                    else if (std.Status == "Absent")
                                    {
                                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin-right: 4px;"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>@:Vắng
                                    }
                                    else
                                    {
                                        @:Chưa điểm danh
                                    }
                                </span>
                            </td>
                            <td><input type="text" class="notes-input" id="note-@std.StudentId" value="@std.Note" placeholder="Nhập ghi chú..." @(initialCanEdit ? "" : "disabled") /></td>
                            <td class="ds-table-center">
                                <div class="ds-table-actions">
                                    <button class="ds-btn ds-btn-outline ds-btn-sm btn-status btn-present-select @(std.Status == "Present" ? "btn-status-active" : "")" @(initialCanEdit ? "" : "disabled") data-id="@std.StudentId">Có mặt</button>
                                    <button class="ds-btn ds-btn-outline ds-btn-sm btn-status btn-late-select @(std.Status == "Late" ? "btn-status-active" : "")" @(initialCanEdit ? "" : "disabled") data-id="@std.StudentId">Muộn</button>
                                    <button class="ds-btn ds-btn-outline ds-btn-sm btn-status btn-absent-select @(std.Status == "Absent" ? "btn-status-active" : "")" @(initialCanEdit ? "" : "disabled") data-id="@std.StudentId">Vắng</button>
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="5" class="text-center text-muted py-4">Không có học sinh hoặc buổi học nào được chọn.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    
    <div class="attendance-footer">
        <button class="btn-save" id="btnSaveAttendance" style="@(initialCanEdit ? "" : "display: none;")">Lưu điểm danh</button>
    </div>
</div>

<div class="attendance-card mt-4" style="margin-top: 1.5rem;">
    <div class="attendance-card-header">
        <h3 class="attendance-card-title m-0">Lịch sử điểm danh</h3>
    </div>
    
    <div class="ds-table-wrap">
        <table class="ds-table">
            <thead>
                <tr>
                    <th class="ds-table-center" style="width: 80px;">STT</th>
                    <th class="ds-table-center" style="width: 120px;">Ngày</th>
                    <th>Lớp</th>
                    <th class="ds-table-center" style="width: 100px;">Có mặt</th>
                    <th class="ds-table-center" style="width: 100px;">Vắng</th>
                    <th class="ds-table-center" style="width: 100px;">Muộn</th>
                    <th class="ds-table-center" style="width: 120px;">Tỷ lệ</th>
                    <th class="ds-table-center" style="width: 100px;">Thao tác</th>
                </tr>
            </thead>
            <tbody id="attendanceHistoryTableBody">
                <!-- Nạp động bằng JavaScript -->
            </tbody>
        </table>
    </div>
    <div id="attendanceHistoryPagination" class="ds-pagination"></div>
</div>

@section Scripts {
    <style>
        .notes-input {
            width: 100%;
            padding: 0.5rem 1rem;
            border: 1px solid #cbd5e1;
            background-color: #f8fafc;
            border-radius: 8px;
            font-size: 0.9rem;
            color: #334155;
            outline: none;
            transition: all 0.2s;
        }
        .notes-input:focus {
            background-color: #ffffff;
            border-color: #94a3b8;
        }
        .stat-circle-green {
            background-color: #dcfce7;
            color: #166534;
            padding: 2px 10px;
            border-radius: 12px;
            font-weight: 600;
            font-size: 0.85rem;
            display: inline-block;
            min-width: 32px;
            text-align: center;
        }
        .stat-circle-red {
            background-color: #fee2e2;
            color: #991b1b;
            padding: 2px 10px;
            border-radius: 12px;
            font-weight: 600;
            font-size: 0.85rem;
            display: inline-block;
            min-width: 32px;
            text-align: center;
        }
        .stat-circle-orange {
            background-color: #ffedd5;
            color: #9a3412;
            padding: 2px 10px;
            border-radius: 12px;
            font-weight: 600;
            font-size: 0.85rem;
            display: inline-block;
            min-width: 32px;
            text-align: center;
        }
        .status-badge {
            display: inline-flex;
            align-items: center;
            padding: 0.25rem 0.75rem;
            border-radius: 8px;
            font-weight: 600;
            font-size: 0.85rem;
        }
        .status-present {
            background-color: #dcfce7;
            color: #166534;
        }
        .status-late {
            background-color: #ffedd5;
            color: #b45309;
        }
        .status-absent {
            background-color: #fee2e2;
            color: #b91c1c;
        }
        .status-empty {
            background-color: #f1f5f9;
            color: #64748b;
        }
    </style>

    <script>
        // Dữ liệu học sinh điểm danh cục bộ
        let rawAttendancesData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.StudentAttendances));
        let studentAttendancesData = (rawAttendancesData || []).map(std => ({
            StudentId: std.StudentId !== undefined ? std.StudentId : std.studentId,
            StudentName: std.StudentName !== undefined ? std.StudentName : std.studentName,
            StudentCode: std.StudentCode !== undefined ? std.StudentCode : std.studentCode,
            Status: std.Status !== undefined ? std.Status : std.status,
            Note: std.Note !== undefined ? std.Note : std.note
        }));
        let rawHistoryData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.AttendanceHistory));
        let attendanceHistoryData = (rawHistoryData || []).map(h => ({
            LessonId: h.LessonId !== undefined ? h.LessonId : h.lessonId,
            DateString: h.DateString !== undefined ? h.DateString : h.dateString,
            ClassName: h.ClassName !== undefined ? h.ClassName : h.className,
            PresentCount: h.PresentCount !== undefined ? h.PresentCount : h.presentCount,
            AbsentCount: h.AbsentCount !== undefined ? h.AbsentCount : h.absentCount,
            LateCount: h.LateCount !== undefined ? h.LateCount : h.lateCount,
            AttendanceRate: h.AttendanceRate !== undefined ? h.AttendanceRate : h.attendanceRate
        }));
        let historyCurrentPage = 1;
        let historyPageSize = 10;

        document.addEventListener("DOMContentLoaded", function () {
            // Thống kê lúc load trang ban đầu
            updateStatistics();
            renderAttendanceHistoryTable();

            // Lắng nghe đổi Lớp học
            document.getElementById("classSelect").addEventListener("change", function () {
                const classId = this.value;
                loadLessonsForClass(classId);
            });

            // Lắng nghe đổi Buổi học
            document.getElementById("lessonSelect").addEventListener("change", function () {
                const lessonId = this.value;
                loadAttendanceForLesson(lessonId);
            });

            // Tìm kiếm học sinh trực tiếp
            document.getElementById("studentSearchInput").addEventListener("input", function () {
                const query = this.value.trim().toLowerCase();
                const filtered = studentAttendancesData.filter(std => 
                    std.StudentName.toLowerCase().includes(query) || 
                    std.StudentCode.toLowerCase().includes(query)
                );
                const lessonSelect = document.getElementById("lessonSelect");
                const selectedOption = lessonSelect.options[lessonSelect.selectedIndex];
                const canEdit = selectedOption ? (selectedOption.getAttribute("data-can-edit") === "true") : true;
                renderAttendanceTable(filtered, canEdit);
            });

            // Gán sự kiện click nút bấm đổi trạng thái & ghi chú ban đầu
            registerAttendanceActions();

            // Sự kiện Click xem chi tiết ở bảng lịch sử điểm danh
            registerHistoryDetails();

            // Sự kiện lưu điểm danh
            document.getElementById("btnSaveAttendance").addEventListener("click", function () {
                saveAttendance();
            });

            // Xuất báo cáo chuyên cần
            document.getElementById("btnExportReport").addEventListener("click", function () {
                exportAttendanceToCSV();
            });
        });

        // Xuất báo cáo chuyên cần ra file CSV chuẩn UTF-8 có BOM
        function exportAttendanceToCSV() {
            if (!studentAttendancesData || studentAttendancesData.length === 0) {
                showToast("Không có dữ liệu để xuất báo cáo.", false);
                return;
            }

            const classSelect = document.getElementById("classSelect");
            const className = classSelect.options[classSelect.selectedIndex].text;
            const lessonSelect = document.getElementById("lessonSelect");
            if (!lessonSelect || !lessonSelect.value) {
                showToast("Vui lòng chọn một buổi học để xuất báo cáo.", false);
                return;
            }
            const lessonTitle = lessonSelect.options[lessonSelect.selectedIndex].text;

            let csvContent = "\uFEFF"; // BOM để Excel nhận dạng UTF-8 tiếng Việt
            csvContent += `BÁO CÁO ĐIỂM DANH - LỚP: ${className}\r\n`;
            csvContent += `Buổi học: ${lessonTitle}\r\n\r\n`;
            csvContent += "Mã học sinh,Học sinh,Trạng thái,Ghi chú\r\n";

            studentAttendancesData.forEach(std => {
                const statusText = std.Status === "Present" ? "Có mặt" :
                                   std.Status === "Late" ? "Muộn" :
                                   std.Status === "Absent" ? "Vắng" : "Chưa điểm danh";
                const noteText = std.Note ? std.Note.replace(/"/g, '""').replace(/,/g, ";") : "";
                csvContent += `"${std.StudentCode}","${std.StudentName}","${statusText}","${noteText}"\r\n`;
            });

            const blob = new Blob([csvContent], { type: "text/csv;charset=utf-8;" });
            const link = document.createElement("a");
            const url = URL.createObjectURL(blob);
            link.setAttribute("href", url);
            
            const fileName = `diem_danh_${className.replace(/\s+/g, "_")}_lesson_${lessonSelect.value}.csv`;
            link.setAttribute("download", fileName);
            link.style.visibility = 'hidden';
            document.body.appendChild(link);
            link.click();
            document.body.removeChild(link);
            
            showToast("Xuất báo cáo chuyên cần thành công!");
        }

        // Tải danh sách buổi học & lịch sử khi đổi lớp
        function loadLessonsForClass(classId) {
            fetch(`/api/v1/teacher/attendance/lessons?classId=${classId}`)
                .then(res => res.json())
                .then(res => {
                    const lessonSelect = document.getElementById("lessonSelect");
                    lessonSelect.innerHTML = "";
                    
                    if (res.success && res.data.length > 0) {
                        res.data.forEach(l => {
                            const opt = document.createElement("option");
                            opt.value = l.lessonId;
                            opt.textContent = `${l.lessonTitle} (${l.dateString})`;
                            opt.setAttribute("data-can-edit", l.canEdit);
                            lessonSelect.appendChild(opt);
                        });
                        
                        // Tải bảng điểm danh buổi học đầu tiên
                        loadAttendanceForLesson(res.data[0].lessonId);
                    } else {
                        lessonSelect.innerHTML = `<option value="">-- Không có buổi học --</option>`;
                        studentAttendancesData = [];
                        renderAttendanceTable([]);
                        updateStatistics();
                    }
                })
                .catch(err => {
                    console.error(err);
                    showToast("Đã xảy ra lỗi khi tải danh sách buổi học.", false);
                });

            // Tải lịch sử điểm danh của lớp
            loadHistoryForClass(classId);
        }

        // Tải lịch sử điểm danh qua API
        function loadHistoryForClass(classId) {
            fetch(`/api/v1/teacher/attendance/history?classId=${classId}`)
                .then(res => res.json())
                .then(res => {
                    if (res.success) {
                        attendanceHistoryData = res.data;
                        historyCurrentPage = 1;
                        renderAttendanceHistoryTable();
                    } else {
                        attendanceHistoryData = [];
                        renderAttendanceHistoryTable();
                    }
                })
                .catch(err => {
                    console.error(err);
                    attendanceHistoryData = [];
                    renderAttendanceHistoryTable();
                });
        }

        // Tải bảng điểm danh của một buổi học
        function loadAttendanceForLesson(lessonId) {
            if (!lessonId) return;
            fetch(`/api/v1/teacher/attendance?lessonId=${lessonId}`)
                .then(res => res.json())
                .then(res => {
                    if (res.success) {
                        studentAttendancesData = res.data.map(std => ({
                            StudentId: std.studentId,
                            StudentName: std.studentName,
                            StudentCode: std.studentCode,
                            Status: std.status,
                            Note: std.note
                        }));

                        // Đọc canEdit từ option được chọn
                        const lessonSelect = document.getElementById("lessonSelect");
                        const selectedOption = lessonSelect.options[lessonSelect.selectedIndex];
                        const canEdit = selectedOption ? (selectedOption.getAttribute("data-can-edit") === "true") : true;

                        // Ẩn/Hiện alert
                        const alertEl = document.getElementById("attendanceAlert");
                        if (alertEl) {
                            if (canEdit) {
                                alertEl.classList.add("d-none");
                            } else {
                                alertEl.classList.remove("d-none");
                            }
                        }

                        // Ẩn/Hiện nút Save
                        const saveBtn = document.getElementById("btnSaveAttendance");
                        if (saveBtn) {
                            saveBtn.style.display = canEdit ? "" : "none";
                        }

                        renderAttendanceTable(studentAttendancesData, canEdit);
                        updateStatistics();
                        // Reset tìm kiếm
                        document.getElementById("studentSearchInput").value = "";
                    } else {
                        showToast(res.message, false);
                    }
                })
                .catch(err => {
                    console.error(err);
                    showToast("Đã xảy ra lỗi khi tải danh sách điểm danh.", false);
                });
        }

        // Render bảng Lịch sử điểm danh kèm phân trang
        function renderAttendanceHistoryTable() {
            const tbody = document.getElementById("attendanceHistoryTableBody");
            const paginationEl = document.getElementById("attendanceHistoryPagination");
            if (!tbody) return;

            tbody.innerHTML = "";

            const totalItems = attendanceHistoryData.length;
            const totalPages = Math.ceil(totalItems / historyPageSize) || 1;

            if (historyCurrentPage > totalPages) historyCurrentPage = totalPages;
            if (historyCurrentPage < 1) historyCurrentPage = 1;

            const start = (historyCurrentPage - 1) * historyPageSize;
            const end = Math.min(start + historyPageSize, totalItems);
            const pageItems = attendanceHistoryData.slice(start, end);

            if (pageItems.length === 0) {
                tbody.innerHTML = `<tr><td colspan="8" class="text-center text-muted py-4">Chưa có lịch sử điểm danh nào.</td></tr>`;
                if (paginationEl) paginationEl.innerHTML = "";
                return;
            }

            pageItems.forEach((h, index) => {
                const indexGlobal = start + index + 1;
                const tr = document.createElement("tr");
                tr.innerHTML = `
                    <td class="ds-table-center">${indexGlobal}</td>
                    <td class="ds-table-center" style="color: #6b7280;">${h.dateString || h.DateString}</td>
                    <td><span class="ds-badge ds-badge-muted">${h.className || h.ClassName}</span></td>
                    <td class="ds-table-center"><span class="stat-circle-green">${h.presentCount ?? h.PresentCount}</span></td>
                    <td class="ds-table-center"><span class="stat-circle-red">${h.absentCount ?? h.AbsentCount}</span></td>
                    <td class="ds-table-center"><span class="stat-circle-orange">${h.lateCount ?? h.LateCount}</span></td>
                    <td class="ds-table-center" style="font-weight: 600; color: #1a202c;">${h.attendanceRate || h.AttendanceRate}</td>
                    <td class="ds-table-center">
                        <div class="ds-table-actions">
                            <button class="ds-icon-btn ds-icon-btn-view view-history-detail" data-lesson-id="${h.lessonId || h.LessonId}" title="Xem chi tiết">
                                <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.25 12s3.75-6.75 9.75-6.75S21.75 12 21.75 12 18 18.75 12 18.75 2.25 12 2.25 12z"></path>
                                    <circle cx="12" cy="12" r="3" stroke-width="2"></circle>
                                </svg>
                            </button>
                        </div>
                    </td>
                `;
                tbody.appendChild(tr);
            });

            registerHistoryDetails();
            renderHistoryPagination(totalPages, totalItems);
        }

        function renderHistoryPagination(totalPages, totalItems) {
            const container = document.getElementById("attendanceHistoryPagination");
            if (!container) return;

            let html = `<div class="ds-pagination-pages">`;
            html += `<a class="ds-page-link ${historyCurrentPage === 1 ? 'ds-page-link-disabled' : ''}" data-page="1">«</a>`;
            html += `<a class="ds-page-link ${historyCurrentPage === 1 ? 'ds-page-link-disabled' : ''}" data-page="${historyCurrentPage - 1}">‹</a>`;

            let startPage = Math.max(1, historyCurrentPage - 2);
            let endPage = Math.min(totalPages, startPage + 4);
            if (endPage - startPage < 4) {
                startPage = Math.max(1, endPage - 4);
            }

            for (let i = startPage; i <= endPage; i++) {
                html += `<a class="ds-page-link ${i === historyCurrentPage ? 'ds-page-link-active' : ''}" data-page="${i}">${i}</a>`;
            }

            html += `<a class="ds-page-link ${historyCurrentPage === totalPages ? 'ds-page-link-disabled' : ''}" data-page="${historyCurrentPage + 1}">›</a>`;
            html += `<a class="ds-page-link ${historyCurrentPage === totalPages ? 'ds-page-link-disabled' : ''}" data-page="${totalPages}">»</a>`;
            html += `</div>`;

            html += `
                <div class="ds-pagination-meta">
                    <span>Tổng số: ${totalItems} bản ghi</span>
                    <select class="ds-page-size">
                        <option value="5" ${historyPageSize === 5 ? 'selected' : ''}>5</option>
                        <option value="10" ${historyPageSize === 10 ? 'selected' : ''}>10</option>
                        <option value="20" ${historyPageSize === 20 ? 'selected' : ''}>20</option>
                        <option value="50" ${historyPageSize === 50 ? 'selected' : ''}>50</option>
                    </select>
                </div>
            `;

            container.innerHTML = html;

            container.querySelectorAll(".ds-page-link:not(.ds-page-link-disabled)").forEach(link => {
                link.addEventListener("click", function(e) {
                    e.preventDefault();
                    historyCurrentPage = parseInt(this.getAttribute("data-page"));
                    renderAttendanceHistoryTable();
                });
            });

            container.querySelector(".ds-page-size").addEventListener("change", function() {
                historyPageSize = parseInt(this.value);
                historyCurrentPage = 1;
                renderAttendanceHistoryTable();
            });
        }

        // Render bảng điểm danh học sinh
        function renderAttendanceTable(studentsList, canEdit = true) {
            const tbody = document.getElementById("attendanceTableBody");
            if (!tbody) return;
            tbody.innerHTML = "";

            if (studentsList.length === 0) {
                tbody.innerHTML = `<tr><td colspan="5" class="text-center text-muted py-4">Không tìm thấy học sinh nào.</td></tr>`;
                return;
            }

            const disabledAttr = canEdit ? "" : "disabled";

            studentsList.forEach((std, index) => {
                const tr = document.createElement("tr");
                tr.setAttribute("data-student-id", std.StudentId);
                const stdName = std.StudentName || "";
                const avatarText = stdName.substring(0, Math.min(2, stdName.length)).toUpperCase() || "??";
                tr.innerHTML = `
                    <td class="ds-table-center">${index + 1}</td>
                    <td>
                        <div class="ds-entity">
                            <div class="ds-avatar">${avatarText}</div>
                            <div>
                                <div class="ds-entity-title">${stdName}</div>
                                <div class="ds-entity-subtitle">Mã: ${std.StudentCode || ""}</div>
                            </div>
                        </div>
                    </td>
                    <td class="ds-table-center">
                        <span class="ds-badge ${getBadgeClass(std.Status)}" id="badge-${std.StudentId}">
                            ${getBadgeText(std.Status)}
                        </span>
                    </td>
                    <td><input type="text" class="notes-input" id="note-${std.StudentId}" value="${std.Note || ''}" placeholder="Nhập ghi chú..." ${disabledAttr} /></td>
                    <td class="ds-table-center">
                        <div class="ds-table-actions">
                            <button class="ds-btn ds-btn-outline ds-btn-sm btn-status btn-present-select ${std.Status === 'Present' ? 'btn-status-active' : ''}" ${disabledAttr} data-id="${std.StudentId}">Có mặt</button>
                            <button class="ds-btn ds-btn-outline ds-btn-sm btn-status btn-late-select ${std.Status === 'Late' ? 'btn-status-active' : ''}" ${disabledAttr} data-id="${std.StudentId}">Muộn</button>
                            <button class="ds-btn ds-btn-outline ds-btn-sm btn-status btn-absent-select ${std.Status === 'Absent' ? 'btn-status-active' : ''}" ${disabledAttr} data-id="${std.StudentId}">Vắng</button>
                        </div>
                    </td>
                `;
                tbody.appendChild(tr);
            });

            registerAttendanceActions();
        }

        // Gán sự kiện click nút bấm đổi trạng thái & ghi chú
        function registerAttendanceActions() {
            // Có mặt
            document.querySelectorAll(".btn-present-select").forEach(btn => {
                btn.addEventListener("click", function () {
                    const studentId = parseInt(this.getAttribute("data-id"));
                    changeStudentStatus(studentId, "Present", this);
                });
            });

            // Muộn
            document.querySelectorAll(".btn-late-select").forEach(btn => {
                btn.addEventListener("click", function () {
                    const studentId = parseInt(this.getAttribute("data-id"));
                    changeStudentStatus(studentId, "Late", this);
                });
            });

            // Vắng
            document.querySelectorAll(".btn-absent-select").forEach(btn => {
                btn.addEventListener("click", function () {
                    const studentId = parseInt(this.getAttribute("data-id"));
                    changeStudentStatus(studentId, "Absent", this);
                });
            });

            // Lắng nghe ghi chú thay đổi để cập nhật dữ liệu cục bộ
            document.querySelectorAll(".notes-input").forEach(input => {
                input.addEventListener("change", function () {
                    const tr = this.closest("tr");
                    if (tr) {
                        const studentId = parseInt(tr.getAttribute("data-student-id"));
                        const std = studentAttendancesData.find(s => s.StudentId === studentId);
                        if (std) {
                            std.Note = this.value;
                        }
                    }
                });
            });
        }

        // Đổi trạng thái học sinh cục bộ
        function changeStudentStatus(studentId, status, clickedBtn) {
            const std = studentAttendancesData.find(s => s.StudentId === studentId);
            if (!std) return;

            std.Status = status;

            // Cập nhật giao diện nút bấm trong dòng tương ứng
            const row = clickedBtn.closest("tr");
            row.querySelectorAll(".btn-status").forEach(btn => btn.classList.remove("btn-status-active"));
            clickedBtn.classList.add("btn-status-active");

            // Cập nhật badge
            const badge = document.getElementById(`badge-${studentId}`);
            badge.className = `status-badge ${getBadgeClass(status)}`;
            badge.innerHTML = getBadgeText(status);

            // Cập nhật lại số liệu thống kê
            updateStatistics();
        }

        // Đăng ký sự kiện nút Xem chi tiết ở bảng Lịch sử
        function registerHistoryDetails() {
            document.querySelectorAll(".view-history-detail").forEach(btn => {
                btn.addEventListener("click", function () {
                    const lessonId = parseInt(this.getAttribute("data-lesson-id"));
                    const lessonSelect = document.getElementById("lessonSelect");
                    
                    lessonSelect.value = lessonId;
                    loadAttendanceForLesson(lessonId);
                    
                    // Cuộn trang lên trên để xem bảng
                    window.scrollTo({
                        top: 0,
                        behavior: 'smooth'
                    });
                });
            });
        }

        // Lưu thông tin điểm danh lên Server
        function saveAttendance() {
            const lessonSelect = document.getElementById("lessonSelect");
            if (!lessonSelect || !lessonSelect.value) {
                showToast("Vui lòng chọn một buổi học hợp lệ trước khi lưu.", false);
                return;
            }

            const lessonId = parseInt(lessonSelect.value);

            // Gom dữ liệu nộp theo định dạng camelCase
            const attendances = studentAttendancesData.map(std => {
                const noteInput = document.getElementById(`note-${std.StudentId}`);
                return {
                    studentId: std.StudentId,
                    status: std.Status || "Present", // Mặc định là Có mặt nếu giáo viên chưa chọn
                    note: noteInput ? noteInput.value : (std.Note || "")
                };
            });

            const requestData = {
                lessonId: lessonId,
                attendances: attendances
            };

            fetch('/api/v1/teacher/attendance/save', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify(requestData)
            })
            .then(async res => {
                const isJson = res.headers.get('content-type')?.includes('application/json');
                const data = isJson ? await res.json() : null;
                
                if (res.ok) {
                    return data;
                } else {
                    const errorMsg = data?.message || `Lỗi máy chủ (${res.status})`;
                    throw new Error(errorMsg);
                }
            })
            .then(res => {
                if (res && res.success) {
                    showToast("Lưu thông tin điểm danh thành công!");
                    // Tải lại lịch sử điểm danh của lớp
                    const classId = parseInt(document.getElementById("classSelect").value);
                    loadHistoryForClass(classId);
                } else {
                    showToast(res ? res.message : "Đã có lỗi xảy ra", false);
                }
            })
            .catch(err => {
                console.error(err);
                showToast("Lỗi lưu điểm danh: " + err.message, false);
            });
        }

        // Tính toán lại số liệu thống kê ở 4 thẻ trên
        function updateStatistics() {
            if (!studentAttendancesData || studentAttendancesData.length === 0) {
                document.getElementById("statPresent").textContent = "0";
                document.getElementById("statAbsent").textContent = "0";
                document.getElementById("statLate").textContent = "0";
                document.getElementById("statRate").textContent = "0%";
                return;
            }

            let present = 0;
            let absent = 0;
            let late = 0;
            let total = studentAttendancesData.length;

            studentAttendancesData.forEach(std => {
                if (std.Status === "Present") present++;
                else if (std.Status === "Absent") absent++;
                else if (std.Status === "Late") late++;
                // Nếu chưa điểm danh, ta có thể mặc định là Có mặt trong thống kê hoặc bỏ qua
                else total--; // Không tính vào tổng nếu chưa điểm danh
            });

            document.getElementById("statPresent").textContent = present;
            document.getElementById("statAbsent").textContent = absent;
            document.getElementById("statLate").textContent = late;

            let rate = "0%";
            if (total > 0) {
                const percent = Math.round((present + late) / total * 100);
                rate = `${percent}%`;
            }
            document.getElementById("statRate").textContent = rate;
        }

        // Hàm helper lấy class của Badge
        function getBadgeClass(status) {
            return status === "Present" ? "status-present" :
                   status === "Late" ? "status-late" :
                   status === "Absent" ? "status-absent" : "status-empty";
        }

        // Hàm helper lấy text kèm icon của Badge
        function getBadgeText(status) {
            if (status === "Present") {
                return `<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin-right: 4px;"><polyline points="20 6 9 17 4 12"></polyline></svg>Có mặt`;
            } else if (status === "Late") {
                return `<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin-right: 4px;"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>Muộn`;
            } else if (status === "Absent") {
                return `<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin-right: 4px;"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>Vắng`;
            }
            return "Chưa điểm danh";
        }
    </script>
}
