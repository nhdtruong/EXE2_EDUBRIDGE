@page
@model EduBridge.Pages.Teacher.LecturesModel
@{
    Layout = "_TeacherLayout";
    ViewData["Title"] = "Quản lý bài giảng";
    ViewData["ActivePage"] = "Lectures";
}

<div class="lectures-header-section">
    <div>
        <h1 class="lectures-main-title">Quản lý bài giảng</h1>
        <p class="lectures-subtitle">Ghi chú nội dung và tiến độ bài học</p>
    </div>
    <button class="btn-primary-green">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14"/><path d="M12 5v14"/></svg>
        Ghi chú bài giảng
    </button>
</div>

<!-- Progress Cards -->
<div class="lectures-progress-grid">
    <div class="lecture-progress-card">
        <h3>Toán 10A</h3>
        <div class="progress-row">
            <span class="progress-label">Tiến độ giảng dạy</span>
            <span class="progress-value">8/15 bài</span>
        </div>
        <div class="progress-bar-container mb-2">
            <div class="progress-bar-fill" style="width: 53%"></div>
        </div>
        <div class="text-muted text-sm">53% hoàn thành</div>
    </div>

    <div class="lecture-progress-card">
        <h3>Toán 10B</h3>
        <div class="progress-row">
            <span class="progress-label">Tiến độ giảng dạy</span>
            <span class="progress-value">9/16 bài</span>
        </div>
        <div class="progress-bar-container mb-2">
            <div class="progress-bar-fill" style="width: 56%"></div>
        </div>
        <div class="text-muted text-sm">56% hoàn thành</div>
    </div>

    <div class="lecture-progress-card">
        <h3>Toán 11A</h3>
        <div class="progress-row">
            <span class="progress-label">Tiến độ giảng dạy</span>
            <span class="progress-value">12/18 bài</span>
        </div>
        <div class="progress-bar-container mb-2">
            <div class="progress-bar-fill" style="width: 67%"></div>
        </div>
        <div class="text-muted text-sm">67% hoàn thành</div>
    </div>
</div>

<!-- History Table Section -->
<div class="dashboard-card">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3 class="card-title fw-semibold">Lịch sử bài giảng</h3>
        <div class="search-wrapper">
            <svg class="search-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
            <input type="text" class="search-input" placeholder="Tìm kiếm bài giảng...">
        </div>
    </div>

    <div class="table-responsive">
        <table class="table-custom">
            <thead>
                <tr>
                    <th>Ngày</th>
                    <th>Lớp</th>
                    <th>Chủ đề</th>
                    <th>Nội dung</th>
                    <th>Tiến độ</th>
                    <th class="text-center">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td>24/3/2026</td>
                    <td><span class="badge-outline">Toán 10A</span></td>
                    <td class="fw-semibold">Hàm số bậc nhất</td>
                    <td class="text-muted text-sm">Giới thiệu khái niệm hàm số, tập xác định, tập giá trị. Vẽ đồ thị hàm số bậc nhất.</td>
                    <td>
                        <span class="badge-success">
                            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" class="me-1" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"></polyline></svg>
                            Hoàn thành
                        </span>
                    </td>
                    <td class="text-center">
                        <button class="action-icon-btn"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 20h9"></path><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"></path></svg></button>
                    </td>
                </tr>
                <tr>
                    <td>22/3/2026</td>
                    <td><span class="badge-outline">Toán 10A</span></td>
                    <td class="fw-semibold">Phương trình bậc nhất</td>
                    <td class="text-muted text-sm">Ôn tập và luyện tập các dạng bài tập về phương trình bậc nhất.</td>
                    <td>
                        <span class="badge-success">
                            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" class="me-1" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"></polyline></svg>
                            Hoàn thành
                        </span>
                    </td>
                    <td class="text-center">
                        <button class="action-icon-btn"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 20h9"></path><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"></path></svg></button>
                    </td>
                </tr>
                <tr>
                    <td>23/3/2026</td>
                    <td><span class="badge-outline">Toán 10B</span></td>
                    <td class="fw-semibold">Phương trình bậc hai</td>
                    <td class="text-muted text-sm">Công thức nghiệm, định lý Viète, ứng dụng.</td>
                    <td>
                        <span class="badge-success">
                            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" class="me-1" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"></polyline></svg>
                            Hoàn thành
                        </span>
                    </td>
                    <td class="text-center">
                        <button class="action-icon-btn"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 20h9"></path><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"></path></svg></button>
                    </td>
                </tr>
                <tr>
                    <td>21/3/2026</td>
                    <td><span class="badge-outline">Toán 10B</span></td>
                    <td class="fw-semibold">Biểu thức đại số</td>
                    <td class="text-muted text-sm">Phép nhân và phân tích đa thức thành nhân tử.</td>
                    <td>
                        <span class="badge-default">Đang dạy</span>
                    </td>
                    <td class="text-center">
                        <button class="action-icon-btn"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 20h9"></path><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"></path></svg></button>
                    </td>
                </tr>
            </tbody>
        </table>
    </div>
</div>
