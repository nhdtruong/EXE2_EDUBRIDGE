@page
@model EduBridge.Pages.Teacher.LecturesModel
@{
    Layout = "_TeacherLayout";
    ViewData["Title"] = "Quản lý bài giảng";
    ViewData["ActivePage"] = "Lectures";
}

<div class="lectures-header-section">
    <div>
        <h1 class="lectures-main-title">Quản lý bài giảng</h1>
        <p class="lectures-subtitle">Ghi chú nội dung và tiến độ bài học</p>
    </div>
    <button class="btn-primary-green" data-bs-toggle="modal" data-bs-target="#addNoteModal">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14"/><path d="M12 5v14"/></svg>
        Ghi chú bài giảng
    </button>
</div>

<!-- Progress Cards -->
<div class="lectures-progress-grid">
    @if (Model.ClassesProgress.Any())
    {
        foreach (var progress in Model.ClassesProgress)
        {
            <div class="lecture-progress-card">
                <h3>@progress.ClassName</h3>
                <div class="progress-row">
                    <span class="progress-label">Tiến độ giảng dạy</span>
                    <span class="progress-value">@progress.CompletedLessons/@progress.TotalLessons bài</span>
                </div>
                <div class="progress-bar-container mb-2">
                    <div class="progress-bar-fill" style="width: @progress.PercentComplete%"></div>
                </div>
                <div class="text-muted text-sm">@progress.PercentComplete% hoàn thành</div>
            </div>
        }
    }
    else
    {
        <div class="empty-state text-center py-4 text-muted w-100" style="grid-column: 1 / -1;">
            <p>Bạn chưa phụ trách lớp học nào.</p>
        </div>
    }
</div>

<!-- History Table Section -->
<div class="dashboard-card">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3 class="card-title fw-semibold">Lịch sử bài giảng</h3>
        <div class="search-wrapper">
            <svg class="search-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
            <input type="text" class="search-input" placeholder="Tìm kiếm bài giảng...">
        </div>
    </div>

    <div class="table-responsive">
        <table class="table-custom">
            <thead>
                <tr>
                    <th>Ngày</th>
                    <th>Lớp</th>
                    <th>Chủ đề</th>
                    <th>Nội dung</th>
                    <th>Tiến độ</th>
                    <th class="text-center">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.LectureHistories.Any())
                {
                    foreach (var history in Model.LectureHistories)
                    {
                        <tr>
                            <td>@history.DateString</td>
                            <td><span class="badge-outline">@history.ClassName</span></td>
                            <td class="fw-semibold">@history.Topic</td>
                            <td class="text-muted text-sm">@history.Content</td>
                            <td>
                                <span class="badge-success">
                                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" class="me-1" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"></polyline></svg>
                                    @history.Status
                                </span>
                            </td>
                            <td class="text-center">
                                <button class="action-icon-btn"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 20h9"></path><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"></path></svg></button>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="6">
                            <div class="empty-state text-center py-4 text-muted">
                                <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="mb-2 text-gray-400" style="opacity:0.5"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"></path><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"></path></svg>
                                <p>Chưa có lịch sử bài giảng nào.</p>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<!-- Add Note Modal -->
<div class="modal fade" id="addNoteModal" tabindex="-1" aria-labelledby="addNoteModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" style="border-radius: 20px; border: none; box-shadow: 0 25px 50px -12px rgba(0,0,0,0.25);">
            <div class="modal-header" style="border-bottom: 1px solid rgba(226,232,240,0.8); padding: 1.5rem;">
                <h5 class="modal-title fw-bold" id="addNoteModalLabel">Thêm ghi chú bài giảng</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form method="post" asp-page-handler="AddNote">
                <div class="modal-body" style="padding: 1.5rem;">
                    @if (TempData["ErrorMessage"] != null)
                    {
                        <div class="alert alert-danger mb-3" style="border-radius: 12px; font-size: 0.9rem;">
                            @TempData["ErrorMessage"]
                        </div>
                    }

                    <div class="mb-3">
                        <label class="form-label fw-semibold text-sm">Lớp học</label>
                        <select asp-for="Input.ClassId" class="form-select" style="border-radius: 12px; padding: 0.75rem 1rem; border-color: #e2e8f0; box-shadow: 0 1px 2px rgba(0,0,0,0.05);" required>
                            <option value="">-- Chọn lớp học --</option>
                            @foreach (var cls in Model.TeacherClasses)
                            {
                                <option value="@cls.ClassId">@cls.ClassName</option>
                            }
                        </select>
                        <span asp-validation-for="Input.ClassId" class="text-danger text-sm mt-1 d-block"></span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold text-sm">Chủ đề bài giảng</label>
                        <input asp-for="Input.Topic" class="form-control" placeholder="Nhập chủ đề (vd: Hàm số bậc nhất)" style="border-radius: 12px; padding: 0.75rem 1rem; border-color: #e2e8f0; box-shadow: 0 1px 2px rgba(0,0,0,0.05);" required>
                        <span asp-validation-for="Input.Topic" class="text-danger text-sm mt-1 d-block"></span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold text-sm">Nội dung ghi chú</label>
                        <textarea asp-for="Input.Content" class="form-control" rows="4" placeholder="Nhập nội dung bài học, nhắc nhở, hoặc ghi chú về học sinh..." style="border-radius: 12px; padding: 0.75rem 1rem; border-color: #e2e8f0; box-shadow: 0 1px 2px rgba(0,0,0,0.05);" required></textarea>
                        <span asp-validation-for="Input.Content" class="text-danger text-sm mt-1 d-block"></span>
                    </div>
                </div>
                <div class="modal-footer" style="border-top: 1px solid rgba(226,232,240,0.8); padding: 1.5rem;">
                    <button type="button" class="btn btn-outline" data-bs-dismiss="modal" style="border-radius: 12px; font-weight: 600;">Hủy</button>
                    <button type="submit" class="btn-primary-green">Lưu ghi chú</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @if (TempData["ErrorMessage"] != null)
    {
        <script>
            document.addEventListener("DOMContentLoaded", function() {
                var addNoteModal = new bootstrap.Modal(document.getElementById('addNoteModal'));
                addNoteModal.show();
            });
        </script>
    }
}
