@page
@model EduBridge.Pages.Teacher.LecturesModel
@{
    Layout = "_TeacherLayout";
    ViewData["Title"] = "Quản lý bài giảng";
    ViewData["ActivePage"] = "Lectures";
}

@functions {
    public string GetStatusBadgeClass(string status)
    {
        return status switch
        {
            "Completed" => "bg-green-100 text-green-800 border border-green-200",
            "Scheduled" => "bg-yellow-100 text-yellow-800 border border-yellow-200",
            "Cancelled" => "bg-red-100 text-red-800 border border-red-200",
            "Rescheduled" => "bg-blue-100 text-blue-800 border border-blue-200",
            _ => "bg-gray-100 text-gray-800 border border-gray-200"
        };
    }

    public string GetStatusText(string status)
    {
        return status switch
        {
            "Completed" => "Hoàn thành",
            "Scheduled" => "Lên lịch",
            "Cancelled" => "Đã hủy",
            "Rescheduled" => "Thay đổi lịch",
            _ => status
        };
    }
}

<div class="mb-6 bg-gradient-to-br from-white to-blue-50 p-6 rounded-2xl shadow-sm border border-gray-100">
    <div>
        <h1 class="text-2xl font-bold text-gray-800 bg-clip-text text-transparent bg-gradient-to-r from-blue-600 to-indigo-600">Quản lý bài giảng</h1>
        <p class="text-gray-500 mt-1">Ghi chú nội dung và tiến độ bài học</p>
    </div>
</div>

<!-- Progress Cards -->
<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-8">
    @if (Model.ClassesProgress.Any())
    {
        foreach (var progress in Model.ClassesProgress)
        {
            <div class="bg-white rounded-xl p-5 shadow-sm border border-gray-100 hover:shadow-md transition-all">
                <h3 class="text-lg font-semibold text-gray-800 mb-4 truncate">@progress.ClassName</h3>
                <div class="flex justify-between items-center mb-2">
                    <span class="text-sm font-medium text-gray-500">Tiến độ giảng dạy</span>
                    <span class="text-sm font-bold text-blue-600">@progress.CompletedLessons/@progress.TotalLessons bài</span>
                </div>
                <div class="w-full bg-gray-100 rounded-full h-2 mb-2 overflow-hidden">
                    <div class="bg-blue-500 h-2 rounded-full transition-all duration-500" style="width: @progress.PercentComplete%"></div>
                </div>
                <div class="text-gray-400 text-xs">@progress.PercentComplete% hoàn thành</div>
            </div>
        }
    }
    else
    {
        <div class="col-span-full text-center py-8 text-gray-500 bg-white rounded-xl border border-gray-100 shadow-sm">
            <p>Bạn chưa phụ trách lớp học nào.</p>
        </div>
    }
</div>

<!-- History Table Section -->
<div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
    <div class="flex justify-between items-center mb-6">
        <h3 class="text-lg font-bold text-gray-800">Lịch sử bài giảng</h3>
        <div class="relative">
            <svg class="absolute left-3 top-1/2 transform -translate-y-1/2 text-gray-400" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
            <input type="text" id="lectureSearchInput" class="pl-10 pr-4 py-2 border border-gray-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 w-64 transition-all" placeholder="Tìm kiếm bài giảng...">
        </div>
    </div>

    <div class="overflow-x-auto rounded-2xl border border-gray-200 bg-white shadow-sm">
        <table class="w-full text-left border-collapse">
            <thead>
                <tr class="whitespace-nowrap bg-slate-100 border-b border-slate-200 text-sm font-bold text-slate-800">
                    <th class="py-4 px-4 text-center font-bold border-r border-slate-200 w-20">STT</th>
                    <th class="py-4 px-6 text-center font-bold border-r border-slate-200 w-32">Ngày</th>
                    <th class="py-4 px-6 text-center font-bold border-r border-slate-200 w-40">Lớp</th>
                    <th class="py-4 px-6 font-bold border-r border-slate-200">Chủ đề</th>
                    <th class="py-4 px-6 font-bold border-r border-slate-200">Nội dung</th>
                    <th class="py-4 px-6 text-center font-bold border-r border-slate-200 w-40">Trạng thái</th>
                    <th class="py-4 px-6 font-bold text-center w-24">Thao tác</th>
                </tr>
            </thead>
            <tbody id="lecturesTableBody" class="text-sm divide-y divide-gray-100">
                <!-- Nạp động bằng JavaScript -->
            </tbody>
        </table>
        <div id="lecturesPagination"></div>
    </div>
</div>

<!-- Edit Note Modal -->
<div id="editLectureModal" class="fixed inset-0 z-[60] hidden items-center justify-center bg-black bg-opacity-50 px-4">
    <div class="w-full max-w-xl rounded-2xl bg-white shadow-2xl">
        <div class="flex items-center justify-between border-b border-gray-100 p-5 bg-gray-50/50 rounded-t-2xl">
            <h3 class="text-lg font-bold text-gray-800">Sửa ghi chú bài giảng</h3>
            <button type="button" onclick="closeEditLectureModal()" class="text-gray-500 hover:text-gray-700">
                <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
            </button>
        </div>
        <form method="post" asp-page-handler="EditNote">
            <input type="hidden" id="editLessonId" asp-for="Input.LessonId" />
            <div class="p-6">
                <div class="mb-4">
                    <label class="block text-sm font-semibold text-gray-700 mb-1">Lớp học</label>
                    <input type="text" id="editClassNameDisplay" class="w-full px-4 py-2 bg-gray-50 border border-gray-200 rounded-lg text-sm text-gray-600 focus:outline-none" readonly>
                </div>

                <div class="mb-4">
                    <label class="block text-sm font-semibold text-gray-700 mb-1">Chủ đề bài giảng</label>
                    <input id="editTopic" asp-for="Input.Topic" class="w-full px-4 py-2 border border-gray-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-all" placeholder="Nhập chủ đề (vd: Hàm số bậc nhất)" required>
                    <span asp-validation-for="Input.Topic" class="text-red-500 text-xs mt-1 block"></span>
                </div>

                <div class="mb-4">
                    <label class="block text-sm font-semibold text-gray-700 mb-1">Nội dung ghi chú</label>
                    <textarea id="editContent" asp-for="Input.Content" class="w-full px-4 py-2 border border-gray-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-all resize-none" rows="4" placeholder="Nhập nội dung bài học..." required></textarea>
                    <span asp-validation-for="Input.Content" class="text-red-500 text-xs mt-1 block"></span>
                </div>

                <div class="mb-4">
                    <label class="block text-sm font-semibold text-gray-700 mb-1">Trạng thái</label>
                    <select id="editStatus" asp-for="Input.Status" class="w-full px-4 py-2 border border-gray-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-all bg-white">
                        <option value="Completed">Hoàn thành</option>
                        <option value="Scheduled">Lên lịch / Chưa hoàn thành</option>
                        <option value="Cancelled">Đã hủy</option>
                        <option value="Rescheduled">Thay đổi lịch</option>
                    </select>
                    <span asp-validation-for="Input.Status" class="text-red-500 text-xs mt-1 block"></span>
                </div>
            </div>
            <div class="flex justify-end gap-3 border-t border-gray-100 p-5 bg-gray-50/50 rounded-b-2xl">
                <button type="button" onclick="closeEditLectureModal()" class="px-4 py-2 text-sm font-semibold text-gray-600 bg-white border border-gray-200 rounded-lg hover:bg-gray-50 transition-colors">Hủy</button>
                <button type="submit" class="px-4 py-2 text-sm font-semibold text-white bg-blue-600 rounded-lg hover:bg-blue-700 shadow-sm shadow-blue-600/30 transition-all">Lưu thay đổi</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        let rawLecturesData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.LectureHistories));
        let lectureHistoriesData = (rawLecturesData || []).map(lh => ({
            LessonId: lh.LessonId !== undefined ? lh.LessonId : lh.lessonId,
            ClassId: lh.ClassId !== undefined ? lh.ClassId : lh.classId,
            DateString: lh.DateString !== undefined ? lh.DateString : lh.dateString,
            ClassName: lh.ClassName !== undefined ? lh.ClassName : lh.className,
            Topic: lh.Topic !== undefined ? lh.Topic : lh.topic,
            Content: lh.Content !== undefined ? lh.Content : lh.content,
            Status: lh.Status !== undefined ? lh.Status : lh.status
        }));
        let currentPage = 1;
        let pageSize = 10;
        let filteredLectures = [...lectureHistoriesData];

        document.addEventListener("DOMContentLoaded", function() {
            renderLecturesTable();

            document.getElementById("lectureSearchInput").addEventListener("input", function() {
                const query = this.value.trim().toLowerCase();
                filteredLectures = lectureHistoriesData.filter(lh => 
                    lh.Topic.toLowerCase().includes(query) || 
                    (lh.Content && lh.Content.toLowerCase().includes(query)) ||
                    lh.ClassName.toLowerCase().includes(query)
                );
                currentPage = 1;
                renderLecturesTable();
            });
        });

        function renderLecturesTable() {
            const tbody = document.getElementById("lecturesTableBody");
            const paginationEl = document.getElementById("lecturesPagination");
            if (!tbody) return;

            tbody.innerHTML = "";

            const totalItems = filteredLectures.length;
            const totalPages = Math.ceil(totalItems / pageSize) || 1;

            if (currentPage > totalPages) currentPage = totalPages;
            if (currentPage < 1) currentPage = 1;

            const start = (currentPage - 1) * pageSize;
            const end = Math.min(start + pageSize, totalItems);
            const pageItems = filteredLectures.slice(start, end);

            if (pageItems.length === 0) {
                tbody.innerHTML = `<tr><td colspan="7" class="py-10 px-6 text-center text-gray-500">Chưa có lịch sử bài giảng nào.</td></tr>`;
                if (paginationEl) paginationEl.innerHTML = "";
                return;
            }

            pageItems.forEach((lh, index) => {
                const indexGlobal = start + index + 1;
                const tr = document.createElement("tr");
                tr.className = "group hover:bg-slate-100 transition-colors";
                tr.innerHTML = `
                    <td class="py-5 px-4 text-center font-medium text-gray-700 border-r border-gray-200">${indexGlobal}</td>
                    <td class="py-5 px-6 text-center text-gray-700 border-r border-gray-200">${lh.DateString}</td>
                    <td class="py-5 px-6 text-center border-r border-gray-200">
                        <span class="inline-block px-2.5 py-1 bg-gray-100 text-gray-700 text-xs font-semibold rounded-md border border-gray-200">
                            ${lh.ClassName}
                        </span>
                    </td>
                    <td class="py-5 px-6 font-semibold text-gray-800 border-r border-gray-200">${lh.Topic}</td>
                    <td class="py-5 px-6 text-gray-500 border-r border-gray-200">${lh.Content || ''}</td>
                    <td class="py-5 px-6 text-center border-r border-gray-200">
                        <span class="inline-flex items-center px-2.5 py-1 rounded-md text-xs font-semibold ${getBadgeClass(lh.Status)}">
                            ${getStatusIcon(lh.Status)} ${getStatusText(lh.Status)}
                        </span>
                    </td>
                    <td class="py-5 px-6 text-center">
                        <div class="flex items-center justify-center gap-3">
                            <button type="button" class="edit-btn inline-flex h-10 w-10 items-center justify-center rounded-full border border-blue-500 bg-blue-50 text-blue-600 transition-colors hover:bg-blue-100" 
                                    data-id="${lh.LessonId}"
                                    data-class-id="${lh.ClassId}"
                                    data-topic="${lh.Topic}"
                                    data-content="${lh.Content || ''}"
                                    data-status="${lh.Status}"
                                    data-classname="${lh.ClassName}">
                                <svg class="h-5 w-5 pointer-events-none" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.25 12s3.75-6.75 9.75-6.75S21.75 12 21.75 12 18 18.75 12 18.75 2.25 12 2.25 12z"></path>
                                    <circle cx="12" cy="12" r="3" stroke-width="2"></circle>
                                </svg>
                            </button>
                        </div>
                    </td>
                `;
                tbody.appendChild(tr);
            });

            // Gán sự kiện click nút edit
            tbody.querySelectorAll(".edit-btn").forEach(btn => {
                btn.addEventListener("click", function() {
                    const id = this.getAttribute("data-id");
                    const topic = this.getAttribute("data-topic");
                    const content = this.getAttribute("data-content");
                    const status = this.getAttribute("data-status");
                    const className = this.getAttribute("data-classname");

                    document.getElementById("editLessonId").value = id;
                    document.getElementById("editClassNameDisplay").value = className;
                    document.getElementById("editTopic").value = topic;
                    document.getElementById("editContent").value = content;
                    document.getElementById("editStatus").value = status;

                    const editModalEl = document.getElementById("editLectureModal");
                    editModalEl.classList.remove('hidden');
                    editModalEl.classList.add('flex');
                });
            });

            renderPagination(totalPages, totalItems);
        }

        function closeEditLectureModal() {
            const editModalEl = document.getElementById("editLectureModal");
            editModalEl.classList.add('hidden');
            editModalEl.classList.remove('flex');
        }

        function getBadgeClass(status) {
            return status === "Completed" ? "bg-green-100 text-green-800 border border-green-200" :
                   status === "Scheduled" ? "bg-yellow-100 text-yellow-800 border border-yellow-200" :
                   status === "Cancelled" ? "bg-red-100 text-red-800 border border-red-200" : 
                   status === "Rescheduled" ? "bg-blue-100 text-blue-800 border border-blue-200" : "bg-gray-100 text-gray-800 border border-gray-200";
        }

        function getStatusText(status) {
            return status === "Completed" ? "Hoàn thành" : 
                   status === "Scheduled" ? "Lên lịch" : 
                   status === "Cancelled" ? "Đã hủy" : 
                   status === "Rescheduled" ? "Thay đổi lịch" : status;
        }

        function getStatusIcon(status) {
            if (status === "Completed") {
                return `<svg width="12" height="12" viewBox="0 0 24 24" fill="none" class="mr-1" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"></polyline></svg>`;
            } else if (status === "Scheduled") {
                return `<svg width="12" height="12" viewBox="0 0 24 24" fill="none" class="mr-1" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>`;
            } else if (status === "Cancelled") {
                return `<svg width="12" height="12" viewBox="0 0 24 24" fill="none" class="mr-1" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"></circle><line x1="15" y1="9" x2="9" y2="15"></line><line x1="9" y1="9" x2="15" y2="15"></line></svg>`;
            }
            return '';
        }

        function renderPagination(totalPages, totalItems) {
            const container = document.getElementById("lecturesPagination");
            if (!container) return;

            let html = `<div class="flex flex-wrap items-center justify-center gap-6 rounded-b-2xl border-t border-gray-200 bg-white px-6 py-4 text-sm text-gray-600">`;
            
            html += `<div class="flex items-center gap-1">`;
            
            html += `<button class="page-link-btn inline-flex h-9 w-9 items-center justify-center rounded text-gray-400 transition-colors ${currentPage === 1 ? 'opacity-50 cursor-not-allowed' : 'hover:bg-blue-50 hover:text-blue-600'}" data-page="1" ${currentPage === 1 ? 'disabled' : ''}>«</button>`;
            html += `<button class="page-link-btn inline-flex h-9 w-9 items-center justify-center rounded text-gray-400 transition-colors ${currentPage === 1 ? 'opacity-50 cursor-not-allowed' : 'hover:bg-blue-50 hover:text-blue-600'}" data-page="${currentPage - 1}" ${currentPage === 1 ? 'disabled' : ''}>‹</button>`;

            let startPage = Math.max(1, currentPage - 2);
            let endPage = Math.min(totalPages, startPage + 4);
            if (endPage - startPage < 4) {
                startPage = Math.max(1, endPage - 4);
            }

            for (let i = startPage; i <= endPage; i++) {
                if (i === currentPage) {
                    html += `<button class="page-link-btn inline-flex h-9 w-9 items-center justify-center rounded bg-blue-100 text-blue-700 font-semibold" data-page="${i}">${i}</button>`;
                } else {
                    html += `<button class="page-link-btn inline-flex h-9 w-9 items-center justify-center rounded text-gray-600 hover:bg-blue-50 hover:text-blue-600 transition-colors" data-page="${i}">${i}</button>`;
                }
            }

            html += `<button class="page-link-btn inline-flex h-9 w-9 items-center justify-center rounded text-gray-400 transition-colors ${currentPage === totalPages || totalPages === 0 ? 'opacity-50 cursor-not-allowed' : 'hover:bg-blue-50 hover:text-blue-600'}" data-page="${currentPage + 1}" ${currentPage === totalPages || totalPages === 0 ? 'disabled' : ''}>›</button>`;
            html += `<button class="page-link-btn inline-flex h-9 w-9 items-center justify-center rounded text-gray-400 transition-colors ${currentPage === totalPages || totalPages === 0 ? 'opacity-50 cursor-not-allowed' : 'hover:bg-blue-50 hover:text-blue-600'}" data-page="${totalPages}" ${currentPage === totalPages || totalPages === 0 ? 'disabled' : ''}>»</button>`;
            
            html += `</div>`;

            html += `<div class="font-medium text-gray-600">Tổng số: ${totalItems} bản ghi</div>`;
            
            html += `<div class="flex items-center">
                        <select class="page-size-select h-10 rounded border border-blue-300 bg-white px-3 text-sm text-gray-700 focus:border-blue-500 focus:outline-none focus:ring-1 focus:ring-blue-500">
                            <option value="10" ${pageSize === 10 ? 'selected' : ''}>10</option>
                            <option value="20" ${pageSize === 20 ? 'selected' : ''}>20</option>
                            <option value="50" ${pageSize === 50 ? 'selected' : ''}>50</option>
                            <option value="100" ${pageSize === 100 ? 'selected' : ''}>100</option>
                            <option value="200" ${pageSize === 200 ? 'selected' : ''}>200</option>
                            <option value="500" ${pageSize === 500 ? 'selected' : ''}>500</option>
                        </select>
                     </div>`;
                     
            html += `</div>`;
            
            container.innerHTML = html;

            container.querySelectorAll(".page-link-btn").forEach(link => {
                if(!link.hasAttribute('disabled')){
                    link.addEventListener("click", function(e) {
                        e.preventDefault();
                        currentPage = parseInt(this.getAttribute("data-page"));
                        renderLecturesTable();
                    });
                }
            });

            container.querySelector(".page-size-select").addEventListener("change", function() {
                pageSize = parseInt(this.value);
                currentPage = 1;
                renderLecturesTable();
            });
        }
    </script>
}
