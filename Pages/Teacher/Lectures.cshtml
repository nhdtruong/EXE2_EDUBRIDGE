@page
@model EduBridge.Pages.Teacher.LecturesModel
@{
    Layout = "_TeacherLayout";
    ViewData["Title"] = "Quản lý bài giảng";
    ViewData["ActivePage"] = "Lectures";
}

@functions {
    public string GetStatusBadgeClass(string status)
    {
        return status switch
        {
            "Completed" => "badge-success",
            "Scheduled" => "badge-warning",
            "Cancelled" => "badge-danger",
            "Rescheduled" => "badge-info",
            _ => "badge-default"
        };
    }

    public string GetStatusText(string status)
    {
        return status switch
        {
            "Completed" => "Hoàn thành",
            "Scheduled" => "Lên lịch",
            "Cancelled" => "Đã hủy",
            "Rescheduled" => "Thay đổi lịch",
            _ => status
        };
    }
}

<div class="lectures-header-section">
    <div>
        <h1 class="lectures-main-title">Quản lý bài giảng</h1>
        <p class="lectures-subtitle">Ghi chú nội dung và tiến độ bài học</p>
    </div>
</div>

<!-- Progress Cards -->
<div class="lectures-progress-grid">
    @if (Model.ClassesProgress.Any())
    {
        foreach (var progress in Model.ClassesProgress)
        {
            <div class="lecture-progress-card">
                <h3>@progress.ClassName</h3>
                <div class="progress-row">
                    <span class="progress-label">Tiến độ giảng dạy</span>
                    <span class="progress-value">@progress.CompletedLessons/@progress.TotalLessons bài</span>
                </div>
                <div class="progress-bar-container mb-2">
                    <div class="progress-bar-fill" style="width: @progress.PercentComplete%"></div>
                </div>
                <div class="text-muted text-sm">@progress.PercentComplete% hoàn thành</div>
            </div>
        }
    }
    else
    {
        <div class="empty-state text-center py-4 text-muted w-100" style="grid-column: 1 / -1;">
            <p>Bạn chưa phụ trách lớp học nào.</p>
        </div>
    }
</div>

<!-- History Table Section -->
<div class="dashboard-card">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3 class="card-title fw-semibold">Lịch sử bài giảng</h3>
        <div class="search-wrapper">
            <svg class="search-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
            <input type="text" id="lectureSearchInput" class="search-input" placeholder="Tìm kiếm bài giảng...">
        </div>
    </div>

    <div class="ds-table-wrap">
        <table class="ds-table">
            <thead>
                <tr>
                    <th class="ds-table-center" style="width: 80px;">STT</th>
                    <th class="ds-table-center" style="width: 120px;">Ngày</th>
                    <th class="ds-table-center" style="width: 120px;">Lớp</th>
                    <th>Chủ đề</th>
                    <th>Nội dung</th>
                    <th class="ds-table-center" style="width: 150px;">Trạng thái</th>
                    <th class="ds-table-center" style="width: 100px;">Thao tác</th>
                </tr>
            </thead>
            <tbody id="lecturesTableBody">
                <!-- Nạp động bằng JavaScript -->
            </tbody>
        </table>
    </div>
    <div id="lecturesPagination" class="ds-pagination"></div>
</div>



<!-- Edit Note Modal -->
<div class="modal fade" id="editLectureModal" tabindex="-1" aria-labelledby="editLectureModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" style="border-radius: 20px; border: none; box-shadow: 0 25px 50px -12px rgba(0,0,0,0.25);">
            <div class="modal-header" style="border-bottom: 1px solid rgba(226,232,240,0.8); padding: 1.5rem;">
                <h5 class="modal-title fw-bold" id="editLectureModalLabel">Sửa ghi chú bài giảng</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form method="post" asp-page-handler="EditNote">
                <input type="hidden" id="editLessonId" asp-for="Input.LessonId" />
                <div class="modal-body" style="padding: 1.5rem;">
                    <div class="mb-3">
                        <label class="form-label fw-semibold text-sm">Lớp học</label>
                        <input type="text" id="editClassNameDisplay" class="form-control" style="border-radius: 12px; padding: 0.75rem 1rem; border-color: #e2e8f0; background-color: #f8fafc;" readonly>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold text-sm">Chủ đề bài giảng</label>
                        <input id="editTopic" asp-for="Input.Topic" class="form-control" placeholder="Nhập chủ đề (vd: Hàm số bậc nhất)" style="border-radius: 12px; padding: 0.75rem 1rem; border-color: #e2e8f0; box-shadow: 0 1px 2px rgba(0,0,0,0.05);" required>
                        <span asp-validation-for="Input.Topic" class="text-danger text-sm mt-1 d-block"></span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold text-sm">Nội dung ghi chú</label>
                        <textarea id="editContent" asp-for="Input.Content" class="form-control" rows="4" placeholder="Nhập nội dung bài học..." style="border-radius: 12px; padding: 0.75rem 1rem; border-color: #e2e8f0; box-shadow: 0 1px 2px rgba(0,0,0,0.05);" required></textarea>
                        <span asp-validation-for="Input.Content" class="text-danger text-sm mt-1 d-block"></span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold text-sm">Trạng thái</label>
                        <select id="editStatus" asp-for="Input.Status" class="form-select" style="border-radius: 12px; padding: 0.75rem 1rem; border-color: #e2e8f0; box-shadow: 0 1px 2px rgba(0,0,0,0.05);">
                            <option value="Completed">Hoàn thành</option>
                            <option value="Scheduled">Lên lịch / Chưa hoàn thành</option>
                            <option value="Cancelled">Đã hủy</option>
                            <option value="Rescheduled">Thay đổi lịch</option>
                        </select>
                        <span asp-validation-for="Input.Status" class="text-danger text-sm mt-1 d-block"></span>
                    </div>
                </div>
                <div class="modal-footer" style="border-top: 1px solid rgba(226,232,240,0.8); padding: 1.5rem;">
                    <button type="button" class="btn btn-outline" data-bs-dismiss="modal" style="border-radius: 12px; font-weight: 600;">Hủy</button>
                    <button type="submit" class="btn-primary-green">Lưu thay đổi</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        let rawLecturesData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.LectureHistories));
        let lectureHistoriesData = (rawLecturesData || []).map(lh => ({
            LessonId: lh.LessonId !== undefined ? lh.LessonId : lh.lessonId,
            ClassId: lh.ClassId !== undefined ? lh.ClassId : lh.classId,
            DateString: lh.DateString !== undefined ? lh.DateString : lh.dateString,
            ClassName: lh.ClassName !== undefined ? lh.ClassName : lh.className,
            Topic: lh.Topic !== undefined ? lh.Topic : lh.topic,
            Content: lh.Content !== undefined ? lh.Content : lh.content,
            Status: lh.Status !== undefined ? lh.Status : lh.status
        }));
        let currentPage = 1;
        let pageSize = 10;
        let filteredLectures = [...lectureHistoriesData];

        document.addEventListener("DOMContentLoaded", function() {
            renderLecturesTable();

            document.getElementById("lectureSearchInput").addEventListener("input", function() {
                const query = this.value.trim().toLowerCase();
                filteredLectures = lectureHistoriesData.filter(lh => 
                    lh.Topic.toLowerCase().includes(query) || 
                    (lh.Content && lh.Content.toLowerCase().includes(query)) ||
                    lh.ClassName.toLowerCase().includes(query)
                );
                currentPage = 1;
                renderLecturesTable();
            });
        });

        function renderLecturesTable() {
            const tbody = document.getElementById("lecturesTableBody");
            const paginationEl = document.getElementById("lecturesPagination");
            if (!tbody) return;

            tbody.innerHTML = "";

            const totalItems = filteredLectures.length;
            const totalPages = Math.ceil(totalItems / pageSize) || 1;

            if (currentPage > totalPages) currentPage = totalPages;
            if (currentPage < 1) currentPage = 1;

            const start = (currentPage - 1) * pageSize;
            const end = Math.min(start + pageSize, totalItems);
            const pageItems = filteredLectures.slice(start, end);

            if (pageItems.length === 0) {
                tbody.innerHTML = `<tr><td colspan="7" class="text-center text-muted py-4">Chưa có lịch sử bài giảng nào.</td></tr>`;
                if (paginationEl) paginationEl.innerHTML = "";
                return;
            }

            pageItems.forEach((lh, index) => {
                const indexGlobal = start + index + 1;
                const tr = document.createElement("tr");
                tr.innerHTML = `
                    <td class="ds-table-center">${indexGlobal}</td>
                    <td class="ds-table-center">${lh.DateString}</td>
                    <td class="ds-table-center"><span class="ds-badge ds-badge-muted">${lh.ClassName}</span></td>
                    <td class="fw-semibold">${lh.Topic}</td>
                    <td class="text-muted text-sm">${lh.Content || ''}</td>
                    <td class="ds-table-center">
                        <span class="ds-badge ${getBadgeClass(lh.Status)}">
                            ${getStatusText(lh.Status)}
                        </span>
                    </td>
                    <td class="ds-table-center">
                        <div class="ds-table-actions">
                            <button class="ds-icon-btn ds-icon-btn-view edit-btn" 
                                    data-id="${lh.LessonId}"
                                    data-class-id="${lh.ClassId}"
                                    data-topic="${lh.Topic}"
                                    data-content="${lh.Content || ''}"
                                    data-status="${lh.Status}"
                                    data-classname="${lh.ClassName}">
                                <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.25 12s3.75-6.75 9.75-6.75S21.75 12 21.75 12 18 18.75 12 18.75 2.25 12 2.25 12z"></path>
                                    <circle cx="12" cy="12" r="3" stroke-width="2"></circle>
                                </svg>
                            </button>
                        </div>
                    </td>
                `;
                tbody.appendChild(tr);
            });

            // Gán sự kiện click nút edit
            tbody.querySelectorAll(".edit-btn").forEach(btn => {
                btn.addEventListener("click", function() {
                    const id = this.getAttribute("data-id");
                    const topic = this.getAttribute("data-topic");
                    const content = this.getAttribute("data-content");
                    const status = this.getAttribute("data-status");
                    const className = this.getAttribute("data-classname");

                    document.getElementById("editLessonId").value = id;
                    document.getElementById("editClassNameDisplay").value = className;
                    document.getElementById("editTopic").value = topic;
                    document.getElementById("editContent").value = content;
                    document.getElementById("editStatus").value = status;

                    const editModalEl = document.getElementById("editLectureModal");
                    const editModal = new bootstrap.Modal(editModalEl);
                    editModal.show();
                });
            });

            renderPagination(totalPages, totalItems);
        }

        function getBadgeClass(status) {
            return status === "Completed" ? "status-present" :
                   status === "Scheduled" ? "status-late" :
                   status === "Cancelled" ? "status-absent" : "status-empty";
        }

        function getStatusText(status) {
            return status === "Completed" ? "Hoàn thành" : 
                   status === "Scheduled" ? "Lên lịch" : 
                   status === "Cancelled" ? "Đã hủy" : 
                   status === "Rescheduled" ? "Thay đổi lịch" : status;
        }

        function getStatusIcon(status) {
            if (status === "Completed") {
                return `<svg width="12" height="12" viewBox="0 0 24 24" fill="none" class="me-1" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"></polyline></svg>`;
            } else if (status === "Scheduled") {
                return `<svg width="12" height="12" viewBox="0 0 24 24" fill="none" class="me-1" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>`;
            } else if (status === "Cancelled") {
                return `<svg width="12" height="12" viewBox="0 0 24 24" fill="none" class="me-1" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"></circle><line x1="15" y1="9" x2="9" y2="15"></line><line x1="9" y1="9" x2="15" y2="15"></line></svg>`;
            }
            return '';
        }

        function renderPagination(totalPages, totalItems) {
            const container = document.getElementById("lecturesPagination");
            if (!container) return;

            let html = `<div class="ds-pagination-pages">`;
            html += `<a class="ds-page-link ${currentPage === 1 ? 'ds-page-link-disabled' : ''}" data-page="1">«</a>`;
            html += `<a class="ds-page-link ${currentPage === 1 ? 'ds-page-link-disabled' : ''}" data-page="${currentPage - 1}">‹</a>`;

            let startPage = Math.max(1, currentPage - 2);
            let endPage = Math.min(totalPages, startPage + 4);
            if (endPage - startPage < 4) {
                startPage = Math.max(1, endPage - 4);
            }

            for (let i = startPage; i <= endPage; i++) {
                html += `<a class="ds-page-link ${i === currentPage ? 'ds-page-link-active' : ''}" data-page="${i}">${i}</a>`;
            }

            html += `<a class="ds-page-link ${currentPage === totalPages ? 'ds-page-link-disabled' : ''}" data-page="${currentPage + 1}">›</a>`;
            html += `<a class="ds-page-link ${currentPage === totalPages ? 'ds-page-link-disabled' : ''}" data-page="${totalPages}">»</a>`;
            html += `</div>`;

            html += `
                <div class="ds-pagination-meta">
                    <span>Tổng số: ${totalItems} bản ghi</span>
                    <select class="ds-page-size">
                        <option value="5" ${pageSize === 5 ? 'selected' : ''}>5</option>
                        <option value="10" ${pageSize === 10 ? 'selected' : ''}>10</option>
                        <option value="20" ${pageSize === 20 ? 'selected' : ''}>20</option>
                        <option value="50" ${pageSize === 50 ? 'selected' : ''}>50</option>
                    </select>
                </div>
            `;

            container.innerHTML = html;

            container.querySelectorAll(".ds-page-link:not(.ds-page-link-disabled)").forEach(link => {
                link.addEventListener("click", function(e) {
                    e.preventDefault();
                    currentPage = parseInt(this.getAttribute("data-page"));
                    renderLecturesTable();
                });
            });

            container.querySelector(".ds-page-size").addEventListener("change", function() {
                pageSize = parseInt(this.value);
                currentPage = 1;
                renderLecturesTable();
            });
        }
    </script>
}

