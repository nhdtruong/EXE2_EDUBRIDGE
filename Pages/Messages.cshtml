@page
@{
    ViewData["Title"] = "Tin nhắn";
    Layout = "_TeacherLayout";
    ViewData["ActivePage"] = "Messages";

    var mockConversations = new[] {
        new { Id = 1, Name = "Nguyễn Văn Hùng", Student = "Nguyễn Văn Minh", LastMsg = "Xin chào cô, con em học bài này hơi khó. Có thể giải thích thêm không ạ?", Time = "14:30", Unread = 2 },
        new { Id = 2, Name = "Trần Văn Toàn", Student = "Trần Thị Lan", LastMsg = "Cảm ơn cô đã quan tâm đến con em.", Time = "10:15", Unread = 0 },
        new { Id = 3, Name = "Lê Thị Mai", Student = "Lê Hoàng Nam", LastMsg = "Con em có thể học bù vào thứ 7 được không ạ?", Time = "16:45", Unread = 1 }
    };

    var mockMessages = new[] {
        new { Sender = "parent", Content = "Xin chào cô, con em học bài này hơi khó. Có thể giải thích thêm không ạ?", Time = "14:30" },
        new { Sender = "teacher", Content = "Chào phụ huynh. Cô sẽ gửi thêm tài liệu và video bài giảng cho em ạ. Phụ huynh có thể cho em xem lại.", Time = "14:35" },
        new { Sender = "parent", Content = "Cảm ơn cô nhiều ạ!", Time = "14:40" }
    };
}

<!-- Header -->
<div class="messages-header-section">
    <div>
        <h1 class="messages-main-title">Tin nhắn</h1>
        <p class="messages-subtitle">Trao đổi với phụ huynh</p>
    </div>
    <button class="btn-notification">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 8a6 6 0 0 1 12 0c0 7 3 9 3 9H3s3-2 3-9"/><path d="M10.3 21a1.94 1.94 0 0 0 3.4 0"/></svg>
        Gửi thông báo chung
    </button>
</div>

<!-- Main Layout -->
<div class="messages-container">
    <!-- Left Sidebar: Conversations -->
    <div class="messages-sidebar">
        <div class="messages-sidebar-header">
            <h3 class="messages-sidebar-title">Cuộc hội thoại</h3>
            <div class="search-wrapper">
                <svg class="search-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
                <input type="text" placeholder="Tìm kiếm..." class="search-input-field" />
            </div>
        </div>

        <div class="messages-list">
            @foreach(var conv in mockConversations)
            {
                var isActive = conv.Id == 1;
                <div class="message-item @(isActive ? "message-item-active" : "")">
                    <div class="message-avatar" style="position: relative;">
                        @conv.Name.Substring(0, 1)
                        @if(isActive) {
                            <span style="position: absolute; bottom: 0; right: 0; width: 12px; height: 12px; background-color: #22c55e; border: 2px solid white; border-radius: 50%;"></span>
                        }
                    </div>
                    <div class="message-item-content">
                        <div class="message-item-header">
                            <h4 class="message-item-name">@conv.Name</h4>
                            @if(conv.Unread > 0)
                            {
                                <span class="unread-badge">@conv.Unread</span>
                            }
                        </div>
                        <p class="message-item-student">PH: @conv.Student</p>
                        <p class="message-item-preview">@conv.LastMsg</p>
                        <p class="message-item-time">@conv.Time</p>
                    </div>
                </div>
            }
        </div>
    </div>

    <!-- Right: Chat -->
    <div class="messages-chat">
        <!-- Header -->
        <div class="messages-chat-header">
            <div class="chat-user-info">
                <div class="chat-avatar" style="position: relative;">
                    N
                    <span style="position: absolute; bottom: 2px; right: 2px; width: 12px; height: 12px; background-color: #22c55e; border: 2px solid white; border-radius: 50%;"></span>
                </div>
                <div>
                    <h3 class="chat-username">Nguyễn Văn Hùng</h3>
                    <p class="chat-userinfo">Phụ huynh: Nguyễn Văn Minh</p>
                </div>
            </div>
        </div>

        <!-- Messages Area -->
        <div class="messages-area">
            @foreach(var msg in mockMessages)
            {
                var isTeacher = msg.Sender == "teacher";
                <div class="message-bubble-wrapper @(isTeacher ? "message-teacher" : "message-parent")">
                    <div class="message-bubble">
                        <p class="message-content">@msg.Content</p>
                        <p class="message-time">@msg.Time</p>
                    </div>
                </div>
            }
        </div>

        <!-- Input Area -->
        <div class="messages-input-area">
            <div class="input-wrapper">
                <button class="btn-attach">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m21.44 11.05-9.19 9.19a6 6 0 0 1-8.49-8.49l8.57-8.57A4 4 0 1 1 18 8.84l-8.59 8.57a2 2 0 0 1-2.83-2.83l8.49-8.48"/></svg>
                </button>
                <input type="text" placeholder="Nhập tin nhắn..." class="input-message" />
                <button class="btn-send">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m22 2-7 20-4-9-9-4Z"/><path d="M22 2 11 13"/></svg>
                    Gửi
                </button>
            </div>
        </div>
    </div>
</div>