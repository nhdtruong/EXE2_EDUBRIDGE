@page
@model IndexModel
@{
    Layout = null;
    ViewData["Title"] = "Đăng nhập";
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Đăng nhập - EduBridge</title>
    <!-- Import Google Fonts API -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <div class="login-page">
        <div class="login-card">
            <div class="text-center">
                <div class="logo-circle">
                    <!-- Simple SVG icon matching the image logo approx -->
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M4 19v-2c0-1.1.9-2 2-2h12c1.1 0 2 .9 2 2v2"></path>
                        <path d="M12 3v11"></path>
                        <path d="M8 8l4-4 4 4"></path>
                    </svg>
                </div>
                <h1 class="app-title">EduBridge</h1>
                <p class="app-subtitle">Nền tảng quản lý giáo dục toàn diện</p>
            </div>

            <div class="role-toggle-container">
                <div class="role-toggle-btn" id="role-owner" onclick="setRole('owner')">Chủ trung tâm</div>
                <div class="role-toggle-btn active" id="role-teacher" onclick="setRole('teacher')">Giáo viên</div>
            </div>

            <form method="get" action="/Teacher/Dashboard">
                <div class="form-group">
                    <label class="form-label">Email</label>
                    <div class="input-with-icon">
                        <svg class="input-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
                            <circle cx="12" cy="7" r="4"></circle>
                        </svg>
                        <input type="email" class="form-control" placeholder="admin@edubridge.com" required>
                    </div>
                </div>

                <div class="form-group">
                    <label class="form-label">Mật khẩu</label>
                    <div class="input-with-icon">
                        <svg class="input-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect>
                            <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
                        </svg>
                        <input type="password" class="form-control" placeholder="••••••••" required>
                    </div>
                </div>

                <button type="submit" class="btn-primary mt-4" id="loginBtn">Đăng nhập với tư cách Giáo viên</button>

                <p class="demo-text">Demo: Bạn có thể đăng nhập với bất kỳ email/mật khẩu nào</p>
            </form>
        </div>
    </div>

    <script>
        function setRole(role) {
            const btnOwner = document.getElementById('role-owner');
            const btnTeacher = document.getElementById('role-teacher');
            const submitBtn = document.getElementById('loginBtn');
            const form = document.querySelector('form');

            if (role === 'owner') {
                btnOwner.classList.add('active');
                btnTeacher.classList.remove('active');
                submitBtn.innerText = 'Đăng nhập với tư cách Chủ trung tâm';
                form.action = '/AdminDashboard'; 
            } else {
                btnTeacher.classList.add('active');
                btnOwner.classList.remove('active');
                submitBtn.innerText = 'Đăng nhập với tư cách Giáo viên';
                form.action = '/TeacherDashboard'; 
            }
        }
        
        // Initialize based on image showing Admin or Teacher? 
        // The image shows "Đăng nhập với tư cách Admin" when Chủ trung tâm is selected.
        setRole('owner'); // let's set 'owner' as default active to match image 1 if possible
    </script>
</body>
</html>
