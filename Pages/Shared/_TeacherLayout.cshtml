    <script>
        const adminSidebarStorageKey = 'edubridge.admin.sidebar.collapsed';
        const adminSidebarToggle = document.getElementById('admin-sidebar-toggle');

        function setAdminSidebarCollapsed(isCollapsed) {
            document.body.classList.toggle('admin-sidebar-collapsed', isCollapsed);
            adminSidebarToggle?.setAttribute('aria-expanded', (!isCollapsed).toString());
            localStorage.setItem(adminSidebarStorageKey, isCollapsed ? 'true' : 'false');
        }

        setAdminSidebarCollapsed(localStorage.getItem(adminSidebarStorageKey) === 'true');
        adminSidebarToggle?.addEventListener('click', () => {
            setAdminSidebarCollapsed(!document.body.classList.contains('admin-sidebar-collapsed'));
        });

        const adminProfileBtn = document.getElementById('adminProfileBtn');
        const adminProfileMenu = document.getElementById('adminProfileMenu');
        
        if (adminProfileBtn && adminProfileMenu) {
            adminProfileBtn.addEventListener('click', (e) => {
                e.stopPropagation();
                if (document.body.classList.contains('admin-sidebar-collapsed')) {
                    setAdminSidebarCollapsed(false);
                    setTimeout(() => {
                        adminProfileMenu.classList.toggle('hidden');
                    }, 200);
                } else {
                    adminProfileMenu.classList.toggle('hidden');
                }
            });
            
            document.addEventListener('click', (e) => {
                if (!adminProfileMenu.contains(e.target) && !adminProfileBtn.contains(e.target)) {
                    adminProfileMenu.classList.add('hidden');
                }
            });
        }

        const layoutToastStorageKey = 'edubridge.admin.toasts';

        function getStoredLayoutToasts() {
            try {
                const value = localStorage.getItem(layoutToastStorageKey);
                const toasts = value ? JSON.parse(value) : [];
                const now = Date.now();

                return Array.isArray(toasts)
                    ? toasts.filter(toast => toast && toast.expiresAt > now)
                    : [];
            } catch {
                return [];
            }
        }

        function saveStoredLayoutToasts(toasts) {
            localStorage.setItem(layoutToastStorageKey, JSON.stringify(toasts));
        }

        function removeStoredLayoutToast(id) {
            saveStoredLayoutToasts(getStoredLayoutToasts().filter(toast => toast.id !== id));
        }

        function pushStoredLayoutToast(title, message, type) {
            if (!message) {
                return;
            }

            const toasts = getStoredLayoutToasts();
            toasts.push({
                id: `${Date.now()}-${Math.random().toString(16).slice(2)}`,
                title,
                message,
                type,
                expiresAt: Date.now() + 4500
            });

            saveStoredLayoutToasts(toasts);
        }

        function showLayoutToast(title, message, type, id, remainingMs) {
            if (!message) {
                return;
            }

            const container = document.getElementById('layout-toast-container');
            const isError = type === 'error' || type === 'danger' || type === 'failed';
            const toast = document.createElement('div');
            const colorClasses = isError
                ? 'border-red-300 bg-red-100 text-red-900'
                : 'border-green-300 bg-green-100 text-green-900';
            const iconColor = isError ? 'text-red-700' : 'text-green-700';

            toast.className = `${colorClasses} pointer-events-auto flex translate-x-5 gap-3 rounded border-l-4 px-4 py-4 opacity-0 shadow-xl transition-all duration-300`;
            toast.innerHTML = `
                <div class="${iconColor} mt-0.5 flex h-9 w-9 flex-shrink-0 items-center justify-center rounded-full bg-white/60">
                    ${isError
                        ? '<svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.4" d="M6 18L18 6M6 6l12 12"></path></svg>'
                        : '<svg class="h-7 w-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.4" d="M5 13l4 4L19 7"></path></svg>'}
                </div>
                <div class="min-w-0 flex-1">
                    <div class="text-base font-bold leading-5">${title || (isError ? 'Thất bại' : 'Thành công')}</div>
                    <div class="mt-1 text-sm font-medium leading-5">${message}</div>
                </div>
                <button type="button" class="${iconColor} -mr-1 -mt-1 flex h-8 w-8 flex-shrink-0 items-center justify-center rounded hover:bg-white/60" aria-label="Đóng thông báo">
                    <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.2" d="M6 18L18 6M6 6l12 12"></path></svg>
                </button>
            `;

            const closeToast = () => {
                toast.classList.add('translate-x-5', 'opacity-0');
                if (id) {
                    removeStoredLayoutToast(id);
                }
                setTimeout(() => toast.remove(), 300);
            };

            toast.querySelector('button')?.addEventListener('click', closeToast);
            container.appendChild(toast);

            requestAnimationFrame(() => {
                toast.classList.remove('translate-x-5', 'opacity-0');
            });

            setTimeout(closeToast, Math.max(1200, remainingMs ?? 4500));
        }

        window.showToast = function(message, isSuccess = true) {
            const type = isSuccess ? 'success' : 'error';
            const title = isSuccess ? 'Thành công' : 'Thất bại';
            showLayoutToast(title, message, type, null, 4500);
        };

        pushStoredLayoutToast(
            @Html.Raw(System.Text.Json.JsonSerializer.Serialize(TempData["ToastTitle"] as string)),
            @Html.Raw(System.Text.Json.JsonSerializer.Serialize(TempData["ToastMessage"] as string)),
            @Html.Raw(System.Text.Json.JsonSerializer.Serialize(TempData["ToastType"] as string))
        );

        getStoredLayoutToasts().forEach(toast => {
            showLayoutToast(
                toast.title,
                toast.message,
                toast.type,
                toast.id,
                toast.expiresAt - Date.now()
            );
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
