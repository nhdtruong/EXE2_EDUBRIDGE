@using System.Security.Claims
@inject EduBridge.Services.Auth.IAccountAuthenticationService AuthService
@{
    var fullName = User.FindFirstValue(ClaimTypes.Name) ?? "Người dùng";
    var email = User.FindFirstValue(ClaimTypes.Email) ?? string.Empty;
    var role = User.FindFirstValue(ClaimTypes.Role) ?? string.Empty;
    var roleDisplay = role switch
    {
        "OWNER" => "Chủ trung tâm",
        "TEACHER" => "Giáo viên",
        "PARENT" => "Phụ huynh",
        _ => "Người dùng"
    };
    var initials = string.Join(
        string.Empty,
        fullName
            .Split(' ', StringSplitOptions.RemoveEmptyEntries)
            .TakeLast(2)
            .Select(part => part[0]))
        .ToUpperInvariant();

    if (string.IsNullOrWhiteSpace(initials))
    {
        initials = "U";
    }

    var userIdStr = User.FindFirstValue(ClaimTypes.NameIdentifier);
    var availableRoles = new List<string>();
    if (int.TryParse(userIdStr, out int layoutUserId))
    {
        availableRoles = await AuthService.GetAvailableRolesAsync(layoutUserId);
    }
    var hasOwnerRole = availableRoles.Contains("OWNER");
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - EduBridge</title>
    <!-- Import Google Fonts API -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <!-- Exported Design System Stylesheets -->
    <link rel="stylesheet" href="~/css/design-system/design-system.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/design-system/buttons.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/design-system/forms.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/design-system/filters.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/design-system/tables.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/design-system/pagination.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/design-system/toggle.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/design-system/toast.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/design-system/datepicker.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/design-system/icons.css" asp-append-version="true" />
    
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/teacher.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/teacher-premium.css" asp-append-version="true" />
    <style>
        .sidebar,
        .main-content {
            transition: width 0.2s ease, margin-left 0.2s ease;
        }

        .teacher-sidebar-toggle {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 36px;
            height: 36px;
            flex-shrink: 0;
            border: 0;
            border-radius: 10px;
            background: transparent;
            color: #64748b;
        }

        .teacher-sidebar-toggle:hover {
            background: #f1f5f9;
            color: #2563eb;
        }

        .brand-text,
        .sidebar-nav .nav-item span,
        .sidebar-footer .user-info,
        .teacher-sidebar-logout-label {
            transition: opacity 0.15s ease, visibility 0.15s ease;
        }

        body.teacher-sidebar-collapsed .sidebar {
            width: 84px;
        }

        body.teacher-sidebar-collapsed .main-content {
            margin-left: 84px;
        }

        body.teacher-sidebar-collapsed .sidebar-brand {
            justify-content: center;
            padding-left: 0.75rem;
            padding-right: 0.75rem;
            gap: 0.5rem;
        }

        body.teacher-sidebar-collapsed .logo-box {
            display: none;
        }

        body.teacher-sidebar-collapsed .brand-text,
        body.teacher-sidebar-collapsed .sidebar-nav .nav-item span,
        body.teacher-sidebar-collapsed .sidebar-footer .user-info,
        body.teacher-sidebar-collapsed .teacher-sidebar-logout-label,
        body.teacher-sidebar-collapsed .teacher-sidebar-dropdown-icon {
            width: 0;
            opacity: 0;
            visibility: hidden;
            overflow: hidden;
            white-space: nowrap;
        }

        body.teacher-sidebar-collapsed .sidebar-nav {
            padding-left: 0.75rem;
            padding-right: 0.75rem;
        }

        body.teacher-sidebar-collapsed .nav-item {
            justify-content: center;
            padding-left: 0.75rem;
            padding-right: 0.75rem;
        }

        body.teacher-sidebar-collapsed .nav-icon,
        body.teacher-sidebar-collapsed .logout-btn svg {
            margin-right: 0 !important;
        }

        body.teacher-sidebar-collapsed .user-profile {
            justify-content: center;
        }

        body.teacher-sidebar-collapsed .avatar {
            margin-right: 0;
        }
    </style>
</head>
<body class="bg-gray">
    <!-- Stacked Toast Container from Design System -->
    <div id="layout-toast-container" class="ds-toast-container"></div>

    <div class="app-container">
        <!-- Sidebar -->
        <aside class="sidebar">
            <div class="sidebar-brand">
                <div class="logo-box">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M22 10v6M2 10l10-5 10 5-10 5z"></path>
                        <path d="M6 12v5c3 3 9 3 12 0v-5"></path>
                    </svg>
                </div>
                <div class="brand-text">
                    <span class="brand-name">EduBridge</span>
                    <span class="brand-sub">Giáo viên</span>
                </div>
                <button id="teacher-sidebar-toggle" type="button" class="teacher-sidebar-toggle" aria-label="Thu gọn/mở rộng sidebar" aria-expanded="true">
                    <svg width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 7h16M4 12h16M4 17h16"></path>
                    </svg>
                </button>
            </div>

            <nav class="sidebar-nav">
                <a href="/Teacher/Dashboard" title="Dashboard" class="nav-item @(ViewData["ActivePage"] as string == "Dashboard" ? "active" : "")">
                    <svg class="nav-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7"></rect><rect x="14" y="3" width="7" height="7"></rect><rect x="14" y="14" width="7" height="7"></rect><rect x="3" y="14" width="7" height="7"></rect></svg>
                    <span>Dashboard</span>
                </a>
                <a href="/Teacher/Lectures" title="Bài giảng" class="nav-item @(ViewData["ActivePage"] as string == "Lectures" ? "active" : "")">
                    <svg class="nav-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"></path><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"></path></svg>
                    <span>Bài giảng</span>
                </a>
                <a href="/Homework" title="Bài tập" class="nav-item @(ViewData["ActivePage"] as string == "Assignments" ? "active" : "")">
                    <svg class="nav-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line><polyline points="10 9 9 9 8 9"></polyline></svg>
                    <span>Bài tập</span>
                </a>
                <a href="/Grades" title="Sổ điểm" class="nav-item @(ViewData["ActivePage"] as string == "Grades" ? "active" : "")">
                    <svg class="nav-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9H4.5a2.5 2.5 0 0 1 0-5H6"></path><path d="M18 9h1.5a2.5 2.5 0 0 0 0-5H18"></path><path d="M4 22h16"></path><path d="M10 14.66V17c0 .55-.47.98-.97 1.21C7.85 18.75 7 20.24 7 22"></path><path d="M14 14.66V17c0 .55.47.98.97 1.21C16.15 18.75 17 20.24 17 22"></path><path d="M18 2H6v7a6 6 0 0 0 12 0V2Z"></path></svg>
                    <span>Sổ điểm</span>
                </a>
                <a href="/Teacher/Attendance" title="Điểm danh" class="nav-item @(ViewData["ActivePage"] as string == "Attendance" ? "active" : "")">
                    <svg class="nav-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>
                    <span>Điểm danh</span>
                </a>
                <a href="/Messages" title="Tin nhắn" class="nav-item @(ViewData["ActivePage"] as string == "Messages" ? "active" : "")">
                    <svg class="nav-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path></svg>
                    <span>Tin nhắn</span>
                </a>
            </nav>

            <div class="sidebar-footer position-relative">
                <button type="button" id="teacherProfileBtn" class="user-profile w-100 bg-transparent border-0 d-flex align-items-center text-start p-0 m-0" style="cursor: pointer;">
                    <div class="avatar flex-shrink-0">@initials</div>
                    <div class="user-info flex-grow-1 overflow-hidden" style="min-width: 0;">
                        <span class="user-name text-truncate d-block">@fullName</span>
                        <span class="user-role text-truncate d-block">@roleDisplay</span>
                    </div>
                    <svg class="teacher-sidebar-dropdown-icon text-muted ms-2 flex-shrink-0" width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 15l7-7 7 7"></path></svg>
                </button>
                
                <div id="teacherProfileMenu" class="d-none position-absolute start-0 w-100 mb-2 px-3 z-3" style="bottom: 72px;">
                    <div class="bg-white rounded shadow border p-2">
                        @if (hasOwnerRole)
                        {
                            <form method="post" asp-page="/SwitchRole" class="w-100 mb-1">
                                <input type="hidden" name="roleCode" value="OWNER" />
                                <button type="submit" class="logout-btn w-100 justify-content-start border-0 px-3 py-2" style="color: #2563eb; background: #eff6ff; border-radius: 8px;">
                                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="me-3 flex-shrink-0"><path d="M16 3h5v5M4 20L21 3M21 16v5h-5M15 15l6 6M4 4l5 5"></path></svg>
                                    <span>Giao diện Quản lý</span>
                                </button>
                            </form>
                        }
                        <a href="/ChangePassword" class="logout-btn w-100 justify-content-start border-0 px-3 py-2 mb-1" style="text-decoration: none; color: #4b5563; background: #fff; border-radius: 8px;">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="me-3 flex-shrink-0"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg>
                            <span>Đổi mật khẩu</span>
                        </a>
                        <form method="post" asp-page="/Logout" class="w-100 m-0">
                            <button type="submit" class="logout-btn w-100 justify-content-start border-0 px-3 py-2" style="color: #dc3545; background: #fff; border-radius: 8px;">
                                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="me-3 flex-shrink-0"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path><polyline points="16 17 21 12 16 7"></polyline><line x1="21" y1="12" x2="9" y2="12"></line></svg>
                                <span>Đăng xuất</span>
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </aside>

        <!-- Main Content -->
        <main class="main-content">
            @RenderBody()
        </main>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script>
        const teacherSidebarStorageKey = 'edubridge.teacher.sidebar.collapsed';
        const teacherSidebarToggle = document.getElementById('teacher-sidebar-toggle');

        function setTeacherSidebarCollapsed(isCollapsed) {
            document.body.classList.toggle('teacher-sidebar-collapsed', isCollapsed);
            teacherSidebarToggle?.setAttribute('aria-expanded', (!isCollapsed).toString());
            localStorage.setItem(teacherSidebarStorageKey, isCollapsed ? 'true' : 'false');
        }

        setTeacherSidebarCollapsed(localStorage.getItem(teacherSidebarStorageKey) === 'true');
        teacherSidebarToggle?.addEventListener('click', () => {
            setTeacherSidebarCollapsed(!document.body.classList.contains('teacher-sidebar-collapsed'));
        });

        const teacherProfileBtn = document.getElementById('teacherProfileBtn');
        const teacherProfileMenu = document.getElementById('teacherProfileMenu');
        
        if (teacherProfileBtn && teacherProfileMenu) {
            teacherProfileBtn.addEventListener('click', (e) => {
                e.stopPropagation();
                if (document.body.classList.contains('teacher-sidebar-collapsed')) {
                    setTeacherSidebarCollapsed(false);
                    setTimeout(() => {
                        teacherProfileMenu.classList.toggle('d-none');
                    }, 200);
                } else {
                    teacherProfileMenu.classList.toggle('d-none');
                }
            });
            
            document.addEventListener('click', (e) => {
                if (!teacherProfileMenu.contains(e.target) && !teacherProfileBtn.contains(e.target)) {
                    teacherProfileMenu.classList.add('d-none');
                }
            });
        }

        // Dynamic stacked toast logic
        const layoutToastStorageKey = 'edubridge.teacher.toasts';

        function getStoredLayoutToasts() {
            try {
                const value = localStorage.getItem(layoutToastStorageKey);
                const toasts = value ? JSON.parse(value) : [];
                const now = Date.now();
                return Array.isArray(toasts) ? toasts.filter(toast => toast && toast.expiresAt > now) : [];
            } catch {
                return [];
            }
        }

        function saveStoredLayoutToasts(toasts) {
            localStorage.setItem(layoutToastStorageKey, JSON.stringify(toasts));
        }

        function removeStoredLayoutToast(id) {
            saveStoredLayoutToasts(getStoredLayoutToasts().filter(toast => toast.id !== id));
        }

        function pushStoredLayoutToast(title, message, type) {
            if (!message) return;
            const toasts = getStoredLayoutToasts();
            toasts.push({
                id: `${Date.now()}-${Math.random().toString(16).slice(2)}`,
                title,
                message,
                type,
                expiresAt: Date.now() + 4500
            });
            saveStoredLayoutToasts(toasts);
        }

        function showLayoutToast(title, message, type, id, remainingMs) {
            if (!message) return;
            const container = document.getElementById('layout-toast-container');
            if (!container) return;

            const isError = type === 'error' || type === 'danger' || type === 'failed' || type === false;
            const toast = document.createElement('div');
            
            toast.className = `ds-toast ${isError ? 'ds-toast-error' : 'ds-toast-success'}`;
            toast.innerHTML = `
                <div class="min-w-0 flex-1">
                    <div class="ds-toast-title">${title || (isError ? 'Thất bại' : 'Thành công')}</div>
                    <div class="ds-toast-message">${message}</div>
                </div>
                <button type="button" class="ds-toast-close" aria-label="Đóng thông báo">&times;</button>
            `;

            const closeToast = () => {
                if (id) {
                    removeStoredLayoutToast(id);
                }
                toast.remove();
            };

            toast.querySelector('.ds-toast-close')?.addEventListener('click', closeToast);
            container.appendChild(toast);

            setTimeout(closeToast, Math.max(1200, remainingMs ?? 4500));
        }

        // Global showToast helper
        window.showToast = function(message, isSuccess = true) {
            showLayoutToast(isSuccess ? 'Thành công' : 'Lỗi', message, isSuccess ? 'success' : 'error');
        };

        // Push layout toasts from TempData
        const tempToastTitle = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(TempData["ToastTitle"] as string));
        const tempToastMessage = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(TempData["ToastMessage"] as string));
        const tempToastType = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(TempData["ToastType"] as string));

        if (tempToastMessage) {
            pushStoredLayoutToast(tempToastTitle, tempToastMessage, tempToastType);
        }

        getStoredLayoutToasts().forEach(toast => {
            showLayoutToast(
                toast.title,
                toast.message,
                toast.type,
                toast.id,
                toast.expiresAt - Date.now()
            );
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
