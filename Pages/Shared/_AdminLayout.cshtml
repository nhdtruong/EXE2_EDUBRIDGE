@using System.Security.Claims
@using Microsoft.EntityFrameworkCore
@inject EduBridge.Services.Auth.ICurrentCenterService CurrentCenterService
@inject EduBridge.Services.Auth.IAccountAuthenticationService AuthService
@inject EduBridge.Data.AppDbContext DbContext
@{
    var fullName = User.FindFirstValue(ClaimTypes.Name) ?? "Người dùng";
    var email = User.FindFirstValue(ClaimTypes.Email) ?? string.Empty;
    var initials = string.Join(
        string.Empty,
        fullName
            .Split(' ', StringSplitOptions.RemoveEmptyEntries)
            .TakeLast(2)
            .Select(part => part[0]))
        .ToUpperInvariant();

    if (string.IsNullOrWhiteSpace(initials))
    {
        initials = "U";
    }

    var userIdStr = User.FindFirstValue(ClaimTypes.NameIdentifier);
    var availableRoles = new List<string>();
    if (int.TryParse(userIdStr, out int layoutUserId))
    {
        availableRoles = await AuthService.GetAvailableRolesAsync(layoutUserId);
    }
    var hasTeacherRole = availableRoles.Contains("TEACHER");

    var currentRole = User.FindFirst(ClaimTypes.Role)?.Value;
    var isSystemAdmin = currentRole == "SYSTEM_ADMIN";
    var isOwner = currentRole == "OWNER";
    
    var supportCenterIdStr = Context.Request.Cookies["SupportCenterId"];
    var isSupportMode = isSystemAdmin && !string.IsNullOrEmpty(supportCenterIdStr);
    
    var showCenterMenu = isOwner || isSupportMode;

    // Lấy trung tâm và danh sách cơ sở đang hoạt động.
    var currentCenterId = await CurrentCenterService.GetCenterIdAsync();
    var currentBranchIdStr = Context.Request.Cookies["CurrentBranchId"];
    int.TryParse(currentBranchIdStr, out int currentBranchId);

    var currentCenterName = "Trung tâm";
    var ownerContextLabel = currentCenterName;
    var branches = new List<EduBridge.Models.Branch>();
    if (currentCenterId.HasValue)
    {
        currentCenterName = await DbContext.Centers
            .AsNoTracking()
            .Where(c => c.CenterId == currentCenterId.Value)
            .Select(c => c.CenterName)
            .FirstOrDefaultAsync() ?? currentCenterName;

        branches = await DbContext.Branches
            .AsNoTracking()
            .Where(b => b.CenterId == currentCenterId.Value && b.Status.ToUpper() == "ACTIVE")
            .OrderBy(b => b.BranchName)
            .ToListAsync();

        ownerContextLabel = branches
            .FirstOrDefault(branch => branch.BranchId == currentBranchId)
            ?.BranchName ?? currentCenterName;
    }

    var isCenterManagementScope = showCenterMenu && currentBranchId == 0;
}
