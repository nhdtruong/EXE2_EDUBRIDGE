                    </a>
                    <a href="/AdminFinance" title="Tài chính" class="admin-sidebar-link flex items-center px-4 py-3 @(ViewData["ActivePage"] as string == "AdminFinance" ? "bg-blue-50 text-blue-600 rounded-xl font-medium" : "text-gray-600 hover:bg-gray-50 hover:text-gray-900 rounded-xl font-medium transition-colors")">
                        <svg class="w-5 h-5 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><line x1="12" y1="1" x2="12" y2="23"></line><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"></path></svg>
                        <span class="admin-sidebar-label">Tài chính</span>
                    </a>
                    <a href="/AdminSettings" title="Cài đặt" class="admin-sidebar-link flex items-center px-4 py-3 @(ViewData["ActivePage"] as string == "AdminSettings" ? "bg-blue-50 text-blue-600 rounded-xl font-medium" : "text-gray-600 hover:bg-gray-50 hover:text-gray-900 rounded-xl font-medium transition-colors")">
                        <svg class="w-5 h-5 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><circle cx="12" cy="12" r="3"></circle><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"></path></svg>
                        <span class="admin-sidebar-label">Cài đặt</span>
                    </a>
                    }
                }
            </nav>
        </div>

    </aside>

    <!-- Main Content -->
    <main class="admin-main flex-1 overflow-y-auto relative">
        <!-- Top bar containing Branch Selector -->
        @if (showCenterMenu && branches.Any())
        {
            <div class="owner-main-branch-row flex justify-end mb-4">
                <form method="post" asp-page="/SetBranch" class="flex items-center space-x-2">
                    <label for="branchSelector" class="text-sm font-medium text-gray-700">Cơ sở:</label>
                    <select id="branchSelector" name="branchId" onchange="this.form.submit()" class="border-gray-300 rounded-lg text-sm focus:ring-blue-500 focus:border-blue-500">
                        <option value="0">Tất cả cơ sở</option>
                        @foreach (var branch in branches)
                        {
                            if (currentBranchId == branch.BranchId)
                            {
                                <option value="@branch.BranchId" selected>@branch.BranchName</option>
                            }
                            else
                            {
                                <option value="@branch.BranchId">@branch.BranchName</option>
                            }
                        }
                    </select>
                </form>
            </div>
        }

        @if (isSupportMode)
        {
            <div class="bg-red-50 text-red-700 border border-red-200 px-4 py-3 rounded-xl mb-4 flex justify-between items-center shadow-sm">
                <div class="font-medium flex items-center">
                    <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path></svg>
                    Bạn đang trong chế độ Hỗ Trợ (Support Mode). Mọi thao tác sẽ được ghi lại.
                </div>
                <form method="post" asp-page="/SystemAdmin/ExitSupportMode">
                    <button type="submit" class="bg-white text-red-600 px-3 py-1.5 rounded-lg border border-red-200 text-sm font-bold hover:bg-red-50 transition-colors">
                        Thoát chế độ hỗ trợ
                    </button>
                </form>
            </div>
        }
        @RenderBody()
    </main>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script>
        const adminSidebarStorageKey = 'edubridge.admin.sidebar.collapsed';
        const adminSidebarToggle = document.getElementById('admin-sidebar-toggle');

        function setAdminSidebarCollapsed(isCollapsed) {
            document.body.classList.toggle('admin-sidebar-collapsed', isCollapsed);
            adminSidebarToggle?.setAttribute('aria-expanded', (!isCollapsed).toString());
            localStorage.setItem(adminSidebarStorageKey, isCollapsed ? 'true' : 'false');
        }

        setAdminSidebarCollapsed(localStorage.getItem(adminSidebarStorageKey) === 'true');
        adminSidebarToggle?.addEventListener('click', () => {
            setAdminSidebarCollapsed(!document.body.classList.contains('admin-sidebar-collapsed'));
        });

        document.querySelectorAll('#admin-sidebar .admin-sidebar-nav > a.admin-sidebar-link').forEach((link) => {
            const item = document.createElement('div');
            item.className = 'admin-sidebar-item';
            const label = link.querySelector('.admin-sidebar-label')?.textContent?.trim() || link.textContent.trim();
            const href = link.getAttribute('href') || '#';
            const isActive = link.classList.contains('bg-blue-50') || link.classList.contains('text-blue-600');

            link.parentNode.insertBefore(item, link);
            item.appendChild(link);
            link.setAttribute('role', 'button');
            link.setAttribute('aria-expanded', isActive.toString());

            const submenu = document.createElement('div');
            submenu.className = 'admin-sidebar-submenu';

            const submenuLink = document.createElement('a');
            submenuLink.href = href;
            submenuLink.className = `admin-sidebar-submenu-link${isActive ? ' is-active' : ''}`;
            submenuLink.textContent = label;
            submenu.appendChild(submenuLink);
            item.appendChild(submenu);

            item.classList.toggle('is-open', isActive);
            link.dataset.sidebarToggleBound = 'true';
            link.addEventListener('click', (event) => {
                event.preventDefault();
                const shouldOpen = !item.classList.contains('is-open');
                item.classList.toggle('is-open', shouldOpen);
                link.setAttribute('aria-expanded', shouldOpen.toString());
            });
        });

        document.querySelectorAll('#admin-sidebar .admin-sidebar-item > .admin-sidebar-link').forEach((link) => {
            if (link.dataset.sidebarToggleBound === 'true') {
                return;
            }

            const item = link.closest('.admin-sidebar-item');
            if (!item) {
                return;
            }

            link.dataset.sidebarToggleBound = 'true';
            link.addEventListener('click', (event) => {
                event.preventDefault();
                const shouldOpen = !item.classList.contains('is-open');
                item.classList.toggle('is-open', shouldOpen);
                link.setAttribute('aria-expanded', shouldOpen.toString());
            });
        });

        const ownerCenterTree = document.getElementById('ownerCenterTree');
        const ownerCenterToggle = document.getElementById('ownerCenterToggle');
        const ownerCenterPanel = document.getElementById('ownerCenterPanel');
        const ownerCenterClose = document.getElementById('ownerCenterClose');
        const ownerCenterSearchInput = document.getElementById('ownerCenterSearchInput');
        const ownerCenterRow = document.getElementById('ownerCenterRow');
        const ownerBranchToggle = document.getElementById('ownerBranchToggle');
        const ownerCenterChildren = document.getElementById('ownerCenterChildren');
        const ownerCenterNoResult = document.getElementById('ownerCenterNoResult');
        const ownerBranchForms = Array.from(document.querySelectorAll('.owner-branch-form'));

        function setOwnerCenterTreeOpen(isOpen) {
            ownerCenterPanel?.classList.toggle('hidden', !isOpen);
            ownerCenterTree?.classList.toggle('is-open', isOpen);
            ownerCenterToggle?.setAttribute('aria-expanded', isOpen.toString());
            if (isOpen) {
                requestAnimationFrame(() => ownerCenterSearchInput?.focus());
            }
        }

        function setOwnerCenterChildrenOpen(isOpen) {
            ownerCenterChildren?.classList.toggle('is-hidden', !isOpen);
            ownerCenterRow?.classList.toggle('is-collapsed', !isOpen);
            ownerBranchToggle?.setAttribute('aria-expanded', isOpen.toString());
        }

        function normalizeSearchText(value) {
            return (value || '')
                .toLocaleLowerCase('vi-VN')
                .normalize('NFD')
                .replace(/[\u0300-\u036f]/g, '')
                .replace(/đ/g, 'd');
        }

        function filterOwnerCenterTree() {
            const keyword = normalizeSearchText(ownerCenterSearchInput?.value || '').trim();
            const centerText = normalizeSearchText(ownerCenterRow?.dataset.searchText || '');
            const centerMatches = !keyword || centerText.includes(keyword);
            let visibleBranchCount = 0;

            ownerCenterRow?.classList.toggle('hidden', !centerMatches);

            ownerBranchForms.forEach(form => {
                const itemText = normalizeSearchText(form.dataset.searchText || '');
                const isMatch = !keyword || itemText.includes(keyword);
                form.classList.toggle('hidden', !isMatch);
                if (isMatch) {
                    visibleBranchCount += 1;
                }
            });

            if (keyword) {
                setOwnerCenterChildrenOpen(true);
            }

            ownerCenterNoResult?.classList.toggle('is-hidden', centerMatches || visibleBranchCount > 0);
        }

        ownerCenterToggle?.addEventListener('click', (e) => {
            e.stopPropagation();
            setOwnerCenterTreeOpen(ownerCenterPanel?.classList.contains('hidden') ?? true);
        });

        ownerCenterClose?.addEventListener('click', (e) => {
            e.stopPropagation();
            setOwnerCenterTreeOpen(false);
        });

        ownerBranchToggle?.addEventListener('click', (e) => {
            e.preventDefault();
            e.stopPropagation();
            setOwnerCenterChildrenOpen(ownerCenterChildren?.classList.contains('is-hidden') ?? false);
        });

        ownerCenterSearchInput?.addEventListener('input', filterOwnerCenterTree);

        document.addEventListener('click', (e) => {
            if (ownerCenterTree && !ownerCenterTree.contains(e.target)) {
                setOwnerCenterTreeOpen(false);
            }
        });

        const adminProfileBtn = document.getElementById('adminProfileBtn');
        const adminProfileMenu = document.getElementById('adminProfileMenu');
        
        if (adminProfileBtn && adminProfileMenu) {
            adminProfileBtn.addEventListener('click', (e) => {
                e.stopPropagation();
                adminProfileMenu.classList.toggle('hidden');
                adminProfileBtn.setAttribute('aria-expanded', (!adminProfileMenu.classList.contains('hidden')).toString());
            });
            
            document.addEventListener('click', (e) => {
                if (!adminProfileMenu.contains(e.target) && !adminProfileBtn.contains(e.target)) {
                    adminProfileMenu.classList.add('hidden');
                    adminProfileBtn.setAttribute('aria-expanded', 'false');
                }
            });
        }

        const layoutToastStorageKey = 'edubridge.admin.toasts';

        function getStoredLayoutToasts() {
            try {
                const value = localStorage.getItem(layoutToastStorageKey);
                const toasts = value ? JSON.parse(value) : [];
                const now = Date.now();

                return Array.isArray(toasts)
                    ? toasts.filter(toast => toast && toast.expiresAt > now)
                    : [];
            } catch {
                return [];
            }
        }

        function saveStoredLayoutToasts(toasts) {
            localStorage.setItem(layoutToastStorageKey, JSON.stringify(toasts));
        }

        function removeStoredLayoutToast(id) {
            saveStoredLayoutToasts(getStoredLayoutToasts().filter(toast => toast.id !== id));
        }

        function pushStoredLayoutToast(title, message, type) {
            if (!message) {
                return;
            }

            const toasts = getStoredLayoutToasts();
            toasts.push({
                id: `${Date.now()}-${Math.random().toString(16).slice(2)}`,
                title,
                message,
                type,
                expiresAt: Date.now() + 4500
            });

            saveStoredLayoutToasts(toasts);
        }

        function showLayoutToast(title, message, type, id, remainingMs) {
            if (!message) {
                return;
            }

            const container = document.getElementById('layout-toast-container');
            const isError = type === 'error' || type === 'danger' || type === 'failed';
            const toast = document.createElement('div');
            const colorClasses = isError
                ? 'border-red-300 bg-red-100 text-red-900'
                : 'border-green-300 bg-green-100 text-green-900';
            const iconColor = isError ? 'text-red-700' : 'text-green-700';

            toast.className = `${colorClasses} pointer-events-auto flex translate-x-5 gap-3 rounded border-l-4 px-4 py-4 opacity-0 shadow-xl transition-all duration-300`;
            toast.innerHTML = `
                <div class="${iconColor} mt-0.5 flex h-9 w-9 flex-shrink-0 items-center justify-center rounded-full bg-white/60">
                    ${isError
                        ? '<svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.4" d="M6 18L18 6M6 6l12 12"></path></svg>'
                        : '<svg class="h-7 w-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.4" d="M5 13l4 4L19 7"></path></svg>'}
                </div>
                <div class="min-w-0 flex-1">
                    <div class="text-base font-bold leading-5">${title || (isError ? 'Thất bại' : 'Thành công')}</div>
                    <div class="mt-1 text-sm font-medium leading-5">${message}</div>
                </div>
                <button type="button" class="${iconColor} -mr-1 -mt-1 flex h-8 w-8 flex-shrink-0 items-center justify-center rounded hover:bg-white/60" aria-label="Đóng thông báo">
                    <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.2" d="M6 18L18 6M6 6l12 12"></path></svg>
                </button>
            `;

            const closeToast = () => {
                toast.classList.add('translate-x-5', 'opacity-0');
                if (id) {
                    removeStoredLayoutToast(id);
                }
                setTimeout(() => toast.remove(), 300);
            };

            toast.querySelector('button')?.addEventListener('click', closeToast);
            container.appendChild(toast);

            requestAnimationFrame(() => {
                toast.classList.remove('translate-x-5', 'opacity-0');
            });

            setTimeout(closeToast, Math.max(1200, remainingMs ?? 4500));
        }

        pushStoredLayoutToast(
            @Html.Raw(System.Text.Json.JsonSerializer.Serialize(TempData["ToastTitle"] as string)),
            @Html.Raw(System.Text.Json.JsonSerializer.Serialize(TempData["ToastMessage"] as string)),
            @Html.Raw(System.Text.Json.JsonSerializer.Serialize(TempData["ToastType"] as string))
        );

        getStoredLayoutToasts().forEach(toast => {
            showLayoutToast(
                toast.title,
                toast.message,
                toast.type,
                toast.id,
                toast.expiresAt - Date.now()
            );
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
