@using System.Security.Claims
@{
    var fullName = User.FindFirstValue(ClaimTypes.Name) ?? "Người dùng";
    var email = User.FindFirstValue(ClaimTypes.Email) ?? string.Empty;
    var initials = string.Join(
        string.Empty,
        fullName
            .Split(' ', StringSplitOptions.RemoveEmptyEntries)
            .TakeLast(2)
            .Select(part => part[0]))
        .ToUpperInvariant();

    if (string.IsNullOrWhiteSpace(initials))
    {
        initials = "U";
    }
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - EduBridge Admin Panel</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; background-color: #f8fafc; font-size: 14px; }

        .admin-main {
            padding: 1.25rem;
        }

        .admin-main h1 {
            font-size: 1.625rem;
            line-height: 2rem;
        }

        .admin-main h1 + p {
            font-size: 0.875rem;
        }

        .admin-main .rounded-2xl {
            border-radius: 0.75rem;
        }

        .admin-main .bg-blue-50\/60.p-6 {
            padding: 1.25rem;
        }

        .admin-main input:not([type="hidden"]):not([type="radio"]):not([type="checkbox"]):not([type="file"]),
        .admin-main select,
        .admin-main [data-dropdown-toggle],
        .admin-main [data-range-toggle] {
            min-height: 2.5rem !important;
            height: 2.5rem !important;
            font-size: 0.8125rem !important;
            padding-left: 0.875rem !important;
            padding-right: 0.875rem !important;
        }

        .admin-main [data-range-toggle] span:last-child {
            width: 2.75rem !important;
        }

        .admin-main [data-range-toggle] {
            padding-left: 0 !important;
            padding-right: 0 !important;
        }

        .admin-main [data-dropdown-search] {
            height: 2.375rem !important;
        }

        .admin-main a.inline-flex:not(.h-11):not(.h-12),
        .admin-main button.inline-flex:not(.h-11):not(.h-12) {
            font-size: 0.8125rem;
        }

        .admin-main a.h-11,
        .admin-main button.h-11,
        .admin-main a.h-12,
        .admin-main button.h-12 {
            height: 2.5rem !important;
            min-height: 2.5rem !important;
            font-size: 0.8125rem !important;
        }

        .admin-main table thead tr {
            font-size: 0.8125rem !important;
        }

        .admin-main table th {
            padding: 0.75rem 0.875rem !important;
        }

        .admin-main table td {
            padding: 0.75rem 0.875rem !important;
            font-size: 0.8125rem !important;
        }

        .admin-main table .h-10.w-10,
        .admin-main table .w-10.h-10 {
            width: 2rem !important;
            height: 2rem !important;
            margin-right: 0.75rem !important;
        }

        .admin-main table .h-11.w-11,
        .admin-main table .w-11.h-11 {
            width: 2.375rem !important;
            height: 2.375rem !important;
        }

        .admin-main table .h-5.w-5,
        .admin-main table .w-5.h-5 {
            width: 1.125rem !important;
            height: 1.125rem !important;
        }

        .admin-main table .gap-3 {
            gap: 0.5rem !important;
        }

        .admin-main table .min-w-28 {
            min-width: 5.75rem !important;
        }

        .admin-main .border-t.bg-white.px-6.py-4 {
            padding: 0.75rem 1rem !important;
        }
    </style>
</head>
<body class="text-gray-800 flex h-screen overflow-hidden">
    <div id="layout-toast-container" class="fixed right-6 top-6 z-50 flex w-[380px] max-w-[calc(100vw-2rem)] flex-col gap-3"></div>

    <!-- Sidebar -->
    <aside class="w-64 bg-white border-r border-gray-200 flex flex-col justify-between flex-shrink-0">
        <div>
            <!-- Logo -->
            <div class="h-20 flex items-center px-6 border-b border-gray-50">
                <div class="text-blue-600 mr-3">
                    <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M22 10v6M2 10l10-5 10 5-10 5z"></path>
                        <path d="M6 12v5c3 3 9 3 12 0v-5"></path>
                    </svg>
                </div>
                <div>
                    <div class="font-bold text-xl text-gray-900 leading-tight">EduBridge</div>
                    <div class="text-xs text-gray-500 font-medium">Chủ trung tâm</div>
                </div>
            </div>

            <!-- Navigation -->
            <nav class="p-4 space-y-1.5 mt-2">
                <a href="/AdminDashboard" class="flex items-center px-4 py-3 @(ViewData["ActivePage"] as string == "AdminDashboard" || ViewData["ActivePage"] == null ? "bg-blue-50 text-blue-600 rounded-xl font-medium" : "text-gray-600 hover:bg-gray-50 hover:text-gray-900 rounded-xl font-medium transition-colors")">
                    <svg class="w-5 h-5 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><rect x="3" y="3" width="7" height="7"></rect><rect x="14" y="3" width="7" height="7"></rect><rect x="14" y="14" width="7" height="7"></rect><rect x="3" y="14" width="7" height="7"></rect></svg>
                    Dashboard
                </a>
                <a href="/AdminClasses" class="flex items-center px-4 py-3 @(ViewData["ActivePage"] as string == "AdminClasses" ? "bg-blue-50 text-blue-600 rounded-xl font-medium" : "text-gray-600 hover:bg-gray-50 hover:text-gray-900 rounded-xl font-medium transition-colors")">
                    <svg class="w-5 h-5 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path><polyline points="9 22 9 12 15 12 15 22"></polyline></svg>
                    Lớp học
                </a>
                <a href="/AdminCourses" class="flex items-center px-4 py-3 @(ViewData["ActivePage"] as string == "AdminCourses" ? "bg-blue-50 text-blue-600 rounded-xl font-medium" : "text-gray-600 hover:bg-gray-50 hover:text-gray-900 rounded-xl font-medium transition-colors")">
                    <svg class="w-5 h-5 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"></path><path d="M4 4.5A2.5 2.5 0 0 1 6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5z"></path><path d="M8 6h8"></path><path d="M8 10h6"></path></svg>
                    Môn học
                </a>
                <a href="/AdminStudents" class="flex items-center px-4 py-3 @(ViewData["ActivePage"] as string == "AdminStudents" ? "bg-blue-50 text-blue-600 rounded-xl font-medium" : "text-gray-600 hover:bg-gray-50 hover:text-gray-900 rounded-xl font-medium transition-colors")">
                    <svg class="w-5 h-5 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M23 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg>
                    Học sinh
                </a>
                <a href="/AdminParents" class="flex items-center px-4 py-3 @(ViewData["ActivePage"] as string == "AdminParents" ? "bg-blue-50 text-blue-600 rounded-xl font-medium" : "text-gray-600 hover:bg-gray-50 hover:text-gray-900 rounded-xl font-medium transition-colors")">
                    <svg class="w-5 h-5 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><circle cx="12" cy="7" r="4"></circle><path d="M5.5 21a6.5 6.5 0 0 1 13 0"></path><path d="M19 8.5a3 3 0 0 1 0 5"></path><path d="M21.5 21a5 5 0 0 0-3.5-4.77"></path></svg>
                    Phụ huynh
                </a>
                <a href="/AdminTeachers" class="flex items-center px-4 py-3 @(ViewData["ActivePage"] as string == "AdminTeachers" ? "bg-blue-50 text-blue-600 rounded-xl font-medium" : "text-gray-600 hover:bg-gray-50 hover:text-gray-900 rounded-xl font-medium transition-colors")">
                    <svg class="w-5 h-5 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"></path><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"></path></svg>
                    Giáo viên
                </a>
                <a href="/AdminFinance" class="flex items-center px-4 py-3 @(ViewData["ActivePage"] as string == "AdminFinance" ? "bg-blue-50 text-blue-600 rounded-xl font-medium" : "text-gray-600 hover:bg-gray-50 hover:text-gray-900 rounded-xl font-medium transition-colors")">
                    <svg class="w-5 h-5 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><line x1="12" y1="1" x2="12" y2="23"></line><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"></path></svg>
                    Tài chính
                </a>
                <a href="/AdminSettings" class="flex items-center px-4 py-3 @(ViewData["ActivePage"] as string == "AdminSettings" ? "bg-blue-50 text-blue-600 rounded-xl font-medium" : "text-gray-600 hover:bg-gray-50 hover:text-gray-900 rounded-xl font-medium transition-colors")">
                    <svg class="w-5 h-5 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><circle cx="12" cy="12" r="3"></circle><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"></path></svg>
                    Cài đặt
                </a>
            </nav>
        </div>

        <!-- User Profile & Logout -->
        <div class="p-5 border-t border-gray-100">
            <div class="flex items-center mb-5">
                <div class="w-10 h-10 rounded-full bg-blue-100 text-blue-600 flex items-center justify-center font-bold mr-3">
                    @initials
                </div>
                <div>
                    <div class="font-bold text-sm text-gray-900">@fullName</div>
                    <div class="text-xs text-gray-500">@email</div>
                </div>
            </div>
            <form method="post" asp-page="/Logout" class="w-full">
                <button type="submit" class="flex items-center justify-center w-full py-2.5 px-4 border border-gray-200 rounded-xl text-sm font-medium text-gray-700 hover:bg-gray-50 transition-colors bg-white">
                    <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path><polyline points="16 17 21 12 16 7"></polyline><line x1="21" y1="12" x2="9" y2="12"></line></svg>
                    Đăng xuất
                </button>
            </form>
        </div>
    </aside>

    <!-- Main Content -->
    <main class="admin-main flex-1 overflow-y-auto">
        @RenderBody()
    </main>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script>
        const layoutToastStorageKey = 'edubridge.admin.toasts';

        function getStoredLayoutToasts() {
            try {
                const value = localStorage.getItem(layoutToastStorageKey);
                const toasts = value ? JSON.parse(value) : [];
                const now = Date.now();

                return Array.isArray(toasts)
                    ? toasts.filter(toast => toast && toast.expiresAt > now)
                    : [];
            } catch {
                return [];
            }
        }

        function saveStoredLayoutToasts(toasts) {
            localStorage.setItem(layoutToastStorageKey, JSON.stringify(toasts));
        }

        function removeStoredLayoutToast(id) {
            saveStoredLayoutToasts(getStoredLayoutToasts().filter(toast => toast.id !== id));
        }

        function pushStoredLayoutToast(title, message, type) {
            if (!message) {
                return;
            }

            const toasts = getStoredLayoutToasts();
            toasts.push({
                id: `${Date.now()}-${Math.random().toString(16).slice(2)}`,
                title,
                message,
                type,
                expiresAt: Date.now() + 4500
            });

            saveStoredLayoutToasts(toasts);
        }

        function showLayoutToast(title, message, type, id, remainingMs) {
            if (!message) {
                return;
            }

            const container = document.getElementById('layout-toast-container');
            const isError = type === 'error' || type === 'danger' || type === 'failed';
            const toast = document.createElement('div');
            const colorClasses = isError
                ? 'border-red-300 bg-red-100 text-red-900'
                : 'border-green-300 bg-green-100 text-green-900';
            const iconColor = isError ? 'text-red-700' : 'text-green-700';

            toast.className = `${colorClasses} pointer-events-auto flex translate-x-5 gap-3 rounded border-l-4 px-4 py-4 opacity-0 shadow-xl transition-all duration-300`;
            toast.innerHTML = `
                <div class="${iconColor} mt-0.5 flex h-9 w-9 flex-shrink-0 items-center justify-center rounded-full bg-white/60">
                    ${isError
                        ? '<svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.4" d="M6 18L18 6M6 6l12 12"></path></svg>'
                        : '<svg class="h-7 w-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.4" d="M5 13l4 4L19 7"></path></svg>'}
                </div>
                <div class="min-w-0 flex-1">
                    <div class="text-base font-bold leading-5">${title || (isError ? 'Thất bại' : 'Thành công')}</div>
                    <div class="mt-1 text-sm font-medium leading-5">${message}</div>
                </div>
                <button type="button" class="${iconColor} -mr-1 -mt-1 flex h-8 w-8 flex-shrink-0 items-center justify-center rounded hover:bg-white/60" aria-label="Đóng thông báo">
                    <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.2" d="M6 18L18 6M6 6l12 12"></path></svg>
                </button>
            `;

            const closeToast = () => {
                toast.classList.add('translate-x-5', 'opacity-0');
                if (id) {
                    removeStoredLayoutToast(id);
                }
                setTimeout(() => toast.remove(), 300);
            };

            toast.querySelector('button')?.addEventListener('click', closeToast);
            container.appendChild(toast);

            requestAnimationFrame(() => {
                toast.classList.remove('translate-x-5', 'opacity-0');
            });

            setTimeout(closeToast, Math.max(1200, remainingMs ?? 4500));
        }

        pushStoredLayoutToast(
            @Html.Raw(System.Text.Json.JsonSerializer.Serialize(TempData["ToastTitle"] as string)),
            @Html.Raw(System.Text.Json.JsonSerializer.Serialize(TempData["ToastMessage"] as string)),
            @Html.Raw(System.Text.Json.JsonSerializer.Serialize(TempData["ToastType"] as string))
        );

        getStoredLayoutToasts().forEach(toast => {
            showLayoutToast(
                toast.title,
                toast.message,
                toast.type,
                toast.id,
                toast.expiresAt - Date.now()
            );
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
