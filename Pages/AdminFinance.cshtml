@page
@model EduBridge.Pages.AdminFinanceModel
@{
    ViewData["Title"] = "Quản lý tài chính";
    Layout = "_AdminLayout";
    ViewData["ActivePage"] = "AdminFinance";
    var centerId = Model.CenterId;
    
    var selectedClassText = "Lớp học";
    if (Model.ClassId.HasValue && Model.Classes != null)
    {
        var classItem = Model.Classes.FirstOrDefault(x => x.Value == Model.ClassId.Value.ToString());
        if (classItem != null) selectedClassText = classItem.Text;
    }
    
    var selectedStatusText = Model.Status switch
    {
        "Unpaid" => "Chưa thanh toán",
        "Partial" => "Thanh toán 1 phần",
        "Paid" => "Đã thanh toán đủ",
        "Cancelled" => "Đã hủy",
        _ => "Trạng thái"
    };
}
<div class="space-y-6 pb-20">
    <!-- Header -->
    <div class="flex justify-between items-start">
        <div>
            <h1 class="text-3xl font-bold text-gray-900">Quản lý tài chính</h1>
            <p class="text-gray-500 mt-1">Theo dõi doanh thu, công nợ và đóng tiền học của học sinh</p>
        </div>
    </div>

    @if (Model.Summary != null)
    {
    <!-- Stat Cards Grid -->
    <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-4">
        <!-- Total Revenue -->
        <div class="rounded-2xl border border-gray-200 bg-white shadow-sm p-6">
            <div class="flex flex-row items-center justify-between pb-4">
                <h3 class="text-sm font-medium text-gray-600">Tổng doanh thu dự kiến</h3>
                <div class="bg-purple-50 p-2.5 rounded-xl text-purple-500">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                </div>
            </div>
            <div class="text-2xl font-bold text-gray-900">@((Model.Summary.TotalRevenue + Model.Summary.TotalDebt).ToString("N0")) đ</div>
            <p class="text-xs text-green-500 font-medium mt-2">Tháng này</p>
        </div>

        <!-- Collected -->
        <div class="rounded-2xl border border-gray-200 bg-white shadow-sm p-6">
            <div class="flex flex-row items-center justify-between pb-4">
                <h3 class="text-sm font-medium text-gray-600">Thực thu (Đã đóng)</h3>
                <div class="bg-green-50 p-2.5 rounded-xl text-green-500">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                </div>
            </div>
            <div class="text-2xl font-bold text-gray-900">@(Model.Summary.TotalRevenue.ToString("N0")) đ</div>
            <p class="text-xs text-gray-500 font-medium mt-2">Đã thu thành công</p>
        </div>

        <!-- Uncollected -->
        <div class="rounded-2xl border border-gray-200 bg-white shadow-sm p-6">
            <div class="flex flex-row items-center justify-between pb-4">
                <h3 class="text-sm font-medium text-gray-600">Còn lại (Công nợ)</h3>
                <div class="bg-orange-50 p-2.5 rounded-xl text-orange-500">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path></svg>
                </div>
            </div>
            <div class="text-2xl font-bold text-gray-900">@(Model.Summary.TotalDebt.ToString("N0")) đ</div>
            <p class="text-xs text-orange-500 font-medium mt-2">Chưa thu</p>
        </div>

        <!-- Debt Count -->
        <div class="rounded-2xl border border-gray-200 bg-white shadow-sm p-6">
            <div class="flex flex-row items-center justify-between pb-4">
                <h3 class="text-sm font-medium text-gray-600">Học sinh nợ phí</h3>
                <div class="bg-red-50 p-2.5 rounded-xl text-red-500">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"></path></svg>
                </div>
            </div>
            <div class="text-2xl font-bold text-gray-900">@(Model.ClassDebts.Sum(c => c.UnpaidStudentsCount)) học sinh</div>
            <p class="text-xs text-red-500 font-medium mt-2">Cần nhắc nhở</p>
        </div>
    </div>
    }

    <!-- Main Section -->
    <div class="mb-6 rounded-2xl bg-white shadow-sm ring-1 ring-gray-900/5">
        <div class="border-b border-gray-100 bg-white p-6 rounded-t-2xl">
            <h3 class="text-base font-bold text-gray-900">Danh sách hóa đơn</h3>
            <p class="mt-1 text-sm text-gray-500">Quản lý các khoản thu của học sinh</p>

            <form method="get" class="mt-5 space-y-4">
                <input type="hidden" name="PageNumber" value="1" />
                <input type="hidden" name="PageSize" value="@Model.PageSize" />
                <div class="grid gap-4 lg:grid-cols-4">
                    <input type="text" name="InvoiceCode" value="@Model.InvoiceCode" maxlength="50" class="block h-12 w-full rounded border border-gray-300 bg-white px-4 text-sm text-gray-900 placeholder-gray-500 focus:border-blue-500 focus:outline-none focus:ring-1 focus:ring-blue-500" placeholder="Mã hóa đơn">
                    <input type="text" name="StudentName" value="@Model.StudentName" maxlength="150" class="block h-12 w-full rounded border border-gray-300 bg-white px-4 text-sm text-gray-900 placeholder-gray-500 focus:border-blue-500 focus:outline-none focus:ring-1 focus:ring-blue-500" placeholder="Tên/mã học sinh">
                    <div class="relative w-full" data-search-dropdown>
                        <input type="hidden" name="ClassId" value="@Model.ClassId" data-filter-value="finance-class" />
                        <button type="button" data-dropdown-toggle class="flex h-12 w-full items-center justify-between rounded border border-gray-300 bg-white px-4 text-left text-sm text-gray-600 focus:border-blue-500 focus:outline-none focus:ring-1 focus:ring-blue-500">
                            <span data-dropdown-label>@selectedClassText</span>
                            <svg class="h-4 w-4 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
                        </button>
                        <div data-dropdown-panel class="absolute left-0 top-[calc(100%+4px)] z-40 hidden max-h-72 w-full overflow-y-auto rounded border border-gray-300 bg-white shadow-lg">
                            <div class="relative p-2 sticky top-0 bg-white z-10 border-b border-gray-100">
                                <input type="text" data-dropdown-search class="h-11 w-full rounded border border-blue-400 px-3 pr-9 text-sm focus:outline-none focus:ring-1 focus:ring-blue-500">
                                <svg class="absolute right-5 top-5 h-4 w-4 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
                            </div>
                            <button type="button" data-dropdown-option data-value="" data-label="Lớp học" class="block w-full px-4 py-2 text-left text-sm hover:bg-blue-50">Tất cả lớp học</button>
                            @if (Model.Classes != null)
                            {
                                foreach (var cls in Model.Classes)
                                {
                                    <button type="button" data-dropdown-option data-value="@cls.Value" data-label="@cls.Text" class="block w-full px-4 py-2 text-left text-sm hover:bg-blue-50">@cls.Text</button>
                                }
                            }
                        </div>
                    </div>
                    <div class="relative w-full" data-search-dropdown>
                        <input type="hidden" name="Status" value="@Model.Status" data-filter-value="finance-status" />
                        <button type="button" data-dropdown-toggle class="flex h-12 w-full items-center justify-between rounded border border-gray-300 bg-white px-4 text-left text-sm text-gray-600 focus:border-blue-500 focus:outline-none focus:ring-1 focus:ring-blue-500">
                            <span data-dropdown-label>@selectedStatusText</span>
                            <svg class="h-4 w-4 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
                        </button>
                        <div data-dropdown-panel class="absolute left-0 top-[calc(100%+4px)] z-40 hidden w-full rounded border border-gray-300 bg-white shadow-lg">
                            <div class="relative p-2 sticky top-0 bg-white z-10 border-b border-gray-100">
                                <input type="text" data-dropdown-search class="h-11 w-full rounded border border-blue-400 px-3 pr-9 text-sm focus:outline-none focus:ring-1 focus:ring-blue-500">
                                <svg class="absolute right-5 top-5 h-4 w-4 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
                            </div>
                            <button type="button" data-dropdown-option data-value="" data-label="Trạng thái" class="block w-full px-4 py-2 text-left text-sm hover:bg-blue-50">Tất cả trạng thái</button>
                            <button type="button" data-dropdown-option data-value="Unpaid" data-label="Chưa thanh toán" class="block w-full px-4 py-2 text-left text-sm hover:bg-blue-50">Chưa thanh toán</button>
                            <button type="button" data-dropdown-option data-value="Partial" data-label="Thanh toán 1 phần" class="block w-full px-4 py-2 text-left text-sm hover:bg-blue-50">Thanh toán 1 phần</button>
                            <button type="button" data-dropdown-option data-value="Paid" data-label="Đã thanh toán đủ" class="block w-full px-4 py-2 text-left text-sm hover:bg-blue-50">Đã thanh toán đủ</button>
                            <button type="button" data-dropdown-option data-value="Cancelled" data-label="Đã hủy" class="block w-full px-4 py-2 text-left text-sm hover:bg-blue-50">Đã hủy</button>
                        </div>
                    </div>
                </div>

                <div class="grid gap-4 lg:grid-cols-4">
                    <div class="relative min-w-0">
                        <input asp-for="DateFrom" type="hidden" data-date-hidden="finance-date-from">
                        <input type="text" data-date-display="finance-date-from" value="@Model.DateFrom?.ToString("dd/MM/yyyy")" autocomplete="off" class="block h-12 w-full rounded border border-gray-300 bg-white px-4 pr-12 text-sm text-gray-900 placeholder-gray-500 focus:border-blue-500 focus:outline-none focus:ring-1 focus:ring-blue-500" placeholder="Từ ngày">
                        <button type="button" data-date-toggle="finance-date-from" class="absolute right-0 top-0 flex h-12 w-12 items-center justify-center rounded-r bg-sky-600 text-white hover:bg-sky-700 transition-colors">
                            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3M4 11h16M5 5h14a1 1 0 011 1v14a1 1 0 01-1 1H5a1 1 0 01-1-1V6a1 1 0 011-1z"></path></svg>
                        </button>
                    </div>
                    <div class="relative min-w-0">
                        <input asp-for="DateTo" type="hidden" data-date-hidden="finance-date-to">
                        <input type="text" data-date-display="finance-date-to" value="@Model.DateTo?.ToString("dd/MM/yyyy")" autocomplete="off" class="block h-12 w-full rounded border border-gray-300 bg-white px-4 pr-12 text-sm text-gray-900 placeholder-gray-500 focus:border-blue-500 focus:outline-none focus:ring-1 focus:ring-blue-500" placeholder="Đến ngày">
                        <button type="button" data-date-toggle="finance-date-to" class="absolute right-0 top-0 flex h-12 w-12 items-center justify-center rounded-r bg-sky-600 text-white hover:bg-sky-700 transition-colors">
                            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3M4 11h16M5 5h14a1 1 0 011 1v14a1 1 0 01-1 1H5a1 1 0 01-1-1V6a1 1 0 011-1z"></path></svg>
                        </button>
                    </div>
                    <div class="hidden lg:block"></div>
                    <div class="flex flex-wrap justify-end gap-3">
                        <a asp-page="/AdminFinance" class="inline-flex h-12 min-w-32 items-center justify-center rounded bg-slate-600 px-4 text-sm font-semibold text-white shadow-sm transition-colors hover:bg-slate-700">Làm mới bộ lọc</a>
                        <button type="submit" class="inline-flex h-12 min-w-32 items-center justify-center rounded bg-blue-600 px-4 text-sm font-semibold text-white shadow-sm transition-colors hover:bg-blue-700">
                            <svg class="mr-2 h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
                            Tìm kiếm
                        </button>
                    </div>
                </div>
            </form>
        </div>

        <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="whitespace-nowrap bg-slate-100 border-b border-slate-200 text-sm font-bold text-slate-800">
                        <th class="py-4 px-4 text-center border-r border-slate-200">STT</th>
                        <th class="py-4 px-4 text-center border-r border-slate-200">ID</th>
                        <th class="py-4 px-6 text-center border-r border-slate-200">Mã HĐ</th>
                        <th class="py-4 px-6 text-center border-r border-slate-200">Học sinh</th>
                        <th class="py-4 px-6 text-center border-r border-slate-200">Lớp học</th>
                        <th class="py-4 px-6 text-right border-r border-slate-200">Số tiền</th>
                        <th class="py-4 px-6 text-right border-r border-slate-200">Đã thanh toán</th>
                        <th class="py-4 px-6 text-right border-r border-slate-200">Còn nợ</th>
                        <th class="py-4 px-6 text-center border-r border-slate-200">Trạng thái</th>
                        <th class="py-4 px-6 text-center border-r border-slate-200">Thời gian</th>
                        <th class="py-4 px-6 text-center">Thao tác</th>
                    </tr>
                </thead>
                <tbody class="text-sm divide-y divide-gray-100">
                    @if (Model.Invoices?.Items != null && Model.Invoices.Items.Any())
                    {
                        var stt = (Model.PageNumber - 1) * Model.PageSize;
                        foreach (var inv in Model.Invoices.Items)
                        {
                            stt++;
                            <tr class="group hover:bg-slate-100 transition-colors">
                                <td class="py-5 px-4 text-center text-gray-700 border-r border-gray-200">@stt</td>
                                <td class="py-5 px-4 text-center text-gray-900 border-r border-gray-200">@inv.InvoiceId</td>
                                <td class="py-5 px-6 border-r border-gray-200">
                                    <div class="font-semibold text-gray-900">@inv.InvoiceCode</div>
                                </td>
                                <td class="py-5 px-6 border-r border-gray-200">
                                    <div class="font-semibold text-gray-900">@inv.StudentName</div>
                                    <div class="text-xs text-gray-500 mt-0.5">@inv.StudentCode</div>
                                </td>
                                <td class="py-5 px-6 border-r border-gray-200">
                                    <div class="font-medium text-gray-700">@inv.ClassName</div>
                                </td>
                                <td class="py-5 px-6 font-semibold text-gray-900 text-right border-r border-gray-200">@inv.FinalAmount.ToString("N0")</td>
                                <td class="py-5 px-6 font-semibold text-green-600 text-right border-r border-gray-200">@inv.PaidAmount.ToString("N0")</td>
                                <td class="py-5 px-6 font-semibold text-red-600 text-right border-r border-gray-200">@inv.RemainingAmount.ToString("N0")</td>
                                <td class="py-5 px-6 text-center border-r border-gray-200">
                                    @if (inv.Status == "Paid")
                                    {
                                        <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-semibold bg-gray-900 text-white">Đã đóng đủ</span>
                                    }
                                    else if (inv.Status == "Partial")
                                    {
                                        <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-semibold bg-blue-100 text-blue-700">Đóng một phần</span>
                                    }
                                    else if (inv.Status == "Unpaid")
                                    {
                                        <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-semibold bg-orange-100 text-orange-700">Chưa đóng</span>
                                    }
                                    else if (inv.Status == "Cancelled")
                                    {
                                        <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-semibold bg-red-100 text-red-700">Đã hủy</span>
                                    }
                                </td>
                                <td class="py-5 px-6 border-r border-gray-200">
                                    <div class="text-gray-900">Ngày tạo: @inv.CreatedAt.ToString("dd/MM/yyyy")</div>
                                    <div class="text-xs text-gray-500 mt-0.5">Hạn đóng: @(inv.DueDate?.ToString("dd/MM/yyyy") ?? "-")</div>
                                </td>
                                <td class="py-5 px-6 text-center border-r border-gray-200">
                                    @if (inv.Status == "Unpaid" || inv.Status == "Partial")
                                    {
                                        <button type="button" 
                                                data-id="@inv.InvoiceId" 
                                                data-amount="@inv.RemainingAmount.ToString(System.Globalization.CultureInfo.InvariantCulture)" 
                                                data-student="@inv.StudentName"
                                                onclick="openPaymentModal(this)" 
                                                class="inline-flex h-9 items-center rounded border border-blue-500 bg-blue-50 px-3 text-xs font-bold text-blue-600 transition-colors hover:bg-blue-100">
                                            <svg class="w-3.5 h-3.5 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                                            Thu tiền
                                        </button>
                                    }
                                    else if (inv.Status == "Paid" || inv.Status == "Partial")
                                    {
                                        if (inv.LatestReceiptId.HasValue)
                                        {
                                            <a href="/AdminReceiptsPrint/@inv.LatestReceiptId.Value" target="_blank"
                                                    class="inline-flex h-9 items-center rounded border border-gray-300 bg-gray-100 px-3 text-xs font-bold text-gray-700 transition-colors hover:bg-gray-200">
                                                <svg class="w-3.5 h-3.5 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 17h2a2 2 0 002-2v-4a2 2 0 00-2-2H5a2 2 0 00-2 2v4a2 2 0 002 2h2m2 4h6a2 2 0 002-2v-4a2 2 0 00-2-2H9a2 2 0 00-2 2v4a2 2 0 002 2zm8-12V5a2 2 0 00-2-2H9a2 2 0 00-2 2v4h10z"></path></svg>
                                                Biên lai
                                            </a>
                                        }
                                        else
                                        {
                                            <button type="button" 
                                                    onclick="showToast('Chưa có biên lai cho hóa đơn này.', true)" 
                                                    class="inline-flex h-9 items-center rounded border border-gray-300 bg-gray-100 px-3 text-xs font-bold text-gray-400 cursor-not-allowed">
                                                <svg class="w-3.5 h-3.5 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 17h2a2 2 0 002-2v-4a2 2 0 00-2-2H5a2 2 0 00-2 2v4a2 2 0 002 2h2m2 4h6a2 2 0 002-2v-4a2 2 0 00-2-2H9a2 2 0 00-2 2v4a2 2 0 002 2zm8-12V5a2 2 0 00-2-2H9a2 2 0 00-2 2v4h10z"></path></svg>
                                                Biên lai
                                            </button>
                                        }
                                    }
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="11" class="py-10 text-center text-gray-500">
                                Không có hóa đơn nào.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @if (Model.Invoices != null)
        {
            <div class="flex flex-wrap items-center justify-center gap-6 border-t border-gray-200 bg-white px-6 py-4 text-sm text-gray-600">
                <div class="flex items-center gap-1">
                    <a asp-page="/AdminFinance" asp-route-invoiceCode="@Model.InvoiceCode" asp-route-studentName="@Model.StudentName" asp-route-classId="@Model.ClassId" asp-route-status="@Model.Status" asp-route-dateFrom="@Model.DateFrom?.ToString("yyyy-MM-dd")" asp-route-dateTo="@Model.DateTo?.ToString("yyyy-MM-dd")" asp-route-pageNumber="1" asp-route-pageSize="@Model.Invoices.PageSize" class="inline-flex h-9 w-9 items-center justify-center rounded text-gray-500 transition-colors hover:bg-blue-50 hover:text-blue-600 @(Model.Invoices.PageNumber <= 1 ? "pointer-events-none opacity-40" : "")" title="Trang đầu">&laquo;</a>
                    <a asp-page="/AdminFinance" asp-route-invoiceCode="@Model.InvoiceCode" asp-route-studentName="@Model.StudentName" asp-route-classId="@Model.ClassId" asp-route-status="@Model.Status" asp-route-dateFrom="@Model.DateFrom?.ToString("yyyy-MM-dd")" asp-route-dateTo="@Model.DateTo?.ToString("yyyy-MM-dd")" asp-route-pageNumber="@(Model.Invoices.PageNumber - 1)" asp-route-pageSize="@Model.Invoices.PageSize" class="inline-flex h-9 w-9 items-center justify-center rounded text-gray-500 transition-colors hover:bg-blue-50 hover:text-blue-600 @(Model.Invoices.PageNumber <= 1 ? "pointer-events-none opacity-40" : "")" title="Trang trước">&lsaquo;</a>
                    @{
                        var startPage = Math.Max(1, Model.Invoices.PageNumber - 2);
                        var endPage = Math.Min(Model.Invoices.TotalPages, startPage + 4);
                        startPage = Math.Max(1, endPage - 4);
                    }
                    @for (var pageIndex = startPage; pageIndex <= endPage; pageIndex++)
                    {
                        <a asp-page="/AdminFinance" asp-route-invoiceCode="@Model.InvoiceCode" asp-route-studentName="@Model.StudentName" asp-route-classId="@Model.ClassId" asp-route-status="@Model.Status" asp-route-dateFrom="@Model.DateFrom?.ToString("yyyy-MM-dd")" asp-route-dateTo="@Model.DateTo?.ToString("yyyy-MM-dd")" asp-route-pageNumber="@pageIndex" asp-route-pageSize="@Model.Invoices.PageSize" class="inline-flex h-9 min-w-9 items-center justify-center rounded px-3 font-medium transition-colors @(pageIndex == Model.Invoices.PageNumber ? "bg-blue-100 text-blue-700" : "text-gray-600 hover:bg-blue-50 hover:text-blue-600")">@pageIndex</a>
                    }
                    <a asp-page="/AdminFinance" asp-route-invoiceCode="@Model.InvoiceCode" asp-route-studentName="@Model.StudentName" asp-route-classId="@Model.ClassId" asp-route-status="@Model.Status" asp-route-dateFrom="@Model.DateFrom?.ToString("yyyy-MM-dd")" asp-route-dateTo="@Model.DateTo?.ToString("yyyy-MM-dd")" asp-route-pageNumber="@(Model.Invoices.PageNumber + 1)" asp-route-pageSize="@Model.Invoices.PageSize" class="inline-flex h-9 w-9 items-center justify-center rounded text-gray-500 transition-colors hover:bg-blue-50 hover:text-blue-600 @(Model.Invoices.PageNumber >= Model.Invoices.TotalPages ? "pointer-events-none opacity-40" : "")" title="Trang sau">&rsaquo;</a>
                    <a asp-page="/AdminFinance" asp-route-invoiceCode="@Model.InvoiceCode" asp-route-studentName="@Model.StudentName" asp-route-classId="@Model.ClassId" asp-route-status="@Model.Status" asp-route-dateFrom="@Model.DateFrom?.ToString("yyyy-MM-dd")" asp-route-dateTo="@Model.DateTo?.ToString("yyyy-MM-dd")" asp-route-pageNumber="@Model.Invoices.TotalPages" asp-route-pageSize="@Model.Invoices.PageSize" class="inline-flex h-9 w-9 items-center justify-center rounded text-gray-500 transition-colors hover:bg-blue-50 hover:text-blue-600 @(Model.Invoices.PageNumber >= Model.Invoices.TotalPages ? "pointer-events-none opacity-40" : "")" title="Trang cuối">&raquo;</a>
                </div>

                <div class="flex items-center gap-4">
                    <span>Tổng số: @Model.Invoices.TotalItems bản ghi</span>
                    <form method="get" class="flex items-center">
                        <input type="hidden" name="InvoiceCode" value="@Model.InvoiceCode" />
                        <input type="hidden" name="StudentName" value="@Model.StudentName" />
                        <input type="hidden" name="ClassId" value="@Model.ClassId" />
                        <input type="hidden" name="Status" value="@Model.Status" />
                        <input type="hidden" name="DateFrom" value="@Model.DateFrom?.ToString("yyyy-MM-dd")" />
                        <input type="hidden" name="DateTo" value="@Model.DateTo?.ToString("yyyy-MM-dd")" />
                        <input type="hidden" name="PageNumber" value="1" />
                        <select name="PageSize" onchange="this.form.submit()" class="h-10 rounded border border-blue-400 bg-white px-3 text-sm text-gray-700 shadow-sm focus:border-blue-500 focus:outline-none focus:ring-2 focus:ring-blue-100">
                            @foreach (var option in Model.PageSizeOptions)
                            {
                                <option value="@option" selected="@(Model.Invoices.PageSize == option)">@option</option>
                            }
                        </select>
                    </form>
                </div>
            </div>
        }
    </div>
</div>

<!-- Payment Modal (Real API) -->
<div id="paymentModal" class="hidden fixed inset-0 z-50 overflow-y-auto bg-black bg-opacity-40 backdrop-blur-sm flex justify-center items-center p-4">
    <div class="bg-white rounded-2xl max-w-md w-full shadow-2xl p-6 relative transform transition-all duration-300 scale-95 opacity-0" id="paymentModalBody">
        <button onclick="closePaymentModal()" class="absolute top-4 right-4 text-gray-400 hover:text-gray-600 focus:outline-none">
            <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
        </button>
        <div class="text-center pb-4 border-b border-gray-100">
            <div class="text-gray-900 font-bold text-xl">Thu học phí</div>
            <div class="text-sm text-gray-500 font-medium mt-1" id="payStudentName"></div>
        </div>
        <div class="py-6 space-y-4 text-sm text-gray-700">
            <input type="hidden" id="payInvoiceId" />

            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Số tiền (VNĐ)</label>
                <input type="number" id="payAmount" class="w-full px-3 py-2 border border-gray-200 rounded-xl focus:ring-1 focus:ring-blue-500 focus:outline-none bg-gray-50" />
            </div>

            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Phương thức thanh toán</label>
                <select id="payMethod" class="w-full px-3 py-2 border border-gray-200 rounded-xl focus:ring-1 focus:ring-blue-500 focus:outline-none bg-gray-50">
                    <option value="CASH">Tiền mặt</option>
                    <option value="BANK_TRANSFER">Chuyển khoản</option>
                </select>
            </div>

            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Mã giao dịch (Nếu CK)</label>
                <input type="text" id="payRef" class="w-full px-3 py-2 border border-gray-200 rounded-xl focus:ring-1 focus:ring-blue-500 focus:outline-none bg-gray-50" placeholder="VD: MBBANK123" />
            </div>
        </div>
        <div class="flex gap-3 pt-2">
            <button onclick="closePaymentModal()" class="w-1/2 py-2.5 border border-gray-200 hover:bg-gray-50 text-gray-700 font-bold rounded-xl text-sm transition-colors">Hủy</button>
            <button onclick="submitPayment()" id="btnSubmitPayment" class="w-1/2 py-2.5 bg-blue-600 hover:bg-blue-700 text-white font-bold rounded-xl text-sm transition-colors shadow-md">Xác nhận thu</button>
        </div>
    </div>
</div>



<!-- Toast Alert -->
<div id="toast" class="fixed top-5 right-5 z-50 bg-green-500 text-white font-bold px-4 py-3 rounded-xl shadow-lg transform translate-y-[-100px] opacity-0 transition-all duration-300 pointer-events-none flex items-center gap-2">
    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
    <span id="toastMsg">Thao tác thành công!</span>
</div>

@section Scripts {
    <script>
        const centerId = @centerId;

        function showToast(msg, isError = false) {
            const toast = document.getElementById('toast');
            document.getElementById('toastMsg').textContent = msg;

            if (isError) {
                toast.classList.replace('bg-green-500', 'bg-red-500');
            } else {
                toast.classList.replace('bg-red-500', 'bg-green-500');
            }

            toast.classList.remove('translate-y-[-100px]', 'opacity-0');
            toast.classList.add('translate-y-0', 'opacity-100');

            setTimeout(() => {
                toast.classList.remove('translate-y-0', 'opacity-100');
                toast.classList.add('translate-y-[-100px]', 'opacity-0');
            }, 4000);
        }

        // Payment Modal Logic
        function openPaymentModal(btn) {
            const invoiceId = btn.getAttribute('data-id');
            const remainingAmount = btn.getAttribute('data-amount');
            const studentName = btn.getAttribute('data-student');

            document.getElementById('payInvoiceId').value = invoiceId;
            document.getElementById('payAmount').value = remainingAmount;
            document.getElementById('payStudentName').textContent = "Học sinh: " + studentName;
            document.getElementById('payRef').value = "";
            document.getElementById('payMethod').value = "CASH";

            const modal = document.getElementById('paymentModal');
            const body = document.getElementById('paymentModalBody');
            modal.classList.remove('hidden');
            setTimeout(() => {
                body.classList.remove('scale-95', 'opacity-0');
                body.classList.add('scale-100', 'opacity-100');
            }, 50);
        }

        function closePaymentModal() {
            const modal = document.getElementById('paymentModal');
            const body = document.getElementById('paymentModalBody');
            body.classList.remove('scale-100', 'opacity-100');
            body.classList.add('scale-95', 'opacity-0');
            setTimeout(() => {
                modal.classList.add('hidden');
            }, 300);
        }

        async function submitPayment() {
            const invoiceId = document.getElementById('payInvoiceId').value;
            const amount = document.getElementById('payAmount').value;
            const method = document.getElementById('payMethod').value;
            const reference = document.getElementById('payRef').value;
            const btn = document.getElementById('btnSubmitPayment');

            if (!amount || amount <= 0) {
                showToast("Số tiền không hợp lệ", true);
                return;
            }

            btn.disabled = true;
            btn.textContent = "Đang xử lý...";

            try {
                const response = await fetch(`/api/v1/owner/payments?centerId=${centerId}`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        invoiceId: parseInt(invoiceId),
                        amount: parseFloat(amount),
                        paymentMethod: method,
                        transactionReference: reference || null
                    })
                });

                const data = await response.json();
                if (data.success) {
                    closePaymentModal();
                    showToast("Thu tiền thành công!");
                    setTimeout(() => window.location.reload(), 1000);
                } else {
                    showToast(data.message || "Có lỗi xảy ra", true);
                    btn.disabled = false;
                    btn.textContent = "Xác nhận thu";
                }
            } catch (error) {
                showToast("Lỗi kết nối", true);
                btn.disabled = false;
                btn.textContent = "Xác nhận thu";
            }
        }

        document.querySelectorAll('[data-search-dropdown]').forEach(dropdown => {
            const container = dropdown.parentElement;
            const hiddenInput = container.querySelector('[data-filter-value]') || dropdown.querySelector('[data-filter-value]');
            const toggle = dropdown.querySelector('[data-dropdown-toggle]');
            const panel = dropdown.querySelector('[data-dropdown-panel]');
            const label = dropdown.querySelector('[data-dropdown-label]');
            const searchInput = dropdown.querySelector('[data-dropdown-search]');
            const options = Array.from(dropdown.querySelectorAll('[data-dropdown-option]'));

            function close() {
                panel.classList.add('hidden');
            }

            function open() {
                document.querySelectorAll('[data-dropdown-panel]').forEach(item => item.classList.add('hidden'));
                panel.classList.remove('hidden');
                searchInput.value = '';
                filterOptions('');
                searchInput.focus();
            }

            function filterOptions(keyword) {
                const normalizedKeyword = keyword.trim().toLowerCase();

                options.forEach(option => {
                    const text = option.textContent.trim().toLowerCase();
                    const labelText = (option.dataset.label || '').toLowerCase();
                    const visible = !normalizedKeyword ||
                        text.includes(normalizedKeyword) ||
                        labelText.includes(normalizedKeyword);

                    option.classList.toggle('hidden', !visible);
                });
            }

            toggle.addEventListener('click', event => {
                event.stopPropagation();

                if (panel.classList.contains('hidden')) {
                    open();
                } else {
                    close();
                }
            });

            searchInput.addEventListener('input', () => filterOptions(searchInput.value));
            searchInput.addEventListener('click', event => event.stopPropagation());

            options.forEach(option => {
                option.addEventListener('click', () => {
                    hiddenInput.value = option.dataset.value || '';
                    label.textContent = option.dataset.label || option.textContent.trim();
                    close();
                });
            });

            document.addEventListener('click', event => {
                if (!dropdown.contains(event.target)) {
                    close();
                }
            });
        });

    </script>
}
