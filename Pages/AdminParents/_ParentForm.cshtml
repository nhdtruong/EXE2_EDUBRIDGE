@model EduBridge.Contracts.Parents.SaveParentRequest
<section class="border border-gray-200">
    <div class="border-b border-gray-200 px-4 py-3"><h2 class="text-sm font-bold">Thông tin tài khoản phụ huynh</h2></div>
    <div class="grid gap-5 p-5 lg:grid-cols-2">
        <div><label asp-for="FullName" class="block text-sm font-semibold">Họ và tên (*)</label><input asp-for="FullName" class="mt-1 h-11 w-full border border-gray-300 px-3"><span asp-validation-for="FullName" class="text-xs text-red-600"></span></div>
        <div><label asp-for="PhoneNumber" class="block text-sm font-semibold">Số điện thoại (*)</label><input asp-for="PhoneNumber" inputmode="numeric" class="mt-1 h-11 w-full border border-gray-300 px-3"><span asp-validation-for="PhoneNumber" class="text-xs text-red-600"></span></div>
        <div><label asp-for="Email" class="block text-sm font-semibold">Email</label><input asp-for="Email" class="mt-1 h-11 w-full border border-gray-300 px-3"><span asp-validation-for="Email" class="text-xs text-red-600"></span></div>
        <div>
            <label asp-for="DateOfBirth" class="block text-sm font-semibold">Ngày sinh</label>
            <div class="relative mt-1">
                <input asp-for="DateOfBirth" type="hidden" data-date-hidden="parent-date-of-birth">
                <input type="text" data-date-display="parent-date-of-birth" value="@Model.DateOfBirth?.ToString("dd/MM/yyyy")" autocomplete="off" class="h-11 w-full border border-gray-300 px-3 pr-12" placeholder="dd/mm/yyyy">
                <button type="button" data-date-toggle="parent-date-of-birth" class="absolute right-0 top-0 flex h-11 w-11 items-center justify-center bg-sky-600 text-white"><svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2"></rect><path d="M16 2v4M8 2v4M3 10h18"></path></svg></button>
            </div>
            <span asp-validation-for="DateOfBirth" class="text-xs text-red-600"></span>
        </div>
        <div><label class="block text-sm font-semibold">Giới tính</label><div class="mt-3 flex gap-8"><label><input asp-for="Gender" type="radio" value="Nam"> Nam</label><label><input asp-for="Gender" type="radio" value="Nữ"> Nữ</label></div></div>
        
        <div><label asp-for="Ethnicity" class="block text-sm font-semibold">Dân tộc</label><input asp-for="Ethnicity" class="mt-1 h-11 w-full border border-gray-300 px-3"><span asp-validation-for="Ethnicity" class="text-xs text-red-600"></span></div>
        <div><label asp-for="Religion" class="block text-sm font-semibold">Tôn giáo</label><input asp-for="Religion" class="mt-1 h-11 w-full border border-gray-300 px-3"><span asp-validation-for="Religion" class="text-xs text-red-600"></span></div>
        
        <div><label asp-for="IdentityNumber" class="block text-sm font-semibold">Số CMND/CCCD</label><input asp-for="IdentityNumber" inputmode="numeric" class="mt-1 h-11 w-full border border-gray-300 px-3"><span asp-validation-for="IdentityNumber" class="text-xs text-red-600"></span></div>
        <div>
            <label asp-for="IdentityIssuedDate" class="block text-sm font-semibold">Ngày cấp</label>
            <div class="relative mt-1">
                <input asp-for="IdentityIssuedDate" type="hidden" data-date-hidden="parent-identity-date">
                <input type="text" data-date-display="parent-identity-date" value="@Model.IdentityIssuedDate?.ToString("dd/MM/yyyy")" autocomplete="off" class="h-11 w-full border border-gray-300 px-3 pr-12" placeholder="dd/mm/yyyy">
                <button type="button" data-date-toggle="parent-identity-date" class="absolute right-0 top-0 flex h-11 w-11 items-center justify-center bg-sky-600 text-white"><svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2"></rect><path d="M16 2v4M8 2v4M3 10h18"></path></svg></button>
            </div>
            <span asp-validation-for="IdentityIssuedDate" class="text-xs text-red-600"></span>
        </div>
        <div><label asp-for="IdentityIssuedPlace" class="block text-sm font-semibold">Nơi cấp</label><input asp-for="IdentityIssuedPlace" class="mt-1 h-11 w-full border border-gray-300 px-3"><span asp-validation-for="IdentityIssuedPlace" class="text-xs text-red-600"></span></div>

        <div><label asp-for="CurrentAddress" class="block text-sm font-semibold">Địa chỉ hiện tại</label><input asp-for="CurrentAddress" class="mt-1 h-11 w-full border border-gray-300 px-3"><span asp-validation-for="CurrentAddress" class="text-xs text-red-600"></span></div>
        <div><label asp-for="PermanentAddress" class="block text-sm font-semibold">Địa chỉ thường trú</label><input asp-for="PermanentAddress" class="mt-1 h-11 w-full border border-gray-300 px-3"><span asp-validation-for="PermanentAddress" class="text-xs text-red-600"></span></div>
        <div><label asp-for="Hometown" class="block text-sm font-semibold">Nguyên quán</label><input asp-for="Hometown" class="mt-1 h-11 w-full border border-gray-300 px-3"><span asp-validation-for="Hometown" class="text-xs text-red-600"></span></div>
        <div><label asp-for="PlaceOfBirth" class="block text-sm font-semibold">Nơi sinh</label><input asp-for="PlaceOfBirth" class="mt-1 h-11 w-full border border-gray-300 px-3"><span asp-validation-for="PlaceOfBirth" class="text-xs text-red-600"></span></div>
        <div>
            <label asp-for="Status" class="block text-sm font-semibold">Trạng thái tại trung tâm</label>
            <input asp-for="Status" type="hidden" data-parent-status-value>
            <button type="button" data-parent-status-toggle class="mt-2 inline-flex items-center gap-3 rounded-full border px-3 py-1.5 text-xs font-semibold @(Model.Status == "Inactive" ? "border-gray-200 bg-gray-100 text-gray-600" : "border-green-200 bg-green-50 text-green-700")">
                <span data-parent-status-track class="relative h-6 w-11 rounded-full @(Model.Status == "Inactive" ? "bg-gray-300" : "bg-green-500")">
                    <span data-parent-status-knob class="absolute top-0.5 h-5 w-5 rounded-full bg-white shadow @(Model.Status == "Inactive" ? "left-0.5" : "left-5")"></span>
                </span>
                <span data-parent-status-label>@(Model.Status == "Inactive" ? "Tạm dừng" : "Đang hoạt động")</span>
            </button>
        </div>
    </div>
</section>
