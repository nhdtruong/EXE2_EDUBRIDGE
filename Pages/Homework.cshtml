@page
@model EduBridge.Pages.HomeworkModel
@{
    if (User.IsInRole("PARENT"))
    {
        Layout = "_Layout";
        ViewData["Title"] = "Bài tập của con";
    }
    else
    {
        Layout = "_TeacherLayout";
        ViewData["Title"] = "Quản lý bài tập";
        ViewData["ActivePage"] = "Assignments";
    }
}

@functions {
    public string GetStatusBadgeClass(string status)
    {
        return status switch
        {
            "Graded" => "badge-success",
            "Submitted" => "badge-warning",
            "NotSubmitted" => "badge-danger",
            "Overdue" => "badge-dark",
            _ => "badge-default"
        };
    }

    public string GetStatusText(string status)
    {
        return status switch
        {
            "Graded" => "Đã chấm",
            "Submitted" => "Chờ chấm",
            "NotSubmitted" => "Chưa nộp",
            "Overdue" => "Trễ hạn",
            _ => status
        };
    }
}

@if (User.IsInRole("PARENT"))
{
    <!-- ==========================================
         PARENT INTERFACE (MOBILE-FIRST & PREMIUM)
         ========================================== -->
    <div class="pb-20">
        <!-- Header -->
        <div class="mb-6 bg-gradient-to-r from-blue-600 to-indigo-600 rounded-3xl p-6 text-white shadow-lg">
            <h1 class="text-2xl font-bold mb-1">Bài tập của con</h1>
            <p class="text-sm opacity-90">Theo dõi, tải đề bài PDF và nộp bài làm của các con cho giáo viên.</p>
        </div>

        @if (Model.ParentHomeworkList.Any())
        {
            // Nhóm bài tập theo học sinh
            var groupedHomework = Model.ParentHomeworkList.GroupBy(h => new { h.StudentId, h.StudentName });
            
            <!-- Student Tab Headers if multiple children -->
            @if (groupedHomework.Count() > 1)
            {
                <div class="flex gap-2 overflow-x-auto pb-3 mb-4 no-scrollbar">
                    <button class="student-tab-btn active px-4 py-2 bg-blue-600 text-white rounded-full font-semibold text-sm whitespace-nowrap transition-all shadow-sm" data-student-id="all">
                        Tất cả các con (@Model.ParentHomeworkList.Count)
                    </button>
                    @foreach (var studentGroup in groupedHomework)
                    {
                        <button class="student-tab-btn px-4 py-2 bg-white text-gray-700 border border-gray-200 rounded-full font-medium text-sm whitespace-nowrap transition-all hover:bg-gray-50" data-student-id="@studentGroup.Key.StudentId">
                            @studentGroup.Key.StudentName
                        </button>
                    }
                </div>
            }

            <!-- Homework Cards Grid -->
            <div class="grid gap-4 md:grid-cols-2" id="parentHomeworkGrid">
                @foreach (var hw in Model.ParentHomeworkList)
                {
                    var isOverdue = hw.Status == "Overdue";
                    var isGraded = hw.Status == "Graded";
                    var isSubmitted = hw.Status == "Submitted";
                    var isNotSubmitted = hw.Status == "NotSubmitted";
                    
                    <div class="homework-card bg-white rounded-2xl border border-gray-100 p-5 shadow-sm transition-all hover:shadow-md hover:-translate-y-0.5" data-student-id="@hw.StudentId">
                        <div class="flex justify-between items-start mb-3">
                            <div>
                                <span class="inline-block px-2.5 py-1 rounded-lg bg-blue-50 text-blue-600 font-semibold text-xs mb-2">@hw.ClassName</span>
                                <h3 class="text-lg font-bold text-gray-900 leading-tight">@hw.Title</h3>
                                <p class="text-xs text-gray-500 mt-1">Bài học: @hw.LessonTitle</p>
                            </div>
                            <!-- Status Badge -->
                            <div>
                                @if (isGraded)
                                {
                                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">
                                        <span class="w-1.5 h-1.5 mr-1 bg-green-500 rounded-full"></span>
                                        Đã chấm (@hw.Score đ)
                                    </span>
                                }
                                else if (isSubmitted)
                                {
                                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-yellow-100 text-yellow-800">
                                        <span class="w-1.5 h-1.5 mr-1 bg-yellow-500 rounded-full"></span>
                                        Chờ chấm
                                    </span>
                                }
                                else if (isOverdue)
                                {
                                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-800">
                                        <span class="w-1.5 h-1.5 mr-1 bg-gray-500 rounded-full"></span>
                                        Trễ hạn
                                    </span>
                                }
                                else
                                {
                                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-red-100 text-red-800">
                                        <span class="w-1.5 h-1.5 mr-1 bg-red-500 rounded-full"></span>
                                        Chưa nộp
                                    </span>
                                }
                            </div>
                        </div>

                        <!-- Student name -->
                        <div class="flex items-center gap-1.5 text-xs text-gray-600 bg-gray-50 px-3 py-1.5 rounded-lg mb-3">
                            <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path></svg>
                            <span>Học sinh: <strong class="text-gray-800">@hw.StudentName</strong></span>
                        </div>

                        <p class="text-sm text-gray-600 mb-4 whitespace-pre-line">@hw.Description</p>

                        <!-- PDF Attachment from Teacher -->
                        @if (!string.IsNullOrEmpty(hw.AttachmentUrl))
                        {
                            <div class="mb-4">
                                <a href="@hw.AttachmentUrl" target="_blank" class="inline-flex items-center gap-2 px-4 py-2.5 border border-red-200 bg-red-50 text-red-700 rounded-xl text-sm font-semibold hover:bg-red-100 hover:text-red-800 transition-colors w-full justify-center">
                                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>
                                    Tải bài tập PDF đề bài
                                </a>
                            </div>
                        }

                        <div class="border-t border-gray-100 pt-4 flex justify-between items-center text-xs">
                            <span class="text-gray-500">Hạn nộp: <strong class="text-gray-700">@hw.DueDateString</strong></span>
                            
                            @if (isGraded)
                            {
                                <button class="px-4 py-2 bg-green-50 text-green-700 rounded-xl font-bold text-xs hover:bg-green-100 transition-all view-feedback-btn" data-score="@hw.Score" data-feedback="@hw.Feedback" data-file-url="@hw.SubmissionFileUrl" data-content="@hw.SubmissionContent" data-title="@hw.Title">
                                    Xem điểm & Nhận xét
                                </button>
                            }
                            else if (isSubmitted)
                            {
                                <button class="px-4 py-2 bg-yellow-50 text-yellow-700 rounded-xl font-bold text-xs hover:bg-yellow-100 transition-all view-feedback-btn" data-score="" data-feedback="" data-file-url="@hw.SubmissionFileUrl" data-content="@hw.SubmissionContent" data-title="@hw.Title">
                                    Xem bài đã nộp
                                </button>
                            }
                            else if (isOverdue)
                            {
                                <span class="text-red-500 font-bold">Đã đóng (Quá hạn)</span>
                            }
                            else
                            {
                                <button class="px-4 py-2 bg-blue-600 text-white rounded-xl font-bold text-xs hover:bg-blue-700 transition-all shadow-sm open-submit-modal-btn" data-homework-id="@hw.HomeworkId" data-student-id="@hw.StudentId" data-title="@hw.Title">
                                    Nộp bài tập
                                </button>
                            }
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="bg-white rounded-2xl border border-gray-100 p-8 text-center text-gray-500 shadow-sm">
                <svg class="w-16 h-16 mx-auto text-gray-300 mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>
                <p class="font-medium text-gray-700">Chưa có bài tập nào được giao cho các con.</p>
            </div>
        }
    </div>

    <!-- Parent Submit Homework Modal -->
    <div class="modal fade" id="parentSubmitModal" tabindex="-1" aria-labelledby="parentSubmitModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content" style="border-radius: 20px; border: none; box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1);">
                <div class="modal-header" style="border-bottom: 1px solid #f1f5f9; padding: 1.5rem;">
                    <h5 class="modal-title fw-bold text-gray-900" id="parentSubmitModalLabel">Nộp bài tập cho con</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body" style="padding: 1.5rem;">
                    <p class="text-sm text-gray-500 mb-4" id="submitModalHWTitle"></p>
                    
                    <form id="parentSubmitForm">
                        <input type="hidden" id="submitHomeworkId" />
                        <input type="hidden" id="submitStudentId" />
                        
                        <div class="mb-3">
                            <label class="form-label fw-bold text-gray-700 small">Chọn file bài làm (Ảnh hoặc file tài liệu)</label>
                            <input type="file" class="form-control" id="submitFileInput" accept="image/*,.pdf,.docx,.xlsx,.pptx,.zip,.rar" required style="border-radius: 12px; padding: 0.75rem 1rem; border-color: #cbd5e1;" />
                            <span class="text-xs text-gray-400 d-block mt-1">Hỗ trợ các định dạng ảnh hoặc tài liệu PDF, DOCX, ZIP... Dung lượng tối đa 20MB.</span>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold text-gray-700 small">Lời nhắn gửi giáo viên (tùy chọn)</label>
                            <textarea class="form-control" id="submitContentInput" rows="3" placeholder="Nhập ghi chú hoặc lời nhắn..." style="border-radius: 12px; border-color: #cbd5e1;"></textarea>
                        </div>

                        <div class="d-grid mt-4">
                            <button type="submit" id="btnSubmitHomework" class="btn btn-primary bg-blue-600 border-none hover:bg-blue-700 py-3 font-semibold" style="border-radius: 12px;">
                                Nộp bài làm
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <!-- Parent View Submission & Feedback Modal -->
    <div class="modal fade" id="parentFeedbackModal" tabindex="-1" aria-labelledby="parentFeedbackModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content" style="border-radius: 20px; border: none; box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1);">
                <div class="modal-header" style="border-bottom: 1px solid #f1f5f9; padding: 1.5rem;">
                    <h5 class="modal-title fw-bold text-gray-900" id="parentFeedbackModalLabel">Chi tiết bài làm đã nộp</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body" style="padding: 1.5rem;">
                    <h4 class="font-bold text-md mb-3 text-gray-800" id="feedbackModalHWTitle"></h4>
                    
                    <div class="mb-4">
                        <h5 class="font-semibold text-xs text-gray-500 uppercase tracking-wider mb-2">Bài đã nộp</h5>
                        <div id="feedbackSubmittedFileContainer"></div>
                        <p class="text-sm text-gray-600 bg-gray-50 p-3 rounded-xl border border-gray-100 whitespace-pre-line mt-2" id="feedbackSubmittedContent"></p>
                    </div>

                    <div id="feedbackEvaluationSection" class="border-t border-gray-100 pt-4" style="display: none;">
                        <h5 class="font-semibold text-xs text-gray-500 uppercase tracking-wider mb-2">Đánh giá của giáo viên</h5>
                        <div class="flex items-center gap-2 mb-3">
                            <span class="text-xs text-gray-500">Điểm số:</span>
                            <span class="inline-flex px-3 py-1 bg-green-100 text-green-800 rounded-full font-bold text-sm" id="feedbackScoreValue"></span>
                        </div>
                        <div class="text-sm text-gray-700 bg-green-50/50 p-4 rounded-xl border border-green-100/50 italic whitespace-pre-line" id="feedbackTextValue">
                            Chưa có nhận xét cụ thể.
                        </div>
                    </div>
                </div>
                <div class="modal-footer" style="border-top: none; padding: 1rem 1.5rem 1.5rem;">
                    <button type="button" class="btn btn-secondary w-full" data-bs-dismiss="modal" style="border-radius: 12px; padding: 10px; font-weight: 600;">Đóng</button>
                </div>
            </div>
        </div>
    </div>
}
else
{
    <!-- ==========================================
         TEACHER INTERFACE (TAILWIND)
         ========================================== -->
    <div class="flex justify-between items-start mb-6">
        <div>
            <h1 class="text-3xl font-bold text-gray-900">Quản lý bài tập</h1>
            <p class="text-gray-500 mt-1">Giao bài tập và chấm điểm</p>
        </div>
        <button onclick="toggleModal('createHomeworkModal', true)" class="inline-flex h-11 items-center rounded bg-blue-600 px-4 text-sm font-semibold text-white shadow-sm transition-colors hover:bg-blue-700">
            <svg class="mr-2 h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
            Giao bài tập mới
        </button>
    </div>

    <!-- Main Card -->
    <div class="rounded-2xl border border-gray-200 bg-white shadow-sm overflow-hidden mb-8">
        <!-- List Header -->
        <div class="rounded-t-2xl border-b border-blue-100 bg-blue-50/60 p-6 flex justify-between items-center">
            <h3 class="text-base font-bold text-gray-900">Danh sách bài tập</h3>
            <div class="relative w-full max-w-sm">
                <svg class="absolute left-3 top-1/2 -translate-y-1/2 h-4 w-4 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
                <input type="text" placeholder="Tìm kiếm bài tập..." class="block h-10 w-full rounded border border-gray-300 bg-white pl-10 pr-4 text-sm text-gray-900 placeholder-gray-500 focus:border-blue-500 focus:outline-none focus:ring-1 focus:ring-blue-500" />
            </div>
        </div>

        <!-- Assignments Table -->
        <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="whitespace-nowrap bg-slate-100 border-b border-slate-200 text-sm font-bold text-slate-800">
                        <th class="py-4 px-6 font-bold border-r border-slate-200">Bài tập</th>
                        <th class="py-4 px-6 text-center font-bold border-r border-slate-200">Đã nộp</th>
                        <th class="py-4 px-6 text-center font-bold border-r border-slate-200">Đã chấm</th>
                        <th class="py-4 px-6 text-center font-bold border-r border-slate-200">Hạn nộp</th>
                        <th class="py-4 px-6 font-bold text-center">Thao tác</th>
                    </tr>
                </thead>
                <tbody class="text-sm divide-y divide-gray-100">
                    @if (!Model.HomeworkList.Any())
                    {
                        <tr>
                            <td colspan="5" class="py-10 px-6 text-center text-gray-500">
                                Chưa có bài tập nào được giao.
                            </td>
                        </tr>
                    }
                    else
                    {
                        foreach (var hw in Model.HomeworkList)
                        {
                            var submitPct = hw.TotalStudents == 0 ? 0 : (double)hw.SubmittedCount / hw.TotalStudents * 100;
                            var gradePct = hw.SubmittedCount == 0 ? 0 : (double)hw.GradedCount / hw.SubmittedCount * 100;

                            <tr class="group hover:bg-slate-100 transition-colors">
                                <td class="py-5 px-6 border-r border-gray-200">
                                    <div class="font-semibold text-blue-700 group-hover:text-blue-800 text-base">@hw.Title</div>
                                    <div class="mt-1 text-xs font-semibold text-slate-600 bg-slate-200 inline-block px-2 py-0.5 rounded">@hw.ClassName</div>
                                    <div class="mt-2 text-sm text-gray-600">@hw.Description</div>
                                    @if (!string.IsNullOrEmpty(hw.AttachmentUrl))
                                    {
                                        <div class="mt-2">
                                            <a href="@hw.AttachmentUrl" target="_blank" class="text-red-600 hover:text-red-800 text-decoration-none fw-semibold text-xs inline-flex items-center gap-1">
                                                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>
                                                Tài liệu đính kèm
                                            </a>
                                        </div>
                                    }
                                    <div class="mt-3 text-xs text-gray-500">
                                        Giao: @hw.CreatedAtString
                                    </div>
                                </td>
                                <td class="py-5 px-6 text-center border-r border-gray-200">
                                    <div class="font-semibold text-gray-900">@hw.SubmittedCount / @hw.TotalStudents</div>
                                    <div class="mt-2 w-full max-w-[120px] mx-auto bg-gray-200 rounded-full h-2">
                                        <div class="bg-blue-600 h-2 rounded-full" style="width: @submitPct%"></div>
                                    </div>
                                </td>
                                <td class="py-5 px-6 text-center border-r border-gray-200">
                                    <div class="font-semibold text-gray-900">@hw.GradedCount / @hw.SubmittedCount</div>
                                    <div class="mt-2 w-full max-w-[120px] mx-auto bg-gray-200 rounded-full h-2">
                                        <div class="bg-green-500 h-2 rounded-full" style="width: @gradePct%"></div>
                                    </div>
                                    @if (hw.PendingCount > 0)
                                    {
                                        <div class="mt-2 inline-block px-2 py-1 bg-orange-100 text-orange-700 text-xs font-bold rounded-full">
                                            @hw.PendingCount cần chấm
                                        </div>
                                    }
                                </td>
                                <td class="py-5 px-6 text-center border-r border-gray-200">
                                    <div class="text-sm font-semibold text-gray-700">@hw.DueDateString</div>
                                </td>
                                <td class="py-5 px-6 text-center">
                                    <button type="button" class="inline-flex h-10 w-10 items-center justify-center rounded-full border border-blue-500 bg-blue-50 text-blue-600 transition-colors hover:bg-blue-100 detail-btn" data-homework-id="@hw.HomeworkId" data-title="@hw.Title" data-class-name="@hw.ClassName" title="Xem/Chấm điểm">
                                        <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.25 12s3.75-6.75 9.75-6.75S21.75 12 21.75 12 18 18.75 12 18.75 2.25 12 2.25 12z"></path><circle cx="12" cy="12" r="3" stroke-width="2"></circle></svg>
                                    </button>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- Create Homework Modal -->
    <div id="createHomeworkModal" class="fixed inset-0 z-[60] hidden items-center justify-center bg-black bg-opacity-50 px-4 transition-opacity">
        <div class="w-full max-w-lg rounded-2xl bg-white shadow-2xl">
            <div class="flex items-center justify-between border-b border-gray-100 px-6 py-4">
                <h3 class="text-lg font-bold text-gray-900">Giao bài tập mới</h3>
                <button type="button" onclick="toggleModal('createHomeworkModal', false)" class="text-gray-400 hover:text-gray-600">
                    <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
                </button>
            </div>
            <form method="post" asp-page-handler="Create" enctype="multipart/form-data">
                <div class="px-6 py-4">
                    @if (TempData["ErrorMessage"] != null)
                    {
                        <div class="mb-4 rounded-xl bg-red-50 p-4 text-sm text-red-600">
                            @TempData["ErrorMessage"]
                        </div>
                    }
                    <div class="mb-4">
                        <label class="mb-1.5 block text-sm font-semibold text-gray-700">Lớp học</label>
                        <select id="selectClass" class="block h-11 w-full rounded-xl border border-gray-300 bg-white px-4 text-sm focus:border-blue-500 focus:outline-none focus:ring-1 focus:ring-blue-500" required>
                            <option value="">-- Chọn lớp học --</option>
                            @foreach (var cls in Model.TeacherClasses)
                            {
                                <option value="@cls.ClassId">@cls.ClassName</option>
                            }
                        </select>
                    </div>
                    <div class="mb-4">
                        <label class="mb-1.5 block text-sm font-semibold text-gray-700">Buổi học (Lesson)</label>
                        <select id="selectLesson" name="lessonId" class="block h-11 w-full rounded-xl border border-gray-300 bg-white px-4 text-sm focus:border-blue-500 focus:outline-none focus:ring-1 focus:ring-blue-500" required disabled>
                            <option value="">-- Vui lòng chọn lớp học trước --</option>
                        </select>
                    </div>
                    <div class="mb-4">
                        <label class="mb-1.5 block text-sm font-semibold text-gray-700">Tiêu đề bài tập</label>
                        <input type="text" name="title" class="block h-11 w-full rounded-xl border border-gray-300 bg-white px-4 text-sm focus:border-blue-500 focus:outline-none focus:ring-1 focus:ring-blue-500" placeholder="Nhập tiêu đề..." required>
                    </div>
                    <div class="mb-4">
                        <label class="mb-1.5 block text-sm font-semibold text-gray-700">Mô tả / Yêu cầu</label>
                        <textarea name="description" rows="3" class="block w-full rounded-xl border border-gray-300 bg-white p-3 text-sm focus:border-blue-500 focus:outline-none focus:ring-1 focus:ring-blue-500" placeholder="Nhập mô tả chi tiết..."></textarea>
                    </div>
                    <div class="mb-4">
                        <label class="mb-1.5 block text-sm font-semibold text-gray-700">Hạn nộp (Due Date)</label>
                        <input type="datetime-local" name="dueDate" class="block h-11 w-full rounded-xl border border-gray-300 bg-white px-4 text-sm focus:border-blue-500 focus:outline-none focus:ring-1 focus:ring-blue-500" required>
                    </div>
                    <div class="mb-2">
                        <label class="mb-1.5 block text-sm font-semibold text-gray-700">Tài liệu đính kèm (File PDF đề bài)</label>
                        <input type="file" name="pdfFile" accept=".pdf" class="block w-full rounded-xl border border-gray-300 bg-white px-4 py-2 text-sm focus:border-blue-500 focus:outline-none focus:ring-1 focus:ring-blue-500">
                        <p class="mt-1 text-xs text-gray-500">Chỉ chấp nhận file PDF, dung lượng tối đa 20MB.</p>
                    </div>
                </div>
                <div class="flex items-center justify-end gap-3 rounded-b-2xl border-t border-gray-100 bg-gray-50 px-6 py-4">
                    <button type="button" onclick="toggleModal('createHomeworkModal', false)" class="inline-flex h-10 items-center justify-center rounded-xl bg-white px-5 text-sm font-semibold text-gray-700 shadow-sm ring-1 ring-inset ring-gray-300 hover:bg-gray-50">Hủy</button>
                    <button type="submit" class="inline-flex h-10 items-center justify-center rounded-xl bg-blue-600 px-5 text-sm font-semibold text-white shadow-sm hover:bg-blue-700">Giao bài tập</button>
                </div>
            </form>
        </div>
    </div>

    <!-- Homework Submission Detail Modal -->
    <div id="homeworkDetailModal" class="fixed inset-0 z-[60] hidden items-center justify-center bg-black bg-opacity-50 px-4 transition-opacity">
        <div class="w-full max-w-5xl rounded-2xl bg-white shadow-2xl overflow-hidden flex flex-col max-h-[90vh]">
            <div class="flex items-center justify-between border-b border-gray-100 px-6 py-4 flex-shrink-0">
                <div>
                    <h3 class="text-lg font-bold text-gray-900">Chi tiết & Chấm điểm bài tập</h3>
                    <p id="detailSubTitle" class="mt-1 text-sm font-semibold text-gray-500"></p>
                </div>
                <button type="button" onclick="toggleModal('homeworkDetailModal', false)" class="text-gray-400 hover:text-gray-600">
                    <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
                </button>
            </div>
            <div class="overflow-y-auto p-6 bg-gray-50 flex-grow">
                <div class="rounded-xl border border-gray-200 bg-white shadow-sm overflow-x-auto">
                    <table class="w-full text-left border-collapse min-w-[800px]">
                        <thead>
                            <tr class="bg-slate-100 text-sm font-bold text-slate-800 border-b border-gray-200">
                                <th class="py-3 px-4 text-center border-r border-gray-200 w-16">STT</th>
                                <th class="py-3 px-4 border-r border-gray-200">Học sinh</th>
                                <th class="py-3 px-4 border-r border-gray-200 w-64">Nội dung nộp</th>
                                <th class="py-3 px-4 text-center border-r border-gray-200 w-32">Trạng thái</th>
                                <th class="py-3 px-4 border-r border-gray-200 w-24">Điểm</th>
                                <th class="py-3 px-4 border-r border-gray-200 w-48">Nhận xét</th>
                                <th class="py-3 px-4 text-center w-28">Thao tác</th>
                            </tr>
                        </thead>
                        <tbody id="submissionsTableBody" class="text-sm divide-y divide-gray-100">
                            <!-- Sẽ được fill bằng JavaScript -->
                        </tbody>
                    </table>
                </div>
            </div>
            <div class="flex items-center justify-end border-t border-gray-100 px-6 py-4 flex-shrink-0">
                <button type="button" onclick="toggleModal('homeworkDetailModal', false)" class="inline-flex h-10 items-center justify-center rounded-xl bg-white px-5 text-sm font-semibold text-gray-700 shadow-sm ring-1 ring-inset ring-gray-300 hover:bg-gray-50">Đóng</button>
            </div>
        </div>
    </div>

    <!-- Form ẩn phục vụ việc Submit chấm điểm -->
    <form id="hiddenGradeForm" method="post" asp-page-handler="Grade" class="hidden">
        <input type="hidden" name="homeworkId" id="gradeHomeworkId" />
        <input type="hidden" name="studentId" id="gradeStudentId" />
        <input type="hidden" name="score" id="gradeScore" />
        <input type="hidden" name="feedback" id="gradeFeedback" />
    </form>
}

@section Scripts {
    @if (User.IsInRole("PARENT"))
    {
        <script>
            document.addEventListener("DOMContentLoaded", function() {
                // 1. Phân lọc theo Học sinh (con)
                const tabBtns = document.querySelectorAll(".student-tab-btn");
                const cards = document.querySelectorAll(".homework-card");

                tabBtns.forEach(btn => {
                    btn.addEventListener("click", function() {
                        tabBtns.forEach(b => {
                            b.classList.remove("active", "bg-blue-600", "text-white", "shadow-sm");
                            b.classList.add("bg-white", "text-gray-700", "border-gray-200");
                        });

                        this.classList.add("active", "bg-blue-600", "text-white", "shadow-sm");
                        this.classList.remove("bg-white", "text-gray-700", "border-gray-200");

                        const studentId = this.getAttribute("data-student-id");
                        
                        cards.forEach(c => {
                            if (studentId === "all" || c.getAttribute("data-student-id") === studentId) {
                                c.style.display = "block";
                            } else {
                                c.style.display = "none";
                            }
                        });
                    });
                });

                // 2. Nộp bài tập
                const openSubmitBtns = document.querySelectorAll(".open-submit-modal-btn");
                const submitModal = new bootstrap.Modal(document.getElementById("parentSubmitModal"));
                const modalHwTitle = document.getElementById("submitModalHWTitle");
                const submitForm = document.getElementById("parentSubmitForm");

                openSubmitBtns.forEach(btn => {
                    btn.addEventListener("click", function() {
                        const hwId = this.getAttribute("data-homework-id");
                        const studentId = this.getAttribute("data-student-id");
                        const title = this.getAttribute("data-title");

                        document.getElementById("submitHomeworkId").value = hwId;
                        document.getElementById("submitStudentId").value = studentId;
                        document.getElementById("submitFileInput").value = "";
                        document.getElementById("submitContentInput").value = "";
                        modalHwTitle.textContent = `Bài tập: ${title}`;

                        submitModal.show();
                    });
                });

                submitForm.addEventListener("submit", function(e) {
                    e.preventDefault();

                    const fileInput = document.getElementById("submitFileInput");
                    const file = fileInput.files[0];
                    if (!file) return;

                    // Validate client size
                    if (file.size > 20 * 1024 * 1024) {
                        window.showToast("File vượt quá kích thước giới hạn (20MB).", false);
                        return;
                    }

                    const hwId = document.getElementById("submitHomeworkId").value;
                    const studentId = document.getElementById("submitStudentId").value;
                    const content = document.getElementById("submitContentInput").value;

                    const submitBtn = document.getElementById("btnSubmitHomework");
                    const originalText = submitBtn.textContent;
                    submitBtn.disabled = true;
                    submitBtn.textContent = "Đang tải tệp lên...";

                    const formData = new FormData();
                    formData.append("file", file);

                    // B1: Upload file
                    fetch('/api/v1/parent/homework/upload', {
                        method: 'POST',
                        body: formData
                    })
                    .then(res => res.json())
                    .then(res => {
                        if (res.success) {
                            const fileUrl = res.data.fileUrl;
                            submitBtn.textContent = "Đang nộp bài...";

                            // B2: Submit bài tập
                            return fetch('/api/v1/parent/homework/submit', {
                                method: 'POST',
                                headers: { 'Content-Type': 'application/json' },
                                body: JSON.stringify({
                                    homeworkId: parseInt(hwId),
                                    studentId: parseInt(studentId),
                                    submissionFileUrl: fileUrl,
                                    submissionContent: content
                                })
                            });
                        } else {
                            throw new Error(res.message || "Lỗi upload file.");
                        }
                    })
                    .then(res => res.json())
                    .then(res => {
                        submitBtn.disabled = false;
                        submitBtn.textContent = originalText;

                        if (res.success) {
                            submitModal.hide();
                            window.showToast("Đã nộp bài làm thành công!");
                            setTimeout(() => window.location.reload(), 1000);
                        } else {
                            window.showToast(res.message, false);
                        }
                    })
                    .catch(err => {
                        submitBtn.disabled = false;
                        submitBtn.textContent = originalText;
                        console.error(err);
                        window.showToast(err.message || "Có lỗi xảy ra trong quá trình nộp bài.", false);
                    });
                });

                // 3. Xem Feedback/Điểm/Bài đã nộp
                const viewFeedbackBtns = document.querySelectorAll(".view-feedback-btn");
                const feedbackModal = new bootstrap.Modal(document.getElementById("parentFeedbackModal"));

                viewFeedbackBtns.forEach(btn => {
                    btn.addEventListener("click", function() {
                        const title = this.getAttribute("data-title");
                        const score = this.getAttribute("data-score");
                        const feedback = this.getAttribute("data-feedback");
                        const fileUrl = this.getAttribute("data-file-url");
                        const content = this.getAttribute("data-content");

                        document.getElementById("feedbackModalHWTitle").textContent = title;
                        
                        // File đã nộp
                        const fileContainer = document.getElementById("feedbackSubmittedFileContainer");
                        fileContainer.innerHTML = "";
                        if (fileUrl) {
                            const isImg = fileUrl.match(/\.(jpg|jpeg|png|gif|webp)$/i);
                            if (isImg) {
                                fileContainer.innerHTML = `
                                    <a href="${fileUrl}" target="_blank" class="block border border-gray-200 rounded-2xl overflow-hidden hover:opacity-90 transition-opacity">
                                        <img src="${fileUrl}" alt="Bài làm" class="max-h-48 w-full object-cover" />
                                    </a>
                                `;
                            } else {
                                const fileName = fileUrl.split('_').slice(1).join('_') || "file_bai_lam";
                                fileContainer.innerHTML = `
                                    <a href="${fileUrl}" target="_blank" class="flex items-center gap-3 p-3 bg-gray-50 border border-gray-200 rounded-xl text-blue-600 hover:bg-gray-100 transition-colors text-sm font-semibold">
                                        <svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>
                                        <span class="text-truncate">${fileName}</span>
                                    </a>
                                `;
                            }
                        }

                        // Lời nhắn
                        const contentP = document.getElementById("feedbackSubmittedContent");
                        if (content) {
                            contentP.textContent = content;
                            contentP.style.display = "block";
                        } else {
                            contentP.style.display = "none";
                        }

                        // Đánh giá điểm
                        const evalSection = document.getElementById("feedbackEvaluationSection");
                        if (score) {
                            document.getElementById("feedbackScoreValue").textContent = score;
                            document.getElementById("feedbackTextValue").textContent = feedback || "Chưa có nhận xét cụ thể.";
                            evalSection.style.display = "block";
                        } else {
                            evalSection.style.display = "none";
                        }

                        feedbackModal.show();
                    });
                });
            });
        </script>
    }
    else
    {
        <script>
            // Utility toggleModal function (since this is Teacher UI)
            function toggleModal(modalId, show) {
                const modal = document.getElementById(modalId);
                if (!modal) return;
                if (show) {
                    modal.classList.remove('hidden');
                    modal.classList.add('flex');
                } else {
                    modal.classList.add('hidden');
                    modal.classList.remove('flex');
                }
            }
        </script>

        @if (TempData["ErrorMessage"] != null)
        {
            <script>
                document.addEventListener("DOMContentLoaded", function() {
                    toggleModal('createHomeworkModal', true);
                });
            </script>
        }

        <script>
            document.addEventListener("DOMContentLoaded", function() {
                // 1. Tải Lessons khi chọn Lớp học
                const selectClass = document.getElementById("selectClass");
                const selectLesson = document.getElementById("selectLesson");

                selectClass.addEventListener("change", async function() {
                    const classId = this.value;
                    selectLesson.innerHTML = "";
                    selectLesson.disabled = true;

                    if (!classId) {
                        selectLesson.innerHTML = '<option value="">-- Vui lòng chọn lớp học trước --</option>';
                        return;
                    }

                    selectLesson.innerHTML = '<option value="">Đang tải các buổi học...</option>';

                    try {
                        const response = await fetch(`/api/v1/teacher/homework/lessons?classId=${classId}`);
                        const json = await response.json();
                        
                        if (json.success && json.data.length > 0) {
                            let html = '<option value="">-- Chọn buổi học --</option>';
                            json.data.forEach(l => {
                                html += `<option value="${l.lessonId}">${l.lessonTitle} (${l.dateString})</option>`;
                            });
                            selectLesson.innerHTML = html;
                            selectLesson.disabled = false;
                        } else {
                            selectLesson.innerHTML = '<option value="">Lớp học chưa có buổi học nào</option>';
                        }
                    } catch (err) {
                        console.error("Lỗi tải buổi học:", err);
                        selectLesson.innerHTML = '<option value="">Lỗi tải dữ liệu</option>';
                    }
                });

                // 2. Chi tiết và chấm điểm bài nộp
                const detailButtons = document.querySelectorAll(".detail-btn");
                const submissionsTableBody = document.getElementById("submissionsTableBody");
                const detailSubTitle = document.getElementById("detailSubTitle");

                detailButtons.forEach(btn => {
                    btn.addEventListener("click", async function() {
                        const homeworkId = this.getAttribute("data-homework-id");
                        const title = this.getAttribute("data-title");
                        const className = this.getAttribute("data-class-name");

                        detailSubTitle.textContent = `Lớp: ${className} | Bài tập: ${title}`;
                        submissionsTableBody.innerHTML = '<tr><td colspan="7" class="text-center py-4 text-gray-500">Đang tải danh sách bài nộp...</td></tr>';
                        
                        toggleModal('homeworkDetailModal', true);

                        try {
                            const response = await fetch(`/api/v1/teacher/homework/${homeworkId}/submissions`);
                            const json = await response.json();

                            if (json.success && json.data.length > 0) {
                                let html = "";
                                json.data.forEach((sub, index) => {
                                    // Hỗ trợ fallback cho cả camelCase và PascalCase để đảm bảo hiển thị đúng bất chấp cấu hình JSON serializer
                                    const sName = sub.studentName || sub.StudentName || "";
                                    const sCode = sub.studentCode || sub.StudentCode || "";
                                    const avatarText = sName.substring(0, Math.min(2, sName.length)).toUpperCase() || "??";
                                    const sId = sub.studentId || sub.StudentId;
                                    const status = sub.status || sub.Status || 'NotSubmitted';
                                    const fileUrl = sub.submissionFileUrl || sub.SubmissionFileUrl;
                                    const content = sub.submissionContent || sub.SubmissionContent;

                                    let submissionContent = content || '<span class="text-gray-400 italic">Chưa nộp bài</span>';
                                    const badgeClass = status === 'Graded' ? 'bg-green-100 text-green-700' : (status === 'Submitted' ? 'bg-orange-100 text-orange-700' : 'bg-red-100 text-red-700');
                                    const statusText = status === 'Graded' ? 'Đã chấm' : (status === 'Submitted' ? 'Chờ chấm' : 'Chưa nộp');
                                    
                                    // Xử lý an toàn cho Score (Điểm số)
                                    let scoreValue = '';
                                    if (sub.score !== undefined && sub.score !== null) {
                                        scoreValue = sub.score;
                                    } else if (sub.Score !== undefined && sub.Score !== null) {
                                        scoreValue = sub.Score;
                                    }

                                    // Xử lý an toàn cho Feedback (Nhận xét)
                                    let feedbackValue = '';
                                    if (sub.feedback !== undefined && sub.feedback !== null) {
                                        feedbackValue = sub.feedback;
                                    } else if (sub.Feedback !== undefined && sub.Feedback !== null) {
                                        feedbackValue = sub.Feedback;
                                    }

                                    // Nếu có tệp đính kèm nộp bài
                                    if (fileUrl) {
                                        const isImg = fileUrl.match(/\.(jpg|jpeg|png|gif|webp)$/i);
                                        if (isImg) {
                                            submissionContent = `
                                                <div class="mb-1 truncate text-xs text-gray-700" title="${content || ''}">${content || 'Nộp bằng ảnh'}</div>
                                                <a href="${fileUrl}" target="_blank" class="block mt-1">
                                                    <img src="${fileUrl}" class="max-h-16 rounded border border-gray-200 object-cover" />
                                                </a>
                                            `;
                                        } else {
                                            const fileDisplay = fileUrl.split('_').slice(1).join('_') || "file_bai_lam";
                                            submissionContent = `
                                                <div class="mb-1 truncate text-xs text-gray-700" title="${content || ''}">${content || 'Nộp bằng file'}</div>
                                                <a href="${fileUrl}" target="_blank" class="inline-flex items-center gap-1 text-xs font-semibold text-blue-600 hover:text-blue-800">
                                                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
                                                    Tải bài làm
                                                </a>
                                            `;
                                        }
                                    }

                                    html += `
                                        <tr class="hover:bg-slate-50 transition-colors">
                                            <td class="py-3 px-4 text-center border-r border-gray-200 text-gray-700 font-medium">${index + 1}</td>
                                            <td class="py-3 px-4 border-r border-gray-200">
                                                <div class="flex items-center gap-3">
                                                    <div class="h-8 w-8 rounded-full bg-blue-100 flex items-center justify-center text-blue-700 font-bold text-xs flex-shrink-0">${avatarText}</div>
                                                    <div>
                                                        <div class="font-semibold text-gray-900">${sName}</div>
                                                        <div class="text-xs text-gray-500">Mã: ${sCode}</div>
                                                    </div>
                                                </div>
                                            </td>
                                            <td class="py-3 px-4 border-r border-gray-200" style="max-width: 250px;">
                                                ${submissionContent}
                                            </td>
                                            <td class="py-3 px-4 text-center border-r border-gray-200">
                                                <span class="inline-block px-2 py-1 text-xs font-bold rounded-full ${badgeClass}">${statusText}</span>
                                            </td>
                                            <td class="py-3 px-4 border-r border-gray-200">
                                                <input type="number" class="block h-9 w-full rounded border border-gray-300 bg-white px-2 text-sm focus:border-blue-500 focus:outline-none focus:ring-1 focus:ring-blue-500 score-input" step="0.1" min="0" max="10" value="${scoreValue}" placeholder="Điểm" data-student-id="${sId}" />
                                            </td>
                                            <td class="py-3 px-4 border-r border-gray-200">
                                                <input type="text" class="block h-9 w-full rounded border border-gray-300 bg-white px-2 text-sm focus:border-blue-500 focus:outline-none focus:ring-1 focus:ring-blue-500 feedback-input" value="${feedbackValue}" placeholder="Nhận xét" data-student-id="${sId}" />
                                            </td>
                                            <td class="py-3 px-4 text-center">
                                                <button type="button" class="inline-flex h-9 items-center justify-center rounded bg-blue-600 px-3 text-xs font-semibold text-white shadow-sm hover:bg-blue-700 save-grade-btn" data-homework-id="${homeworkId}" data-student-id="${sId}">Lưu</button>
                                            </td>
                                        </tr>
                                    `;
                                });
                                submissionsTableBody.innerHTML = html;

                                // Đăng ký sự kiện click cho các nút Lưu điểm
                                const saveBtns = submissionsTableBody.querySelectorAll(".save-grade-btn");
                                saveBtns.forEach(saveBtn => {
                                    saveBtn.addEventListener("click", function() {
                                        const hwId = this.getAttribute("data-homework-id");
                                        const sId = this.getAttribute("data-student-id");
                                        
                                        // Tìm ô input tương ứng
                                        const scoreInput = submissionsTableBody.querySelector(`input.score-input[data-student-id="${sId}"]`);
                                        const feedbackInput = submissionsTableBody.querySelector(`input.feedback-input[data-student-id="${sId}"]`);
                                        
                                        const score = scoreInput.value;
                                        const feedback = feedbackInput.value;

                                        if (score === "" || isNaN(score) || parseFloat(score) < 0 || parseFloat(score) > 10) {
                                            window.showToast("Vui lòng nhập điểm số hợp lệ từ 0 đến 10.", false);
                                            return;
                                        }

                                        // Điền dữ liệu vào form ẩn và Submit
                                        document.getElementById("gradeHomeworkId").value = hwId;
                                        document.getElementById("gradeStudentId").value = sId;
                                        document.getElementById("gradeScore").value = score;
                                        document.getElementById("gradeFeedback").value = feedback;
                                        
                                        document.getElementById("hiddenGradeForm").submit();
                                    });
                                });
                            } else {
                                submissionsTableBody.innerHTML = '<tr><td colspan="7" class="text-center py-4">Lớp học này chưa có học sinh nào.</td></tr>';
                            }
                        } catch (err) {
                            console.error("Lỗi tải bài nộp:", err);
                            submissionsTableBody.innerHTML = '<tr><td colspan="7" class="text-center py-4 text-danger">Có lỗi khi tải danh sách nộp bài.</td></tr>';
                        }
                    });
                });
            });
        </script>
    }
}

