@page
@model ErrorModel
@{
    ViewData["Title"] = "Lỗi hệ thống";
}

<div class="container mt-5 mb-5">
    <div class="row justify-content-center">
        <div class="col-md-8 text-center">
            <h1 class="text-danger mb-3"><i class="bi bi-exclamation-triangle-fill"></i> Đã xảy ra lỗi</h1>
            <h4 class="text-muted mb-4">Xin lỗi, hệ thống đã gặp sự cố trong quá trình xử lý yêu cầu của bạn.</h4>
            
            @if (Model.ShowRequestId)
            {
                <div class="alert alert-secondary d-inline-block">
                    <strong>Mã lỗi (Request ID):</strong> <code>@Model.RequestId</code>
                </div>
                <p class="mt-3 text-muted small">
                    Vui lòng cung cấp mã lỗi này cho bộ phận hỗ trợ kỹ thuật để được trợ giúp.
                </p>
            }
            
            <div class="mt-4">
                <a href="/" class="btn btn-primary">
                    <i class="bi bi-house-door me-2"></i>Trở về Trang chủ
                </a>
            </div>
        </div>
    </div>
</div>
