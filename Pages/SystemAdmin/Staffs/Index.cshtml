@page
@model EduBridge.Pages.SystemAdmin.Staffs.IndexModel
@{
    ViewData["Title"] = "Nhân sự Admin";
    Layout = "_AdminLayout";
    ViewData["ActivePage"] = "SystemStaff";
    var selectedStatusText = Model.StatusFilter switch
    {
        "ACTIVE" => "Hoạt động",
        "INACTIVE" => "Đã khóa",
        _ => "Trạng thái"
    };
}

<div class="space-y-6 pb-20">
    <div>
        <h1 class="text-3xl font-bold text-gray-900">Quản lý Nhân sự Admin</h1>
        <p class="text-gray-500 mt-1">Quản lý các tài khoản quản trị hệ thống và quản trị dự án</p>
    </div>

    <div class="rounded-2xl border border-gray-200 bg-white shadow-sm overflow-hidden">
        <div class="border-b border-blue-100 bg-blue-50/60 p-6">
            <h3 class="text-base font-bold text-gray-900">Danh sách nhân sự</h3>

            <form method="get" class="mt-5 space-y-4">
                <input type="hidden" name="PageNumber" value="1" />
                <input type="hidden" name="PageSize" value="@Model.PageSize" />
                <div class="grid gap-4 lg:grid-cols-3">
                    <div>
                        <label for="NameCodeSearch" class="sr-only">Tìm kiếm theo mã, tên</label>
                        <input id="NameCodeSearch" type="text" name="NameCodeSearch" value="@Model.NameCodeSearch" maxlength="150" class="block h-12 w-full rounded border border-gray-300 bg-white px-4 text-sm text-gray-900 placeholder-gray-500 focus:border-blue-500 focus:outline-none focus:ring-1 focus:ring-blue-500" placeholder="Tìm kiếm theo mã, tên...">
                    </div>
                    <div>
                        <label for="EmailPhoneSearch" class="sr-only">Tìm kiếm theo email, sđt</label>
                        <input id="EmailPhoneSearch" type="text" name="EmailPhoneSearch" value="@Model.EmailPhoneSearch" maxlength="150" class="block h-12 w-full rounded border border-gray-300 bg-white px-4 text-sm text-gray-900 placeholder-gray-500 focus:border-blue-500 focus:outline-none focus:ring-1 focus:ring-blue-500" placeholder="Tìm kiếm theo email, sđt...">
                    </div>



                    <div>
                        <input type="hidden" name="StatusFilter" value="@Model.StatusFilter" data-filter-value="status" />
                        <div class="relative" data-search-dropdown>
                            <button type="button" data-dropdown-toggle class="flex h-12 w-full items-center justify-between rounded border border-gray-300 bg-white px-4 text-left text-sm text-gray-600 focus:border-blue-500 focus:outline-none focus:ring-1 focus:ring-blue-500">
                                <span data-dropdown-label>@selectedStatusText</span>
                                <svg class="h-4 w-4 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
                            </button>
                            <div data-dropdown-panel class="absolute left-0 top-[calc(100%+4px)] z-40 hidden w-full rounded border border-gray-300 bg-white shadow-lg">
                                <button type="button" data-dropdown-option data-value="" data-label="Trạng thái" class="block w-full px-4 py-2 text-left text-sm hover:bg-blue-50">Tất cả</button>
                                <button type="button" data-dropdown-option data-value="ACTIVE" data-label="Hoạt động" class="block w-full px-4 py-2 text-left text-sm hover:bg-blue-50">Hoạt động</button>
                                <button type="button" data-dropdown-option data-value="INACTIVE" data-label="Đã khóa" class="block w-full px-4 py-2 text-left text-sm hover:bg-blue-50">Đã khóa</button>
                            </div>
                        </div>
                        <span asp-validation-for="StatusFilter" class="mt-1 block text-xs font-medium text-red-600"></span>
                    </div>
                </div>

                <div class="flex flex-wrap items-center justify-between gap-3">
                    <a asp-page="/SystemAdmin/Staffs/Create" class="inline-flex h-11 items-center rounded bg-blue-600 px-4 text-sm font-semibold text-white shadow-sm transition-colors hover:bg-blue-700">
                        <svg class="mr-2 h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
                        Thêm nhân sự
                    </a>
                    <div class="flex flex-wrap items-center gap-3">
                        <a asp-page="/SystemAdmin/Staffs/Index" class="inline-flex h-11 items-center rounded bg-slate-600 px-4 text-sm font-semibold text-white shadow-sm transition-colors hover:bg-slate-700">
                            Làm mới bộ lọc
                        </a>
                        <button type="submit" class="inline-flex h-11 items-center rounded bg-blue-600 px-4 text-sm font-semibold text-white shadow-sm transition-colors hover:bg-blue-700">
                            <svg class="mr-2 h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
                            Tìm kiếm
                        </button>
                    </div>
                </div>
            </form>
        </div>

        <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="whitespace-nowrap bg-slate-100 border-b border-slate-200 text-sm font-bold text-slate-800">
                        <th class="py-4 px-4 text-center font-bold border-r border-slate-200">STT</th>
                        <th class="py-4 px-6 text-center font-bold border-r border-slate-200">ID</th>
                        <th class="py-4 px-6 text-center font-bold border-r border-slate-200">Nhân sự</th>
                        <th class="py-4 px-6 text-center font-bold border-r border-slate-200">Liên hệ</th>
                        <th class="py-4 px-6 text-center font-bold border-r border-slate-200">Ngày tạo</th>
                        <th class="py-4 px-6 text-center font-bold border-r border-slate-200">Trạng thái</th>
                        <th class="py-4 px-6 text-center font-bold">Thao tác</th>
                    </tr>
                </thead>
                <tbody class="text-sm divide-y divide-gray-100">
                    @if (Model.Staffs.Count == 0)
                    {
                        <tr>
                            <td colspan="7" class="py-10 px-6 text-center text-gray-500">
                                Chưa có nhân sự phù hợp.
                            </td>
                        </tr>
                    }
                    else
                    {
                        @for (var index = 0; index < Model.Staffs.Count; index++)
                        {
                            var staff = Model.Staffs[index];
                            var isActive = staff.Status?.ToUpper() == "ACTIVE";
                            <tr class="group hover:bg-slate-100 transition-colors">
                                <td class="py-4 px-4 text-center font-medium text-gray-700 border-r border-gray-200">
                                    @(Model.FirstItemNumber + index)
                                </td>
                                <td class="py-4 px-6 text-center font-medium text-gray-700 border-r border-gray-200">
                                    @staff.UserId
                                </td>
                                <td class="py-4 px-6 border-r border-gray-200">
                                    <div class="flex items-center">
                                        @if (!string.IsNullOrWhiteSpace(staff.AvatarUrl))
                                        {
                                            <img src="@staff.AvatarUrl" alt="@staff.FullName" class="mr-4 h-10 w-10 flex-shrink-0 rounded-full bg-white object-contain" />
                                        }
                                        else
                                        {
                                            <div class="w-10 h-10 rounded-full @(isActive ? "bg-green-50 text-green-600" : "bg-gray-100 text-gray-500") flex items-center justify-center font-bold mr-4 flex-shrink-0">
                                                @(staff.FullName.Length > 0 ? staff.FullName.Substring(0, 1).ToUpper() : "A")
                                            </div>
                                        }
                                        <div>
                                            <div class="font-semibold text-gray-900 group-hover:text-gray-950 flex flex-wrap items-center gap-2">
                                                @staff.FullName
                                            </div>
                                            <div class="text-xs text-gray-500 mt-0.5">
                                                @staff.StaffCode
                                            </div>
                                        </div>
                                    </div>
                                </td>
                                <td class="py-4 px-6 text-gray-600 border-r border-gray-200">
                                    <div class="flex items-center mb-1 whitespace-nowrap">
                                        <svg class="w-3.5 h-3.5 mr-2 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
                                        @(string.IsNullOrWhiteSpace(staff.Email) ? "-" : staff.Email)
                                    </div>
                                    <div class="flex items-center whitespace-nowrap">
                                        <svg class="w-3.5 h-3.5 mr-2 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>
                                        @(string.IsNullOrWhiteSpace(staff.PhoneNumber) ? "-" : staff.PhoneNumber)
                                    </div>
                                </td>

                                <td class="py-4 px-6 text-center text-gray-600 border-r border-gray-200">
                                    @staff.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")
                                </td>
                                <td class="py-4 px-6 border-r border-gray-200">
                                    <form method="post" asp-page-handler="ToggleStatus" asp-route-StaffId="@staff.UserId" asp-route-nameCodeSearch="@Model.NameCodeSearch" asp-route-emailPhoneSearch="@Model.EmailPhoneSearch" asp-route-statusFilter="@Model.StatusFilter" asp-route-pageNumber="@Model.PageNumber" asp-route-pageSize="@Model.PageSize" class="flex justify-center">
                                        <button type="submit" class="inline-flex items-center gap-3 rounded-full border px-3 py-1.5 transition-colors @(isActive ? "border-green-200 bg-green-50 text-green-700 hover:bg-green-100" : "border-gray-200 bg-gray-100 text-gray-600 hover:bg-gray-200")" title="Đổi trạng thái">
                                            <span class="relative h-6 w-11 rounded-full transition-colors @(isActive ? "bg-green-500" : "bg-gray-300")">
                                                <span class="absolute top-0.5 h-5 w-5 rounded-full bg-white shadow transition-transform @(isActive ? "left-5" : "left-0.5")"></span>
                                            </span>
                                            <span class="min-w-20 text-left text-xs font-semibold">@(isActive ? "Hoạt động" : "Đã khóa")</span>
                                        </button>
                                    </form>
                                </td>
                                <td class="py-4 px-6">
                                    <div class="flex items-center justify-center gap-1.5 whitespace-nowrap">
                                        <a asp-page="/SystemAdmin/Staffs/Edit" asp-route-id="@staff.UserId" class="inline-flex h-8 w-8 items-center justify-center rounded-full border border-blue-500 bg-blue-50 text-blue-600 transition-colors hover:bg-blue-100" title="Xem chi tiết/Sửa">
                                            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.25 12s3.75-6.75 9.75-6.75S21.75 12 21.75 12 18 18.75 12 18.75 2.25 12 2.25 12z"></path><circle cx="12" cy="12" r="3" stroke-width="2"></circle></svg>
                                        </a>
                                        <button type="button" onclick="openDeleteStaffConfirm(this)" data-staff-id="@staff.UserId" data-staff-name="@staff.FullName" class="inline-flex h-8 w-8 items-center justify-center rounded-full border border-red-500 bg-red-50 text-red-500 transition-colors hover:bg-red-100" title="Xóa">
                                            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
                                        </button>
                                        <button type="button" onclick="openResetPasswordConfirm(this)" data-staff-id="@staff.UserId" data-staff-name="@staff.FullName" class="inline-flex h-8 w-8 items-center justify-center rounded-full border border-blue-500 bg-white text-blue-600 transition-colors hover:bg-blue-50" title="Cấp lại mật khẩu nhanh">
                                            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v6h6M20 20v-6h-6M19 9A7 7 0 007.05 4.05M5 15a7 7 0 0011.95 4.95"></path></svg>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>

        <div class="flex flex-wrap items-center justify-center gap-6 border-t border-gray-200 bg-white px-6 py-4 text-sm text-gray-600">
            <div class="flex items-center gap-1">
                <a asp-page="/SystemAdmin/Staffs/Index" asp-route-nameCodeSearch="@Model.NameCodeSearch" asp-route-emailPhoneSearch="@Model.EmailPhoneSearch" asp-route-statusFilter="@Model.StatusFilter" asp-route-pageNumber="1" asp-route-pageSize="@Model.PageSize" class="inline-flex h-9 w-9 items-center justify-center rounded text-gray-500 transition-colors hover:bg-blue-50 hover:text-blue-600 @(Model.PageNumber <= 1 ? "pointer-events-none opacity-40" : "")" title="Trang đầu">
                    <span class="text-lg">&laquo;</span>
                </a>
                <a asp-page="/SystemAdmin/Staffs/Index" asp-route-nameCodeSearch="@Model.NameCodeSearch" asp-route-emailPhoneSearch="@Model.EmailPhoneSearch" asp-route-statusFilter="@Model.StatusFilter" asp-route-pageNumber="@(Model.PageNumber - 1)" asp-route-pageSize="@Model.PageSize" class="inline-flex h-9 w-9 items-center justify-center rounded text-gray-500 transition-colors hover:bg-blue-50 hover:text-blue-600 @(Model.PageNumber <= 1 ? "pointer-events-none opacity-40" : "")" title="Trang trước">
                    <span class="text-lg">&lsaquo;</span>
                </a>

                @{
                    var startPage = Math.Max(1, Model.PageNumber - 2);
                    var endPage = Math.Min(Model.TotalPages, startPage + 4);
                    startPage = Math.Max(1, endPage - 4);
                }

                @for (var pageIndex = startPage; pageIndex <= endPage; pageIndex++)
                {
                    <a asp-page="/SystemAdmin/Staffs/Index" asp-route-nameCodeSearch="@Model.NameCodeSearch" asp-route-emailPhoneSearch="@Model.EmailPhoneSearch" asp-route-statusFilter="@Model.StatusFilter" asp-route-pageNumber="@pageIndex" asp-route-pageSize="@Model.PageSize" class="inline-flex h-9 min-w-9 items-center justify-center rounded px-3 font-medium transition-colors @(pageIndex == Model.PageNumber ? "bg-blue-100 text-blue-700" : "text-gray-600 hover:bg-blue-50 hover:text-blue-600")">
                        @pageIndex
                    </a>
                }

                <a asp-page="/SystemAdmin/Staffs/Index" asp-route-nameCodeSearch="@Model.NameCodeSearch" asp-route-emailPhoneSearch="@Model.EmailPhoneSearch" asp-route-statusFilter="@Model.StatusFilter" asp-route-pageNumber="@(Model.PageNumber + 1)" asp-route-pageSize="@Model.PageSize" class="inline-flex h-9 w-9 items-center justify-center rounded text-gray-500 transition-colors hover:bg-blue-50 hover:text-blue-600 @(Model.PageNumber >= Model.TotalPages ? "pointer-events-none opacity-40" : "")" title="Trang sau">
                    <span class="text-lg">&rsaquo;</span>
                </a>
                <a asp-page="/SystemAdmin/Staffs/Index" asp-route-nameCodeSearch="@Model.NameCodeSearch" asp-route-emailPhoneSearch="@Model.EmailPhoneSearch" asp-route-statusFilter="@Model.StatusFilter" asp-route-pageNumber="@Model.TotalPages" asp-route-pageSize="@Model.PageSize" class="inline-flex h-9 w-9 items-center justify-center rounded text-gray-500 transition-colors hover:bg-blue-50 hover:text-blue-600 @(Model.PageNumber >= Model.TotalPages ? "pointer-events-none opacity-40" : "")" title="Trang cuối">
                    <span class="text-lg">&raquo;</span>
                </a>
            </div>

            <div class="flex items-center gap-4">
                <span>Tổng số: @Model.TotalStaffs bản ghi</span>
                <form method="get" class="flex items-center">
                    <input type="hidden" name="NameCodeSearch" value="@Model.NameCodeSearch" />
                    <input type="hidden" name="EmailPhoneSearch" value="@Model.EmailPhoneSearch" />
                    <input type="hidden" name="StatusFilter" value="@Model.StatusFilter" />
                                        <input type="hidden" name="PageNumber" value="1" />
                    <select name="PageSize" onchange="this.form.submit()" class="h-10 rounded border border-blue-400 bg-white px-3 text-sm text-gray-700 shadow-sm focus:border-blue-500 focus:outline-none focus:ring-2 focus:ring-blue-100">
                        @foreach (var option in Model.PageSizeOptions)
                        {
                            <option value="@option" selected="@(Model.PageSize == option)">@option</option>
                        }
                    </select>
                </form>
            </div>
        </div>
    </div>
</div>

<div id="resetPasswordConfirmModal" class="fixed inset-0 z-[60] hidden items-center justify-center bg-black bg-opacity-50 px-4">
    <div class="w-full max-w-xl rounded bg-white shadow-2xl">
        <div class="flex items-center justify-end border-b border-gray-100 px-5 py-4">
            <button type="button" onclick="closeResetPasswordConfirm()" class="text-gray-500 hover:text-gray-700">
                <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
            </button>
        </div>
        <div class="flex items-start gap-4 px-6 py-6">
            <div class="mt-1 flex h-9 w-9 flex-shrink-0 items-center justify-center rounded-full border-2 border-gray-500 text-gray-600">
                <span class="text-xl font-semibold">i</span>
            </div>
            <div>
                <p class="text-sm text-gray-600">Bạn có muốn tiếp tục thay đổi mật khẩu của nhân sự này?</p>
                <p id="resetPasswordStaffName" class="mt-1 text-sm font-semibold text-gray-900"></p>
            </div>
        </div>
        <form id="resetPasswordForm" method="post" asp-page-handler="ResetPassword" asp-route-nameCodeSearch="@Model.NameCodeSearch" asp-route-emailPhoneSearch="@Model.EmailPhoneSearch" asp-route-statusFilter="@Model.StatusFilter" asp-route-pageNumber="@Model.PageNumber" asp-route-pageSize="@Model.PageSize">
            <input id="resetPasswordStaffId" type="hidden" name="StaffId" />
            <div class="flex justify-end gap-5 px-6 pb-6">
                <button type="button" onclick="closeResetPasswordConfirm()" class="text-sm font-semibold text-blue-600 hover:text-blue-700">Hủy</button>
                <button type="submit" class="rounded bg-blue-600 px-5 py-2 text-sm font-semibold text-white shadow-sm hover:bg-blue-700">Tiếp tục</button>
            </div>
        </form>
    </div>
</div>

<div id="resetPasswordResultModal" class="fixed inset-0 z-[60] hidden items-center justify-center bg-black bg-opacity-50 px-4">
    <div class="w-full max-w-lg rounded bg-white shadow-2xl">
        <div class="flex items-center justify-between border-b border-gray-100 px-6 py-5">
            <h3 class="text-xl font-bold text-gray-800">Mật khẩu mới</h3>
            <button type="button" onclick="closeResetPasswordResult()" class="flex h-10 w-10 items-center justify-center rounded-full border-2 border-blue-200 text-gray-500 hover:bg-blue-50">
                <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
            </button>
        </div>
        <div class="px-6 py-14 text-center">
            <p class="text-lg font-semibold text-gray-700">Mật khẩu mới là: <span class="text-gray-900">@Model.ResetPasswordValue</span></p>
            @if (!string.IsNullOrWhiteSpace(Model.ResetPasswordStaffName))
            {
                <p class="mt-2 text-sm text-gray-500">@Model.ResetPasswordStaffName</p>
            }
        </div>
    </div>
</div>

<div id="deleteStaffConfirmModal" class="fixed inset-0 z-[60] hidden items-center justify-center bg-black bg-opacity-50 px-4">
    <div class="w-full max-w-xl rounded bg-white shadow-2xl">
        <div class="flex items-center justify-end border-b border-gray-100 px-5 py-4">
            <button type="button" onclick="closeDeleteStaffConfirm()" class="text-gray-500 hover:text-gray-700">
                <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
            </button>
        </div>
        <div class="flex items-start gap-4 px-6 py-6">
            <div class="mt-1 flex h-10 w-10 flex-shrink-0 items-center justify-center rounded-full border-2 border-red-500 text-red-600">
                <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v4m0 4h.01M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"></path></svg>
            </div>
            <div>
                <p class="text-sm text-gray-700">Bạn có chắc chắn muốn xóa nhân sự này?</p>
                <p id="deleteStaffName" class="mt-1 text-sm font-semibold text-gray-900"></p>
                <p class="mt-3 text-xs text-gray-500">Thao tác này sẽ xóa nhân sự khỏi hệ thống (xóa mềm).</p>
            </div>
        </div>
        <form id="deleteStaffForm" method="post" asp-page-handler="Delete" asp-route-nameCodeSearch="@Model.NameCodeSearch" asp-route-emailPhoneSearch="@Model.EmailPhoneSearch" asp-route-statusFilter="@Model.StatusFilter" asp-route-pageNumber="@Model.PageNumber" asp-route-pageSize="@Model.PageSize">
            <input id="deleteStaffId" type="hidden" name="StaffId" />
            <div class="flex justify-end gap-5 px-6 pb-6">
                <button type="button" onclick="closeDeleteStaffConfirm()" class="text-sm font-semibold text-blue-600 hover:text-blue-700">Hủy</button>
                <button type="submit" class="rounded bg-red-600 px-5 py-2 text-sm font-semibold text-white shadow-sm hover:bg-red-700">Xóa</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.querySelectorAll('[data-search-dropdown]').forEach(dropdown => {
            const container = dropdown.parentElement;
            const hiddenInput = container.querySelector('[data-filter-value]');
            const toggle = dropdown.querySelector('[data-dropdown-toggle]');
            const panel = dropdown.querySelector('[data-dropdown-panel]');
            const label = dropdown.querySelector('[data-dropdown-label]');
            const options = Array.from(dropdown.querySelectorAll('[data-dropdown-option]'));

            function close() {
                panel.classList.add('hidden');
            }

            function open() {
                document.querySelectorAll('[data-dropdown-panel]').forEach(item => item.classList.add('hidden'));
                panel.classList.remove('hidden');
            }

            toggle.addEventListener('click', event => {
                event.stopPropagation();
                if (panel.classList.contains('hidden')) {
                    open();
                } else {
                    close();
                }
            });

            options.forEach(option => {
                option.addEventListener('click', () => {
                    hiddenInput.value = option.dataset.value || '';
                    label.textContent = option.dataset.label || option.textContent.trim();
                    close();
                });
            });

            document.addEventListener('click', event => {
                if (!dropdown.contains(event.target)) {
                    close();
                }
            });
        });

        function openResetPasswordConfirm(button) {
            const StaffId = button.dataset.staffId;
            const StaffName = button.dataset.staffName;
            document.getElementById('resetPasswordStaffId').value = StaffId;
            document.getElementById('resetPasswordStaffName').textContent = StaffName;
            const modal = document.getElementById('resetPasswordConfirmModal');
            modal.classList.remove('hidden');
            modal.classList.add('flex');
        }

        function closeResetPasswordConfirm() {
            const modal = document.getElementById('resetPasswordConfirmModal');
            modal.classList.add('hidden');
            modal.classList.remove('flex');
        }

        function openResetPasswordResult() {
            const modal = document.getElementById('resetPasswordResultModal');
            modal.classList.remove('hidden');
            modal.classList.add('flex');
        }

        function closeResetPasswordResult() {
            const modal = document.getElementById('resetPasswordResultModal');
            modal.classList.add('hidden');
            modal.classList.remove('flex');
        }

        function openDeleteStaffConfirm(button) {
            const StaffId = button.dataset.staffId;
            const StaffName = button.dataset.staffName;
            document.getElementById('deleteStaffId').value = StaffId;
            document.getElementById('deleteStaffName').textContent = StaffName;
            const modal = document.getElementById('deleteStaffConfirmModal');
            modal.classList.remove('hidden');
            modal.classList.add('flex');
        }

        function closeDeleteStaffConfirm() {
            const modal = document.getElementById('deleteStaffConfirmModal');
            modal.classList.add('hidden');
            modal.classList.remove('flex');
        }

        const hasResetPasswordValue = @Json.Serialize(!string.IsNullOrWhiteSpace(Model.ResetPasswordValue));
        if (hasResetPasswordValue) {
            openResetPasswordResult();
        }
    </script>
}
