@page
@model EduBridge.Pages.AdminDashboardModel
@{
    ViewData["Title"] = "Dashboard Quản trị viên";
    Layout = "_AdminLayout";
    ViewData["ActivePage"] = "AdminDashboard";
}

<div class="space-y-6 pb-20">
    <!-- Header -->
    <div>
        <h1 class="text-3xl font-bold text-gray-900">Dashboard</h1>
        <p class="text-gray-500 mt-1">Tổng quan hoạt động trung tâm</p>
    </div>

    <!-- Stat Cards -->
    <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-4">
        <!-- Card 1 -->
        <div class="rounded-2xl border border-gray-200 bg-white shadow-sm p-6">
            <div class="flex flex-row items-center justify-between pb-4">
                <h3 class="text-sm font-medium text-gray-600">Tổng số học sinh</h3>
                <div class="bg-blue-50 p-2.5 rounded-xl text-blue-500">
                    <svg class="w-5 h-5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                </div>
            </div>
            <div class="text-3xl font-bold text-gray-900">@Model.Dashboard.TotalStudents</div>
            <p class="text-xs text-green-500 font-medium mt-2">@Model.Dashboard.StudentChangeText</p>
        </div>

        <!-- Card 2 -->
        <div class="rounded-2xl border border-gray-200 bg-white shadow-sm p-6">
            <div class="flex flex-row items-center justify-between pb-4">
                <h3 class="text-sm font-medium text-gray-600">Số lớp đang hoạt động</h3>
                <div class="bg-green-50 p-2.5 rounded-xl text-green-500">
                    <svg class="w-5 h-5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21V5a2 2 0 0 0-2-2H7a2 2 0 0 0-2 2v16M14 21h2M8 21h2M3 21h18M9 7h6M9 11h6M9 15h6"></path></svg>
                </div>
            </div>
            <div class="text-3xl font-bold text-gray-900">@Model.Dashboard.ActiveClasses</div>
            <p class="text-xs text-green-500 font-medium mt-2">@Model.Dashboard.ClassChangeText</p>
        </div>

        <!-- Card 3 -->
        <div class="rounded-2xl border border-gray-200 bg-white shadow-sm p-6">
            <div class="flex flex-row items-center justify-between pb-4">
                <h3 class="text-sm font-medium text-gray-600">Doanh thu tháng này</h3>
                <div class="bg-purple-50 p-2.5 rounded-xl text-purple-500">
                    <svg class="w-5 h-5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
                </div>
            </div>
            <div class="text-3xl font-bold text-gray-900">@Model.Dashboard.MonthlyRevenue.ToString("N0") VNĐ</div>
            <p class="text-xs text-green-500 font-medium mt-2">@Model.Dashboard.RevenueChangeText</p>
        </div>

        <!-- Card 4 -->
        <div class="rounded-2xl border border-gray-200 bg-white shadow-sm p-6">
            <div class="flex flex-row items-center justify-between pb-4">
                <h3 class="text-sm font-medium text-gray-600">Tỷ lệ chuyên cần</h3>
                <div class="bg-orange-50 p-2.5 rounded-xl text-orange-500">
                    <svg class="w-5 h-5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 7 13.5 15.5 8.5 10.5 2 17"></polyline><polyline points="16 7 22 7 22 13"></polyline></svg>
                </div>
            </div>
            <div class="text-3xl font-bold text-gray-900">@Model.Dashboard.WeeklyAttendanceRate%</div>
            <p class="text-xs text-green-500 font-medium mt-2">@Model.Dashboard.AttendanceChangeText</p>
        </div>
    </div>

    <!-- Charts Row -->
    <div class="grid gap-6 md:grid-cols-2">
        <!-- Revenue Chart -->
        <div class="rounded-2xl border border-gray-200 bg-white shadow-sm p-6">
            <h3 class="text-sm font-semibold text-gray-900 mb-6">Doanh thu 6 tháng gần nhất</h3>
            <div class="relative h-64">
                <canvas id="revenueChart"></canvas>
            </div>
        </div>

        <!-- Attendance Chart -->
        <div class="rounded-2xl border border-gray-200 bg-white shadow-sm p-6">
            <h3 class="text-sm font-semibold text-gray-900 mb-6">Tình hình điểm danh tuần này</h3>
            <div class="relative h-64">
                <canvas id="attendanceChart"></canvas>
            </div>
        </div>
    </div>

    <!-- Bottom Row (Lớp học mới nhất & Thông báo quan trọng) -->
    <div class="grid gap-6 md:grid-cols-2">
        <div class="rounded-2xl border border-gray-200 bg-white shadow-sm p-6">
            <h3 class="text-sm font-bold text-gray-900 mb-6">Lớp học mới nhất</h3>
            <div class="space-y-4">
                @if (Model.Dashboard.LatestClasses.Count == 0)
                {
                    <div class="text-sm text-gray-500">Chưa có lớp học.</div>
                }
                else
                {
                    @foreach (var cls in Model.Dashboard.LatestClasses)
                    {
                        <div class="flex items-center justify-between border-b border-gray-100 pb-4">
                            <div>
                                <div class="font-bold text-gray-900 text-sm">@cls.ClassName</div>
                                <div class="text-xs text-gray-400 mt-1">GV: @cls.TeacherName</div>
                            </div>
                            <div class="text-sm font-bold text-gray-700">@cls.TotalStudents học sinh</div>
                        </div>
                    }
                }
            </div>
        </div>

        <div class="rounded-2xl border border-gray-200 bg-white shadow-sm p-6">
            <h3 class="text-sm font-bold text-gray-900 mb-6">Thông báo quan trọng</h3>
            <div class="space-y-4">
                @if (Model.Dashboard.ImportantNotifications.Count == 0)
                {
                    <div class="text-sm text-gray-500">Chưa có thông báo quan trọng.</div>
                }
                else
                {
                    @foreach (var notification in Model.Dashboard.ImportantNotifications)
                    {
                        <div class="border-b border-gray-100 pb-4">
                            <div class="font-bold @notification.LevelCssClass text-sm">@notification.Title</div>
                            <div class="text-xs text-gray-400 mt-1">@notification.Content</div>
                        </div>
                    }
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const revenueLabels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Dashboard.RevenueChartLabels));
            const revenueValues = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Dashboard.RevenueChartValues));
            const attendanceLabels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Dashboard.AttendanceChartLabels));
            const presentValues = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Dashboard.PresentChartValues));
            const absentValues = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Dashboard.AbsentChartValues));
            const maxRevenue = Math.max(...revenueValues, 0);
            const suggestedRevenueMax = maxRevenue > 0 ? maxRevenue * 1.2 : 1000000;
            const maxAttendance = Math.max(...presentValues, ...absentValues, 0);
            const suggestedAttendanceMax = maxAttendance > 0 ? Math.max(2, Math.ceil(maxAttendance * 1.25)) : 2;

            function formatVndShort(value) {
                if (value >= 1000000000) {
                    return (value / 1000000000).toFixed(1).replace('.0', '') + 'B';
                }

                if (value >= 1000000) {
                    return (value / 1000000).toFixed(1).replace('.0', '') + 'M';
                }

                if (value >= 1000) {
                    return (value / 1000).toFixed(0) + 'K';
                }

                return value;
            }

            // Chart.js defaults
            Chart.defaults.font.family = "'Inter', sans-serif";
            Chart.defaults.color = '#6b7280';
            Chart.defaults.scale.grid.color = '#f3f4f6';
            
            // Biểu đồ đường (Line Chart) cho Doanh thu
            var ctxRev = document.getElementById('revenueChart').getContext('2d');
            new Chart(ctxRev, {
                type: 'line',
                data: {
                    labels: revenueLabels,
                    datasets: [{
                        label: 'Doanh thu',
                        data: revenueValues,
                        borderColor: '#8b5cf6',
                        backgroundColor: '#8b5cf6',
                        tension: 0.4,
                        borderWidth: 2,
                        pointBackgroundColor: '#ffffff',
                        pointBorderColor: '#8b5cf6',
                        pointBorderWidth: 2,
                        pointRadius: 4,
                        pointHoverRadius: 6
                    }]
                },
                options: { 
                    responsive: true, 
                    maintainAspectRatio: false,
                    plugins: {
                        legend: { display: false },
                        tooltip: {
                            callbacks: {
                                label: function(context) {
                                    return new Intl.NumberFormat('vi-VN').format(context.parsed.y) + ' VNĐ';
                                }
                            }
                        }
                    },
                    scales: {
                        y: {
                            beginAtZero: true,
                            suggestedMax: suggestedRevenueMax,
                            ticks: {
                                callback: function(value) {
                                    return formatVndShort(value);
                                }
                            },
                            border: { dash: [4, 4] }
                        },
                        x: {
                            grid: { display: false }
                        }
                    }
                }
            });

            // Biểu đồ cột (Bar Chart) cho Điểm danh
            var ctxAtt = document.getElementById('attendanceChart').getContext('2d');
            new Chart(ctxAtt, {
                type: 'bar',
                data: {
                    labels: attendanceLabels,
                    datasets: [
                        { 
                            label: 'Có mặt', 
                            data: presentValues, 
                            backgroundColor: '#10b981',
                            barThickness: 32,
                            borderRadius: { topLeft: 4, topRight: 4 }
                        },
                        { 
                            label: 'Vắng mặt', 
                            data: absentValues, 
                            backgroundColor: '#ef4444',
                            barThickness: 32,
                            borderRadius: { topLeft: 4, topRight: 4 }
                        }
                    ]
                },
                options: { 
                    responsive: true, 
                    maintainAspectRatio: false,
                    plugins: {
                        legend: { 
                            position: 'bottom',
                            labels: {
                                usePointStyle: true,
                                boxWidth: 8,
                                boxHeight: 8,
                                padding: 20
                            }
                        }
                    },
                    scales: {
                        y: {
                            beginAtZero: true,
                            suggestedMax: suggestedAttendanceMax,
                            ticks: {
                                precision: 0,
                                stepSize: 1
                            },
                            border: { dash: [4, 4] }
                        },
                        x: {
                            grid: { display: false }
                        }
                    }
                }
            });
        });
    </script>
}
