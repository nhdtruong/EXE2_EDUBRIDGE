@page
@model EduBridge.Pages.AdminParentsModel
@{
    ViewData["Title"] = "Quản lý phụ huynh";
    Layout = "_AdminLayout";
    ViewData["ActivePage"] = "AdminParents";
}

<div class="mb-5">
    <h1 class="text-2xl font-bold text-gray-900">Quản lý phụ huynh</h1>
    <p class="mt-1 text-sm text-gray-500">Quản lý tài khoản phụ huynh và học sinh liên kết</p>
</div>

<section class="overflow-hidden rounded-xl bg-white shadow-sm ring-1 ring-gray-200">
    <div class="bg-blue-50/60 p-5">
        <h2 class="mb-4 text-base font-bold text-gray-900">Danh sách phụ huynh</h2>
        <form method="get" class="space-y-4">
            <input type="hidden" name="PageNumber" value="1">
            <input type="hidden" asp-for="PageSize">
            <div class="grid gap-3 md:grid-cols-2 xl:grid-cols-5">
            <div>
                <input asp-for="NameFilter" class="h-11 w-full rounded border border-gray-300 bg-white px-3 text-sm" placeholder="Tên phụ huynh">
            </div>
            <div>
                <input asp-for="EmailFilter" class="h-11 w-full rounded border border-gray-300 bg-white px-3 text-sm" placeholder="Email">
            </div>
            <div>
                <input asp-for="PhoneFilter" class="h-11 w-full rounded border border-gray-300 bg-white px-3 text-sm" placeholder="Số điện thoại">
            </div>
            <select asp-for="StatusFilter" class="h-11 w-full rounded border border-gray-300 bg-white px-3 text-sm">
                <option value="">Trạng thái</option><option value="Active">Đang hoạt động</option><option value="Inactive">Tạm dừng</option>
            </select>
            <select asp-for="ChildrenFilter" class="h-11 w-full rounded border border-gray-300 bg-white px-3 text-sm">
                <option value="">Liên kết học sinh</option><option value="yes">Có học sinh</option><option value="no">Chưa có học sinh</option>
            </select>
            </div>
            <div class="flex flex-wrap items-center justify-between gap-3">
                <a asp-page="/AdminParents/Create" class="inline-flex h-10 items-center rounded bg-blue-600 px-4 text-sm font-semibold text-white"><span class="mr-2 text-lg">+</span>Thêm phụ huynh</a>
                <div class="flex gap-3">
                    <a asp-page="/AdminParents" class="inline-flex h-10 items-center rounded bg-slate-700 px-4 text-sm font-semibold text-white">Làm mới bộ lọc</a>
                    <button class="inline-flex h-10 items-center rounded bg-blue-600 px-4 text-sm font-semibold text-white">Tìm kiếm</button>
                </div>
            </div>
        </form>
    </div>
    <div asp-validation-summary="ModelOnly" class="px-4 py-2 text-sm font-semibold text-red-600"></div>
    <div class="overflow-x-auto">
        <table class="min-w-full text-sm">
            <thead class="bg-slate-100 text-gray-800"><tr>
                <th class="border-r border-slate-200 px-4 py-4 text-center">STT</th>
                <th class="border-r border-slate-200 px-4 py-4 text-center">ID</th>
                <th class="border-r border-slate-200 px-5 py-4 text-left">Phụ huynh</th>
                <th class="border-r border-slate-200 px-5 py-4 text-left">Email</th>
                <th class="border-r border-slate-200 px-5 py-4 text-left">Số điện thoại</th>
                <th class="border-r border-slate-200 px-5 py-4 text-left">Học sinh liên kết</th>
                <th class="border-r border-slate-200 px-4 py-4 text-center">Ngày tạo</th>
                <th class="border-r border-slate-200 px-5 py-4 text-center">Trạng thái tại trung tâm</th>
                <th class="px-5 py-4 text-center">Thao tác</th>
            </tr></thead>
            <tbody class="divide-y divide-gray-200">
            @if (Model.Result.Items.Count == 0)
            {
                <tr><td colspan="9" class="px-6 py-10 text-center text-gray-500">Chưa có phụ huynh phù hợp.</td></tr>
            }
            @for (var i = 0; i < Model.Result.Items.Count; i++)
            {
                var item = Model.Result.Items[i];
                <tr class="hover:bg-blue-50/50">
                    <td class="border-r border-gray-200 px-4 py-4 text-center">@((Model.Result.Page - 1) * Model.Result.PageSize + i + 1)</td>
                    <td class="border-r border-gray-200 px-4 py-4 text-center">@item.UserId</td>
                    <td class="border-r border-gray-200 px-5 py-4"><div class="font-semibold text-gray-900">@item.FullName</div></td>
                    <td class="border-r border-gray-200 px-5 py-4 text-gray-600">@(item.Email ?? "-")</td>
                    <td class="border-r border-gray-200 px-5 py-4 text-gray-600">@(item.PhoneNumber ?? "-")</td>
                    <td class="border-r border-gray-200 px-5 py-4"><div class="font-semibold">@item.ChildrenCount học sinh</div><div class="max-w-64 truncate text-gray-500" title="@string.Join(", ", item.ChildrenNames)">@string.Join(", ", item.ChildrenNames)</div></td>
                    <td class="border-r border-gray-200 px-4 py-4 text-center">@item.CreatedAt.ToString("dd/MM/yyyy")</td>
                    <td class="border-r border-gray-200 px-5 py-4 text-center">
                        <form method="post" asp-page-handler="ToggleStatus" asp-route-parentUserId="@item.UserId" asp-route-currentStatus="@item.Status">
                            <input type="hidden" asp-for="NameFilter"><input type="hidden" asp-for="EmailFilter"><input type="hidden" asp-for="PhoneFilter"><input type="hidden" asp-for="StatusFilter"><input type="hidden" asp-for="ChildrenFilter"><input type="hidden" asp-for="PageNumber"><input type="hidden" asp-for="PageSize">
                            <button class="inline-flex items-center gap-3 rounded-full border px-3 py-1.5 text-xs font-semibold transition-colors @(item.Status == "Active" ? "border-green-200 bg-green-50 text-green-700 hover:bg-green-100" : "border-gray-200 bg-gray-100 text-gray-600 hover:bg-gray-200")" title="Đổi trạng thái phụ huynh tại trung tâm">
                                <span class="relative h-6 w-11 rounded-full @(item.Status == "Active" ? "bg-green-500" : "bg-gray-300")"><span class="absolute top-0.5 h-5 w-5 rounded-full bg-white shadow @(item.Status == "Active" ? "left-5" : "left-0.5")"></span></span>
                                <span class="min-w-20 text-left">@(item.Status == "Active" ? "Đang hoạt động" : "Tạm dừng")</span>
                            </button>
                        </form>
                    </td>
                    <td class="px-5 py-4 text-center"><div class="flex justify-center gap-3"><a asp-page="/AdminParents/Edit" asp-route-id="@item.UserId" class="inline-flex h-11 w-11 items-center justify-center rounded-full border border-blue-500 bg-blue-50 text-blue-600 transition-colors hover:bg-blue-100" title="Xem chi tiết/Sửa">
                        <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2 12s3.5-7 10-7 10 7 10 7-3.5 7-10 7S2 12 2 12z"/><circle cx="12" cy="12" r="3"/></svg>
                    </a>
                    <button type="button" data-reset-parent="@item.UserId" data-parent-name="@item.FullName" class="inline-flex h-11 w-11 items-center justify-center rounded-full border border-blue-500 bg-white text-blue-600 transition-colors hover:bg-blue-50" title="Cấp lại mật khẩu nhanh">
                            <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v6h6M20 20v-6h-6M19 9A7 7 0 007.05 4.05M5 15a7 7 0 0011.95 4.95"></path></svg>
                    </button>
                    <button type="button" data-delete-parent="@item.UserId" data-parent-name="@item.FullName" class="inline-flex h-11 w-11 items-center justify-center rounded-full border border-red-500 bg-red-50 text-red-500 transition-colors hover:bg-red-100" title="Xóa phụ huynh">
                        <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
                    </button>
                    </div></td>
                </tr>
            }
            </tbody>
        </table>
    </div>
    <div class="flex flex-wrap items-center justify-center gap-6 border-t border-gray-200 bg-white px-6 py-4 text-sm text-gray-600">
        <div class="flex items-center gap-1">
            <a asp-route-pageNumber="1" asp-route-pageSize="@Model.Result.PageSize" asp-route-nameFilter="@Model.NameFilter" asp-route-emailFilter="@Model.EmailFilter" asp-route-phoneFilter="@Model.PhoneFilter" asp-route-statusFilter="@Model.StatusFilter" asp-route-childrenFilter="@Model.ChildrenFilter" class="inline-flex h-9 w-9 items-center justify-center rounded text-gray-500 hover:bg-blue-50 hover:text-blue-600 @(Model.Result.Page <= 1 ? "pointer-events-none opacity-40" : "")">«</a>
            <a asp-route-pageNumber="@(Math.Max(1, Model.Result.Page - 1))" asp-route-pageSize="@Model.Result.PageSize" asp-route-nameFilter="@Model.NameFilter" asp-route-emailFilter="@Model.EmailFilter" asp-route-phoneFilter="@Model.PhoneFilter" asp-route-statusFilter="@Model.StatusFilter" asp-route-childrenFilter="@Model.ChildrenFilter" class="inline-flex h-9 w-9 items-center justify-center rounded text-gray-500 hover:bg-blue-50 hover:text-blue-600 @(Model.Result.Page <= 1 ? "pointer-events-none opacity-40" : "")">‹</a>
            @for (var pageIndex = Math.Max(1, Model.Result.Page - 2); pageIndex <= Math.Min(Model.Result.TotalPages, Model.Result.Page + 2); pageIndex++)
            {
                <a asp-route-pageNumber="@pageIndex" asp-route-pageSize="@Model.Result.PageSize" asp-route-nameFilter="@Model.NameFilter" asp-route-emailFilter="@Model.EmailFilter" asp-route-phoneFilter="@Model.PhoneFilter" asp-route-statusFilter="@Model.StatusFilter" asp-route-childrenFilter="@Model.ChildrenFilter" class="inline-flex h-9 min-w-9 items-center justify-center rounded px-3 @(pageIndex == Model.Result.Page ? "bg-blue-100 font-semibold text-blue-700" : "text-gray-600 hover:bg-blue-50 hover:text-blue-600")">@pageIndex</a>
            }
            <a asp-route-pageNumber="@(Math.Min(Model.Result.TotalPages, Model.Result.Page + 1))" asp-route-pageSize="@Model.Result.PageSize" asp-route-nameFilter="@Model.NameFilter" asp-route-emailFilter="@Model.EmailFilter" asp-route-phoneFilter="@Model.PhoneFilter" asp-route-statusFilter="@Model.StatusFilter" asp-route-childrenFilter="@Model.ChildrenFilter" class="inline-flex h-9 w-9 items-center justify-center rounded text-gray-500 hover:bg-blue-50 hover:text-blue-600 @(Model.Result.Page >= Model.Result.TotalPages ? "pointer-events-none opacity-40" : "")">›</a>
            <a asp-route-pageNumber="@Model.Result.TotalPages" asp-route-pageSize="@Model.Result.PageSize" asp-route-nameFilter="@Model.NameFilter" asp-route-emailFilter="@Model.EmailFilter" asp-route-phoneFilter="@Model.PhoneFilter" asp-route-statusFilter="@Model.StatusFilter" asp-route-childrenFilter="@Model.ChildrenFilter" class="inline-flex h-9 w-9 items-center justify-center rounded text-gray-500 hover:bg-blue-50 hover:text-blue-600 @(Model.Result.Page >= Model.Result.TotalPages ? "pointer-events-none opacity-40" : "")">»</a>
        </div>
        <span class="font-medium">Tổng số: @Model.Result.TotalItems bản ghi</span>
        <form method="get" class="flex items-center">
            <input type="hidden" asp-for="NameFilter"><input type="hidden" asp-for="EmailFilter"><input type="hidden" asp-for="PhoneFilter"><input type="hidden" asp-for="StatusFilter"><input type="hidden" asp-for="ChildrenFilter"><input type="hidden" name="PageNumber" value="1">
            <select name="PageSize" onchange="this.form.submit()" class="h-10 rounded border border-blue-400 bg-white px-3 text-sm text-gray-700">
                @foreach (var size in new[] { 10, 20, 50, 100, 200, 500 }) { <option value="@size" selected="@(Model.Result.PageSize == size)">@size</option> }
            </select>
        </form>
    </div>
</section>

<div id="resetPasswordConfirmModal" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/50 p-4">
    <div class="w-full max-w-md rounded-xl bg-white shadow-2xl">
        <div class="flex items-center justify-between border-b px-5 py-4">
            <h2 class="text-lg font-bold">Cấp lại mật khẩu</h2>
            <button type="button" data-close-reset-confirm class="text-2xl text-gray-400">&times;</button>
        </div>
        <div class="p-6 text-sm text-gray-700">
            Bạn có chắc muốn cấp lại mật khẩu cho <strong id="resetParentName" class="text-gray-900"></strong>?
            Mật khẩu hiện tại sẽ không còn sử dụng được.
        </div>
        <div class="flex justify-end gap-3 border-t px-5 py-4">
            <button type="button" data-close-reset-confirm class="rounded border border-gray-300 px-5 py-2 text-sm font-semibold">Hủy</button>
            <form method="post" asp-page-handler="ResetPassword">
                <input id="resetParentUserId" name="parentUserId" type="hidden">
                <input type="hidden" asp-for="NameFilter"><input type="hidden" asp-for="EmailFilter"><input type="hidden" asp-for="PhoneFilter"><input type="hidden" asp-for="StatusFilter"><input type="hidden" asp-for="ChildrenFilter"><input type="hidden" asp-for="PageNumber"><input type="hidden" asp-for="PageSize">
                <button type="submit" class="rounded bg-blue-600 px-5 py-2 text-sm font-semibold text-white">Cấp mật khẩu</button>
            </form>
        </div>
    </div>
</div>

@if (!string.IsNullOrWhiteSpace(Model.ResetPasswordResult))
{
    <div id="resetPasswordResultModal" class="fixed inset-0 z-50 flex items-center justify-center bg-black/50 p-4">
        <div class="w-full max-w-md rounded-xl bg-white shadow-2xl">
            <div class="flex items-center justify-between border-b px-5 py-4"><h2 class="text-lg font-bold">Mật khẩu mới</h2><button type="button" onclick="document.getElementById('resetPasswordResultModal').remove()" class="text-2xl text-gray-400">&times;</button></div>
            <div class="p-6 text-center"><p class="text-sm text-gray-600">Mật khẩu tạm thời chỉ hiển thị một lần:</p><div class="mt-3 text-3xl font-bold tracking-widest text-blue-700">@Model.ResetPasswordResult</div></div>
            <div class="flex justify-end border-t px-5 py-4"><button type="button" onclick="document.getElementById('resetPasswordResultModal').remove()" class="rounded bg-blue-600 px-5 py-2 text-sm font-semibold text-white">Đóng</button></div>
        </div>
    </div>
}

<div id="deleteParentConfirmModal" class="fixed inset-0 z-[60] hidden items-center justify-center bg-black bg-opacity-50 px-4">
    <div class="w-full max-w-xl rounded bg-white shadow-2xl">
        <div class="flex items-center justify-end border-b border-gray-100 px-5 py-4">
            <button type="button" data-close-delete-confirm class="text-gray-500 hover:text-gray-700">
                <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
            </button>
        </div>
        <div class="flex items-start gap-4 px-6 py-6">
            <div class="mt-1 flex h-10 w-10 flex-shrink-0 items-center justify-center rounded-full border-2 border-red-500 text-red-600">
                <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v4m0 4h.01M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"></path></svg>
            </div>
            <div>
                <p class="text-sm text-gray-700">Bạn có chắc chắn muốn xóa tài khoản phụ huynh này?</p>
                <p id="deleteParentName" class="mt-1 text-sm font-semibold text-gray-900"></p>
                <p class="mt-3 text-xs text-gray-500">Hệ thống sẽ chặn tính năng xóa nếu phụ huynh đang quản lý học sinh ở trạng thái "Đang hoạt động".</p>
            </div>
        </div>
        <form method="post" asp-page-handler="Delete">
            <input id="deleteParentUserId" type="hidden" name="parentUserId" />
            <input type="hidden" asp-for="NameFilter"><input type="hidden" asp-for="EmailFilter"><input type="hidden" asp-for="PhoneFilter"><input type="hidden" asp-for="StatusFilter"><input type="hidden" asp-for="ChildrenFilter"><input type="hidden" asp-for="PageNumber"><input type="hidden" asp-for="PageSize">
            <div class="flex justify-end gap-5 px-6 pb-6">
                <button type="button" data-close-delete-confirm class="text-sm font-semibold text-blue-600 hover:text-blue-700">Hủy</button>
                <button type="submit" class="rounded bg-red-600 px-5 py-2 text-sm font-semibold text-white shadow-sm hover:bg-red-700">Xóa</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        (() => {
            const modal = document.getElementById('resetPasswordConfirmModal');
            const parentId = document.getElementById('resetParentUserId');
            const parentName = document.getElementById('resetParentName');
            const close = () => {
                modal?.classList.add('hidden');
                modal?.classList.remove('flex');
            };

            document.querySelectorAll('[data-reset-parent]').forEach(button => button.addEventListener('click', () => {
                parentId.value = button.dataset.resetParent;
                parentName.textContent = button.dataset.parentName || 'phụ huynh này';
                modal?.classList.remove('hidden');
                modal?.classList.add('flex');
            }));
            document.querySelectorAll('[data-close-reset-confirm]').forEach(button => button.addEventListener('click', close));
            modal?.addEventListener('click', event => {
                if (event.target === modal) close();
            });

            // Delete Modal
            const deleteModal = document.getElementById('deleteParentConfirmModal');
            const deleteParentId = document.getElementById('deleteParentUserId');
            const deleteParentName = document.getElementById('deleteParentName');
            const closeDelete = () => {
                deleteModal?.classList.add('hidden');
                deleteModal?.classList.remove('flex');
            };

            document.querySelectorAll('[data-delete-parent]').forEach(button => button.addEventListener('click', () => {
                deleteParentId.value = button.dataset.deleteParent;
                deleteParentName.textContent = button.dataset.parentName || 'phụ huynh này';
                deleteModal?.classList.remove('hidden');
                deleteModal?.classList.add('flex');
            }));
            document.querySelectorAll('[data-close-delete-confirm]').forEach(button => button.addEventListener('click', closeDelete));
            deleteModal?.addEventListener('click', event => {
                if (event.target === deleteModal) closeDelete();
            });
        })();
    </script>
}
