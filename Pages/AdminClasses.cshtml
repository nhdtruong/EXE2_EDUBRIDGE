@page
@model EduBridge.Pages.AdminClassesModel
@{
    ViewData["Title"] = "Quản lý lớp học";
    Layout = "_AdminLayout";
    ViewData["ActivePage"] = "AdminClasses";
    var selectedRoomStatusText = Model.RoomStatusFilter switch
    {
        "Active" => "Đang sử dụng",
        "Inactive" => "Tạm dừng",
        "Maintenance" => "Bảo trì",
        _ => "Trạng thái"
    };
    var selectedShiftStatusText = Model.ShiftStatusFilter switch
    {
        "Active" => "Đang sử dụng",
        "Inactive" => "Tạm dừng",
        _ => "Trạng thái"
    };
    var selectedClassCourseText = Model.ClassCourseId is > 0
        ? Model.CourseOptions.FirstOrDefault(course => course.CourseId == Model.ClassCourseId)?.CourseName ?? "Môn học"
        : "Môn học";
    var selectedClassStatusText = Model.ClassStatusFilter switch
    {
        "Active" => "Đang hoạt động",
        "Inactive" => "Tạm dừng",
        "Closed" => "Đã đóng",
        _ => "Trạng thái"
    };
    var selectedClassRoomText = Model.ClassRoomId is > 0
        ? Model.RoomOptions.FirstOrDefault(room => room.RoomId == Model.ClassRoomId)?.DisplayName ?? "Phòng học"
        : "Phòng học";
}

<div class="space-y-6 pb-20">
    <!-- Header -->
    <div class="flex justify-between items-start">
        <div>
            <h1 class="text-3xl font-bold text-gray-900">Quản lý lớp học</h1>
            <p class="text-gray-500 mt-1">Quản lý thông tin các lớp học</p>
        </div>
    </div>

    <div class="flex gap-2 border-b border-gray-200">
        <a asp-page="/AdminClasses" asp-route-tab="classes" asp-route-search="@Model.Search" asp-route-classTeacherSearch="@Model.ClassTeacherSearch" asp-route-classCourseId="@Model.ClassCourseId" asp-route-classStatusFilter="@Model.ClassStatusFilter" asp-route-classStartDateFrom="@Model.ClassStartDateFrom" asp-route-classStartDateTo="@Model.ClassStartDateTo" asp-route-classEndDateFrom="@Model.ClassEndDateFrom" asp-route-classEndDateTo="@Model.ClassEndDateTo" asp-route-classRoomId="@Model.ClassRoomId" asp-route-classPageSize="@Model.ClassPageSize" class="border-b-2 px-4 py-3 text-sm font-semibold transition-colors @(!Model.IsRoomsTab && !Model.IsShiftsTab ? "border-blue-600 text-blue-600" : "border-transparent text-gray-500 hover:text-gray-900")">
            Danh sách lớp học
        </a>
        <a asp-page="/AdminClasses" asp-route-tab="rooms" asp-route-roomPageSize="@Model.RoomPageSize" class="border-b-2 px-4 py-3 text-sm font-semibold transition-colors @(Model.IsRoomsTab ? "border-blue-600 text-blue-600" : "border-transparent text-gray-500 hover:text-gray-900")">
            Quản lý phòng học
        </a>
        <a asp-page="/AdminClasses" asp-route-tab="shifts" asp-route-shiftPageSize="@Model.ShiftPageSize" class="border-b-2 px-4 py-3 text-sm font-semibold transition-colors @(Model.IsShiftsTab ? "border-blue-600 text-blue-600" : "border-transparent text-gray-500 hover:text-gray-900")">
            Quản lý ca học
        </a>
    </div>

    <!-- Main Card -->
    <div class="rounded-2xl border border-gray-200 bg-white shadow-sm">
        <div class="rounded-t-2xl border-b border-blue-100 bg-blue-50/60 p-6">
            <h3 class="text-base font-bold text-gray-900">@(Model.IsRoomsTab ? "Quản lý phòng học" : Model.IsShiftsTab ? "Quản lý ca học" : "Danh sách lớp học")</h3>
            @if (Model.IsRoomsTab)
            {
                <form method="get" class="mt-5">
                    <input type="hidden" name="Tab" value="rooms" />
                    <input type="hidden" name="RoomPageNumber" value="1" />
                    <input type="hidden" name="RoomPageSize" value="@Model.RoomPageSize" />
                    <div class="flex flex-col gap-3">
                        <div class="flex flex-wrap items-start gap-3">
                            <input type="text" name="RoomSearch" value="@Model.RoomSearch" maxlength="150" class="block h-12 w-full max-w-80 rounded border border-gray-300 bg-white px-4 text-sm text-gray-900 placeholder-gray-500 focus:border-blue-500 focus:outline-none focus:ring-1 focus:ring-blue-500" placeholder="Tìm mã phòng, tên phòng">
                            <div class="relative w-full max-w-80" data-search-dropdown>
                                <input type="hidden" name="RoomStatusFilter" value="@Model.RoomStatusFilter" data-filter-value="room-status" />
                                <button type="button" data-dropdown-toggle class="flex h-12 w-full items-center justify-between rounded border border-gray-300 bg-white px-4 text-left text-sm text-gray-600 focus:border-blue-500 focus:outline-none focus:ring-1 focus:ring-blue-500">
                                    <span data-dropdown-label>@selectedRoomStatusText</span>
                                    <svg class="h-4 w-4 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
                                </button>
                                <div data-dropdown-panel class="absolute left-0 top-[calc(100%+4px)] z-40 hidden w-full rounded border border-gray-300 bg-white shadow-lg">
                                    <div class="relative p-2">
                                        <input type="text" data-dropdown-search class="h-11 w-full rounded border border-blue-400 px-3 pr-9 text-sm focus:outline-none focus:ring-1 focus:ring-blue-500">
                                        <svg class="absolute right-5 top-5 h-4 w-4 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
                                    </div>
                                    <button type="button" data-dropdown-option data-value="" data-label="Trạng thái" class="block w-full px-4 py-2 text-left text-sm hover:bg-blue-50">Tất cả</button>
                                    <button type="button" data-dropdown-option data-value="Active" data-label="Đang sử dụng" class="block w-full px-4 py-2 text-left text-sm hover:bg-blue-50">Đang sử dụng</button>
                                    <button type="button" data-dropdown-option data-value="Inactive" data-label="Tạm dừng" class="block w-full px-4 py-2 text-left text-sm hover:bg-blue-50">Tạm dừng</button>
                                    <button type="button" data-dropdown-option data-value="Maintenance" data-label="Bảo trì" class="block w-full px-4 py-2 text-left text-sm hover:bg-blue-50">Bảo trì</button>
                                </div>
                            </div>
                            <div class="ml-auto flex flex-wrap items-start gap-3">
                                <a asp-page="/AdminClasses" asp-route-tab="rooms" asp-route-roomPageSize="@Model.RoomPageSize" class="inline-flex h-12 min-w-32 items-center justify-center rounded bg-slate-600 px-4 text-sm font-semibold text-white shadow-sm transition-colors hover:bg-slate-700">Làm mới bộ lọc</a>
                                <button type="submit" class="inline-flex h-12 min-w-32 items-center justify-center rounded bg-blue-600 px-4 text-sm font-semibold text-white shadow-sm transition-colors hover:bg-blue-700">
                                    <svg class="mr-2 h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
                                    Tìm kiếm
                                </button>
                            </div>
                        </div>
                        <div>
                            <button type="button" onclick="openCreateRoomModal()" class="mt-3 inline-flex h-11 items-center rounded bg-blue-600 px-4 text-sm font-semibold text-white shadow-sm transition-colors hover:bg-blue-700">
                                <svg class="mr-2 h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
                                Thêm phòng học
                            </button>
                        </div>
                    </div>
                </form>
            }
            else if (Model.IsShiftsTab)
            {
                <form method="get" class="mt-5">
                    <input type="hidden" name="Tab" value="shifts" />
                    <input type="hidden" name="ShiftPageNumber" value="1" />
                    <input type="hidden" name="ShiftPageSize" value="@Model.ShiftPageSize" />
                    <div class="flex flex-col gap-3">
                        <div class="flex flex-wrap items-start gap-3">
                            <input type="text" name="ShiftSearch" value="@Model.ShiftSearch" maxlength="150" class="block h-12 w-full max-w-80 rounded border border-gray-300 bg-white px-4 text-sm text-gray-900 placeholder-gray-500 focus:border-blue-500 focus:outline-none focus:ring-1 focus:ring-blue-500" placeholder="Tìm mã ca, tên ca">
                            <div class="relative w-full max-w-80" data-search-dropdown>
                                <input type="hidden" name="ShiftStatusFilter" value="@Model.ShiftStatusFilter" data-filter-value="shift-status" />
                                <button type="button" data-dropdown-toggle class="flex h-12 w-full items-center justify-between rounded border border-gray-300 bg-white px-4 text-left text-sm text-gray-600 focus:border-blue-500 focus:outline-none focus:ring-1 focus:ring-blue-500">
                                    <span data-dropdown-label>@selectedShiftStatusText</span>
                                    <svg class="h-4 w-4 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
                                </button>
                                <div data-dropdown-panel class="absolute left-0 top-[calc(100%+4px)] z-40 hidden w-full rounded border border-gray-300 bg-white shadow-lg">
                                    <div class="relative p-2">
                                        <input type="text" data-dropdown-search class="h-11 w-full rounded border border-blue-400 px-3 pr-9 text-sm focus:outline-none focus:ring-1 focus:ring-blue-500">
                                        <svg class="absolute right-5 top-5 h-4 w-4 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
                                    </div>
                                    <button type="button" data-dropdown-option data-value="" data-label="Trạng thái" class="block w-full px-4 py-2 text-left text-sm hover:bg-blue-50">Tất cả</button>
                                    <button type="button" data-dropdown-option data-value="Active" data-label="Đang sử dụng" class="block w-full px-4 py-2 text-left text-sm hover:bg-blue-50">Đang sử dụng</button>
                                    <button type="button" data-dropdown-option data-value="Inactive" data-label="Tạm dừng" class="block w-full px-4 py-2 text-left text-sm hover:bg-blue-50">Tạm dừng</button>
                                </div>
                            </div>
                            <div class="ml-auto flex flex-wrap items-start gap-3">
                                <a asp-page="/AdminClasses" asp-route-tab="shifts" asp-route-shiftPageSize="@Model.ShiftPageSize" class="inline-flex h-12 min-w-32 items-center justify-center rounded bg-slate-600 px-4 text-sm font-semibold text-white shadow-sm transition-colors hover:bg-slate-700">Làm mới bộ lọc</a>
                                <button type="submit" class="inline-flex h-12 min-w-32 items-center justify-center rounded bg-blue-600 px-4 text-sm font-semibold text-white shadow-sm transition-colors hover:bg-blue-700">
                                    <svg class="mr-2 h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
                                    Tìm kiếm
                                </button>
                            </div>
                        </div>
                        <div>
                            <button type="button" onclick="openCreateShiftModal()" class="mt-3 inline-flex h-11 items-center rounded bg-blue-600 px-4 text-sm font-semibold text-white shadow-sm transition-colors hover:bg-blue-700">
                                <svg class="mr-2 h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
                                Thêm ca học
                            </button>
                        </div>
                    </div>
                </form>
            }
            else
            {
                <form method="get" class="mt-5">
                    <input type="hidden" name="Tab" value="classes" />
                    <input type="hidden" name="ClassPageNumber" value="1" />
                    <input type="hidden" name="ClassPageSize" value="@Model.ClassPageSize" />
                    <div class="space-y-3">
                        <div class="grid grid-cols-1 gap-3 md:grid-cols-2 xl:grid-cols-5">
                        <input type="text" name="Search" value="@Model.Search" maxlength="150" class="block h-12 w-full rounded border border-gray-300 bg-white px-4 text-sm text-gray-900 placeholder-gray-500 focus:border-blue-500 focus:outline-none focus:ring-1 focus:ring-blue-500" placeholder="Tìm tên/mã lớp">
                        <input type="text" name="ClassTeacherSearch" value="@Model.ClassTeacherSearch" maxlength="150" class="block h-12 w-full rounded border border-gray-300 bg-white px-4 text-sm text-gray-900 placeholder-gray-500 focus:border-blue-500 focus:outline-none focus:ring-1 focus:ring-blue-500" placeholder="Tên giáo viên">
                        <div class="relative w-full" data-search-dropdown>
                            <input type="hidden" name="ClassCourseId" value="@Model.ClassCourseId" data-filter-value="class-course" />
                            <button type="button" data-dropdown-toggle class="flex h-12 w-full items-center justify-between rounded border border-gray-300 bg-white px-4 text-left text-sm text-gray-600 focus:border-blue-500 focus:outline-none focus:ring-1 focus:ring-blue-500">
                                <span data-dropdown-label>@selectedClassCourseText</span>
                                <svg class="h-4 w-4 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
                            </button>
                            <div data-dropdown-panel class="absolute left-0 top-[calc(100%+4px)] z-40 hidden max-h-72 w-full overflow-y-auto rounded border border-gray-300 bg-white shadow-lg">
                                <div class="relative p-2">
                                    <input type="text" data-dropdown-search class="h-11 w-full rounded border border-blue-400 px-3 pr-9 text-sm focus:outline-none focus:ring-1 focus:ring-blue-500">
                                    <svg class="absolute right-5 top-5 h-4 w-4 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
                                </div>
                                <button type="button" data-dropdown-option data-value="" data-label="Môn học" class="block w-full px-4 py-2 text-left text-sm hover:bg-blue-50">Tất cả môn học</button>
                                @foreach (var course in Model.CourseOptions)
                                {
                                    <button type="button" data-dropdown-option data-value="@course.CourseId" data-label="@course.CourseName" class="block w-full px-4 py-2 text-left text-sm hover:bg-blue-50">@course.CourseName</button>
                                }
                            </div>
                        </div>
                        <div class="relative w-full" data-search-dropdown>
                            <input type="hidden" name="ClassRoomId" value="@Model.ClassRoomId" data-filter-value="class-room" />
                            <button type="button" data-dropdown-toggle class="flex h-12 w-full items-center justify-between rounded border border-gray-300 bg-white px-4 text-left text-sm text-gray-600 focus:border-blue-500 focus:outline-none focus:ring-1 focus:ring-blue-500">
                                <span data-dropdown-label>@selectedClassRoomText</span>
                                <svg class="h-4 w-4 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
                            </button>
                            <div data-dropdown-panel class="absolute left-0 top-[calc(100%+4px)] z-40 hidden max-h-72 w-full overflow-y-auto rounded border border-gray-300 bg-white shadow-lg">
                                <div class="relative p-2">
                                    <input type="text" data-dropdown-search class="h-11 w-full rounded border border-blue-400 px-3 pr-9 text-sm focus:outline-none focus:ring-1 focus:ring-blue-500">
                                    <svg class="absolute right-5 top-5 h-4 w-4 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
                                </div>
                                <button type="button" data-dropdown-option data-value="" data-label="Phòng học" class="block w-full px-4 py-2 text-left text-sm hover:bg-blue-50">Tất cả phòng học</button>
                                @foreach (var room in Model.RoomOptions)
                                {
                                    <button type="button" data-dropdown-option data-value="@room.RoomId" data-label="@room.DisplayName" class="block w-full px-4 py-2 text-left text-sm hover:bg-blue-50">@room.DisplayName</button>
                                }
                            </div>
                        </div>
                        <div class="relative w-full" data-search-dropdown>
                            <input type="hidden" name="ClassStatusFilter" value="@Model.ClassStatusFilter" data-filter-value="class-status" />
                            <button type="button" data-dropdown-toggle class="flex h-12 w-full items-center justify-between rounded border border-gray-300 bg-white px-4 text-left text-sm text-gray-600 focus:border-blue-500 focus:outline-none focus:ring-1 focus:ring-blue-500">
                                <span data-dropdown-label>@selectedClassStatusText</span>
                                <svg class="h-4 w-4 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
                            </button>
                            <div data-dropdown-panel class="absolute left-0 top-[calc(100%+4px)] z-40 hidden w-full rounded border border-gray-300 bg-white shadow-lg">
                                <div class="relative p-2">
                                    <input type="text" data-dropdown-search class="h-11 w-full rounded border border-blue-400 px-3 pr-9 text-sm focus:outline-none focus:ring-1 focus:ring-blue-500">
                                    <svg class="absolute right-5 top-5 h-4 w-4 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
                                </div>
                                <button type="button" data-dropdown-option data-value="" data-label="Trạng thái" class="block w-full px-4 py-2 text-left text-sm hover:bg-blue-50">Tất cả trạng thái</button>
                                <button type="button" data-dropdown-option data-value="Active" data-label="Đang hoạt động" class="block w-full px-4 py-2 text-left text-sm hover:bg-blue-50">Đang hoạt động</button>
                                <button type="button" data-dropdown-option data-value="Inactive" data-label="Tạm dừng" class="block w-full px-4 py-2 text-left text-sm hover:bg-blue-50">Tạm dừng</button>
                                <button type="button" data-dropdown-option data-value="Closed" data-label="Đã đóng" class="block w-full px-4 py-2 text-left text-sm hover:bg-blue-50">Đã đóng</button>
                            </div>
                        </div>
                        </div>
                        <div class="grid grid-cols-1 gap-3 md:grid-cols-2 xl:grid-cols-5">
                            <div class="relative w-full min-w-0" data-date-range>
                                <input type="hidden" name="ClassStartDateFrom" value="@Model.ClassStartDateFrom?.ToString("yyyy-MM-dd")" data-range-from />
                                <input type="hidden" name="ClassStartDateTo" value="@Model.ClassStartDateTo?.ToString("yyyy-MM-dd")" data-range-to />
                                <button type="button" data-range-toggle class="flex w-full overflow-hidden rounded border border-gray-300 bg-white text-left text-sm text-gray-600 focus:border-blue-500 focus:outline-none focus:ring-1 focus:ring-blue-500">
                                    <span data-range-label data-placeholder="Ngày khai giảng" class="flex min-w-0 flex-1 items-center truncate px-4">Ngày khai giảng</span>
                                    <span class="flex h-full shrink-0 items-center justify-center bg-sky-600 text-white">
                                        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3M4 11h16M5 5h14a1 1 0 011 1v14a1 1 0 01-1 1H5a1 1 0 01-1-1V6a1 1 0 011-1z"></path></svg>
                                    </span>
                                </button>
                            </div>
                            <div class="relative w-full min-w-0" data-date-range>
                                <input type="hidden" name="ClassEndDateFrom" value="@Model.ClassEndDateFrom?.ToString("yyyy-MM-dd")" data-range-from />
                                <input type="hidden" name="ClassEndDateTo" value="@Model.ClassEndDateTo?.ToString("yyyy-MM-dd")" data-range-to />
                                <button type="button" data-range-toggle class="flex w-full overflow-hidden rounded border border-gray-300 bg-white text-left text-sm text-gray-600 focus:border-blue-500 focus:outline-none focus:ring-1 focus:ring-blue-500">
                                    <span data-range-label data-placeholder="Ngày kết thúc" class="flex min-w-0 flex-1 items-center truncate px-4">Ngày kết thúc</span>
                                    <span class="flex h-full shrink-0 items-center justify-center bg-sky-600 text-white">
                                        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3M4 11h16M5 5h14a1 1 0 011 1v14a1 1 0 01-1 1H5a1 1 0 01-1-1V6a1 1 0 011-1z"></path></svg>
                                    </span>
                                </button>
                            </div>
                        </div>
                        <div class="flex flex-wrap items-center justify-between gap-3">
                            <a asp-page="/AdminClasses/Create" class="inline-flex h-11 items-center rounded bg-blue-600 px-4 text-sm font-semibold text-white shadow-sm transition-colors hover:bg-blue-700">
                                <svg class="mr-2 h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
                                Thêm lớp mới
                            </a>
                            <div class="ml-auto flex flex-wrap items-start gap-3">
                            <a asp-page="/AdminClasses" asp-route-tab="classes" asp-route-classPageSize="@Model.ClassPageSize" class="inline-flex h-12 min-w-32 items-center justify-center rounded bg-slate-600 px-4 text-sm font-semibold text-white shadow-sm transition-colors hover:bg-slate-700">Làm mới bộ lọc</a>
                            <button type="submit" class="inline-flex h-12 min-w-32 items-center justify-center rounded bg-blue-600 px-4 text-sm font-semibold text-white shadow-sm transition-colors hover:bg-blue-700">
                                <svg class="mr-2 h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
                                Tìm kiếm
                            </button>
                            </div>
                        </div>
                    </div>
                </form>
            }
        </div>

        <div class="overflow-x-auto">
            @if (Model.IsRoomsTab)
            {
                <table class="w-full text-left border-collapse">
                    <thead>
                        <tr class="whitespace-nowrap bg-slate-100 border-b border-slate-200 text-sm font-bold text-slate-800">
                            <th class="py-4 px-4 text-center font-bold border-r border-slate-200">STT</th>
                            <th class="py-4 px-4 text-center font-bold border-r border-slate-200">ID</th>
                            <th class="py-4 px-6 font-bold border-r border-slate-200">Mã phòng</th>
                            <th class="py-4 px-6 font-bold border-r border-slate-200">Tên phòng</th>
