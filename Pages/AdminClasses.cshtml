@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function openCreateRoomModal() {
            clearRoomValidation('createRoomForm');
            
            document.getElementById('CreateRoomInput_RoomCode').value = '';
            document.getElementById('CreateRoomInput_RoomName').value = '';
            document.getElementById('CreateRoomInput_Capacity').value = '';
            document.getElementById('CreateRoomInput_Location').value = '';
            document.getElementById('CreateRoomInput_Status').value = 'Active';

            const modal = document.getElementById('createRoomModal');
            modal.classList.remove('hidden');
            modal.classList.add('flex');
        }

        function closeCreateRoomModal() {
            const modal = document.getElementById('createRoomModal');
            modal.classList.add('hidden');
            modal.classList.remove('flex');
        }

        function openCreateShiftModal() {
            clearRoomValidation('createShiftForm');
            document.getElementById('CreateShiftInput_ShiftCode').value = '';
            document.getElementById('CreateShiftInput_ShiftName').value = '';
            document.getElementById('CreateShiftInput_StartTime').value = '';
            document.getElementById('CreateShiftInput_EndTime').value = '';
            setCreateShiftStatus('Active');
            document.getElementById('CreateShiftInput_Note').value = '';

            const modal = document.getElementById('createShiftModal');
            modal.classList.remove('hidden');
            modal.classList.add('flex');
        }

        function closeCreateShiftModal() {
            const modal = document.getElementById('createShiftModal');
            modal.classList.add('hidden');
            modal.classList.remove('flex');
        }

        const createShiftStatusInput = document.getElementById('CreateShiftInput_Status');
        const createShiftStatusToggle = document.getElementById('createShiftStatusToggle');
        const createShiftStatusTrack = document.getElementById('createShiftStatusTrack');
        const createShiftStatusKnob = document.getElementById('createShiftStatusKnob');
        const createShiftStatusText = document.getElementById('createShiftStatusText');

        function setCreateShiftStatus(status) {
            const isActive = status !== 'Inactive';

            if (createShiftStatusInput) {
                createShiftStatusInput.value = isActive ? 'Active' : 'Inactive';
            }

            createShiftStatusToggle?.classList.toggle('border-green-200', isActive);
            createShiftStatusToggle?.classList.toggle('bg-green-50', isActive);
            createShiftStatusToggle?.classList.toggle('text-green-700', isActive);
            createShiftStatusToggle?.classList.toggle('hover:bg-green-100', isActive);
            createShiftStatusToggle?.classList.toggle('border-gray-200', !isActive);
            createShiftStatusToggle?.classList.toggle('bg-gray-100', !isActive);
            createShiftStatusToggle?.classList.toggle('text-gray-600', !isActive);
            createShiftStatusToggle?.classList.toggle('hover:bg-gray-200', !isActive);
            createShiftStatusTrack?.classList.toggle('bg-green-500', isActive);
            createShiftStatusTrack?.classList.toggle('bg-gray-300', !isActive);
            createShiftStatusKnob?.classList.toggle('left-5', isActive);
            createShiftStatusKnob?.classList.toggle('left-0.5', !isActive);

            if (createShiftStatusText) {
                createShiftStatusText.textContent = isActive ? 'Đang sử dụng' : 'Tạm dừng';
            }
        }

        createShiftStatusToggle?.addEventListener('click', () => {
            setCreateShiftStatus(createShiftStatusInput?.value === 'Active' ? 'Inactive' : 'Active');
        });

        setCreateShiftStatus(createShiftStatusInput?.value || 'Active');

        const editShiftStatusInput = document.getElementById('EditShiftInput_Status');
        const editShiftStatusToggle = document.getElementById('editShiftStatusToggle');
        const editShiftStatusTrack = document.getElementById('editShiftStatusTrack');
        const editShiftStatusKnob = document.getElementById('editShiftStatusKnob');
        const editShiftStatusText = document.getElementById('editShiftStatusText');

        function setEditShiftStatus(status) {
            const isActive = status !== 'Inactive';

            if (editShiftStatusInput) {
                editShiftStatusInput.value = isActive ? 'Active' : 'Inactive';
            }

            editShiftStatusToggle?.classList.toggle('border-green-200', isActive);
            editShiftStatusToggle?.classList.toggle('bg-green-50', isActive);
            editShiftStatusToggle?.classList.toggle('text-green-700', isActive);
            editShiftStatusToggle?.classList.toggle('hover:bg-green-100', isActive);
            editShiftStatusToggle?.classList.toggle('border-gray-200', !isActive);
            editShiftStatusToggle?.classList.toggle('bg-gray-100', !isActive);
            editShiftStatusToggle?.classList.toggle('text-gray-600', !isActive);
            editShiftStatusToggle?.classList.toggle('hover:bg-gray-200', !isActive);
            editShiftStatusTrack?.classList.toggle('bg-green-500', isActive);
            editShiftStatusTrack?.classList.toggle('bg-gray-300', !isActive);
            editShiftStatusKnob?.classList.toggle('left-5', isActive);
            editShiftStatusKnob?.classList.toggle('left-0.5', !isActive);

            if (editShiftStatusText) {
                editShiftStatusText.textContent = isActive ? 'Đang sử dụng' : 'Tạm dừng';
            }
        }

        editShiftStatusToggle?.addEventListener('click', () => {
            setEditShiftStatus(editShiftStatusInput?.value === 'Active' ? 'Inactive' : 'Active');
        });

        setEditShiftStatus(editShiftStatusInput?.value || 'Active');

        function openEditShiftModal(button) {
            clearRoomValidation('editShiftForm');
            document.getElementById('EditShiftInput_StudyShiftId').value = button.dataset.shiftId || 0;
            document.getElementById('EditShiftInput_ShiftCode').value = button.dataset.shiftCode || '';
            document.getElementById('EditShiftInput_ShiftName').value = button.dataset.shiftName || '';
            document.getElementById('EditShiftInput_StartTime').value = button.dataset.shiftStart || '';
            document.getElementById('EditShiftInput_EndTime').value = button.dataset.shiftEnd || '';
            document.getElementById('EditShiftInput_Note').value = button.dataset.shiftNote || '';
            setEditShiftStatus(button.dataset.shiftStatus || 'Active');

            const modal = document.getElementById('editShiftModal');
            modal.classList.remove('hidden');
            modal.classList.add('flex');
        }

        function closeEditShiftModal() {
            const modal = document.getElementById('editShiftModal');
            modal.classList.add('hidden');
            modal.classList.remove('flex');
        }

        function openEditRoomModal(button) {
            clearRoomValidation('editRoomForm');
            document.getElementById('EditRoomInput_RoomId').value = button.dataset.roomId || 0;
            document.getElementById('EditRoomInput_RoomCode').value = button.dataset.roomCode || '';
            document.getElementById('EditRoomInput_RoomName').value = button.dataset.roomName || '';
            document.getElementById('EditRoomInput_Capacity').value = button.dataset.roomCapacity || '';
            document.getElementById('EditRoomInput_Location').value = button.dataset.roomLocation || '';
            document.getElementById('EditRoomInput_Status').value = button.dataset.roomStatus || 'Active';

            const modal = document.getElementById('editRoomModal');
            modal.classList.remove('hidden');
            modal.classList.add('flex');
        }

        function closeEditRoomModal() {
            const modal = document.getElementById('editRoomModal');
            modal.classList.add('hidden');
            modal.classList.remove('flex');
        }

        function clearRoomValidation(formId) {
            document.querySelectorAll(`#${formId} [data-valmsg-for]`).forEach(item => {
                item.textContent = '';
                item.classList.remove('field-validation-error');
                item.classList.add('field-validation-valid');
            });
            document.querySelectorAll(`#${formId} .validation-summary-errors`).forEach(item => {
                item.innerHTML = '';
            });
            document.querySelectorAll(`#${formId} .input-validation-error`).forEach(item => {
                item.classList.remove('input-validation-error');
            });
        }

        function setSubmitting(buttonId, text) {
            const submitButton = document.getElementById(buttonId);
            submitButton.disabled = true;
            submitButton.classList.add('opacity-70', 'cursor-not-allowed');
            submitButton.textContent = text;
        }

        document.getElementById('createRoomForm')?.addEventListener('submit', () => setSubmitting('createRoomSubmitButton', 'Đang lưu...'));
        document.getElementById('editRoomForm')?.addEventListener('submit', () => setSubmitting('editRoomSubmitButton', 'Đang lưu...'));
        document.getElementById('createShiftForm')?.addEventListener('submit', () => setSubmitting('createShiftSubmitButton', 'Đang lưu...'));
        document.getElementById('editShiftForm')?.addEventListener('submit', () => setSubmitting('editShiftSubmitButton', 'Đang lưu...'));

        function openDeleteShiftConfirm(button) {
            document.getElementById('deleteShiftId').value = button.dataset.shiftId;
            document.getElementById('deleteShiftName').textContent = button.dataset.shiftName;

            const modal = document.getElementById('deleteShiftConfirmModal');
            modal.classList.remove('hidden');
            modal.classList.add('flex');
        }

        function closeDeleteShiftConfirm() {
            const modal = document.getElementById('deleteShiftConfirmModal');
            modal.classList.add('hidden');
            modal.classList.remove('flex');
        }

        function openDeleteRoomConfirm(button) {
            document.getElementById('deleteRoomId').value = button.dataset.roomId;
            document.getElementById('deleteRoomName').textContent = button.dataset.roomName;

            const modal = document.getElementById('deleteRoomConfirmModal');
            modal.classList.remove('hidden');
            modal.classList.add('flex');
        }

        function closeDeleteRoomConfirm() {
            const modal = document.getElementById('deleteRoomConfirmModal');
            modal.classList.add('hidden');
            modal.classList.remove('flex');
        }

        function openCloseClassConfirm(button) {
            document.getElementById('closeClassId').value = button.dataset.classId;
            document.getElementById('closeClassCode').textContent = button.dataset.classCode;

            const modal = document.getElementById('closeClassConfirmModal');
            modal.classList.remove('hidden');
            modal.classList.add('flex');
        }

        function closeCloseClassConfirm() {
            const modal = document.getElementById('closeClassConfirmModal');
            modal.classList.add('hidden');
            modal.classList.remove('flex');
        }

        function openDeleteClassConfirm(button) {
            document.getElementById('deleteClassId').value = button.dataset.classId;
            document.getElementById('deleteClassCode').textContent = button.dataset.classCode;

            const modal = document.getElementById('deleteClassConfirmModal');
            modal.classList.remove('hidden');
            modal.classList.add('flex');
        }

        function closeDeleteClassConfirm() {
            const modal = document.getElementById('deleteClassConfirmModal');
            modal.classList.add('hidden');
            modal.classList.remove('flex');
        }

        document.querySelectorAll('[data-search-dropdown]').forEach(dropdown => {
            const toggle = dropdown.querySelector('[data-dropdown-toggle]');
            const panel = dropdown.querySelector('[data-dropdown-panel]');
            const label = dropdown.querySelector('[data-dropdown-label]');
            const hidden = dropdown.querySelector('[data-filter-value]');
            const search = dropdown.querySelector('[data-dropdown-search]');
            const options = Array.from(dropdown.querySelectorAll('[data-dropdown-option]'));

            if (!toggle || !panel || !label || !hidden) {
                return;
            }

            toggle.addEventListener('click', event => {
                event.stopPropagation();
                document.querySelectorAll('[data-dropdown-panel]').forEach(item => {
                    if (item !== panel) {
                        item.classList.add('hidden');
                    }
                });
                panel.classList.toggle('hidden');
                search?.focus();
            });

            search?.addEventListener('input', () => {
                const keyword = search.value.trim().toLowerCase();
                options.forEach(option => {
                    option.classList.toggle('hidden', !option.textContent.toLowerCase().includes(keyword));
                });
            });

            options.forEach(option => {
                option.addEventListener('click', () => {
                    hidden.value = option.dataset.value || '';
                    label.textContent = option.dataset.label || option.textContent.trim();
                    panel.classList.add('hidden');
                    search.value = '';
                    options.forEach(item => item.classList.remove('hidden'));
                });
            });
        });

        document.addEventListener('click', event => {
            if (!event.target.closest('[data-search-dropdown]')) {
                document.querySelectorAll('[data-dropdown-panel]').forEach(panel => panel.classList.add('hidden'));
            }
        });
        const shouldOpenCreateRoomModal = @Json.Serialize(Model.OpenCreateRoomModal);
        const shouldOpenEditRoomModal = @Json.Serialize(Model.OpenEditRoomModal);
        const shouldOpenCreateShiftModal = @Json.Serialize(Model.OpenCreateShiftModal);
        const shouldOpenEditShiftModal = @Json.Serialize(Model.OpenEditShiftModal);
if (shouldOpenCreateRoomModal) {
            const modal = document.getElementById('createRoomModal');
            modal.classList.remove('hidden');
            modal.classList.add('flex');
        }

        if (shouldOpenEditRoomModal) {
            const modal = document.getElementById('editRoomModal');
            modal.classList.remove('hidden');
            modal.classList.add('flex');
        }

        if (shouldOpenCreateShiftModal) {
            const modal = document.getElementById('createShiftModal');
            modal.classList.remove('hidden');
            modal.classList.add('flex');
        }

        if (shouldOpenEditShiftModal) {
            setEditShiftStatus(editShiftStatusInput?.value || 'Active');
            const modal = document.getElementById('editShiftModal');
            modal.classList.remove('hidden');
            modal.classList.add('flex');
        }
    </script>
}
