@page
@model EduBridge.Pages.AdminClassesModel
@{
    ViewData["Title"] = "Quản lý lớp học";
    Layout = "_AdminLayout";
    ViewData["ActivePage"] = "AdminClasses";
}

<div class="space-y-6 pb-20">
    <!-- Header -->
    <div class="flex justify-between items-start">
        <div>
            <h1 class="text-3xl font-bold text-gray-900">Quản lý lớp học</h1>
            <p class="text-gray-500 mt-1">Quản lý thông tin các lớp học</p>
        </div>
        <button type="button" onclick="openAddClassModal()" class="bg-blue-600 hover:bg-blue-700 text-white font-medium py-2.5 px-4 rounded-xl flex items-center transition-colors">
            <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
            Thêm lớp mới
        </button>
    </div>

    <!-- Main Card -->
    <div class="rounded-2xl border border-gray-200 bg-white shadow-sm overflow-hidden">
        <div class="p-6 border-b border-blue-100 flex justify-between items-center bg-blue-50/60">
            <h3 class="text-base font-bold text-gray-900">Danh sách lớp học</h3>
            <form method="get" class="relative w-64">
                <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                    <svg class="h-4 w-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg>
                </div>
                <input type="text" name="Search" value="@Model.Search" class="block w-full pl-10 pr-3 py-2 border border-gray-200 rounded-xl leading-5 bg-gray-50 text-gray-900 placeholder-gray-400 focus:outline-none focus:bg-white focus:border-blue-500 focus:ring-1 focus:ring-blue-500 sm:text-sm transition-colors" placeholder="Tìm kiếm lớp học...">
            </form>
        </div>

        <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="whitespace-nowrap bg-slate-100 border-b border-slate-200 text-sm font-bold text-slate-800">
                        <th class="py-4 px-6 font-bold border-r border-slate-200">Mã lớp</th>
                        <th class="py-4 px-6 font-bold border-r border-slate-200">Tên lớp</th>
                        <th class="py-4 px-6 font-bold border-r border-slate-200">Môn học</th>
                        <th class="py-4 px-6 font-bold border-r border-slate-200">Giáo viên</th>
                        <th class="py-4 px-6 font-bold border-r border-slate-200">Sĩ số</th>
                        <th class="py-4 px-6 font-bold border-r border-slate-200">Lịch học</th>
                        <th class="py-4 px-6 font-bold border-r border-slate-200">Phòng</th>
                        <th class="py-4 px-6 font-bold border-r border-slate-200">Trạng thái</th>
                        <th class="py-4 px-6 font-bold text-right">Thao tác</th>
                    </tr>
                </thead>
                <tbody class="text-sm divide-y divide-gray-100">
                    @if (Model.Classes.Count == 0)
                    {
                        <tr>
                            <td colspan="9" class="py-10 px-6 text-center text-gray-500">
                                Chưa có lớp học phù hợp.
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var cls in Model.Classes)
                        {
                            <tr class="group hover:bg-slate-100 transition-colors">
                                <td class="py-5 px-6 font-semibold text-blue-700 border-r border-gray-200 group-hover:bg-slate-200 group-hover:text-blue-800">@cls.ClassCode</td>
                                <td class="py-5 px-6 font-semibold text-gray-900 border-r border-gray-200">@cls.ClassName</td>
                                <td class="py-5 px-6 text-gray-600 border-r border-gray-200">@cls.CourseName</td>
                                <td class="py-5 px-6 text-gray-600 border-r border-gray-200">@cls.TeacherName</td>
                                <td class="py-5 px-6 text-gray-600 border-r border-gray-200">
                                    <div class="flex items-center">
                                        <svg class="w-4 h-4 mr-1.5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"></path></svg>
                                        @cls.TotalStudents
                                    </div>
                                </td>
                                <td class="py-5 px-6 text-gray-600 border-r border-gray-200">
                                    <div class="space-y-1">
                                        @foreach (var schedule in cls.ScheduleLines)
                                        {
                                            <div class="whitespace-nowrap">@schedule</div>
                                        }
                                    </div>
                                </td>
                                <td class="py-5 px-6 text-gray-600 border-r border-gray-200">@cls.DisplayRoom</td>
                                <td class="py-5 px-6 border-r border-gray-200">
                                    <span class="inline-flex min-w-28 justify-center rounded-full px-3 py-1 text-xs font-semibold @cls.StatusBadgeClass">
                                        @cls.StatusText
                                    </span>
                                </td>
                                <td class="py-5 px-6 text-right">
                                    <button class="text-gray-800 hover:text-blue-600 transition-colors mr-3" title="Sửa">
                                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path></svg>
                                    </button>
                                    <button class="text-red-500 hover:text-red-700 transition-colors" title="Xóa">
                                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
                                    </button>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div id="addClassModal" class="fixed inset-0 z-50 hidden items-center justify-center bg-black bg-opacity-50 px-4">
    <div class="w-full max-w-2xl rounded-2xl bg-white shadow-2xl">
        <div class="flex items-center justify-between border-b border-gray-100 px-6 py-4">
            <h3 class="text-lg font-bold text-gray-900">Thêm lớp mới</h3>
            <button type="button" onclick="closeAddClassModal()" class="text-gray-400 hover:text-gray-600 transition-colors">
                <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
            </button>
        </div>

        <form id="addClassForm" method="post" asp-page-handler="Create" class="space-y-5 px-6 py-5" onsubmit="buildScheduleText()">
            <div asp-validation-summary="ModelOnly" class="text-sm font-medium text-red-600"></div>

            <div class="grid gap-4 md:grid-cols-2">
                <div>
                    <label asp-for="Input.ClassName" class="block text-sm font-semibold text-gray-700">Tên lớp</label>
                    <input asp-for="Input.ClassName" class="mt-1 block w-full rounded-xl border border-gray-200 bg-gray-50 px-4 py-2.5 text-sm text-gray-900 focus:border-blue-500 focus:bg-white focus:outline-none focus:ring-1 focus:ring-blue-500" placeholder="VD: Kids English A1" />
                    <span asp-validation-for="Input.ClassName" class="mt-1 block text-xs font-medium text-red-600"></span>
                </div>

                <div>
                    <label asp-for="Input.CourseId" class="block text-sm font-semibold text-gray-700">Khóa học</label>
                    <select asp-for="Input.CourseId" class="mt-1 block w-full rounded-xl border border-gray-200 bg-gray-50 px-4 py-2.5 text-sm text-gray-900 focus:border-blue-500 focus:bg-white focus:outline-none focus:ring-1 focus:ring-blue-500">
                        <option value="0">Chọn khóa học</option>
                        @foreach (var course in Model.CourseOptions)
                        {
                            <option value="@course.CourseId">@course.CourseName</option>
                        }
                    </select>
                    <span asp-validation-for="Input.CourseId" class="mt-1 block text-xs font-medium text-red-600"></span>
                </div>

                <div>
                    <label asp-for="Input.TeacherId" class="block text-sm font-semibold text-gray-700">Giáo viên</label>
                    <select asp-for="Input.TeacherId" class="mt-1 block w-full rounded-xl border border-gray-200 bg-gray-50 px-4 py-2.5 text-sm text-gray-900 focus:border-blue-500 focus:bg-white focus:outline-none focus:ring-1 focus:ring-blue-500">
                        <option value="0">Chọn giáo viên</option>
                        @foreach (var teacher in Model.TeacherOptions)
                        {
                            <option value="@teacher.TeacherId">@teacher.TeacherName</option>
                        }
                    </select>
                    <span asp-validation-for="Input.TeacherId" class="mt-1 block text-xs font-medium text-red-600"></span>
                </div>

                <div>
                    <label asp-for="Input.StartDate" class="block text-sm font-semibold text-gray-700">Ngày bắt đầu</label>
                    <input asp-for="Input.StartDate" type="date" class="mt-1 block w-full rounded-xl border border-gray-200 bg-gray-50 px-4 py-2.5 text-sm text-gray-900 focus:border-blue-500 focus:bg-white focus:outline-none focus:ring-1 focus:ring-blue-500" />
                    <span asp-validation-for="Input.StartDate" class="mt-1 block text-xs font-medium text-red-600"></span>
                </div>

                <div>
                    <label asp-for="Input.EndDate" class="block text-sm font-semibold text-gray-700">Ngày kết thúc</label>
                    <input asp-for="Input.EndDate" type="date" class="mt-1 block w-full rounded-xl border border-gray-200 bg-gray-50 px-4 py-2.5 text-sm text-gray-900 focus:border-blue-500 focus:bg-white focus:outline-none focus:ring-1 focus:ring-blue-500" />
                    <span asp-validation-for="Input.EndDate" class="mt-1 block text-xs font-medium text-red-600"></span>
                </div>

                <div>
                    <label asp-for="Input.Room" class="block text-sm font-semibold text-gray-700">Phòng học</label>
                    <input asp-for="Input.Room" class="mt-1 block w-full rounded-xl border border-gray-200 bg-gray-50 px-4 py-2.5 text-sm text-gray-900 focus:border-blue-500 focus:bg-white focus:outline-none focus:ring-1 focus:ring-blue-500" placeholder="VD: Phòng 201" />
                    <span asp-validation-for="Input.Room" class="mt-1 block text-xs font-medium text-red-600"></span>
                </div>
            </div>

            <div>
                <div class="mb-3 flex items-center justify-between">
                    <label asp-for="Input.ScheduleText" class="block text-sm font-semibold text-gray-700">Ngày học</label>
                    <button type="button" onclick="addScheduleRow()" class="inline-flex items-center rounded-lg bg-blue-600 px-3 py-2 text-sm font-semibold text-white hover:bg-blue-700 transition-colors">
                        <svg class="mr-2 h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>
                        Thêm ngày
                    </button>
                </div>

                <input asp-for="Input.ScheduleText" type="hidden" />

                <div class="overflow-hidden rounded-xl border border-gray-200">
                    <div class="grid grid-cols-[1fr_1.35fr_72px] bg-gray-50 text-sm font-semibold text-gray-700">
                        <div class="px-4 py-3">Thứ</div>
                        <div class="px-4 py-3">Ca</div>
                        <div class="px-4 py-3 text-center">Thao tác</div>
                    </div>
                    <div id="scheduleRows" class="divide-y divide-gray-100"></div>
                </div>
                <span asp-validation-for="Input.ScheduleText" class="mt-1 block text-xs font-medium text-red-600"></span>
            </div>

            <div class="flex justify-end gap-3 border-t border-gray-100 pt-4">
                <button type="button" onclick="closeAddClassModal()" class="rounded-xl border border-gray-200 bg-white px-4 py-2.5 text-sm font-semibold text-gray-700 hover:bg-gray-50 transition-colors">Hủy</button>
                <button type="submit" class="rounded-xl bg-blue-600 px-4 py-2.5 text-sm font-semibold text-white hover:bg-blue-700 transition-colors">Lưu lớp học</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function openAddClassModal() {
            const modal = document.getElementById('addClassModal');
            modal.classList.remove('hidden');
            modal.classList.add('flex');

            if (document.querySelectorAll('.schedule-row').length === 0) {
                hydrateScheduleRows();
            }
        }

        function closeAddClassModal() {
            const modal = document.getElementById('addClassModal');
            modal.classList.add('hidden');
            modal.classList.remove('flex');
        }

        function addScheduleRow(day = '', startTime = '', endTime = '') {
            const row = document.createElement('div');
            row.className = 'schedule-row grid grid-cols-[1fr_1.35fr_72px] items-center gap-4 px-3 py-2';
            row.innerHTML = `
                <select class="schedule-day block w-full rounded-lg border border-gray-200 bg-white px-3 py-2.5 text-sm text-gray-900 focus:border-blue-500 focus:outline-none focus:ring-1 focus:ring-blue-500">
                    <option value="">Chọn thứ</option>
                    <option value="Thứ 2">Thứ 2</option>
                    <option value="Thứ 3">Thứ 3</option>
                    <option value="Thứ 4">Thứ 4</option>
                    <option value="Thứ 5">Thứ 5</option>
                    <option value="Thứ 6">Thứ 6</option>
                    <option value="Thứ 7">Thứ 7</option>
                    <option value="Chủ nhật">Chủ nhật</option>
                </select>
                <div class="grid grid-cols-[1fr_auto_1fr] items-center gap-2">
                    <div class="time-picker relative">
                        <button type="button" onclick="openTimePicker(this, 'start')" class="flex w-full overflow-hidden rounded-lg border border-gray-200 bg-white text-left text-sm text-gray-900 focus-within:border-blue-500 focus-within:ring-1 focus-within:ring-blue-500">
                            <span class="schedule-start-display flex-1 px-3 py-2.5 text-gray-500">Bắt đầu</span>
                            <span class="bg-blue-600 px-3 py-2.5 text-white">
                                <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2"></rect><path d="M16 2v4M8 2v4M3 10h18"></path></svg>
                            </span>
                        </button>
                        <input type="hidden" class="schedule-start-value" />
                    </div>
                    <span class="text-sm font-medium text-gray-400">đến</span>
                    <div class="time-picker relative">
                        <button type="button" onclick="openTimePicker(this, 'end')" class="flex w-full overflow-hidden rounded-lg border border-gray-200 bg-white text-left text-sm text-gray-900 focus-within:border-blue-500 focus-within:ring-1 focus-within:ring-blue-500">
                            <span class="schedule-end-display flex-1 px-3 py-2.5 text-gray-500">Kết thúc</span>
                            <span class="bg-blue-600 px-3 py-2.5 text-white">
                                <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2"></rect><path d="M16 2v4M8 2v4M3 10h18"></path></svg>
                            </span>
                        </button>
                        <input type="hidden" class="schedule-end-value" />
                    </div>
                </div>
                <button type="button" onclick="removeScheduleRow(this)" class="mx-auto text-red-500 hover:text-red-700 transition-colors" title="Xóa">
                    <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
                </button>
            `;

            document.getElementById('scheduleRows').appendChild(row);
            row.querySelector('.schedule-day').value = day;
            setTimeValue(row, 'start', startTime);
            setTimeValue(row, 'end', endTime);
        }

        function closeTimePickers() {
            document.querySelectorAll('.time-picker-panel').forEach(panel => panel.remove());
        }

        function openTimePicker(button, prefix) {
            closeTimePickers();

            const picker = button.closest('.time-picker');
            const current = picker.querySelector(`.schedule-${prefix}-value`).value || '08:00';
            const [currentHour, currentMinute] = current.split(':', 2).map(Number);
            const rect = button.getBoundingClientRect();
            const panel = document.createElement('div');
            panel.className = 'time-picker-panel fixed z-[9999] w-[280px] rounded-xl border border-gray-200 bg-white p-4 shadow-2xl';
            panel.dataset.rowId = ensureScheduleRowId(button.closest('.schedule-row'));
            panel.dataset.prefix = prefix;
            panel.dataset.hour = String(Number.isNaN(currentHour) ? 8 : currentHour);
            panel.dataset.minute = String(Number.isNaN(currentMinute) ? 0 : currentMinute);
            panel.innerHTML = `
                <div class="grid grid-cols-[1fr_auto_1fr] items-center text-center">
                    <button type="button" onclick="stepTime(this, 'hour', 1)" class="mx-auto text-gray-500 hover:text-blue-600">
                        <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 15l7-7 7 7"></path></svg>
                    </button>
                    <span></span>
                    <button type="button" onclick="stepTime(this, 'minute', 1)" class="mx-auto text-gray-500 hover:text-blue-600">
                        <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 15l7-7 7 7"></path></svg>
                    </button>
                    <div class="time-hour py-3 text-2xl font-semibold text-gray-800"></div>
                    <div class="text-2xl font-semibold text-gray-500">:</div>
                    <div class="time-minute py-3 text-2xl font-semibold text-gray-800"></div>
                    <button type="button" onclick="stepTime(this, 'hour', -1)" class="mx-auto text-gray-500 hover:text-blue-600">
                        <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
                    </button>
                    <span></span>
                    <button type="button" onclick="stepTime(this, 'minute', -1)" class="mx-auto text-gray-500 hover:text-blue-600">
                        <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
                    </button>
                </div>
                <div class="mt-4 flex items-center justify-between border-t border-gray-100 pt-3">
                    <button type="button" onclick="clearTimePicker(this, '${prefix}')" class="text-sm font-semibold text-gray-500 hover:text-gray-800">Xóa</button>
                    <button type="button" onclick="applyTimePicker(this, '${prefix}')" class="rounded-lg bg-blue-600 px-3 py-2 text-sm font-semibold text-white hover:bg-blue-700">Chọn</button>
                </div>
            `;

            document.body.appendChild(panel);
            positionTimePickerPanel(panel, rect);
            renderTimePicker(panel);
        }

        function ensureScheduleRowId(row) {
            if (!row.dataset.scheduleRowId) {
                row.dataset.scheduleRowId = crypto.randomUUID();
            }

            return row.dataset.scheduleRowId;
        }

        function positionTimePickerPanel(panel, rect) {
            const margin = 8;
            const panelWidth = 280;
            const panelHeight = 190;
            let left = rect.left;
            let top = rect.bottom + margin;

            if (left + panelWidth > window.innerWidth - margin) {
                left = window.innerWidth - panelWidth - margin;
            }

            if (top + panelHeight > window.innerHeight - margin) {
                top = rect.top - panelHeight - margin;
            }

            panel.style.left = `${Math.max(margin, left)}px`;
            panel.style.top = `${Math.max(margin, top)}px`;
        }

        function renderTimePicker(panel) {
            panel.querySelector('.time-hour').textContent = String(Number(panel.dataset.hour)).padStart(2, '0');
            panel.querySelector('.time-minute').textContent = String(Number(panel.dataset.minute)).padStart(2, '0');
        }

        function stepTime(button, part, delta) {
            const panel = button.closest('.time-picker-panel');

            if (part === 'hour') {
                panel.dataset.hour = String((Number(panel.dataset.hour) + delta + 24) % 24);
            } else {
                panel.dataset.minute = String((Number(panel.dataset.minute) + delta + 60) % 60);
            }

            renderTimePicker(panel);
        }

        function applyTimePicker(button, prefix) {
            const panel = button.closest('.time-picker-panel');
            const row = document.querySelector(`[data-schedule-row-id="${panel.dataset.rowId}"]`);
            const value = `${String(Number(panel.dataset.hour)).padStart(2, '0')}:${String(Number(panel.dataset.minute)).padStart(2, '0')}`;
            setTimeValue(row, prefix, value);
            closeTimePickers();
        }

        function clearTimePicker(button, prefix) {
            const panel = button.closest('.time-picker-panel');
            const row = document.querySelector(`[data-schedule-row-id="${panel.dataset.rowId}"]`);
            setTimeValue(row, prefix, '');
            closeTimePickers();
        }

        function setTimeValue(row, prefix, value) {
            const input = row.querySelector(`.schedule-${prefix}-value`);
            const display = row.querySelector(`.schedule-${prefix}-display`);
            input.value = value || '';
            display.textContent = value || (prefix === 'start' ? 'Bắt đầu' : 'Kết thúc');
            display.classList.toggle('text-gray-500', !value);
            display.classList.toggle('text-gray-900', Boolean(value));
        }

        function getTimeParts(row, prefix) {
            return row.querySelector(`.schedule-${prefix}-value`).value;
        }

        document.addEventListener('click', function (event) {
            if (!event.target.closest('.time-picker') && !event.target.closest('.time-picker-panel')) {
                closeTimePickers();
            }
        });

        document.addEventListener('keydown', function (event) {
            if (event.key === 'Escape') {
                closeTimePickers();
            }
        });

        function removeScheduleRow(button) {
            button.closest('.schedule-row').remove();

            if (document.querySelectorAll('.schedule-row').length === 0) {
                addScheduleRow();
            }
        }

        function buildScheduleText() {
            const items = Array.from(document.querySelectorAll('.schedule-row'))
                .map(row => {
                    const day = row.querySelector('.schedule-day').value;
                    const startTime = getTimeParts(row, 'start');
                    const endTime = getTimeParts(row, 'end');
                    return day && startTime && endTime ? `${day} - ${startTime} - ${endTime}` : '';
                })
                .filter(Boolean);

            document.getElementById('Input_ScheduleText').value = items.join('; ');
        }

        function hydrateScheduleRows() {
            const value = document.getElementById('Input_ScheduleText').value;

            if (!value) {
                addScheduleRow();
                return;
            }

            const items = value.split(';').map(item => item.trim()).filter(Boolean);

            if (items.length === 0) {
                addScheduleRow();
                return;
            }

            items.forEach(item => {
                const separatorIndex = item.indexOf(' - ');
                const day = separatorIndex >= 0 ? item.slice(0, separatorIndex) : '';
                const timeRange = separatorIndex >= 0 ? item.slice(separatorIndex + 3) : '';
                const [startTime, endTime] = timeRange.split(' - ', 2).map(value => value.trim());
                addScheduleRow(day, startTime || '', endTime || '');
            });
        }

        const hasCreateErrors = @Json.Serialize(!ViewData.ModelState.IsValid);

        if (hasCreateErrors) {
            openAddClassModal();
        }
    </script>
}
