                <form method="get" class="flex items-center">
                    <input type="hidden" name="Tab" value="classes" />
                    <input type="hidden" name="Search" value="@Model.Search" />
                    <input type="hidden" name="ClassTeacherSearch" value="@Model.ClassTeacherSearch" />
                    <input type="hidden" name="ClassCourseId" value="@Model.ClassCourseId" />
                    <input type="hidden" name="ClassStatusFilter" value="@Model.ClassStatusFilter" />
                    <input type="hidden" name="ClassStartDateFrom" value="@Model.ClassStartDateFrom?.ToString("yyyy-MM-dd")" />
                    <input type="hidden" name="ClassStartDateTo" value="@Model.ClassStartDateTo?.ToString("yyyy-MM-dd")" />
                    <input type="hidden" name="ClassEndDateFrom" value="@Model.ClassEndDateFrom?.ToString("yyyy-MM-dd")" />
                    <input type="hidden" name="ClassEndDateTo" value="@Model.ClassEndDateTo?.ToString("yyyy-MM-dd")" />
                    <input type="hidden" name="ClassRoomId" value="@Model.ClassRoomId" />
                    <input type="hidden" name="ClassPageNumber" value="1" />
                    <select name="ClassPageSize" onchange="this.form.submit()" class="h-10 rounded border border-blue-300 bg-white px-3 text-sm text-gray-700 focus:border-blue-500 focus:outline-none focus:ring-1 focus:ring-blue-500">
                        @foreach (var size in Model.ClassPageSizeOptions)
                        {
                            <option value="@size" selected="@(size == Model.ClassPageSize)">@size</option>
                        }
                    </select>
                </form>
            </div>
            }
        </div>
    </div>
</div>

