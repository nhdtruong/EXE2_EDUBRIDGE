@page
@{
    ViewData["Title"] = "Dashboard Giáo viên";
    
    // Giả lập dữ liệu từ Database
    var upcomingClasses = new[] {
        new { ClassName = "Toán 10A", Time = "14:00 - 15:30", Room = "Phòng 201", Topic = "Hàm số bậc nhất" },
        new { ClassName = "Toán 10B", Time = "16:00 - 17:30", Room = "Phòng 203", Topic = "Phương trình bậc hai" }
    };

    var recentHomework = new[] {
        new { ClassName = "Toán 10A", Title = "Bài tập về hàm số", Submitted = 18, Total = 25, DueDate = "25/03/2026" },
        new { ClassName = "Toán 10B", Title = "Luyện tập phương trình", Submitted = 15, Total = 22, DueDate = "26/03/2026" }
    };
}

<div class="space-y-6 pb-20">
    <div>
        <h1 class="text-3xl font-bold text-gray-900">Chào mừng, Nguyễn Văn A</h1>
        <p class="text-gray-500 mt-1">Hôm nay là Thứ Tư, 25 tháng 3 năm 2026</p>
    </div>

    <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-4">
        <div class="rounded-xl border bg-white text-gray-900 shadow-sm p-6">
            <div class="flex flex-row items-center justify-between pb-2">
                <h3 class="text-sm font-medium text-gray-600">Lớp phụ trách</h3>
                <div class="bg-blue-100 p-2 rounded-lg text-blue-600">
                    <svg class="size-4" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
                </div>
            </div>
            <div class="text-2xl font-bold">3</div>
        </div>
        <div class="rounded-xl border bg-white text-gray-900 shadow-sm p-6">
            <div class="flex flex-row items-center justify-between pb-2">
                <h3 class="text-sm font-medium text-gray-600">Tổng học sinh</h3>
                <div class="bg-green-100 p-2 rounded-lg text-green-600">
                    <svg class="size-4" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9H4.5a2.5 2.5 0 0 1 0-5H6"/><path d="M18 9h1.5a2.5 2.5 0 0 0 0-5H18"/><path d="M4 22h16"/><path d="M10 14.66V17c0 .55-.47.98-.97 1.21C7.85 18.75 7 20.24 7 22"/><path d="M14 14.66V17c0 .55.47.98.97 1.21C16.15 18.75 17 20.24 17 22"/><path d="M18 2H6v7a6 6 0 0 0 12 0V2Z"/></svg>
                </div>
            </div>
            <div class="text-2xl font-bold">75</div>
        </div>
        <div class="rounded-xl border bg-white text-gray-900 shadow-sm p-6">
            <div class="flex flex-row items-center justify-between pb-2">
                <h3 class="text-sm font-medium text-gray-600">Bài tập chưa chấm</h3>
                <div class="bg-orange-100 p-2 rounded-lg text-orange-600">
                    <svg class="size-4" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="8" height="4" x="8" y="2" rx="1" ry="1"/><path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"/><path d="M12 11h4"/><path d="M12 16h4"/><path d="M8 11h.01"/><path d="M8 16h.01"/></svg>
                </div>
            </div>
            <div class="text-2xl font-bold">12</div>
        </div>
        <div class="rounded-xl border bg-white text-gray-900 shadow-sm p-6">
            <div class="flex flex-row items-center justify-between pb-2">
                <h3 class="text-sm font-medium text-gray-600">Tin nhắn mới</h3>
                <div class="bg-purple-100 p-2 rounded-lg text-purple-600">
                    <svg class="size-4" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7.9 20A9 9 0 1 0 4 16.1L2 22Z"/></svg>
                </div>
            </div>
            <div class="text-2xl font-bold">8</div>
        </div>
    </div>

    <div class="grid gap-6 md:grid-cols-2">
        <div class="rounded-xl border bg-white text-gray-900 shadow-sm">
            <div class="flex flex-row items-center justify-between p-6 pb-4">
                <h3 class="font-semibold leading-none tracking-tight">Lịch dạy hôm nay</h3>
            </div>
            <div class="p-6 pt-0 space-y-4">
                @foreach(var cls in upcomingClasses)
                {
                    <div class="p-4 bg-gradient-to-r from-blue-50 to-green-50 rounded-lg border border-blue-100">
                        <div class="flex items-start justify-between mb-2">
                            <div>
                                <h3 class="font-medium text-gray-900">@cls.ClassName</h3>
                                <p class="text-sm text-gray-600">@cls.Topic</p>
                            </div>
                            <span class="inline-flex items-center rounded-full border border-gray-200 px-2.5 py-0.5 text-xs font-semibold text-gray-800">@cls.Room</span>
                        </div>
                        <p class="text-sm text-gray-500 flex items-center gap-1">@cls.Time</p>
                    </div>
                }
                <button class="w-full inline-flex items-center justify-center rounded-md text-sm font-medium border border-gray-200 bg-white hover:bg-gray-100 hover:text-gray-900 h-10 px-4 py-2 transition-colors">
                    Xem lịch đầy đủ
                </button>
            </div>
        </div>

        <div class="rounded-xl border bg-white text-gray-900 shadow-sm">
            <div class="flex flex-row items-center justify-between p-6 pb-4">
                <h3 class="font-semibold leading-none tracking-tight">Bài tập gần đây</h3>
            </div>
            <div class="p-6 pt-0 space-y-4">
                @foreach(var hw in recentHomework)
                {
                    var progress = (double)hw.Submitted / hw.Total * 100;
                    <div class="space-y-2">
                        <div class="flex items-start justify-between">
                            <div>
                                <h3 class="font-medium text-gray-900">@hw.Title</h3>
                                <p class="text-sm text-gray-500">@hw.ClassName</p>
                            </div>
                            <span class="inline-flex items-center rounded-full bg-gray-100 px-2.5 py-0.5 text-xs font-semibold text-gray-800">@hw.DueDate</span>
                        </div>
                        <div class="space-y-1">
                            <div class="flex items-center justify-between text-sm">
                                <span class="text-gray-600">Đã nộp</span>
                                <span class="font-medium">@hw.Submitted/@hw.Total</span>
                            </div>
                            <div class="relative w-full overflow-hidden rounded-full bg-gray-200 h-2">
                                <div class="h-full bg-blue-600 flex-1 transition-all" style="width: @progress%;"></div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>
